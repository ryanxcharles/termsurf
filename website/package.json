{
  "name": "termsurf-website",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "bun run build:data && astro build",
    "build:data": "bun run build:commits && bun run build:blog",
    "build:blog": "bun run scripts/build-blog.ts",
    "build:commits": "bun run scripts/build-commits.ts",
    "build:icons": "bun run scripts/process-icons.ts",
    "deploy": "bun run build && wrangler pages deploy dist"
  },
  "dependencies": {
    "@astrojs/react": "^4.3.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/three": "^0.183.1",
    "astro": "^6.1.1",
    "feed": "^5.2.0",
    "lowlight": "^3.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-smartypants": "^3.0.2",
    "tailwindcss": "^4.2.1",
    "three": "^0.183.2",
    "toml": "^3.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "wrangler": "^4.77.0"
  }
}
