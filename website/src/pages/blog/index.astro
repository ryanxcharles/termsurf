---
import Base from "../../layouts/Base.astro";
import blogData from "../../../data/blog.json";
---

<Base title="Blog — TermSurf">
  <section>
    <h2 class="text-sm font-bold text-foreground mb-4">┌─ Blog ─┐</h2>
    <ul>
      {blogData.posts.map((post) => (
        <li class="py-1">
          <a
            href={`/blog/${post.slug}`}
            class="flex gap-3 items-baseline text-sm hover:bg-background-highlight/30"
          >
            <span class="text-muted">{post.date}</span>
            <span class="text-accent hover:text-primary flex-1">{post.title}</span>
            <span class="text-success">{post.author}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Base>
