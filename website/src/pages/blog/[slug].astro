---
import Base from "../../layouts/Base.astro";
import blogData from "../../../data/blog.json";

export function getStaticPaths() {
  return blogData.posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = blogData.posts.find((p) => p.slug === slug);
if (!post) throw new Error(`Post not found: ${slug}`);
---

<Base title={`${post.title} — TermSurf`}>
  <article>
    <header class="mb-6">
      <h1 class="text-lg font-bold text-primary mb-1">{post.title}</h1>
      <div class="text-xs text-muted flex gap-3">
        <span>{post.date}</span>
        <span class="text-success">{post.author}</span>
      </div>
      <div class="mt-3 text-muted text-xs">
        ──────────────────────────────────────────────────────────
      </div>
    </header>
    <div class="prose-termsurf" set:html={post.html} />
    <footer class="mt-8">
      <div class="text-muted text-xs mb-3">
        ──────────────────────────────────────────────────────────
      </div>
      <a href="/blog" class="text-sm text-accent hover:text-primary">
        [back to blog]
      </a>
    </footer>
  </article>
</Base>
