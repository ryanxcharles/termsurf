---
import Base from "../layouts/Base.astro";
---

<Base title="TermSurf" showHeaderBrand={false}>
  <section class="mb-8">
    <div class="mb-8 flex items-center gap-4">
      <picture>
        <source
          srcset="/images/termsurf-14-dark-192.png"
          media="(prefers-color-scheme: dark)"
        />
        <img
          src="/images/termsurf-14-light-192.png"
          alt="TermSurf logo"
          class="h-16 w-16"
        />
      </picture>
      <div>
        <h1 class="text-foreground text-xl font-bold">TermSurf</h1>
        <p class="text-primary text-sm font-bold">Root access to the 'net.</p>
      </div>
    </div>

    <p class="text-sm text-muted mt-3">
      TermSurf is a protocol that overlays web browser engines, like
      Chromium and WebKit, in your terminal emulator.{" "}
      <a href="/docs" class="text-accent hover:text-primary">
        Read the docs &rarr;
      </a>
    </p>
    <div class="mt-4 border-t border-border"></div>
  </section>
  <section class="mb-8">
    <img
      src="/images/screenshot2.webp"
      alt="TermSurf — a browser pane alongside terminal panes"
      class="w-full"
    />
    <h2 class="text-sm font-bold text-foreground mt-3">
      TermSurf Wezboard: A GUI for TermSurf
    </h2>
    <p class="text-sm text-muted mt-2">
      TermSurf supports GPU-rendered web pages at 60fps+ using real browser
      engines like Chromium and WebKit. <em>In your terminal</em>.
      Furthermore, TermSurf is the only browser that supports multiple
      profiles and multiple engines in the same window at the same time.{" "}
      <a href="/docs" class="text-accent hover:text-primary">
        Learn more in the docs &rarr;
      </a>
    </p>
  </section>
</Base>
