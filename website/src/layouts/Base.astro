---
interface Props {
  title: string;
  showHeaderBrand?: boolean;
}
const { title, showHeaderBrand = true } = Astro.props;
import "../styles/style.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=JetBrains+Mono:wght@400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-background text-foreground min-h-screen font-sans">
    <div class="max-w-3xl mx-auto px-4 py-6">
      <Header showBrand={showHeaderBrand} />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
