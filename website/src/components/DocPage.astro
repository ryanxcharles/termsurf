---
import Base from "../layouts/Base.astro";
import { getDocsNav } from "../lib/docs-nav.ts";
import Search from "./Search.astro";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

const nav = await getDocsNav();
const currentPath = Astro.url.pathname.replace(/\/$/, "");
---

<Base title={`${title} — TermSurf`} description={description}>
  <div class="md:flex md:gap-8">
    <aside class="mb-6 block md:mb-0 md:w-48 md:shrink-0">
      <details class="docs-sidebar" open>
        <summary class="text-foreground-dark mb-2 cursor-pointer font-bold">
          Documentation
        </summary>
        <Search />
        <nav class="space-y-1 text-xs">
        {
          nav.map((group) => (
            <>
              {group.section && (
                <div class="text-foreground-dark mt-3 mb-1 font-bold">
                  {group.section}
                </div>
              )}
              {group.items.map((item) => (
                <a
                  href={item.href}
                  class:list={[
                    "block py-0.5",
                    currentPath === item.href
                      ? "text-accent"
                      : "text-muted hover:text-foreground-dark",
                  ]}
                >
                  {item.label}
                </a>
              ))}
              {group.subgroups.map((sub) => (
                <details
                  class="docs-nav-sub"
                  open={sub.items.some((i) => i.href === currentPath)}
                >
                  <summary class="text-foreground-dark mt-1 cursor-pointer py-0.5">
                    {sub.subsection}
                  </summary>
                  <div class="border-border ml-2 border-l pl-2">
                    {sub.items.map((item) => (
                      <a
                        href={item.href}
                        class:list={[
                          "block py-0.5",
                          currentPath === item.href
                            ? "text-accent"
                            : "text-muted hover:text-foreground-dark",
                        ]}
                      >
                        {item.label}
                      </a>
                    ))}
                  </div>
                </details>
              ))}
            </>
          ))
        }
        </nav>
      </details>
    </aside>
    <article class="prose-termsurf min-w-0 flex-1" data-pagefind-body>
      <slot />
    </article>
  </div>
</Base>
