---
import { Github, ExternalLink, BookOpen } from "lucide-astro";

interface Props {
  showBrand?: boolean;
}
const { showBrand = true } = Astro.props;
const pathname = Astro.url.pathname;
const NAV_ITEMS = [
  { to: "https://github.com/termsurf/termsurf", label: "GitHub", external: true, icon: "github" },
  { to: "/docs", label: "Docs", icon: "docs" },
];
---

<header class="mb-8">
  <div class="flex items-center justify-between text-sm">
    {showBrand ? (
      <a href="/" class="flex items-center gap-2 text-primary font-bold">
        <picture>
          <source
            srcset="/images/termsurf-14-dark-192.png"
            media="(prefers-color-scheme: dark)"
          />
          <img
            src="/images/termsurf-14-light-192.png"
            alt="TermSurf logo"
            class="w-6 h-6"
          />
        </picture>
        TermSurf
      </a>
    ) : (
      <div></div>
    )}
    <nav class="flex gap-3">
      {NAV_ITEMS.map((item) => {
        const active = pathname === item.to;
        return (
          <a
            href={item.to}
            class:list={[
              "flex items-center gap-1",
              active ? "text-primary" : "text-muted hover:text-accent",
            ]}
            {...(item.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
          >
            {item.icon === "github" && <Github class="w-4 h-4" />}
            {item.icon === "docs" && <BookOpen class="w-4 h-4" />}
            {item.label}
            {item.external && <ExternalLink class="w-3 h-3" />}
          </a>
        );
      })}
    </nav>
  </div>
  <div class="mt-3 border-t border-border"></div>
</header>
