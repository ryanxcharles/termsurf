---
const pathname = Astro.url.pathname;
const NAV_ITEMS = [
  { to: "/docs", label: "Docs" },
];
---

<header class="mb-8">
  <div class="flex items-center justify-between text-sm">
    <a href="/" class="flex items-center gap-2 text-primary font-bold">
      <picture>
        <source
          srcset="/images/termsurf-14-dark-192.png"
          media="(prefers-color-scheme: dark)"
        />
        <img
          src="/images/termsurf-14-light-192.png"
          alt="TermSurf logo"
          class="w-6 h-6"
        />
      </picture>
      TermSurf
    </a>
    <nav class="flex gap-1">
      {NAV_ITEMS.map(({ to, label }) => {
        const active = pathname === to;
        return (
          <a
            href={to}
            class={active ? "text-primary" : "text-muted hover:text-accent"}
          >
            {label}
          </a>
        );
      })}
    </nav>
  </div>
  <div class="mt-3 border-t border-border"></div>
</header>
