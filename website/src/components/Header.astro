---
const pathname = Astro.url.pathname;
const NAV_ITEMS = [
  { to: "/blog", label: "Blog" },
  { to: "/commits", label: "Commits" },
  { to: "/docs", label: "Docs" },
  { to: "/manifesto", label: "Manifesto" },
];
---

<header class="mb-8">
  <div class="flex items-center justify-between text-sm">
    <a href="/" class="flex items-center gap-2 text-primary font-bold">
      <img
        src="/images/termsurf-12-transparent-192.png"
        alt="TermSurf logo"
        class="w-6 h-6"
      />
      TermSurf
    </a>
    <nav class="flex gap-1">
      {NAV_ITEMS.map(({ to, label }) => {
        const active = pathname === to;
        return (
          <a
            href={to}
            class={active ? "text-primary" : "text-muted hover:text-accent"}
          >
            {active ? `>[${label}]` : `[${label}]`}
          </a>
        );
      })}
    </nav>
  </div>
  <div class="mt-3 text-muted text-xs">
    ────────────────────────────────────────────────────────────────────
  </div>
</header>
