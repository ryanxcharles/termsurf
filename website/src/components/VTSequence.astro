---
// Static port of Ghostty's VTSequence component
// (https://github.com/ghostty-org/website, MIT, src/components/vt-sequence).
// Renders a VT escape-sequence diagram (hex over value per cell). The original
// is a React component; this is a server-rendered Astro component (zero client
// JS). Only the pure parseSequence logic is ported; React-only scaffolding
// (useMemo, key dedup, classnames) is dropped. Styling uses Tokyo Night vars.
import { OctagonAlert } from "lucide-astro";

interface Props {
  sequence: string | string[];
  unimplemented?: boolean;
}

const { sequence, unimplemented = false } = Astro.props;

// Special sequence elements mapped to their byte value. "..." is a sentinel for
// an elided run, rendered as a parameter-style cell.
const special: Record<string, number> = {
  BEL: 0x07,
  BS: 0x08,
  TAB: 0x09,
  LF: 0x0a,
  CR: 0x0d,
  ESC: 0x1b,
  "...": 0,
};

interface Cell {
  value: string;
  hex: string | null; // null => parameter (no fixed byte)
}

function parseSequence(seq: string | string[]): Cell[] {
  if (!seq) return [];
  const arr = Array.isArray(seq) ? [...seq] : [seq];

  // CSI/OSC expand to their ESC introducer; a trailing ST expands to ESC \.
  if (arr[0] === "CSI") {
    arr.shift();
    arr.unshift("ESC", "[");
  } else if (arr[0] === "OSC") {
    arr.shift();
    arr.unshift("ESC", "]");
  }
  if (arr[arr.length - 1] === "ST") {
    arr.pop();
    arr.push("ESC", "\\");
  }

  return arr.map((value) => {
    // "Pn" is a parameter named n.
    const param = value.match(/P(\w)/)?.[1];
    if (param) return { value: param, hex: null };

    const specialChar = special[value];
    if (specialChar !== undefined) {
      if (specialChar === 0) return { value: "...", hex: null };
      const hex = specialChar.toString(16).padStart(2, "0").toUpperCase();
      return { value, hex: `0x${hex}` };
    }

    // Otherwise UTF-8 encode to hex byte(s).
    const utf8 = new TextEncoder().encode(value);
    const hex = Array.from(utf8)
      .map((b) => `0x${b.toString(16).padStart(2, "0").toUpperCase()}`)
      .join(" ");
    return { value, hex };
  });
}

const cells = parseSequence(sequence);
---

<div class="vtsequence">
  {
    unimplemented && (
      <div class="vtsequence-unimplemented">
        <OctagonAlert size={16} aria-hidden="true" />
        Unimplemented
      </div>
    )
  }
  <ol class="vtsequence-list">
    {
      cells.map((cell) => (
        <li class:list={["vtsequence-cell", { "vtsequence-param": cell.hex == null }]}>
          <dl>
            <dt>{cell.hex ? cell.hex : "____"}</dt>
            <dd>{cell.value}</dd>
          </dl>
        </li>
      ))
    }
  </ol>
</div>

<style>
  .vtsequence {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    margin: 1rem 0;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }

  .vtsequence-unimplemented {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0.75rem;
    background-color: var(--color-secondary);
    color: var(--color-background);
    border: 1px solid var(--color-border);
    border-bottom: none;
  }

  .vtsequence-list {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .vtsequence-cell {
    margin: 0;
    padding: 0.25rem 0.75rem;
    text-align: center;
    border: 1px solid var(--color-border);
  }

  /* Avoid doubled borders between adjacent cells. */
  .vtsequence-cell + .vtsequence-cell {
    border-left: none;
  }

  .vtsequence-cell dl {
    margin: 0;
  }

  .vtsequence-cell dt {
    color: var(--color-muted);
    font-size: 0.6875rem;
  }

  .vtsequence-cell dd {
    margin: 0;
    color: var(--color-foreground);
  }

  .vtsequence-param dd {
    color: var(--color-accent);
    font-style: italic;
  }
</style>
