From 66d2b51d34608cfc405dd60d854642de2b19fb62 Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Sun, 22 Feb 2026 19:04:22 -0600
Subject: [PATCH 36/38] Resize the window, not the view
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

The view was told its size, but not the frame—
The window stayed the same, a stubborn pane.
Now setContentSize adjusts the glass,
And autoresizing does the rest en masse.

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 .../browser/shell_browser_main_parts.cc           | 15 +++++++++------
 .../browser/shell_platform_delegate_mac.mm        |  6 +++---
 2 files changed, 12 insertions(+), 9 deletions(-)

diff --git a/content/chromium_profile_server/browser/shell_browser_main_parts.cc b/content/chromium_profile_server/browser/shell_browser_main_parts.cc
index 65e8873f5882c..bbcb95f794881 100644
--- a/content/chromium_profile_server/browser/shell_browser_main_parts.cc
+++ b/content/chromium_profile_server/browser/shell_browser_main_parts.cc
@@ -335,8 +335,9 @@ void ShellBrowserMainParts::CreateTab(const GURL& url,
   LOG(INFO) << "[ProfileServer] Created tab for pane " << pane_id
             << ", URL: " << url.spec();
 
-  // Resize WebContents view to match the terminal viewport.
-  // SetSize takes logical pixels; Chromium applies device_scale_factor internally.
+  // Resize the NSWindow to match the terminal viewport (Issue 628 Exp 4).
+  // ResizeWebContentForTests sets the window's content size, letting the
+  // autoresizing chain propagate to the RWHV and update dfh_size_dip_.
   if (pixel_width > 0 && pixel_height > 0) {
     RenderWidgetHostView* view =
         shell->web_contents()->GetRenderWidgetHostView();
@@ -345,8 +346,8 @@ void ShellBrowserMainParts::CreateTab(const GURL& url,
       gfx::Size logical(
           static_cast<int>(std::ceil(pixel_width / scale)),
           static_cast<int>(std::ceil(pixel_height / scale)));
-      view->SetSize(logical);
-      LOG(INFO) << "[ProfileServer] Set view size to " << logical.ToString()
+      shell->ResizeWebContentForTests(logical);
+      LOG(INFO) << "[ProfileServer] Set window size to " << logical.ToString()
                 << " (physical " << pixel_width << "x" << pixel_height
                 << ", scale " << scale << ")";
     }
@@ -433,7 +434,9 @@ void ShellBrowserMainParts::ResizeTab(const std::string& pane_id,
   if (!tab)
     return;
 
-  // Resize the WebContents view (logical pixels).
+  // Resize the NSWindow (Issue 628 Exp 4). The autoresizing chain propagates
+  // from the window to the RWHV, updating dfh_size_dip_ so navigation uses
+  // the correct size for the new compositor surface.
   RenderWidgetHostView* view =
       tab->shell->web_contents()->GetRenderWidgetHostView();
   if (view) {
@@ -441,7 +444,7 @@ void ShellBrowserMainParts::ResizeTab(const std::string& pane_id,
     gfx::Size logical(
         static_cast<int>(std::ceil(pixel_width / scale)),
         static_cast<int>(std::ceil(pixel_height / scale)));
-    view->SetSize(logical);
+    tab->shell->ResizeWebContentForTests(logical);
     LOG(INFO) << "[ProfileServer] Resized pane " << pane_id << " to "
               << logical.ToString()
               << " (physical " << pixel_width << "x" << pixel_height << ")";
diff --git a/content/chromium_profile_server/browser/shell_platform_delegate_mac.mm b/content/chromium_profile_server/browser/shell_platform_delegate_mac.mm
index b2abd8ae68535..08baadca3ed6f 100644
--- a/content/chromium_profile_server/browser/shell_platform_delegate_mac.mm
+++ b/content/chromium_profile_server/browser/shell_platform_delegate_mac.mm
@@ -250,9 +250,9 @@ void MakeShellButton(NSRect* rect,
   ShellData& shell_data = shell_data_map_[shell];
 
   int toolbar_height = Shell::ShouldHideToolbar() ? 0 : kURLBarHeight;
-  NSRect frame = NSMakeRect(0, 0, content_size.width(),
-                            content_size.height() + toolbar_height);
-  shell_data.delegate.window.contentView.frame = frame;
+  NSWindow* window = shell_data.delegate.window;
+  [window setContentSize:NSMakeSize(content_size.width(),
+                                    content_size.height() + toolbar_height)];
 }
 
 void ShellPlatformDelegate::EnableUIControl(Shell* shell,
