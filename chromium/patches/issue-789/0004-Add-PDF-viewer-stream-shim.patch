+  std::string raw_headers = "HTTP/1.1 200 OK";
+  raw_headers.push_back('\0');
+  base::StrAppend(&raw_headers, {"Content-Type: ", mime_type});
+  raw_headers.push_back('\0');
+  raw_headers.push_back('\0');
+  response->headers =
+      base::MakeRefCounted<net::HttpResponseHeaders>(raw_headers);
   return response;
 }
 
