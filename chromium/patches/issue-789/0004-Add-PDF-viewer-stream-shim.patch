+std::string QueryValue(const GURL& url, std::string_view key) {
+  std::string value;
+  if (!net::GetValueForKeyInQuery(url, key, &value)) {
+    return std::string();
+  }
+  return value;
+}
+
+std::string CreateStreamInfoJson(const GURL& url) {
+  return base::StrCat({
+      "{\"mimeType\":",
+      base::GetQuotedJSONString(QueryValue(url, "termsurf_mime_type")),
+      ",\"originalUrl\":",
+      base::GetQuotedJSONString(QueryValue(url, "termsurf_original_url")),
+      ",\"streamUrl\":",
+      base::GetQuotedJSONString(QueryValue(url, "termsurf_stream_url")),
+      ",\"tabId\":-1,\"embedded\":",
+      QueryValue(url, "termsurf_embedded") == "true" ? "true" : "false",
+      ",\"responseHeaders\":{}}",
+  });
+}
+
+std::string InjectPdfViewerShim(const GURL& url, std::string html) {
+  const bool has_oopif_attr = html.find("pdfOopifEnabled") != std::string::npos;
+  LOG(INFO) << "[issue-789-exp5] viewer-template pdf_oopif_enabled="
+            << (has_oopif_attr ? "true" : "absent")
+            << " internal_id=" << QueryValue(url, "termsurf_internal_id");
+
+  const size_t head_end = html.find("</head>");
+  if (head_end == std::string::npos) {
+    return html;
+  }
+  html.insert(head_end, kPdfViewerShimScript);
+  return html;
+}
+
 network::mojom::URLResponseHeadPtr ResponseHeadForMimeType(
     const std::string& mime_type) {
