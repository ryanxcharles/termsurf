+constexpr char kPdfViewerShimScript[] = R"(
+<script>
+(function() {
+  const params = new URLSearchParams(window.location.search);
+  const internalId = params.get('termsurf_internal_id') || '';
+  const streamInfo = {
+    mimeType: params.get('termsurf_mime_type') || 'application/pdf',
+    originalUrl: params.get('termsurf_original_url') || '',
+    streamUrl: params.get('termsurf_stream_url') || '',
+    tabId: -1,
+    embedded: params.get('termsurf_embedded') === 'true',
+    responseHeaders: {},
+  };
+  const log = (event, extra = {}) => {
+    const query = new URLSearchParams({
+      event,
+      internal_id: internalId,
+      api: extra.api || 'mimeHandlerPrivate',
+      method: extra.method || '',
+    });
+    const image = new Image();
+    image.src = 'termsurf_viewer_log?' + query.toString();
+  };
+
+  window.chrome = window.chrome || {};
+  const listenerStub = () => ({addListener() {}, removeListener() {}});
+  chrome.mimeHandlerPrivate = chrome.mimeHandlerPrivate || {};
+  chrome.mimeHandlerPrivate.onSave =
+      chrome.mimeHandlerPrivate.onSave || listenerStub();
+  chrome.mimeHandlerPrivate.getStreamInfo = function(callback) {
+    log('viewer-api-call', {method: 'getStreamInfo'});
+    callback(streamInfo);
+  };
+  chrome.mimeHandlerPrivate.setPdfPluginAttributes = function(attributes) {
+    log('viewer-api-call', {method: 'setPdfPluginAttributes'});
+  };
+  chrome.mimeHandlerPrivate.setShowBeforeUnloadDialog = function() {};
+
+  chrome.pdfViewerPrivate = chrome.pdfViewerPrivate || {};
+  chrome.pdfViewerPrivate.SaveRequestType =
+      chrome.pdfViewerPrivate.SaveRequestType ||
+      {ANNOTATION: 'annotation', EDITED: 'edited', ORIGINAL: 'original'};
+  chrome.pdfViewerPrivate.SaveToDriveErrorType =
+      chrome.pdfViewerPrivate.SaveToDriveErrorType || {};
+  chrome.pdfViewerPrivate.SaveToDriveStatus =
+      chrome.pdfViewerPrivate.SaveToDriveStatus || {};
+  chrome.pdfViewerPrivate.onSave =
+      chrome.pdfViewerPrivate.onSave || listenerStub();
+  chrome.pdfViewerPrivate.onShouldUpdateViewport =
+      chrome.pdfViewerPrivate.onShouldUpdateViewport || listenerStub();
+  chrome.pdfViewerPrivate.onSaveToDriveProgress =
+      chrome.pdfViewerPrivate.onSaveToDriveProgress || listenerStub();
+  chrome.pdfViewerPrivate.getStreamInfo = function(callback) {
+    log('viewer-api-call', {
+      api: 'pdfViewerPrivate',
+      method: 'getStreamInfo',
+    });
+    callback(streamInfo);
+  };
+  chrome.pdfViewerPrivate.setPdfPluginAttributes = function() {};
+  chrome.pdfViewerPrivate.isAllowedLocalFileAccess = function(callback) {
+    callback(false);
+  };
+  chrome.pdfViewerPrivate.setPdfDocumentTitle = function() {};
+  chrome.pdfViewerPrivate.saveToDrive = function() {};
+  chrome.pdfViewerPrivate.glicSummarize = function() {};
+
+  log('viewer-api-installed');
+})();
+</script>
+)";
 
 std::string MimeTypeForPath(std::string_view path) {
