+namespace content {
+
+TsPdfStreamDelegate::TsPdfStreamDelegate() {
+  LOG(INFO) << "[issue-789-exp3] delegate-created this=" << this;
+}
+
+TsPdfStreamDelegate::~TsPdfStreamDelegate() = default;
+
+std::optional<GURL> TsPdfStreamDelegate::MapToOriginalUrl(
+    content::NavigationHandle& navigation_handle) {
+  std::string internal_id;
+  TsPdfStreamStore* store =
+      TsPdfStreamStore::GetOrCreate(navigation_handle.GetWebContents());
+  if (!store) {
+    LOG(INFO) << "[issue-789-exp3] map-to-original-url"
+              << " url=" << navigation_handle.GetURL().possibly_invalid_spec()
+              << " internal_id=" << internal_id << " result=no-store";
+    return std::nullopt;
+  }
+  return store->MapToOriginalUrl(navigation_handle, &internal_id);
+}
+
+std::optional<pdf::PdfStreamDelegate::StreamInfo>
+TsPdfStreamDelegate::GetStreamInfo(content::RenderFrameHost* embedder_frame) {
+  TsPdfStreamStore* store =
+      embedder_frame
+          ? TsPdfStreamStore::GetOrCreate(
+                content::WebContents::FromRenderFrameHost(embedder_frame))
+          : nullptr;
+  if (!store) {
+    LOG(INFO) << "[issue-789-exp3] get-stream-info"
+              << " frame_tree_node_id="
+              << (embedder_frame ? embedder_frame->GetFrameTreeNodeId()
+                                 : content::FrameTreeNodeId())
+              << " result=no-store";
+    return std::nullopt;
+  }
+  return store->GetStreamInfo(embedder_frame);
+}
+
+bool TsPdfStreamDelegate::MaybeDeleteSandboxedStream(
+    content::FrameTreeNodeId frame_tree_node_id) {
+  TsPdfStreamStore* store =
+      TsPdfStreamStore::FromFrameTreeNodeId(frame_tree_node_id);
+  if (!store) {
+    LOG(INFO) << "[issue-789-exp3] maybe-delete-sandboxed-stream"
+              << " frame_tree_node_id=" << frame_tree_node_id
+              << " deleted=false reason=no-store";
+    return false;
+  }
+  return store->MaybeDeleteSandboxedStream(frame_tree_node_id);
+}
+
+bool TsPdfStreamDelegate::ShouldAllowPdfFrameNavigation(
+    content::NavigationHandle* navigation_handle) {
+  TsPdfStreamStore* store =
+      navigation_handle
+          ? TsPdfStreamStore::GetOrCreate(navigation_handle->GetWebContents())
+          : nullptr;
+  if (!store) {
+    LOG(INFO) << "[issue-789-exp3] allow-pdf-frame-navigation"
+              << " url="
+              << (navigation_handle
+                      ? navigation_handle->GetURL().possibly_invalid_spec()
+                      : std::string())
+              << " allowed=true reason=no-store";
+    return true;
+  }
+  return store->ShouldAllowPdfFrameNavigation(navigation_handle);
+}
+
+bool TsPdfStreamDelegate::ShouldAllowPdfExtensionFrameNavigation(
+    content::NavigationHandle* navigation_handle) {
+  TsPdfStreamStore* store =
+      navigation_handle
+          ? TsPdfStreamStore::GetOrCreate(navigation_handle->GetWebContents())
+          : nullptr;
+  if (!store) {
+    LOG(INFO) << "[issue-789-exp3] allow-pdf-extension-frame-navigation"
+              << " url="
+              << (navigation_handle
+                      ? navigation_handle->GetURL().possibly_invalid_spec()
+                      : std::string())
+              << " allowed=true reason=no-store";
+    return true;
+  }
+  return store->ShouldAllowPdfExtensionFrameNavigation(navigation_handle);
+}
+
+}  // namespace content
