+
+  static TsPdfStreamStore* GetOrCreate(WebContents* web_contents);
+  static TsPdfStreamStore* FromFrameTreeNodeId(
+      FrameTreeNodeId frame_tree_node_id);
+  static bool HasStreams(WebContents* web_contents);
