diff --git a/content/libtermsurf_chromium/ts_pdf_stream_store.cc b/content/libtermsurf_chromium/ts_pdf_stream_store.cc
new file mode 100644
index 0000000000000..a0eefacbad169
--- /dev/null
+++ b/content/libtermsurf_chromium/ts_pdf_stream_store.cc
@@ -0,0 +1,509 @@
+// Copyright 2026 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/libtermsurf_chromium/ts_pdf_stream_store.h"
+
+#include <tuple>
+#include <utility>
+
+#include "base/feature_list.h"
+#include "base/logging.h"
+#include "components/pdf/common/pdf_util.h"
+#include "content/public/browser/document_user_data.h"
+#include "content/public/browser/navigation_handle.h"
+#include "content/public/browser/render_frame_host.h"
+#include "content/public/browser/web_contents.h"
+#include "extensions/browser/mime_handler/stream_container.h"
+#include "extensions/browser/mime_handler/stream_info.h"
+#include "pdf/pdf_features.h"
+#include "third_party/blink/public/mojom/loader/transferrable_url_loader.mojom.h"
+
+namespace content {
+
+namespace {
+
+TsPdfStreamStore::EmbedderHostInfo GetEmbedderHostInfo(
+    const RenderFrameHost* embedder_host) {
+  return {embedder_host->GetFrameTreeNodeId(), embedder_host->GetGlobalId()};
+}
+
+TsPdfStreamStore::EmbedderHostInfo GetUnclaimedEmbedderHostInfo(
+    FrameTreeNodeId frame_tree_node_id) {
+  return {frame_tree_node_id, GlobalRenderFrameHostId()};
+}
+
+RenderFrameHost* GetEmbedderHostFromPdfContentNavigation(
+    NavigationHandle* navigation_handle) {
+  RenderFrameHost* extension_host = navigation_handle->GetParentFrame();
+  if (!extension_host) {
+    return nullptr;
+  }
+  return extension_host->GetParent();
+}
+
+class TsPdfStreamInfoHelper : public DocumentUserData<TsPdfStreamInfoHelper> {
+ public:
+  std::optional<pdf::PdfStreamDelegate::StreamInfo> TakeStreamInfo() {
+    return std::move(stream_info_);
+  }
+
+ private:
+  friend class DocumentUserData<TsPdfStreamInfoHelper>;
+  DOCUMENT_USER_DATA_KEY_DECL();
+
+  TsPdfStreamInfoHelper(RenderFrameHost* render_frame_host,
+                        pdf::PdfStreamDelegate::StreamInfo stream_info)
+      : DocumentUserData<TsPdfStreamInfoHelper>(render_frame_host),
+        stream_info_(std::move(stream_info)) {}
+
+  std::optional<pdf::PdfStreamDelegate::StreamInfo> stream_info_;
+};
+
+DOCUMENT_USER_DATA_KEY_IMPL(TsPdfStreamInfoHelper);
+
+pdf::PdfStreamDelegate::StreamInfo BuildStreamInfo(
+    extensions::StreamInfo* stream_info) {
+  extensions::StreamContainer* stream = stream_info->stream();
+  pdf::PdfStreamDelegate::StreamInfo info;
+  info.stream_url = stream->stream_url();
+  info.original_url = stream->original_url();
+  static const std::string kEmptyInjectedScript;
+  info.injected_script = &kEmptyInjectedScript;
+  info.full_frame = !stream->embedded();
+  info.allow_javascript =
+      stream->pdf_plugin_attributes()
+          ? stream->pdf_plugin_attributes()->allow_javascript
+          : true;
+  info.background_color =
+      stream->pdf_plugin_attributes()
+          ? static_cast<SkColor>(
+                stream->pdf_plugin_attributes()->background_color)
+          : SK_ColorTRANSPARENT;
+  info.use_skia =
+      base::FeatureList::IsEnabled(chrome_pdf::features::kPdfUseSkiaRenderer);
+  info.allow_xfa_forms =
+      base::FeatureList::IsEnabled(chrome_pdf::features::kPdfXfaSupport);
+  if (stream->response_headers()) {
+    std::optional<std::string> coep_header =
+        stream->response_headers()->GetNormalizedHeader(
+            "Cross-Origin-Embedder-Policy");
+    if (coep_header.has_value()) {
+      info.coep_header = coep_header.value();
+    }
+  }
+  return info;
+}
+
+}  // namespace
+
+bool TsPdfStreamStore::EmbedderHostInfo::operator<(
+    const TsPdfStreamStore::EmbedderHostInfo& other) const {
+  return std::tie(frame_tree_node_id, global_id) <
+         std::tie(other.frame_tree_node_id, other.global_id);
+}
+
+TsPdfStreamStore::TsPdfStreamStore(WebContents* web_contents)
+    : WebContentsObserver(web_contents),
+      WebContentsUserData<TsPdfStreamStore>(*web_contents) {
+  LOG(INFO) << "[issue-789-exp3] stream-store-created web_contents="
+            << web_contents;
+}
+
+TsPdfStreamStore::~TsPdfStreamStore() = default;
+
+// static
+TsPdfStreamStore* TsPdfStreamStore::GetOrCreate(WebContents* web_contents) {
+  if (!web_contents) {
+    return nullptr;
+  }
+  TsPdfStreamStore::CreateForWebContents(web_contents);
+  return TsPdfStreamStore::FromWebContents(web_contents);
+}
+
+// static
+TsPdfStreamStore* TsPdfStreamStore::FromFrameTreeNodeId(
+    FrameTreeNodeId frame_tree_node_id) {
+  return GetOrCreate(WebContents::FromFrameTreeNodeId(frame_tree_node_id));
+}
+
+// static
+bool TsPdfStreamStore::HasStreams(WebContents* web_contents) {
+  TsPdfStreamStore* store = TsPdfStreamStore::FromWebContents(web_contents);
+  return store && !store->stream_infos_.empty();
+}
+
+// static
+void TsPdfStreamStore::AddStreamContainer(
+    FrameTreeNodeId frame_tree_node_id,
+    const std::string& internal_id,
+    std::unique_ptr<extensions::StreamContainer> stream_container) {
+  CHECK(stream_container);
+
+  TsPdfStreamStore* store = FromFrameTreeNodeId(frame_tree_node_id);
+  if (!store) {
+    LOG(INFO) << "[issue-789-exp3] stream-container-add-failed"
+              << " frame_tree_node_id=" << frame_tree_node_id
+              << " internal_id=" << internal_id << " reason=no-web-contents";
+    return;
+  }
+
+  auto key = GetUnclaimedEmbedderHostInfo(frame_tree_node_id);
+  store->stream_infos_[key] = std::make_unique<extensions::StreamInfo>(
+      internal_id, std::move(stream_container));
+
+  LOG(INFO) << "[issue-789-exp3] stream-container-added"
+            << " frame_tree_node_id=" << frame_tree_node_id
+            << " internal_id=" << internal_id
+            << " count=" << store->stream_infos_.size();
+}
+
+std::optional<GURL> TsPdfStreamStore::MapToOriginalUrl(
+    NavigationHandle& navigation_handle,
+    std::string* internal_id) {
+  RenderFrameHost* extension_frame = navigation_handle.GetParentFrame();
+  RenderFrameHost* embedder_frame =
+      extension_frame ? extension_frame->GetParent() : nullptr;
+  if (!embedder_frame) {
+    LOG(INFO) << "[issue-789-exp3] map-to-original-url"
+              << " url=" << navigation_handle.GetURL().possibly_invalid_spec()
+              << " internal_id=" << (internal_id ? *internal_id : std::string())
+              << " result=no-embedder-frame";
+    return std::nullopt;
+  }
+
+  extensions::StreamInfo* stream_info =
+      ClaimStreamInfo(embedder_frame, navigation_handle.GetURL());
+  if (!stream_info) {
+    LOG(INFO) << "[issue-789-exp3] map-to-original-url"
+              << " url=" << navigation_handle.GetURL().possibly_invalid_spec()
+              << " internal_id=" << (internal_id ? *internal_id : std::string())
+              << " result=no-stream";
+    return std::nullopt;
+  }
+
+  stream_info->set_extension_host_frame_tree_node_id(
+      extension_frame->GetFrameTreeNodeId());
+  stream_info->set_content_host_frame_tree_node_id(
+      navigation_handle.GetFrameTreeNodeId());
+  if (internal_id) {
+    *internal_id = stream_info->internal_id();
+  }
+  TsPdfStreamInfoHelper::CreateForCurrentDocument(extension_frame,
+                                                  BuildStreamInfo(stream_info));
+
+  LOG(INFO) << "[issue-789-exp3] map-to-original-url"
+            << " url=" << navigation_handle.GetURL().possibly_invalid_spec()
+            << " internal_id=" << stream_info->internal_id() << " original_url="
+            << stream_info->stream()->original_url().possibly_invalid_spec()
+            << " embedder_frame_tree_node_id="
+            << embedder_frame->GetFrameTreeNodeId()
+            << " content_frame_tree_node_id="
+            << navigation_handle.GetFrameTreeNodeId() << " result=claimed";
+  return stream_info->stream()->original_url();
+}
+
+std::optional<pdf::PdfStreamDelegate::StreamInfo>
+TsPdfStreamStore::GetStreamInfo(RenderFrameHost* embedder_frame) {
+  LOG(INFO) << "[issue-789-exp3] get-stream-info"
+            << " frame_tree_node_id="
+            << (embedder_frame ? embedder_frame->GetFrameTreeNodeId()
+                               : FrameTreeNodeId())
+            << " embedder_exists=" << (embedder_frame ? "true" : "false");
+  if (!embedder_frame) {
+    return std::nullopt;
+  }
+
+  TsPdfStreamInfoHelper* helper =
+      TsPdfStreamInfoHelper::GetForCurrentDocument(embedder_frame);
+  if (helper) {
+    std::optional<pdf::PdfStreamDelegate::StreamInfo> info =
+        helper->TakeStreamInfo();
+    LOG(INFO) << "[issue-789-exp3] get-stream-info"
+              << " frame_tree_node_id=" << embedder_frame->GetFrameTreeNodeId()
+              << " result="
+              << (info.has_value() ? "document-helper"
+                                   : "document-helper-empty");
+    return info;
+  }
+
+  extensions::StreamInfo* stream_info = GetClaimedStreamInfo(embedder_frame);
+  if (!stream_info) {
+    LOG(INFO) << "[issue-789-exp3] get-stream-info result=no-stream";
+    return std::nullopt;
+  }
+
+  pdf::PdfStreamDelegate::StreamInfo info = BuildStreamInfo(stream_info);
+
+  LOG(INFO) << "[issue-789-exp3] get-stream-info"
+            << " internal_id=" << stream_info->internal_id()
+            << " stream_url=" << info.stream_url.possibly_invalid_spec()
+            << " original_url=" << info.original_url.possibly_invalid_spec()
+            << " result=ok";
+  return info;
+}
+
+bool TsPdfStreamStore::MaybeDeleteSandboxedStream(
+    FrameTreeNodeId frame_tree_node_id) {
+  LOG(INFO) << "[issue-789-exp3] maybe-delete-sandboxed-stream"
+            << " frame_tree_node_id=" << frame_tree_node_id;
+  const bool erased =
+      stream_infos_.erase(GetUnclaimedEmbedderHostInfo(frame_tree_node_id)) > 0;
+  LOG(INFO) << "[issue-789-exp3] maybe-delete-sandboxed-stream"
+            << " frame_tree_node_id=" << frame_tree_node_id
+            << " deleted=" << (erased ? "true" : "false");
+  DeleteIfEmpty();
+  return erased;
+}
+
+bool TsPdfStreamStore::ShouldAllowPdfFrameNavigation(
+    NavigationHandle* navigation_handle) {
+  if (!navigation_handle) {
+    return true;
+  }
+
+  RenderFrameHost* parent_frame = navigation_handle->GetParentFrame();
+  if (!parent_frame) {
+    LOG(INFO) << "[issue-789-exp3] allow-pdf-frame-navigation"
+              << " url=" << navigation_handle->GetURL().possibly_invalid_spec()
+              << " allowed=true reason=no-parent";
+    return true;
+  }
+
+  const GURL& url = navigation_handle->GetURL();
+  bool allowed = true;
+  const char* reason = "untracked";
+
+  if (extensions::StreamInfo* stream_info =
+          GetClaimedStreamInfo(parent_frame)) {
+    allowed = url == stream_info->stream()->handler_url() ||
+              navigation_handle->GetFrameTreeNodeId() !=
+                  stream_info->extension_host_frame_tree_node_id();
+    reason = "extension-frame";
+  } else if (RenderFrameHost* grandparent = parent_frame->GetParent()) {
+    stream_info = GetClaimedStreamInfo(grandparent);
+    if (stream_info) {
+      allowed = url == stream_info->stream()->original_url() ||
+                navigation_handle->GetFrameTreeNodeId() !=
+                    stream_info->content_host_frame_tree_node_id();
+      reason = "content-frame";
+    }
+  }
+
+  LOG(INFO) << "[issue-789-exp3] allow-pdf-frame-navigation"
+            << " url=" << url.possibly_invalid_spec()
+            << " allowed=" << (allowed ? "true" : "false")
+            << " reason=" << reason;
+  return allowed;
+}
+
+bool TsPdfStreamStore::ShouldAllowPdfExtensionFrameNavigation(
+    NavigationHandle* navigation_handle) {
+  bool allowed = chrome_pdf::features::IsOopifPdfEnabled() ||
+                 !navigation_handle ||
+                 navigation_handle->GetURL().IsAboutBlank();
+  LOG(INFO) << "[issue-789-exp3] allow-pdf-extension-frame-navigation"
+            << " url="
+            << (navigation_handle
+                    ? navigation_handle->GetURL().possibly_invalid_spec()
+                    : std::string())
+            << " allowed=" << (allowed ? "true" : "false");
+  return allowed;
+}
+
+void TsPdfStreamStore::RenderFrameDeleted(RenderFrameHost* render_frame_host) {
+  if (!render_frame_host) {
+    return;
+  }
+
+  if (GetClaimedStreamInfo(render_frame_host)) {
+    DeleteClaimedStreamInfo(render_frame_host);
+    return;
+  }
+
+  if (!render_frame_host->IsActive()) {
+    return;
+  }
+
+  const FrameTreeNodeId frame_tree_node_id =
+      render_frame_host->GetFrameTreeNodeId();
+  if (stream_infos_.erase(GetUnclaimedEmbedderHostInfo(frame_tree_node_id)) >
+      0) {
+    LOG(INFO) << "[issue-789-exp3] stream-container-deleted"
+              << " frame_tree_node_id=" << frame_tree_node_id
+              << " reason=render-frame-deleted";
+  }
+  DeleteIfEmpty();
+}
+
+void TsPdfStreamStore::FrameDeleted(FrameTreeNodeId frame_tree_node_id) {
+  for (auto iter = stream_infos_.begin(); iter != stream_infos_.end();) {
+    extensions::StreamInfo* stream_info = iter->second.get();
+    if (frame_tree_node_id == iter->first.frame_tree_node_id ||
+        frame_tree_node_id ==
+            stream_info->extension_host_frame_tree_node_id() ||
+        frame_tree_node_id == stream_info->content_host_frame_tree_node_id()) {
+      LOG(INFO) << "[issue-789-exp3] stream-container-deleted"
+                << " frame_tree_node_id=" << frame_tree_node_id
+                << " internal_id=" << stream_info->internal_id()
+                << " reason=frame-deleted";
+      iter = stream_infos_.erase(iter);
+    } else {
+      ++iter;
+    }
+  }
+  DeleteIfEmpty();
+}
+
+void TsPdfStreamStore::ReadyToCommitNavigation(
+    NavigationHandle* navigation_handle) {
+  extensions::StreamInfo* stream_info =
+      GetClaimedStreamInfoFromPdfContentNavigation(navigation_handle);
+  if (!stream_info) {
+    return;
+  }
+
+  if (navigation_handle->GetFrameTreeNodeId() !=
+      stream_info->content_host_frame_tree_node_id()) {
+    return;
+  }
+
+  auto transferrable_loader =
+      stream_info->stream()->TakeTransferrableURLLoader();
+  if (!transferrable_loader) {
+    LOG(INFO) << "[issue-789-exp3] stream-served"
+              << " original_url="
+              << stream_info->stream()->original_url().possibly_invalid_spec()
+              << " internal_id=" << stream_info->internal_id()
+              << " result=no-loader";
+    return;
+  }
+
+  navigation_handle->RegisterSubresourceOverride(
+      std::move(transferrable_loader));
+  LOG(INFO) << "[issue-789-exp3] stream-served"
+            << " original_url="
+            << stream_info->stream()->original_url().possibly_invalid_spec()
+            << " internal_id=" << stream_info->internal_id()
+            << " frame_tree_node_id=" << navigation_handle->GetFrameTreeNodeId()
+            << " result=registered-subresource-override";
+}
+
+void TsPdfStreamStore::DidFinishNavigation(
+    NavigationHandle* navigation_handle) {
+  if (!navigation_handle || !navigation_handle->HasCommitted() ||
+      navigation_handle->IsErrorPage()) {
+    return;
+  }
+
+  RenderFrameHost* parent_frame = navigation_handle->GetParentFrame();
+  if (!parent_frame) {
+    return;
+  }
+
+  if (extensions::StreamInfo* stream_info =
+          GetClaimedStreamInfo(parent_frame)) {
+    if (navigation_handle->GetURL() == stream_info->stream()->handler_url() &&
+        navigation_handle->GetFrameTreeNodeId() ==
+            stream_info->extension_host_frame_tree_node_id()) {
+      stream_info->SetDidExtensionFinishNavigation();
+      LOG(INFO) << "[issue-789-exp3] extension-frame-committed"
+                << " internal_id=" << stream_info->internal_id()
+                << " frame_tree_node_id="
+                << navigation_handle->GetFrameTreeNodeId();
+    }
+  }
+}
+
+extensions::StreamInfo* TsPdfStreamStore::GetClaimedStreamInfo(
+    const RenderFrameHost* embedder_host) {
+  auto iter = stream_infos_.find(GetEmbedderHostInfo(embedder_host));
+  return iter != stream_infos_.end() ? iter->second.get() : nullptr;
+}
+
+const extensions::StreamInfo* TsPdfStreamStore::GetClaimedStreamInfo(
+    const RenderFrameHost* embedder_host) const {
+  auto iter = stream_infos_.find(GetEmbedderHostInfo(embedder_host));
+  return iter != stream_infos_.end() ? iter->second.get() : nullptr;
+}
+
+extensions::StreamInfo*
+TsPdfStreamStore::GetClaimedStreamInfoFromPdfContentNavigation(
+    NavigationHandle* navigation_handle) {
+  if (!navigation_handle || !navigation_handle->IsPdf()) {
+    return nullptr;
+  }
+
+  RenderFrameHost* embedder_host =
+      GetEmbedderHostFromPdfContentNavigation(navigation_handle);
+  if (!embedder_host) {
+    return nullptr;
+  }
+
+  return GetClaimedStreamInfo(embedder_host);
+}
+
+extensions::StreamInfo* TsPdfStreamStore::ClaimStreamInfo(
+    RenderFrameHost* embedder_host,
+    const GURL& stream_url) {
+  LOG(INFO) << "[issue-789-exp3] stream-container-claim-request"
+            << " frame_tree_node_id=" << embedder_host->GetFrameTreeNodeId()
+            << " url=" << stream_url.possibly_invalid_spec();
+
+  auto key = GetUnclaimedEmbedderHostInfo(embedder_host->GetFrameTreeNodeId());
+  auto iter = stream_infos_.find(key);
+  if (iter == stream_infos_.end() ||
+      iter->second->stream()->stream_url() != stream_url) {
+    for (auto candidate = stream_infos_.begin();
+         candidate != stream_infos_.end(); ++candidate) {
+      if (!candidate->first.global_id &&
+          candidate->second->stream()->stream_url() == stream_url) {
+        iter = candidate;
+        break;
+      }
+    }
+  }
+
+  if (iter == stream_infos_.end() ||
+      iter->second->stream()->stream_url() != stream_url) {
+    LOG(INFO) << "[issue-789-exp3] stream-container-claim-request"
+              << " frame_tree_node_id=" << embedder_host->GetFrameTreeNodeId()
+              << " result=no-match";
+    return nullptr;
+  }
+
+  auto claimed_key = GetEmbedderHostInfo(embedder_host);
+  stream_infos_[claimed_key] = std::move(iter->second);
+  stream_infos_.erase(iter);
+
+  extensions::StreamInfo* stream_info = stream_infos_[claimed_key].get();
+  LOG(INFO) << "[issue-789-exp3] stream-container-claimed"
+            << " render_frame_host=" << embedder_host
+            << " frame_tree_node_id=" << embedder_host->GetFrameTreeNodeId()
+            << " internal_id=" << stream_info->internal_id();
+  return stream_info;
+}
+
+void TsPdfStreamStore::DeleteClaimedStreamInfo(RenderFrameHost* embedder_host) {
+  auto iter = stream_infos_.find(GetEmbedderHostInfo(embedder_host));
+  if (iter == stream_infos_.end()) {
+    return;
+  }
+
+  LOG(INFO) << "[issue-789-exp3] stream-container-deleted"
+            << " frame_tree_node_id=" << embedder_host->GetFrameTreeNodeId()
+            << " internal_id=" << iter->second->internal_id()
+            << " reason=claimed-render-frame-deleted";
+  stream_infos_.erase(iter);
+  DeleteIfEmpty();
+}
+
+void TsPdfStreamStore::DeleteIfEmpty() {
+  if (stream_infos_.empty()) {
+    LOG(INFO) << "[issue-789-exp3] stream-store-empty";
+  }
+}
+
+WEB_CONTENTS_USER_DATA_KEY_IMPL(TsPdfStreamStore);
