From 9177d5384ff57f287afc52e27c7bcdd766a8537b Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Thu, 28 May 2026 20:09:29 -0500
Subject: [PATCH 08/10] Add OOPIF PDF state diagnostic
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

We thought the feature lay asleep, switched off—
the log revealed it woke, both flags aloft.
combined=1, yet no PDF process born:
the viewer runs non-OOPIF, plugin-in-frame, forlorn.
The hypothesis dies; the diagnostic stays
to point the next experiment through the maze.
---
 content/libtermsurf_chromium/ts_browser_client.cc | 9 +++++++++
 1 file changed, 9 insertions(+)

diff --git a/content/libtermsurf_chromium/ts_browser_client.cc b/content/libtermsurf_chromium/ts_browser_client.cc
index 3e79a753c9ac8..065c2f4a34dfa 100644
--- a/content/libtermsurf_chromium/ts_browser_client.cc
+++ b/content/libtermsurf_chromium/ts_browser_client.cc
@@ -5,6 +5,7 @@
 #include "content/libtermsurf_chromium/ts_browser_client.h"
 
 #include "base/command_line.h"
+#include "base/feature_list.h"
 #include "base/logging.h"
 #include "components/pdf/browser/pdf_navigation_throttle.h"
 #include "components/pdf/browser/pdf_url_loader_request_interceptor.h"
@@ -28,6 +29,7 @@
 #include "mojo/public/cpp/bindings/binder_map.h"
 #include "mojo/public/cpp/bindings/pending_receiver.h"
 #include "mojo/public/cpp/bindings/receiver_set.h"
+#include "pdf/pdf_features.h"
 #include "services/network/public/cpp/resource_request.h"
 #include "services/network/public/mojom/network_context.mojom.h"
 #include "third_party/blink/public/common/web_preferences/web_preferences.h"
@@ -112,6 +114,13 @@ void TsBrowserClient::CreateThrottlesForNavigation(
     registry.AddThrottle(std::make_unique<pdf::PdfNavigationThrottle>(
         registry, std::make_unique<TsPdfStreamDelegate>()));
     LOG(INFO) << "[issue-789-exp3] pdf-navigation-throttle-installed";
+    // Issue 790 Exp 2 diagnostic: the PDF process designation (and the
+    // throttle's WillProcessResponse OOPIF path) depend on IsOopifPdfEnabled()
+    // = policy_bool && FeatureList::IsEnabled(kPdfOopif). Record the runtime
+    // state.
+    LOG(INFO) << "[issue-790-exp2] oopif-state combined="
+              << chrome_pdf::features::IsOopifPdfEnabled() << " feature="
+              << base::FeatureList::IsEnabled(chrome_pdf::features::kPdfOopif);
   }
 }
 
