+extensions::StreamInfo* TsPdfStreamStore::ClaimStreamInfo(
+    RenderFrameHost* embedder_host) {
+  LOG(INFO) << "[issue-789-exp4] stream-claim-attempt"
+            << " embedder_frame_tree_node_id="
+            << (embedder_host ? embedder_host->GetFrameTreeNodeId()
+                              : FrameTreeNodeId());
+  if (!embedder_host) {
+    LOG(INFO) << "[issue-789-exp4] stream-claim-missing"
+              << " internal_id= reason=no-embedder";
+    return nullptr;
+  }
+
+  auto unclaimed_key =
+      GetUnclaimedEmbedderHostInfo(embedder_host->GetFrameTreeNodeId());
+  auto iter = stream_infos_.find(unclaimed_key);
+  if (iter == stream_infos_.end()) {
+    LOG(INFO) << "[issue-789-exp4] stream-claim-missing"
+              << " internal_id= reason=no-unclaimed-stream"
+              << " embedder_frame_tree_node_id="
+              << embedder_host->GetFrameTreeNodeId();
+    return nullptr;
+  }
+
+  auto claimed_key = GetEmbedderHostInfo(embedder_host);
+  stream_infos_[claimed_key] = std::move(iter->second);
+  stream_infos_.erase(iter);
+
+  extensions::StreamInfo* stream_info = stream_infos_[claimed_key].get();
+  LOG(INFO) << "[issue-789-exp3] stream-container-claimed"
+            << " render_frame_host=" << embedder_host
+            << " frame_tree_node_id=" << embedder_host->GetFrameTreeNodeId()
+            << " internal_id=" << stream_info->internal_id()
+            << " reason=embedder-ready-to-commit";
+  LOG(INFO) << "[issue-789-exp4] stream-claim-ready"
+            << " internal_id=" << stream_info->internal_id()
+            << " embedder_frame_tree_node_id="
+            << embedder_host->GetFrameTreeNodeId()
+            << " embedder_rfh=" << embedder_host;
+  MaybeAttachPdfExtensionFrame(embedder_host);
+  return stream_info;
+}
+
+bool TsPdfStreamStore::ContainsUnclaimedStreamInfo(
+    FrameTreeNodeId frame_tree_node_id) const {
+  return stream_infos_.contains(
+      GetUnclaimedEmbedderHostInfo(frame_tree_node_id));
+}
+
+bool TsPdfStreamStore::MaybeAttachPdfExtensionFrame(
+    RenderFrameHost* embedder_host) {
+  extensions::StreamInfo* stream_info = GetClaimedStreamInfo(embedder_host);
+  if (!stream_info) {
+    return false;
+  }
+  if (stream_info->DidPdfExtensionStartNavigation()) {
+    return false;
+  }
+
+  RenderFrameHost* child_frame = nullptr;
+  embedder_host->ForEachRenderFrameHostWithAction([&](RenderFrameHost* frame) {
+    if (frame != embedder_host && frame->GetParent() == embedder_host) {
+      child_frame = frame;
+      return RenderFrameHost::FrameIterationAction::kStop;
+    }
+    return RenderFrameHost::FrameIterationAction::kContinue;
+  });
+
+  if (!child_frame) {
+    LOG(INFO) << "[issue-789-exp4] stream-claim-missing"
+              << " internal_id=" << stream_info->internal_id()
+              << " reason=no-child-frame"
+              << " embedder_frame_tree_node_id="
+              << embedder_host->GetFrameTreeNodeId();
+    return false;
+  }
+
+  stream_info->set_extension_host_frame_tree_node_id(
+      child_frame->GetFrameTreeNodeId());
+  LOG(INFO) << "[issue-789-exp4] attach-child-found"
+            << " embedder_frame_tree_node_id="
+            << embedder_host->GetFrameTreeNodeId()
+            << " child_frame_tree_node_id=" << child_frame->GetFrameTreeNodeId()
+            << " internal_id=" << stream_info->internal_id();
+  NavigatePdfExtensionFrame(child_frame->GetFrameTreeNodeId(), embedder_host,
+                            stream_info);
+  return true;
+}
+
+void TsPdfStreamStore::NavigatePdfExtensionFrame(
+    FrameTreeNodeId extension_frame_tree_node_id,
+    RenderFrameHost* embedder_host,
+    extensions::StreamInfo* stream_info) {
+  CHECK(embedder_host);
+  CHECK(stream_info);
+
+  NavigationController::LoadURLParams params(
+      stream_info->stream()->handler_url());
+  params.frame_tree_node_id = extension_frame_tree_node_id;
+  params.source_site_instance = embedder_host->GetSiteInstance();
+  params.transition_type = ui::PAGE_TRANSITION_AUTO_SUBFRAME;
+  params.is_renderer_initiated = false;
+  web_contents()->GetController().LoadURLWithParams(std::move(params));
+  LOG(INFO) << "[issue-789-exp4] attach-navigate"
+            << " embedder_frame_tree_node_id="
+            << embedder_host->GetFrameTreeNodeId()
+            << " child_frame_tree_node_id=" << extension_frame_tree_node_id
+            << " target="
+            << stream_info->stream()->handler_url().possibly_invalid_spec();
+}
