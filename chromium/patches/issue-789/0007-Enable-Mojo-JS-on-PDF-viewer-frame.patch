@@ -18663,6 +18663,15 @@ void RenderFrameHostImpl::EnableMojoJsBindingsWithBroker(
   GetFrameBindingsControl()->EnableMojoJsBindingsWithBroker(std::move(broker));
 }
 
+void RenderFrameHostImpl::EnableMojoJsBindingsWithBrokerNoWebUI(
+    mojo::PendingRemote<blink::mojom::BrowserInterfaceBroker> broker) {
+  // TermSurf (Issue 790): unlike EnableMojoJsBindingsWithBroker above, this
+  // does not require an associated WebUI. The caller (TermSurf's PDF embedder)
+  // owns the broker via a self-owned receiver, so there is no WebUIController
+  // to transfer ownership to. The renderer-side effect is identical.
+  GetFrameBindingsControl()->EnableMojoJsBindingsWithBroker(std::move(broker));
+}
+
 bool RenderFrameHostImpl::IsOutermostMainFrame() const {
   return !GetParentOrOuterDocument();
 }
