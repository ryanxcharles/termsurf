--- /dev/null
+++ b/content/libtermsurf_chromium/ts_pdf_mojo_interface_broker.h
@@ -0,0 +1,33 @@
+// Copyright 2026 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CONTENT_LIBTERMSURF_CHROMIUM_TS_PDF_MOJO_INTERFACE_BROKER_H_
+#define CONTENT_LIBTERMSURF_CHROMIUM_TS_PDF_MOJO_INTERFACE_BROKER_H_
+
+#include "mojo/public/cpp/bindings/generic_pending_receiver.h"
+#include "third_party/blink/public/mojom/browser_interface_broker.mojom.h"
+
+namespace content {
+
+// A minimal browser-side interface broker handed to the PDF viewer frame's Mojo
+// JS bindings (Issue 790 Exp 1). It exposes no interfaces: every GetInterface
+// request is logged (to enumerate what the viewer needs) and dropped. This is
+// the most restrictive possible starting point — the viewer JS gets the `Mojo`
+// global but cannot reach any browser interface. Later experiments replace this
+// with a broker that serves the specific PDF interfaces the viewer requires.
+class TsPdfMojoInterfaceBroker : public blink::mojom::BrowserInterfaceBroker {
+ public:
+  TsPdfMojoInterfaceBroker();
+  ~TsPdfMojoInterfaceBroker() override;
+
+  TsPdfMojoInterfaceBroker(const TsPdfMojoInterfaceBroker&) = delete;
+  TsPdfMojoInterfaceBroker& operator=(const TsPdfMojoInterfaceBroker&) = delete;
+
+  // blink::mojom::BrowserInterfaceBroker:
+  void GetInterface(mojo::GenericPendingReceiver receiver) override;
+};
+
+}  // namespace content
+
+#endif  // CONTENT_LIBTERMSURF_CHROMIUM_TS_PDF_MOJO_INTERFACE_BROKER_H_
