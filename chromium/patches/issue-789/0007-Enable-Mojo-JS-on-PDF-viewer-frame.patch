+namespace content {
+
+TsPdfMojoInterfaceBroker::TsPdfMojoInterfaceBroker() = default;
+TsPdfMojoInterfaceBroker::~TsPdfMojoInterfaceBroker() = default;
+
+void TsPdfMojoInterfaceBroker::GetInterface(
+    mojo::GenericPendingReceiver receiver) {
+  // Log which interface the PDF viewer asks for, then drop the receiver (its
+  // pipe closes). This enumerates the interfaces a later experiment must serve.
