 namespace content {
@@ -407,6 +412,25 @@ void TsPdfStreamStore::DidStartNavigation(NavigationHandle* navigation_handle) {
 
 void TsPdfStreamStore::ReadyToCommitNavigation(
     NavigationHandle* navigation_handle) {
+  // Issue 790 Exp 1: enable Mojo JS bindings on the PDF viewer extension frame
+  // before its scripts run, so chrome://resources/mojo/.../bindings.js finds
+  // its `Mojo` global. Gated to the active viewer host frame (same identity
+  // check as Issue 789 Exp 6/7). Uses the broker variant because the viewer is
+  // a subframe (the context-only enable is main-frame-only); the broker is
+  // empty for now and logs the interfaces the viewer requests. Re-enabling on
+  // each navigation is correct — each new document needs its own Mojo JS setup.
+  if (RenderFrameHost* viewer_frame =
+          navigation_handle ? navigation_handle->GetRenderFrameHost() : nullptr;
+      viewer_frame && IsPdfExtensionHostFrame(viewer_frame)) {
+    mojo::PendingRemote<blink::mojom::BrowserInterfaceBroker> broker;
+    mojo::MakeSelfOwnedReceiver(std::make_unique<TsPdfMojoInterfaceBroker>(),
+                                broker.InitWithNewPipeAndPassReceiver());
+    static_cast<RenderFrameHostImpl*>(viewer_frame)
+        ->EnableMojoJsBindingsWithBrokerNoWebUI(std::move(broker));
+    LOG(INFO) << "[issue-790-exp1] mojo-js-enabled frame_tree_node_id="
+              << viewer_frame->GetFrameTreeNodeId();
+  }
+
   extensions::StreamInfo* stream_info =
       GetClaimedStreamInfoFromPdfContentNavigation(navigation_handle);
   if (!stream_info) {
