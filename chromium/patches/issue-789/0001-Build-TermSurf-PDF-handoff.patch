+// found in the LICENSE file.
+
+#include "content/libtermsurf_chromium/ts_pdf_stream_dispatch.h"
+
+#include <map>
+#include <memory>
+#include <string>
+
+#include "base/logging.h"
+#include "base/no_destructor.h"
+#include "base/strings/strcat.h"
+#include "content/public/browser/browser_thread.h"
+#include "extensions/browser/mime_handler/stream_container.h"
+#include "extensions/common/constants.h"
+#include "extensions/common/extension_id.h"
+#include "third_party/blink/public/mojom/loader/transferrable_url_loader.mojom.h"
+#include "url/gurl.h"
+
+namespace content {
+
+namespace {
+
+constexpr int kUnknownTabId = -1;
+
+std::map<std::string, std::unique_ptr<extensions::StreamContainer>>&
+CapturedPdfStreams() {
+  static base::NoDestructor<
+      std::map<std::string, std::unique_ptr<extensions::StreamContainer>>>
+      streams;
+  return *streams;
+}
+
+GURL PdfViewerHandlerUrl() {
+  return GURL(
+      base::StrCat({extensions::kExtensionScheme, "://",
+                    extension_misc::kPdfExtensionId, "/pdf/index.html"}));
+}
+
+}  // namespace
+
+void TsDispatchPdfStream(
+    content::FrameTreeNodeId frame_tree_node_id,
+    const std::string& internal_id,
+    bool embedded,
+    blink::mojom::TransferrableURLLoaderPtr transferrable_loader,
+    const GURL& original_url) {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+
+  GURL handler_url = PdfViewerHandlerUrl();
+  LOG(INFO) << "[issue-789-exp2] stream-dispatch frame_tree_node_id="
+            << frame_tree_node_id
+            << " extension_id=" << extension_misc::kPdfExtensionId
+            << " handler_url=" << handler_url.possibly_invalid_spec()
+            << " internal_id=" << internal_id
+            << " embedded=" << (embedded ? "true" : "false");
+
+  auto stream_container = std::make_unique<extensions::StreamContainer>(
+      kUnknownTabId, embedded, handler_url, extension_misc::kPdfExtensionId,
+      std::move(transferrable_loader), original_url);
+  CapturedPdfStreams()[internal_id] = std::move(stream_container);
+
+  LOG(INFO) << "[issue-789-exp2] stream-container-captured internal_id="
+            << internal_id << " count=" << CapturedPdfStreams().size()
+            << " pdf-viewer-stream-manager=not-linked";
+}
+
+}  // namespace content
