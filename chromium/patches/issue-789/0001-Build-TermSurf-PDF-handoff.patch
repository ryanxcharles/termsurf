+namespace content {
+
+class TsPdfResponseURLLoaderThrottle : public blink::URLLoaderThrottle {
+ public:
+  TsPdfResponseURLLoaderThrottle(
+      network::mojom::RequestDestination request_destination,
+      content::FrameTreeNodeId frame_tree_node_id);
+
+  TsPdfResponseURLLoaderThrottle(const TsPdfResponseURLLoaderThrottle&) =
+      delete;
+  TsPdfResponseURLLoaderThrottle& operator=(
+      const TsPdfResponseURLLoaderThrottle&) = delete;
+
+  ~TsPdfResponseURLLoaderThrottle() override;
+
+ private:
+  void WillProcessResponse(const GURL& response_url,
+                           network::mojom::URLResponseHead* response_head,
+                           bool* defer) override;
