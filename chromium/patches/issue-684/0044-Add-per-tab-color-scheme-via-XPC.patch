   tab->widget_mac = std::make_unique<ui::AcceleratedWidgetMac>();
   ui::ContextFactory* context_factory = content::GetContextFactory();
@@ -891,6 +904,34 @@ void ShellBrowserMainParts::NavigateTab(const std::string& pane_id,
   LOG(WARNING) << "[ProfileServer] Navigate: no tab for pane " << pane_id;
 }
 
+void ShellBrowserMainParts::SetColorScheme(const std::string& pane_id,
+                                            bool dark) {
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+  for (auto& tab : tabs_) {
+    if (tab->pane_id == pane_id) {
+      tab->preferred_color_scheme = dark
+          ? blink::mojom::PreferredColorScheme::kDark
+          : blink::mojom::PreferredColorScheme::kLight;
+      tab->shell->web_contents()->OnWebPreferencesChanged();
+      LOG(INFO) << "[ProfileServer] Set color scheme pane " << pane_id
+                << " dark=" << dark;
+      return;
+    }
+  }
+  LOG(WARNING) << "[ProfileServer] SetColorScheme: no tab for pane " << pane_id;
+}
+
+std::optional<blink::mojom::PreferredColorScheme>
+ShellBrowserMainParts::GetColorSchemeForWebContents(
+    WebContents* web_contents) const {
+  for (const auto& tab : tabs_) {
+    if (tab->shell && tab->shell->web_contents() == web_contents) {
+      return tab->preferred_color_scheme;
+    }
+  }
+  return std::nullopt;
+}
+
