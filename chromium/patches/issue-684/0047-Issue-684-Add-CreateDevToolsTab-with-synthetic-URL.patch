+
+void ShellBrowserMainParts::CreateDevToolsTab(
+    const std::string& pane_id,
+    int inspected_tab_id,
+    int pixel_width,
+    int pixel_height,
+    bool dark) {
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+
+  // Find the inspected tab by tab_id.
+  WebContents* inspected_contents = nullptr;
+  for (auto& t : tabs_) {
+    if (t->tab_id == inspected_tab_id && t->tab_id != 0) {
+      inspected_contents = t->shell->web_contents();
+      break;
+    }
+  }
+  if (!inspected_contents) {
+    LOG(ERROR) << "[ProfileServer] DevTools: tab " << inspected_tab_id
+               << " not found";
+    return;
+  }
+
+  LOG(INFO) << "[ProfileServer] Creating DevTools for tab "
+            << inspected_tab_id << " in pane " << pane_id;
+
+  // Construct the DevTools frontend URL internally.
+  GURL devtools_url(base::StringPrintf(
+      "http://127.0.0.1:%d/devtools/devtools_app.html?targetType=tab",
+      ShellDevToolsManagerDelegate::GetHttpHandlerPort()));
+
+  // Create a new Shell + WebContents with the DevTools frontend URL.
+  Shell* shell = Shell::CreateNewWindow(browser_context_.get(), devtools_url,
+                                        nullptr, gfx::Size());
+  LOG(INFO) << "[ProfileServer] Created DevTools shell for pane " << pane_id
+            << ", URL: " << devtools_url.spec();
+
+  // Resize.
+  if (pixel_width > 0 && pixel_height > 0) {
+    RenderWidgetHostView* view =
+        shell->web_contents()->GetRenderWidgetHostView();
+    if (view) {
+      float scale = view->GetDeviceScaleFactor();
+      gfx::Size logical(
+          static_cast<int>(std::ceil(pixel_width / scale)),
+          static_cast<int>(std::ceil(pixel_height / scale)));
+      shell->ResizeWebContentForTests(logical);
+    }
+  }
+
+  // Create per-tab persistent compositor (same as CreateTab).
+  auto tab = std::make_unique<TabState>();
+  tab->shell = shell;
+  tab->pane_id = pane_id;
+  tab->inspected_tab_id = inspected_tab_id;
+  tab->preferred_color_scheme = dark
+      ? blink::mojom::PreferredColorScheme::kDark
+      : blink::mojom::PreferredColorScheme::kLight;
+
+  tab->widget_mac = std::make_unique<ui::AcceleratedWidgetMac>();
+  ui::ContextFactory* context_factory = content::GetContextFactory();
+  tab->compositor = std::make_unique<ui::Compositor>(
+      context_factory->AllocateFrameSinkId(),
+      context_factory,
+      base::SingleThreadTaskRunner::GetCurrentDefault(),
+      false /* enable_pixel_canvas */);
+  tab->compositor->SetAcceleratedWidget(
+      tab->widget_mac->accelerated_widget());
+
+  tab->root_layer = std::make_unique<ui::Layer>(ui::LAYER_SOLID_COLOR);
+  tab->root_layer->SetColor(SK_ColorTRANSPARENT);
+
+  // Set initial size.
+  {
+    RenderWidgetHostView* view =
+        shell->web_contents()->GetRenderWidgetHostView();
+    if (view) {
+      float scale = view->GetDeviceScaleFactor();
+      gfx::Size size_pixels(pixel_width, pixel_height);
+      gfx::Size size_dip(
+          static_cast<int>(std::ceil(pixel_width / scale)),
+          static_cast<int>(std::ceil(pixel_height / scale)));
+      tab->root_layer->SetBounds(gfx::Rect(size_dip));
+      viz::LocalSurfaceId local_surface_id =
+          viz::LocalSurfaceId(1, 1, base::UnguessableToken::Create());
+      tab->compositor->SetScaleAndSize(
+          scale, size_pixels, local_surface_id);
+    }
+  }
+
+  tab->compositor->SetRootLayer(tab->root_layer.get());
+  tab->compositor->SetVisible(true);
+
+  // Register bridge.
+  tab->bridge = std::make_unique<PersistentCompositorBridge>(
+      tab->widget_mac.get());
+
+  // Set parent_ui_layer_ on the view.
+  {
+    RenderWidgetHostView* view =
+        shell->web_contents()->GetRenderWidgetHostView();
+    if (view) {
+      SetParentUiLayerOnView(view, tab->root_layer.get());
+    }
   }
 
-  // Assign auto-incrementing tab ID for browser tabs only (Issue 684).
-  // DevTools tabs get tab_id=0 (no ID).
-  if (!is_devtools) {
-    tab->tab_id = next_tab_id_++;
-    LOG(INFO) << "[ProfileServer] Assigned tab_id=" << tab->tab_id
-              << " to pane " << pane_id;
+  // Create ShellTabObserver.
+  auto tab_observer = std::make_unique<ShellTabObserver>();
+  tab_observer->SetPaneId(pane_id);
+  tab_observer->SetInspectedTabId(inspected_tab_id);
+
+  // Open a new connection to the app for this tab.
+  xpc_connection_t tab_conn = xpc_connection_create_from_endpoint(app_endpoint_);
+
+  ShellBrowserMainParts* self = this;
+
+  xpc_connection_set_event_handler(tab_conn, ^(xpc_object_t event) {
+    if (xpc_get_type(event) == XPC_TYPE_ERROR) {
+      if (event == XPC_ERROR_CONNECTION_INVALID ||
+          event == XPC_ERROR_CONNECTION_INTERRUPTED) {
+        xpc_connection_t conn = tab_conn;
+        content::GetUIThreadTaskRunner({})->PostTask(
+            FROM_HERE,
+            base::BindOnce(&ShellBrowserMainParts::CloseTab,
+                           base::Unretained(self), conn));
+      }
+    }
+  });
+
+  xpc_connection_resume(tab_conn);
+
+  // Send tab_ready message.
+  xpc_object_t msg = xpc_dictionary_create(NULL, NULL, 0);
+  xpc_dictionary_set_string(msg, "action", "tab_ready");
+  xpc_dictionary_set_string(msg, "pane_id", pane_id.c_str());
+  xpc_connection_send_message(tab_conn, msg);
+  xpc_release(msg);
+
+  // Hand the connection to the observer and start observing.
+  tab_observer->SetConnection(tab_conn);
+  tab_observer->ObserveContents(shell->web_contents());
+
+  // Register cursor change and CALayerParams callbacks.
+  if (auto* view = shell->web_contents()->GetRenderWidgetHostView()) {
+    auto* rwhi = static_cast<RenderWidgetHostImpl*>(
+        view->GetRenderWidgetHost());
+    rwhi->SetCursorChangedCallback(base::BindRepeating(
+        &ShellTabObserver::OnCursorChanged,
+        base::Unretained(tab_observer.get())));
+
+    std::string cb_pane_id = pane_id;
+    xpc_connection_t cb_conn = tab_conn;
+    auto* last_id = new uint32_t(0);
+    auto ca_layer_callback = base::BindRepeating(
+        [](const std::string& pane_id, xpc_connection_t conn,
+           uint32_t* last_id, const gfx::CALayerParams& params) {
+          if (params.ca_context_id == 0 || params.ca_context_id == *last_id)
+            return;
+          *last_id = params.ca_context_id;
+          xpc_object_t msg = xpc_dictionary_create(NULL, NULL, 0);
+          xpc_dictionary_set_string(msg, "action", "ca_context");
+          xpc_dictionary_set_uint64(msg, "ca_context_id",
+                                    params.ca_context_id);
+          xpc_dictionary_set_string(msg, "pane_id", pane_id.c_str());
+          xpc_dictionary_set_uint64(msg, "pixel_width",
+                                    params.pixel_size.width());
+          xpc_dictionary_set_uint64(msg, "pixel_height",
+                                    params.pixel_size.height());
+          xpc_connection_send_message(conn, msg);
+          xpc_release(msg);
+          LOG(INFO) << "[ProfileServer] DevTools ca_context_id="
+                    << params.ca_context_id << " for pane " << pane_id;
+        },
+        cb_pane_id, cb_conn,
+        base::Owned(last_id));
+    SetCALayerParamsCallbackOnView(view, ca_layer_callback);
+
+    tab_observer->SetCALayerParamsCallback(ca_layer_callback);
+    tab_observer->SetLastCAContextIdPtr(last_id);
+
+    tab->bridge->SetCallback(base::BindRepeating(
+        [](const std::string& pane_id, xpc_connection_t conn,
+           uint32_t* last_id, const gfx::CALayerParams& params) {
+          if (params.ca_context_id == 0 || params.ca_context_id == *last_id)
+            return;
+          *last_id = params.ca_context_id;
+          xpc_object_t msg = xpc_dictionary_create(NULL, NULL, 0);
+          xpc_dictionary_set_string(msg, "action", "ca_context");
+          xpc_dictionary_set_uint64(msg, "ca_context_id",
+                                    params.ca_context_id);
+          xpc_dictionary_set_string(msg, "pane_id", pane_id.c_str());
+          xpc_dictionary_set_uint64(msg, "pixel_width",
+                                    params.pixel_size.width());
+          xpc_dictionary_set_uint64(msg, "pixel_height",
+                                    params.pixel_size.height());
+          xpc_connection_send_message(conn, msg);
+          xpc_release(msg);
+          LOG(INFO) << "[ProfileServer] DevTools tab compositor ca_context_id="
+                    << params.ca_context_id << " for pane " << pane_id;
+        },
+        cb_pane_id, cb_conn,
+        base::Unretained(last_id)));
   }
 
+  // Store parent ui layer on observer.
+  tab_observer->SetParentUiLayer(tab->root_layer.get());
+
+  // Wire up DevTools bindings (Issue 684).
+  // ShellDevToolsFrontend observes the DevTools WebContents and calls
+  // Attach() when the DOM loads, connecting the Mojo protocol pipes.
+  new ShellDevToolsFrontend(shell, inspected_contents);
+  LOG(INFO) << "[ProfileServer] DevTools bindings created for tab "
+            << inspected_tab_id;
+
+  // DevTools tabs don't get an auto-incrementing tab ID (stays 0).
+
   // Store remaining tab state.
   tab->tab_observer = std::move(tab_observer);
   tab->tab_connection = tab_conn;
   tabs_.push_back(std::move(tab));
 
-  LOG(INFO) << "[ProfileServer] Tab for pane " << pane_id << " ready, "
-            << tabs_.size() << " tab(s) active";
+  LOG(INFO) << "[ProfileServer] DevTools tab for pane " << pane_id
+            << " ready, " << tabs_.size() << " tab(s) active";
 }
 
