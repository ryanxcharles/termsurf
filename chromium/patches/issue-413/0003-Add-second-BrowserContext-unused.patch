From 786e488894842ff881c2a02246aab12b1a018fdd Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Thu, 12 Feb 2026 05:52:39 -0600
Subject: [PATCH 3/7] Add second BrowserContext (unused)
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Two contexts born, but only one may reign—
The other sits in silence, held in vain.
If sixty falls to two from just this birth,
We'll know the second context shook the earth.

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 .../browser/shell_browser_main_parts.cc           | 15 +++++++++++++--
 .../browser/shell_browser_main_parts.h            |  1 +
 2 files changed, 14 insertions(+), 2 deletions(-)

diff --git a/content/one_profile/browser/shell_browser_main_parts.cc b/content/one_profile/browser/shell_browser_main_parts.cc
index 3f1e17118ac05..053438f4e8139 100644
--- a/content/one_profile/browser/shell_browser_main_parts.cc
+++ b/content/one_profile/browser/shell_browser_main_parts.cc
@@ -140,13 +140,13 @@ int ShellBrowserMainParts::PreEarlyInitialization() {
 }
 
 void ShellBrowserMainParts::InitializeBrowserContexts() {
-  base::FilePath profile_path =
+  base::FilePath profile_a_path =
       base::GetHomeDir()
           .Append(".config")
           .Append("termsurf")
           .Append("poc")
           .Append("profile-a");
-  base::PathService::Override(SHELL_DIR_USER_DATA, profile_path);
+  base::PathService::Override(SHELL_DIR_USER_DATA, profile_a_path);
 
   set_browser_context(new ShellBrowserContext(false));
   set_off_the_record_browser_context(new ShellBrowserContext(true));
@@ -155,6 +155,16 @@ void ShellBrowserMainParts::InitializeBrowserContexts() {
   // request.
   browser_context_->GetOriginTrialsControllerDelegate();
   off_the_record_browser_context_->GetOriginTrialsControllerDelegate();
+
+  base::FilePath profile_b_path =
+      base::GetHomeDir()
+          .Append(".config")
+          .Append("termsurf")
+          .Append("poc")
+          .Append("profile-b");
+  base::PathService::Override(SHELL_DIR_USER_DATA, profile_b_path);
+
+  browser_context_b_ = std::make_unique<ShellBrowserContext>(false);
 }
 
 void ShellBrowserMainParts::InitializeMessageLoopContext() {
@@ -211,6 +221,7 @@ void ShellBrowserMainParts::WillRunMainMessageLoop(
 void ShellBrowserMainParts::PostMainMessageLoopRun() {
   DCHECK_EQ(Shell::windows().size(), 0u);
   ShellDevToolsManagerDelegate::StopHttpHandler();
+  browser_context_b_.reset();
   browser_context_.reset();
   off_the_record_browser_context_.reset();
 #if BUILDFLAG(IS_LINUX)
diff --git a/content/one_profile/browser/shell_browser_main_parts.h b/content/one_profile/browser/shell_browser_main_parts.h
index a94dac9e4196c..c85f505ec29f7 100644
--- a/content/one_profile/browser/shell_browser_main_parts.h
+++ b/content/one_profile/browser/shell_browser_main_parts.h
@@ -83,6 +83,7 @@ class ShellBrowserMainParts : public BrowserMainParts {
  private:
   std::unique_ptr<ShellBrowserContext> browser_context_;
   std::unique_ptr<ShellBrowserContext> off_the_record_browser_context_;
+  std::unique_ptr<ShellBrowserContext> browser_context_b_;
 
   std::unique_ptr<performance_manager::PerformanceManagerLifetime>
       performance_manager_lifetime_;
-- 
