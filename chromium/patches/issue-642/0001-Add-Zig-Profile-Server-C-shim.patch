diff --git a/content/zig_profile_server/content_api_shim.h b/content/zig_profile_server/content_api_shim.h
new file mode 100644
index 0000000000000..a12e204dfad87
--- /dev/null
+++ b/content/zig_profile_server/content_api_shim.h
@@ -0,0 +1,57 @@
+// Copyright 2025 TermSurf. All rights reserved.
+
+#ifndef CONTENT_ZIG_PROFILE_SERVER_CONTENT_API_SHIM_H_
+#define CONTENT_ZIG_PROFILE_SERVER_CONTENT_API_SHIM_H_
+
+#include "build/build_config.h"
+
+#if BUILDFLAG(IS_MAC)
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+// Framework entry point — called by the launcher via dlsym.
+__attribute__((visibility("default")))
+int ContentMain(int argc, const char** argv);
+
+// Opaque handle type for a browser profile.
+typedef void* ts_browser_context_t;
+
+// Create a browser profile with the given absolute storage path.
+// Must be called on the browser thread (i.e., from the on_initialized
+// callback or a posted task after the message loop is running).
+__attribute__((visibility("default")))
+ts_browser_context_t ts_create_browser_context(const char* path);
+
+// Destroy a browser profile.
+__attribute__((visibility("default")))
+void ts_destroy_browser_context(ts_browser_context_t ctx);
+
+// Create a tab in the given profile, loading the URL.
+// Opens a Content Shell window.
+__attribute__((visibility("default")))
+void ts_create_tab(ts_browser_context_t ctx, const char* url);
+
+// Callback type for lifecycle events.
+typedef void (*ts_callback_t)(void);
+
+// Register a callback that fires once when the browser is ready.
+// Must be called before ContentMain. The callback should create
+// profiles and tabs via the C API.
+__attribute__((visibility("default")))
+void ts_set_on_initialized(ts_callback_t callback);
+
+// Register a callback that fires during shutdown, before contexts
+// are destroyed. The callback should call ts_destroy_browser_context
+// on any contexts it created.
+__attribute__((visibility("default")))
+void ts_set_on_shutdown(ts_callback_t callback);
+
+#ifdef __cplusplus
+}  // extern "C"
+#endif
+
+#endif  // BUILDFLAG(IS_MAC)
+
+#endif  // CONTENT_ZIG_PROFILE_SERVER_CONTENT_API_SHIM_H_
diff --git a/content/zig_profile_server/content_api_shim.mm b/content/zig_profile_server/content_api_shim.mm
new file mode 100644
index 0000000000000..a199dc3db87cd
--- /dev/null
+++ b/content/zig_profile_server/content_api_shim.mm
@@ -0,0 +1,209 @@
+// Copyright 2025 TermSurf. All rights reserved.
+//
+// Thin C++ shim that drives the Content API through a C function boundary.
+// Exports C functions for profile and tab lifecycle. The framework exports
+// ContentMain() which the Zig launcher calls via dlsym, plus
+// ts_create_browser_context / ts_destroy_browser_context / ts_create_tab
+// which the launcher uses to control the browser.
+
+#include "content/zig_profile_server/content_api_shim.h"
+
+#include <string>
+
+#include "base/apple/bundle_locations.h"
+#include "base/apple/foundation_util.h"
+#include "base/base_paths.h"
+#include "base/path_service.h"
+#include "base/strings/sys_string_conversions.h"
+#include "build/build_config.h"
+#include "content/public/app/content_main.h"
+#include "content/public/common/content_paths.h"
+#include "content/shell/app/shell_main_delegate.h"
+#include "content/shell/browser/shell.h"
+#include "content/shell/browser/shell_browser_context.h"
+#include "content/shell/browser/shell_browser_main_parts.h"
+#include "content/shell/browser/shell_content_browser_client.h"
+#include "content/shell/common/shell_paths.h"
+#include "url/gurl.h"
+
+namespace {
+
+// ---------------------------------------------------------------------------
+// Path overrides for "Zig Profile Server" product name.
+// These mirror content/shell/app/paths_apple.mm but use our bundle names.
+// We give them unique names to avoid symbol collisions with the functions
+// compiled into content_shell_app (which use "Content Shell" names).
+// ---------------------------------------------------------------------------
+
+base::FilePath GetContentsPath() {
+  base::FilePath path;
+  base::PathService::Get(base::FILE_EXE, &path);
+
+  if (path.value().find("/Helpers/") != std::string::npos) {
+    // Helper process: go up 9 levels from the helper executable.
+    path = path.DirName()
+               .DirName()
+               .DirName()
+               .DirName()
+               .DirName()
+               .DirName()
+               .DirName()
+               .DirName()
+               .DirName();
+  } else {
+    // Main process: up to MacOS, then to Contents.
+    path = path.DirName().DirName();
+  }
+  return path;
+}
+
+base::FilePath GetFrameworksPath() {
+  return GetContentsPath().Append("Frameworks");
+}
+
+void TsOverrideFrameworkBundlePath() {
+  base::FilePath path =
+      GetFrameworksPath().Append("Zig Profile Server Framework.framework");
+  base::apple::SetOverrideFrameworkBundlePath(path);
+}
+
+void TsOverrideOuterBundlePath() {
+  base::FilePath path = GetContentsPath().DirName();
+  base::apple::SetOverrideOuterBundlePath(path);
+}
+
+void TsOverrideChildProcessPath() {
+  base::FilePath path = base::apple::FrameworkBundlePath()
+                             .Append("Helpers")
+                             .Append("Zig Profile Server Helper.app")
+                             .Append("Contents")
+                             .Append("MacOS")
+                             .Append("Zig Profile Server Helper");
+  base::PathService::OverrideAndCreateIfNeeded(
+      content::CHILD_PROCESS_EXE, path, /*is_absolute=*/true,
+      /*create=*/false);
+}
+
+void TsOverrideSourceRootPath() {
+  base::PathService::Override(
+      base::DIR_SRC_TEST_DATA_ROOT,
+      GetFrameworksPath().DirName().DirName().DirName().DirName().DirName());
+}
+
+void TsOverrideBundleID() {
+  NSBundle* bundle = base::apple::OuterBundle();
+  base::apple::SetBaseBundleIDOverride(
+      base::SysNSStringToUTF8(bundle.bundleIdentifier));
+}
+
+// ---------------------------------------------------------------------------
+// Lifecycle callbacks (set by the launcher before ContentMain)
+// ---------------------------------------------------------------------------
+
+static ts_callback_t g_on_initialized = nullptr;
+static ts_callback_t g_on_shutdown = nullptr;
+
+// ---------------------------------------------------------------------------
+// Content API subclasses
+// ---------------------------------------------------------------------------
+
+class TsBrowserMainParts : public content::ShellBrowserMainParts {
+ protected:
+  void InitializeBrowserContexts() override {
+    // Create a default context for parent infrastructure (DevTools, resource
+    // provider). Actual user profiles are created by the on_initialized
+    // callback.
+    base::FilePath home;
+    base::PathService::Get(base::DIR_HOME, &home);
+    base::PathService::Override(
+        content::SHELL_DIR_USER_DATA,
+        home.Append(".config/termsurf/zig-profile-server/default"));
+    set_browser_context(new content::ShellBrowserContext(false));
+  }
+
+  void InitializeMessageLoopContext() override {
+    if (g_on_initialized) {
+      g_on_initialized();
+    }
+  }
+
+  void PostMainMessageLoopRun() override {
+    if (g_on_shutdown) {
+      g_on_shutdown();
+    }
+    ShellBrowserMainParts::PostMainMessageLoopRun();
+  }
+};
+
+class TsContentBrowserClient : public content::ShellContentBrowserClient {
+ public:
+  std::unique_ptr<content::BrowserMainParts> CreateBrowserMainParts(
+      bool /* is_integration_test */) override {
+    auto parts = std::make_unique<TsBrowserMainParts>();
+    set_browser_main_parts(parts.get());
+    return parts;
+  }
+};
+
+class TsMainDelegate : public content::ShellMainDelegate {
+ protected:
+  content::ContentBrowserClient* CreateContentBrowserClient() override {
+    browser_client_ = std::make_unique<TsContentBrowserClient>();
+    return browser_client_.get();
+  }
+
+ private:
+  std::unique_ptr<TsContentBrowserClient> browser_client_;
+};
+
+}  // namespace
+
+// ---------------------------------------------------------------------------
+// Exported C API
+// ---------------------------------------------------------------------------
+
+#if BUILDFLAG(IS_MAC)
+
+int ContentMain(int argc, const char** argv) {
+  TsMainDelegate delegate;
+  content::ContentMainParams params(&delegate);
+  params.argc = argc;
+  params.argv = argv;
+
+  // Set up bundle paths before ContentMain runs.
+  TsOverrideFrameworkBundlePath();
+  TsOverrideOuterBundlePath();
+  TsOverrideChildProcessPath();
+  TsOverrideSourceRootPath();
+  TsOverrideBundleID();
+
+  return content::ContentMain(std::move(params));
+}
+
+ts_browser_context_t ts_create_browser_context(const char* path) {
+  base::PathService::Override(content::SHELL_DIR_USER_DATA,
+                              base::FilePath(path));
+  auto* ctx = new content::ShellBrowserContext(false);
+  return static_cast<ts_browser_context_t>(ctx);
+}
+
+void ts_destroy_browser_context(ts_browser_context_t handle) {
+  delete static_cast<content::ShellBrowserContext*>(handle);
+}
+
+void ts_create_tab(ts_browser_context_t ctx, const char* url) {
+  auto* browser_context =
+      static_cast<content::ShellBrowserContext*>(ctx);
+  content::Shell::CreateNewWindow(browser_context, GURL(url), nullptr,
+                                  gfx::Size());
+}
+
+void ts_set_on_initialized(ts_callback_t callback) {
+  g_on_initialized = callback;
+}
+
+void ts_set_on_shutdown(ts_callback_t callback) {
+  g_on_shutdown = callback;
+}
+
+#endif  // BUILDFLAG(IS_MAC)
