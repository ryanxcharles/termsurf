+// Issue 410.2, Experiment 1: Observes a WebContents and sets throttle bypass
+// flags when the renderer is ready, not at initialization time.
+class ThrottleBypassObserver : public WebContentsObserver {
+ public:
+  ThrottleBypassObserver(WebContents* web_contents, const std::string& label);
+  ~ThrottleBypassObserver() override;
+
+  // WebContentsObserver:
+  void RenderFrameCreated(RenderFrameHost* render_frame_host) override;
+  void RenderFrameHostChanged(RenderFrameHost* old_host,
+                              RenderFrameHost* new_host) override;
+
+ private:
+  void ApplyBypass(RenderFrameHost* render_frame_host);
+  std::string label_;
+};
