   NSView* view_a =
@@ -86,23 +149,12 @@
     view_a.autoresizingMask = NSViewWidthSizable | NSViewHeightSizable;
     view_b.autoresizingMask = NSViewWidthSizable | NSViewHeightSizable;
   }
