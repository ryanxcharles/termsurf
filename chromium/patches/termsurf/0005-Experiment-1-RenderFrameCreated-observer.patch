 }  // namespace
 
+// --- ThrottleBypassObserver ---
+
+ThrottleBypassObserver::ThrottleBypassObserver(WebContents* web_contents,
+                                               const std::string& label)
+    : WebContentsObserver(web_contents), label_(label) {}
+
+ThrottleBypassObserver::~ThrottleBypassObserver() = default;
+
+void ThrottleBypassObserver::RenderFrameCreated(
+    RenderFrameHost* render_frame_host) {
+  LOG(INFO) << "[TermSurf " << label_ << "] RenderFrameCreated";
+  ApplyBypass(render_frame_host);
+}
+
+void ThrottleBypassObserver::RenderFrameHostChanged(
+    RenderFrameHost* old_host,
+    RenderFrameHost* new_host) {
+  LOG(INFO) << "[TermSurf " << label_ << "] RenderFrameHostChanged";
+  if (new_host) {
+    ApplyBypass(new_host);
+  }
+}
+
+void ThrottleBypassObserver::ApplyBypass(RenderFrameHost* render_frame_host) {
+  auto* rwhv = render_frame_host->GetView();
+  if (!rwhv) {
+    LOG(WARNING) << "[TermSurf " << label_ << "] No RenderWidgetHostView yet";
+    return;
+  }
+
+  auto* rwh_impl =
+      static_cast<RenderWidgetHostImpl*>(rwhv->GetRenderWidgetHost());
+  if (!rwh_impl) {
+    LOG(WARNING) << "[TermSurf " << label_ << "] No RenderWidgetHostImpl";
+    return;
+  }
+
+  // Layer 1: Prevent RenderWidgetHost from treating views as hidden.
+  rwh_impl->disable_hidden_ = true;
+  LOG(INFO) << "[TermSurf " << label_ << "] Set disable_hidden_ on " << rwh_impl
+            << " (is_hidden=" << rwh_impl->IsHidden() << ")";
+
+  // Layer 2: Disable Blink's scheduler throttling.
+  render_frame_host->GetRenderViewHost()->SetSchedulerThrottling(false);
+  LOG(INFO) << "[TermSurf " << label_ << "] SetSchedulerThrottling(false)";
+
+  // Force-show if currently hidden (reverses whatever Hide() did).
+  if (rwh_impl->IsHidden()) {
+    LOG(INFO) << "[TermSurf " << label_ << "] Widget is hidden, calling WasShown()";
+    rwh_impl->WasShown({});
+  }
+}
+
+// --- TwoProfilesMainParts ---
+
 TwoProfilesMainParts::TwoProfilesMainParts() = default;
 TwoProfilesMainParts::~TwoProfilesMainParts() = default;
 
@@ -64,6 +121,12 @@
   load_params.transition_type = ui::PAGE_TRANSITION_TYPED;
