+  // Attach throttle bypass observers — they set flags when renderers are ready.
+  observer_a_ = std::make_unique<ThrottleBypassObserver>(
+      shell_a->web_contents(), "Profile-A");
+  observer_b_ = std::make_unique<ThrottleBypassObserver>(
+      web_contents_b_.get(), "Profile-B");
+
 #if BUILDFLAG(IS_MAC)
