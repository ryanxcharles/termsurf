 void TwoProfilesMainParts::PostMainMessageLoopRun() {
+  observer_b_.reset();
+  observer_a_.reset();
   web_contents_b_.reset();
   browser_context_b_.reset();
   ShellBrowserMainParts::PostMainMessageLoopRun();
