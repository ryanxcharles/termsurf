+// --- Tab management ---
+
+void* TsBrowserMainParts::CreateTab(void* ctx, const char* url,
+                                     int width, int height, bool dark) {
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+
+  auto* browser_ctx = static_cast<ShellBrowserContext*>(ctx);
+  Shell* shell = Shell::CreateNewWindow(browser_ctx, GURL(url),
+                                        nullptr, gfx::Size());
+
+  // Resize.
+  if (width > 0 && height > 0) {
+    RenderWidgetHostView* view =
+        shell->web_contents()->GetRenderWidgetHostView();
+    if (view) {
+      float scale = view->GetDeviceScaleFactor();
+      gfx::Size logical(
+          static_cast<int>(std::ceil(width / scale)),
+          static_cast<int>(std::ceil(height / scale)));
+      shell->ResizeWebContentForTests(logical);
+    }
+  }
+
+  auto tab = std::make_unique<TabState>();
+  tab->shell = shell;
+  tab->preferred_color_scheme = dark
+      ? blink::mojom::PreferredColorScheme::kDark
+      : blink::mojom::PreferredColorScheme::kLight;
+
+#if BUILDFLAG(IS_MAC)
+  // Per-tab persistent compositor.
+  tab->widget_mac = std::make_unique<ui::AcceleratedWidgetMac>();
+  ui::ContextFactory* context_factory = content::GetContextFactory();
+  tab->compositor = std::make_unique<ui::Compositor>(
+      context_factory->AllocateFrameSinkId(),
+      context_factory,
+      base::SingleThreadTaskRunner::GetCurrentDefault(),
+      false /* enable_pixel_canvas */);
+  tab->compositor->SetAcceleratedWidget(
+      tab->widget_mac->accelerated_widget());
+
+  tab->root_layer = std::make_unique<ui::Layer>(ui::LAYER_SOLID_COLOR);
+  tab->root_layer->SetColor(SK_ColorTRANSPARENT);
+
+  // Set initial size.
+  {
+    RenderWidgetHostView* view =
+        shell->web_contents()->GetRenderWidgetHostView();
+    if (view) {
+      float scale = view->GetDeviceScaleFactor();
+      gfx::Size size_pixels(width, height);
+      gfx::Size size_dip(
+          static_cast<int>(std::ceil(width / scale)),
+          static_cast<int>(std::ceil(height / scale)));
+      tab->root_layer->SetBounds(gfx::Rect(size_dip));
+      viz::LocalSurfaceId local_surface_id =
+          viz::LocalSurfaceId(1, 1, base::UnguessableToken::Create());
+      tab->compositor->SetScaleAndSize(
+          scale, size_pixels, local_surface_id);
+    }
+  }
+
+  tab->compositor->SetRootLayer(tab->root_layer.get());
+  tab->compositor->SetVisible(true);
+
+  tab->bridge = std::make_unique<PersistentCompositorBridge>(
+      tab->widget_mac.get());
+
+  // Set parent_ui_layer_ on the view.
+  {
+    RenderWidgetHostView* view =
+        shell->web_contents()->GetRenderWidgetHostView();
+    if (view) {
+      SetParentUiLayerOnView(view, tab->root_layer.get());
+    }
+  }
+#endif
+
+  tab->tab_id = next_tab_id_++;
+
+  // Use the WebContents pointer as the opaque handle.
+  void* handle = static_cast<void*>(shell->web_contents());
+
+  // Create observer.
+  auto tab_observer = std::make_unique<TsTabObserver>();
+  tab_observer->SetTabId(tab->tab_id);
+  tab_observer->SetHandle(handle);
+  tab_observer->ObserveContents(shell->web_contents());
+
+  // Fire tab ready callback.
+  TsNotifyTabReady(handle, tab->tab_id);
+
+#if BUILDFLAG(IS_MAC)
+  // Register cursor and CALayerParams callbacks.
+  if (auto* view = shell->web_contents()->GetRenderWidgetHostView()) {
+    auto* rwhi = static_cast<RenderWidgetHostImpl*>(
+        view->GetRenderWidgetHost());
+    rwhi->SetCursorChangedCallback(base::BindRepeating(
+        &TsTabObserver::OnCursorChanged,
+        base::Unretained(tab_observer.get())));
+
+    int cb_tab_id = tab->tab_id;
+    auto* last_id = new uint32_t(0);
+    void* cb_handle = handle;
+
+    auto ca_layer_callback = base::BindRepeating(
+        [](void* handle, int tab_id,
+           uint32_t* last_id, const gfx::CALayerParams& params) {
+          if (params.ca_context_id == 0 || params.ca_context_id == *last_id)
+            return;
+          *last_id = params.ca_context_id;
+          uint32_t ctx_id = params.ca_context_id;
+          int pw = params.pixel_size.width();
+          int ph = params.pixel_size.height();
+          content::GetUIThreadTaskRunner({})->PostTask(
+              FROM_HERE,
+              base::BindOnce([](void* h, uint32_t cid, int pw, int ph) {
+                TsNotifyCAContextId(h, cid, pw, ph);
+              }, handle, ctx_id, pw, ph));
+        },
+        cb_handle, cb_tab_id,
+        base::Owned(last_id));
+    SetCALayerParamsCallbackOnView(view, ca_layer_callback);
+    tab_observer->SetCALayerParamsCallback(ca_layer_callback);
+    tab_observer->SetLastCAContextIdPtr(last_id);
+
+    tab->bridge->SetCallback(base::BindRepeating(
+        [](void* handle, int tab_id,
+           uint32_t* last_id, const gfx::CALayerParams& params) {
+          if (params.ca_context_id == 0 || params.ca_context_id == *last_id)
+            return;
+          *last_id = params.ca_context_id;
+          uint32_t ctx_id = params.ca_context_id;
+          int pw = params.pixel_size.width();
+          int ph = params.pixel_size.height();
+          content::GetUIThreadTaskRunner({})->PostTask(
+              FROM_HERE,
+              base::BindOnce([](void* h, uint32_t cid, int pw, int ph) {
+                TsNotifyCAContextId(h, cid, pw, ph);
+              }, handle, ctx_id, pw, ph));
+        },
+        cb_handle, cb_tab_id,
+        base::Unretained(last_id)));
+  }
+
+  tab_observer->SetParentUiLayer(tab->root_layer.get());
+#endif
+
+  tab->tab_observer = std::move(tab_observer);
+  tabs_.push_back(std::move(tab));
+
+  return handle;
+}
+
+void* TsBrowserMainParts::CreateDevToolsTab(void* ctx, int inspected_tab_id,
+                                             int width, int height,
+                                             bool dark) {
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+
+  auto* browser_ctx = static_cast<ShellBrowserContext*>(ctx);
+
+  // Look up inspected WebContents by tab_id — never cross the C API with a
+  // WebContents pointer (Issue 706 Exp 2).
+  WebContents* inspected_wc = nullptr;
+  for (auto& t : tabs_) {
+    if (t->tab_id == inspected_tab_id && t->tab_id != 0) {
+      inspected_wc = t->shell->web_contents();
+      break;
+    }
+  }
+  if (!inspected_wc) {
+    LOG(ERROR) << "[Plusium] DevTools: inspected tab_id=" << inspected_tab_id
+               << " not found";
+    return nullptr;
+  }
+
+  // Create Shell with the DevTools URL directly (Issue 705 Exp 12).
+  // Matches Profile Server's pattern: create Shell first, do all setup,
+  // then create ShellDevToolsFrontend last.
+  GURL devtools_url(base::StringPrintf(
+      "http://127.0.0.1:%d/devtools/devtools_app.html?targetType=tab",
+      ShellDevToolsManagerDelegate::GetHttpHandlerPort()));
+  Shell* shell = Shell::CreateNewWindow(browser_ctx, devtools_url,
+                                        nullptr, gfx::Size());
+
+  if (width > 0 && height > 0) {
+    RenderWidgetHostView* view =
+        shell->web_contents()->GetRenderWidgetHostView();
+    if (view) {
+      float scale = view->GetDeviceScaleFactor();
+      gfx::Size logical(
+          static_cast<int>(std::ceil(width / scale)),
+          static_cast<int>(std::ceil(height / scale)));
+      shell->ResizeWebContentForTests(logical);
+    }
+  }
+
+  auto tab = std::make_unique<TabState>();
+  tab->shell = shell;
+  tab->inspected_tab_id = inspected_tab_id;
+  tab->preferred_color_scheme = dark
+      ? blink::mojom::PreferredColorScheme::kDark
+      : blink::mojom::PreferredColorScheme::kLight;
+
+#if BUILDFLAG(IS_MAC)
+  tab->widget_mac = std::make_unique<ui::AcceleratedWidgetMac>();
+  ui::ContextFactory* context_factory = content::GetContextFactory();
+  tab->compositor = std::make_unique<ui::Compositor>(
+      context_factory->AllocateFrameSinkId(),
+      context_factory,
+      base::SingleThreadTaskRunner::GetCurrentDefault(),
+      false);
+  tab->compositor->SetAcceleratedWidget(
+      tab->widget_mac->accelerated_widget());
+
+  tab->root_layer = std::make_unique<ui::Layer>(ui::LAYER_SOLID_COLOR);
+  tab->root_layer->SetColor(SK_ColorTRANSPARENT);
+
+  {
+    RenderWidgetHostView* view =
+        shell->web_contents()->GetRenderWidgetHostView();
+    if (view) {
+      float scale = view->GetDeviceScaleFactor();
+      gfx::Size size_pixels(width, height);
+      gfx::Size size_dip(
+          static_cast<int>(std::ceil(width / scale)),
+          static_cast<int>(std::ceil(height / scale)));
+      tab->root_layer->SetBounds(gfx::Rect(size_dip));
+      viz::LocalSurfaceId local_surface_id =
+          viz::LocalSurfaceId(1, 1, base::UnguessableToken::Create());
+      tab->compositor->SetScaleAndSize(
+          scale, size_pixels, local_surface_id);
+    }
+  }
+
+  tab->compositor->SetRootLayer(tab->root_layer.get());
+  tab->compositor->SetVisible(true);
+
+  tab->bridge = std::make_unique<PersistentCompositorBridge>(
+      tab->widget_mac.get());
+
+  {
+    RenderWidgetHostView* view =
+        shell->web_contents()->GetRenderWidgetHostView();
+    if (view) {
+      SetParentUiLayerOnView(view, tab->root_layer.get());
+    }
+  }
+#endif
+
+  tab->tab_id = next_tab_id_++;
+
+  void* handle = static_cast<void*>(shell->web_contents());
+
+  auto tab_observer = std::make_unique<TsTabObserver>();
+  tab_observer->SetTabId(tab->tab_id);
+  tab_observer->SetInspectedTabId(inspected_tab_id);
+  tab_observer->SetHandle(handle);
+  tab_observer->ObserveContents(shell->web_contents());
+
+  TsNotifyTabReady(handle, tab->tab_id);
+
+#if BUILDFLAG(IS_MAC)
+  if (auto* view = shell->web_contents()->GetRenderWidgetHostView()) {
+    auto* rwhi = static_cast<RenderWidgetHostImpl*>(
+        view->GetRenderWidgetHost());
+    rwhi->SetCursorChangedCallback(base::BindRepeating(
+        &TsTabObserver::OnCursorChanged,
+        base::Unretained(tab_observer.get())));
+
+    int cb_tab_id = tab->tab_id;
+    auto* last_id = new uint32_t(0);
+    void* cb_handle = handle;
+
+    auto ca_layer_callback = base::BindRepeating(
+        [](void* handle, int tab_id,
+           uint32_t* last_id, const gfx::CALayerParams& params) {
+          if (params.ca_context_id == 0 || params.ca_context_id == *last_id)
+            return;
+          *last_id = params.ca_context_id;
+          uint32_t ctx_id = params.ca_context_id;
+          int pw = params.pixel_size.width();
+          int ph = params.pixel_size.height();
+          content::GetUIThreadTaskRunner({})->PostTask(
+              FROM_HERE,
+              base::BindOnce([](void* h, uint32_t cid, int pw, int ph) {
+                TsNotifyCAContextId(h, cid, pw, ph);
+              }, handle, ctx_id, pw, ph));
+        },
+        cb_handle, cb_tab_id,
+        base::Owned(last_id));
+    SetCALayerParamsCallbackOnView(view, ca_layer_callback);
+    tab_observer->SetCALayerParamsCallback(ca_layer_callback);
+    tab_observer->SetLastCAContextIdPtr(last_id);
+
+    tab->bridge->SetCallback(base::BindRepeating(
+        [](void* handle, int tab_id,
+           uint32_t* last_id, const gfx::CALayerParams& params) {
+          if (params.ca_context_id == 0 || params.ca_context_id == *last_id)
+            return;
+          *last_id = params.ca_context_id;
+          uint32_t ctx_id = params.ca_context_id;
+          int pw = params.pixel_size.width();
+          int ph = params.pixel_size.height();
+          content::GetUIThreadTaskRunner({})->PostTask(
+              FROM_HERE,
+              base::BindOnce([](void* h, uint32_t cid, int pw, int ph) {
+                TsNotifyCAContextId(h, cid, pw, ph);
+              }, handle, ctx_id, pw, ph));
+        },
+        cb_handle, cb_tab_id,
+        base::Unretained(last_id)));
+  }
+
+  tab_observer->SetParentUiLayer(tab->root_layer.get());
+#endif
+
+  // Create DevTools bindings LAST, after all setup (Issue 705 Exp 12).
+  new ShellDevToolsFrontend(shell, inspected_wc);
+
+  tab->tab_observer = std::move(tab_observer);
+  tabs_.push_back(std::move(tab));
+
+  return handle;
+}
+
+void TsBrowserMainParts::DestroyTab(void* wc_handle) {
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+  for (auto it = tabs_.begin(); it != tabs_.end(); ++it) {
+    if ((*it)->shell &&
+        static_cast<void*>((*it)->shell->web_contents()) == wc_handle) {
+      (*it)->tab_observer.reset();
+      delete (*it)->shell.get();
+      (*it)->shell = nullptr;
+      tabs_.erase(it);
+      if (tabs_.empty()) {
+        Shell::Shutdown();
+      }
+      return;
+    }
+  }
+}
+
+void TsBrowserMainParts::NavigateTab(void* wc_handle, const char* url) {
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+  TabState* tab = FindTab(wc_handle);
+  if (!tab) return;
+  NavigationController::LoadURLParams params((GURL(url)));
+  params.transition_type = ui::PAGE_TRANSITION_TYPED;
+  tab->shell->web_contents()->GetController().LoadURLWithParams(params);
+}
+
+void TsBrowserMainParts::ResizeTab(void* wc_handle, int width, int height) {
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+  if (width <= 0 || height <= 0) return;
+
+  TabState* tab = FindTab(wc_handle);
+  if (!tab) return;
+
+  RenderWidgetHostView* view =
+      tab->shell->web_contents()->GetRenderWidgetHostView();
+  if (view) {
+    float scale = view->GetDeviceScaleFactor();
+    gfx::Size logical(
+        static_cast<int>(std::ceil(width / scale)),
+        static_cast<int>(std::ceil(height / scale)));
+    tab->shell->ResizeWebContentForTests(logical);
+  }
+
+#if BUILDFLAG(IS_MAC)
+  if (tab->compositor && tab->root_layer) {
+    RenderWidgetHostView* cv =
+        tab->shell->web_contents()->GetRenderWidgetHostView();
+    if (cv) {
+      float scale = cv->GetDeviceScaleFactor();
+      gfx::Size size_dip(
+          static_cast<int>(std::ceil(width / scale)),
+          static_cast<int>(std::ceil(height / scale)));
+      tab->root_layer->SetBounds(gfx::Rect(size_dip));
+      gfx::Size size_pixels(width, height);
+      viz::LocalSurfaceId local_surface_id =
+          viz::LocalSurfaceId(1, 1, base::UnguessableToken::Create());
+      tab->compositor->SetScaleAndSize(
+          scale, size_pixels, local_surface_id);
+    }
+  }
+#endif
+}
+
+void TsBrowserMainParts::ForwardMouseEvent(void* wc_handle, int type,
+                                            int button, int x, int y,
+                                            int click_count, int modifiers) {
+#if BUILDFLAG(IS_MAC)
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+  TabState* tab = FindTab(wc_handle);
+  if (!tab) return;
+
+  blink::WebInputEvent::Type event_type;
+  if (type == 0)
+    event_type = blink::WebInputEvent::Type::kMouseDown;
+  else if (type == 1)
+    event_type = blink::WebInputEvent::Type::kMouseUp;
+  else
+    return;
+
+  auto btn = blink::WebPointerProperties::Button::kLeft;
+  if (button == 1)
+    btn = blink::WebPointerProperties::Button::kRight;
+  else if (button == 2)
+    btn = blink::WebPointerProperties::Button::kMiddle;
+
+  int web_modifiers = modifiers & 0xF;
+  if (type == 0) {
+    if (button == 0)
+      web_modifiers |= blink::WebInputEvent::kLeftButtonDown;
+    else if (button == 1)
+      web_modifiers |= blink::WebInputEvent::kRightButtonDown;
+  }
+
+  blink::WebMouseEvent mouse_event(
+      event_type,
+      gfx::PointF(x, y),
+      gfx::PointF(x, y),
+      btn, click_count, web_modifiers,
+      base::TimeTicks::Now());
+
+  auto* view = tab->shell->web_contents()->GetRenderWidgetHostView();
+  if (view)
+    view->GetRenderWidgetHost()->ForwardMouseEvent(mouse_event);
+#endif
+}
+
+void TsBrowserMainParts::ForwardMouseMove(void* wc_handle, int x, int y,
+                                           int modifiers) {
+#if BUILDFLAG(IS_MAC)
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+  TabState* tab = FindTab(wc_handle);
+  if (!tab) return;
+
+  int web_modifiers = modifiers;
+  auto btn = blink::WebPointerProperties::Button::kNoButton;
+  if (web_modifiers & blink::WebInputEvent::kLeftButtonDown)
+    btn = blink::WebPointerProperties::Button::kLeft;
+  else if (web_modifiers & blink::WebInputEvent::kRightButtonDown)
+    btn = blink::WebPointerProperties::Button::kRight;
+
+  blink::WebMouseEvent mouse_event(
+      blink::WebInputEvent::Type::kMouseMove,
+      gfx::PointF(x, y),
+      gfx::PointF(x, y),
+      btn, 0, web_modifiers,
+      base::TimeTicks::Now());
+
+  auto* view = tab->shell->web_contents()->GetRenderWidgetHostView();
+  if (view)
+    view->GetRenderWidgetHost()->ForwardMouseEvent(mouse_event);
+#endif
+}
+
+void TsBrowserMainParts::ForwardScrollEvent(void* wc_handle,
+                                             int x, int y,
+                                             float delta_x, float delta_y,
+                                             int phase, int momentum_phase,
+                                             bool precise, int modifiers) {
+#if BUILDFLAG(IS_MAC)
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+  TabState* tab = FindTab(wc_handle);
+  if (!tab) return;
+
+  int web_modifiers = modifiers & 0xF;
+
+  blink::WebMouseWheelEvent wheel_event(
+      blink::WebInputEvent::Type::kMouseWheel,
+      web_modifiers,
+      base::TimeTicks::Now());
+
+  wheel_event.SetPositionInWidget(gfx::PointF(x, y));
+  wheel_event.SetPositionInScreen(gfx::PointF(x, y));
+  wheel_event.delta_x = delta_x;
+  wheel_event.delta_y = delta_y;
+  wheel_event.phase =
+      static_cast<blink::WebMouseWheelEvent::Phase>(phase);
+  wheel_event.momentum_phase =
+      static_cast<blink::WebMouseWheelEvent::Phase>(momentum_phase);
+  wheel_event.delta_units = precise
+      ? ui::ScrollGranularity::kScrollByPrecisePixel
+      : ui::ScrollGranularity::kScrollByLine;
+
+  auto* view = tab->shell->web_contents()->GetRenderWidgetHostView();
+  if (view)
+    view->GetRenderWidgetHost()->ForwardWheelEvent(wheel_event);
+#endif
+}
+
+void TsBrowserMainParts::ForwardKeyEvent(void* wc_handle, int type,
+                                          int keycode,
+                                          const std::string& utf8,
+                                          int modifiers) {
+#if BUILDFLAG(IS_MAC)
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+  TabState* tab = FindTab(wc_handle);
+  if (!tab) return;
+
+  int web_modifiers = modifiers & 0xF;
+  bool has_meta = (web_modifiers & blink::WebInputEvent::kMetaKey) != 0;
+
+  // Navigation commands: Cmd+[ (back), Cmd+] (forward), Cmd+R (reload).
+  if (has_meta && type != 1) {
+    bool handled = true;
+    switch (keycode) {
+      case ui::VKEY_OEM_4:
+        if (tab->shell->web_contents()->GetController().CanGoBack())
+          tab->shell->web_contents()->GetController().GoBack();
+        break;
+      case ui::VKEY_OEM_6:
+        if (tab->shell->web_contents()->GetController().CanGoForward())
+          tab->shell->web_contents()->GetController().GoForward();
+        break;
+      case ui::VKEY_R:
+        tab->shell->web_contents()->GetController().Reload(
+            content::ReloadType::NORMAL, false);
+        break;
+      default:
+        handled = false;
+        break;
+    }
+    if (handled) return;
+  }
+
+  auto event_type = blink::WebInputEvent::Type::kRawKeyDown;
+  if (type == 1)
+    event_type = blink::WebInputEvent::Type::kKeyUp;
+
+  input::NativeWebKeyboardEvent key_event(
+      event_type, web_modifiers, base::TimeTicks::Now());
+  key_event.windows_key_code = keycode;
+
+  key_event.dom_code = static_cast<int>(
+      ui::UsLayoutKeyboardCodeToDomCode(
+          static_cast<ui::KeyboardCode>(keycode)));
+
+  ui::DomKey dom_key;
+  ui::KeyboardCode dummy_vkey;
+  if (ui::DomCodeToUsLayoutDomKey(
+          static_cast<ui::DomCode>(key_event.dom_code),
+          web_modifiers, &dom_key, &dummy_vkey)) {
+    key_event.dom_key =
+        static_cast<int>(static_cast<ui::DomKey::Base>(dom_key));
+  }
+
+  auto* view = tab->shell->web_contents()->GetRenderWidgetHostView();
+  if (!view) return;
+
+  auto* rwhi = static_cast<RenderWidgetHostImpl*>(
+      view->GetRenderWidgetHost());
+
+  std::vector<blink::mojom::EditCommandPtr> commands;
+  if (has_meta && type != 1) {
+    std::string cmd;
+    switch (keycode) {
+      case ui::VKEY_A: cmd = "selectAll"; break;
+      case ui::VKEY_C: cmd = "copy"; break;
+      case ui::VKEY_V: cmd = "paste"; break;
+      case ui::VKEY_X: cmd = "cut"; break;
+      case ui::VKEY_Z: cmd = "undo"; break;
+      default: break;
+    }
+    if (!cmd.empty()) {
+      commands.push_back(blink::mojom::EditCommand::New(cmd, ""));
+    }
+  }
+
+  ui::LatencyInfo latency;
+  rwhi->ForwardKeyboardEventWithCommands(
+      key_event, latency, std::move(commands));
+
+  if (type != 1 && !utf8.empty() && !has_meta) {
+    input::NativeWebKeyboardEvent char_event(
+        blink::WebInputEvent::Type::kChar, web_modifiers,
+        base::TimeTicks::Now());
+    char_event.windows_key_code = keycode;
+
+    std::u16string text16 = base::UTF8ToUTF16(utf8);
+    if (!text16.empty()) {
+      char_event.text[0] = text16[0];
+      char_event.unmodified_text[0] = text16[0];
+    }
+
+    std::vector<blink::mojom::EditCommandPtr> no_commands;
+    rwhi->ForwardKeyboardEventWithCommands(
+        char_event, latency, std::move(no_commands));
+  }
+#endif
+}
+
+void TsBrowserMainParts::SetFocus(void* wc_handle, bool focused) {
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+  TabState* tab = FindTab(wc_handle);
+  if (!tab) return;
+
+  auto* view = tab->shell->web_contents()->GetRenderWidgetHostView();
+  if (!view) return;
+
+  if (focused) {
+    view->Focus();
+    view->SetActive(true);
+  } else {
+    view->SetActive(false);
+  }
+}
+
+void TsBrowserMainParts::SetColorScheme(void* wc_handle, bool dark) {
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+  TabState* tab = FindTab(wc_handle);
+  if (!tab) return;
+
+  tab->preferred_color_scheme = dark
+      ? blink::mojom::PreferredColorScheme::kDark
+      : blink::mojom::PreferredColorScheme::kLight;
+  tab->shell->web_contents()->OnWebPreferencesChanged();
+}
+
+std::optional<blink::mojom::PreferredColorScheme>
+TsBrowserMainParts::GetColorSchemeForWebContents(
+    WebContents* web_contents) const {
+  for (const auto& tab : tabs_) {
+    if (tab->shell && tab->shell->web_contents() == web_contents) {
+      return tab->preferred_color_scheme;
+    }
+  }
+  return std::nullopt;
+}
+
+TsBrowserMainParts::TabState* TsBrowserMainParts::FindTab(void* wc_handle) {
+  for (auto& t : tabs_) {
+    if (t->shell &&
+        static_cast<void*>(t->shell->web_contents()) == wc_handle)
+      return t.get();
+  }
+  return nullptr;
+}
+
+}  // namespace content
