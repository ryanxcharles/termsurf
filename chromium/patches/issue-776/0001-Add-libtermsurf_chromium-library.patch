+// Copyright 2025 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CONTENT_LIBTERMSURF_CONTENT_TS_TAB_OBSERVER_H_
+#define CONTENT_LIBTERMSURF_CONTENT_TS_TAB_OBSERVER_H_
+
+#include <cstdint>
+
+#include "base/functional/callback.h"
+#include "base/memory/raw_ptr.h"
+#include "build/build_config.h"
+#include "content/public/browser/navigation_handle.h"
+#include "content/public/browser/web_contents_observer.h"
+#include "ui/base/cursor/cursor.h"
+#include "ui/gfx/ca_layer_params.h"
+
+namespace ui { class Layer; }
+
+namespace content {
+
+class WebContents;
+
+// WebContentsObserver that fires C callbacks (via TsNotify* functions)
+// instead of sending protobuf messages over a socket.
+class TsTabObserver : public WebContentsObserver {
+ public:
+  TsTabObserver();
+  ~TsTabObserver() override;
+
+  TsTabObserver(const TsTabObserver&) = delete;
+  TsTabObserver& operator=(const TsTabObserver&) = delete;
+
+  void ObserveContents(WebContents* web_contents);
+  void SetTabId(int tab_id);
+  void SetInspectedTabId(int id);
+
+  // The opaque handle passed to C callbacks to identify the tab.
+  void SetHandle(void* handle) { handle_ = reinterpret_cast<uintptr_t>(handle); }
+
+  // WebContentsObserver:
+  void DidFinishNavigation(NavigationHandle* navigation_handle) override;
+  void DidStartLoading() override;
+  void DidStopLoading() override;
+  void LoadProgressChanged(double progress) override;
+  void DidFailLoad(RenderFrameHost* render_frame_host,
+                   const GURL& validated_url,
+                   int error_code) override;
+  void TitleWasSet(NavigationEntry* entry) override;
+
+#if BUILDFLAG(IS_MAC)
+  void RenderViewHostChanged(RenderViewHost* old_host,
+                             RenderViewHost* new_host) override;
+
+  void OnCursorChanged(const ui::Cursor& cursor);
+
+  using CALayerParamsCallback =
+      base::RepeatingCallback<void(const gfx::CALayerParams&)>;
+  void SetCALayerParamsCallback(CALayerParamsCallback callback);
+  void SetLastCAContextIdPtr(uint32_t* ptr);
+  void SetParentUiLayer(ui::Layer* layer);
+#endif
+
+ private:
+  int tab_id_ = 0;
+  int inspected_tab_id_ = 0;
+  uintptr_t handle_ = 0;
+
+#if BUILDFLAG(IS_MAC)
+  CALayerParamsCallback ca_layer_params_callback_;
+  raw_ptr<uint32_t> last_ca_context_id_ = nullptr;
+  raw_ptr<ui::Layer> parent_ui_layer_ = nullptr;
+#endif
+};
+
+}  // namespace content
+
+#endif  // CONTENT_LIBTERMSURF_CONTENT_TS_TAB_OBSERVER_H_
