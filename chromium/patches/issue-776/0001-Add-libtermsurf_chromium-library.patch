+# Copyright 2025 TermSurf
+# Use of this source code is governed by a BSD-style license that can be
+# found in the LICENSE file.
+
+import("//build/config/ui.gni")
+
+shared_library("libtermsurf_chromium") {
+  testonly = true
+  sources = [
+    "libtermsurf_chromium.cc",
+    "libtermsurf_chromium.h",
+    "ts_browser_client.cc",
+    "ts_browser_client.h",
+    "ts_browser_main_parts.cc",
+    "ts_browser_main_parts.h",
+    "ts_main_delegate.cc",
+    "ts_main_delegate.h",
+    "ts_tab_observer.cc",
+    "ts_tab_observer.h",
+  ]
+
+  if (is_mac) {
+    sources += [
+      "ts_ca_layer_bridge_mac.h",
+      "ts_ca_layer_bridge_mac.mm",
+      "ts_compositor_bridge_mac.h",
+      "ts_compositor_bridge_mac.mm",
+    ]
+  }
+
+  deps = [
+    "//content/shell:content_shell_app",
+    "//content/shell:content_shell_lib",
+    "//content/public/app",
+    "//content/public/browser",
+    "//content/public/common",
+  ]
+
+  if (is_mac) {
+    deps += [
+      "//ui/accelerated_widget_mac",
+      "//ui/compositor",
+    ]
+  }
+}
+
+executable("libtermsurf_chromium_test") {
+  testonly = true
+  sources = [ "test_main.cc" ]
+  deps = [
+    ":libtermsurf_chromium",
+    "//content/shell:content_shell_app",
+    "//content/shell:content_shell_lib",
+  ]
+}
diff --git a/content/libtermsurf_chromium/libtermsurf_chromium.cc b/content/libtermsurf_chromium/libtermsurf_chromium.cc
new file mode 100644
index 0000000000000..6fb382cadcac7
--- /dev/null
+++ b/content/libtermsurf_chromium/libtermsurf_chromium.cc
@@ -0,0 +1,263 @@
+// Copyright 2025 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/libtermsurf_chromium/libtermsurf_chromium.h"
+
+#include "base/functional/bind.h"
+#include "content/public/app/content_main.h"
+#include "content/public/browser/browser_thread.h"
+#include "content/shell/browser/shell.h"
+#include "content/libtermsurf_chromium/ts_main_delegate.h"
+#include "content/libtermsurf_chromium/ts_browser_main_parts.h"
+
+namespace {
+
+// Global state for the library.
+content::TsMainDelegate* g_delegate = nullptr;
+content::TsBrowserMainParts* g_main_parts = nullptr;
+
+// Initialized callback.
+void (*g_on_initialized)(void*) = nullptr;
+void* g_on_initialized_data = nullptr;
+
+// Tab ready callback.
+void (*g_on_tab_ready)(ts_web_contents_t, int, void*) = nullptr;
+void* g_on_tab_ready_data = nullptr;
+
+// CAContext callback.
+void (*g_on_ca_context_id)(ts_web_contents_t, uint32_t, int, int, void*) =
+    nullptr;
+void* g_on_ca_context_id_data = nullptr;
+
+// URL changed callback.
+void (*g_on_url_changed)(ts_web_contents_t, const char*, void*) = nullptr;
+void* g_on_url_changed_data = nullptr;
+
+// Loading state callback.
+void (*g_on_loading_state)(ts_web_contents_t, const char*, int, void*) =
+    nullptr;
+void* g_on_loading_state_data = nullptr;
+
+// Title changed callback.
+void (*g_on_title_changed)(ts_web_contents_t, const char*, void*) = nullptr;
+void* g_on_title_changed_data = nullptr;
+
+// Cursor changed callback.
+void (*g_on_cursor_changed)(ts_web_contents_t, int, void*) = nullptr;
+void* g_on_cursor_changed_data = nullptr;
+
+}  // namespace
+
+namespace content {
+
+// Called by TsBrowserMainParts when initialization is complete.
+void TsNotifyInitialized(TsBrowserMainParts* parts) {
+  g_main_parts = parts;
+  if (g_on_initialized)
+    g_on_initialized(g_on_initialized_data);
+}
+
+// Called by TsTabObserver for state change notifications.
+void TsNotifyTabReady(void* wc_handle, int tab_id) {
+  if (g_on_tab_ready)
+    g_on_tab_ready(wc_handle, tab_id, g_on_tab_ready_data);
+}
+
+void TsNotifyCAContextId(void* wc_handle, uint32_t ca_context_id,
+                          int width, int height) {
+  if (g_on_ca_context_id)
+    g_on_ca_context_id(wc_handle, ca_context_id, width, height,
+                       g_on_ca_context_id_data);
+}
+
+void TsNotifyUrlChanged(void* wc_handle, const char* url) {
+  if (g_on_url_changed)
+    g_on_url_changed(wc_handle, url, g_on_url_changed_data);
+}
+
+void TsNotifyLoadingState(void* wc_handle, const char* state, int progress) {
+  if (g_on_loading_state)
+    g_on_loading_state(wc_handle, state, progress, g_on_loading_state_data);
+}
+
+void TsNotifyTitleChanged(void* wc_handle, const char* title) {
+  if (g_on_title_changed)
+    g_on_title_changed(wc_handle, title, g_on_title_changed_data);
+}
+
+void TsNotifyCursorChanged(void* wc_handle, int cursor_type) {
+  if (g_on_cursor_changed)
+    g_on_cursor_changed(wc_handle, cursor_type, g_on_cursor_changed_data);
+}
+
+}  // namespace content
+
+// --- C API Implementation ---
+
+int ts_content_main(int argc, const char** argv) {
+  g_delegate = new content::TsMainDelegate();
+  content::ContentMainParams params(g_delegate);
+  params.argc = argc;
+  params.argv = argv;
+  return content::ContentMain(std::move(params));
+}
+
+void ts_set_on_initialized(void (*callback)(void* user_data),
+                           void* user_data) {
+  g_on_initialized = callback;
+  g_on_initialized_data = user_data;
+}
+
+void ts_post_task(void (*task)(void* user_data), void* user_data) {
+  content::GetUIThreadTaskRunner({})->PostTask(
+      FROM_HERE,
+      base::BindOnce([](void (*fn)(void*), void* data) { fn(data); },
+                     task, user_data));
+}
+
+void ts_quit(void) {
+  content::Shell::Shutdown();
+}
+
+ts_browser_context_t ts_create_browser_context(const char* path) {
+  if (!g_main_parts) return nullptr;
+  return g_main_parts->CreateBrowserContext(path);
+}
+
+void ts_destroy_browser_context(ts_browser_context_t ctx) {
+  if (!g_main_parts) return;
+  g_main_parts->DestroyBrowserContext(ctx);
+}
+
+ts_web_contents_t ts_create_web_contents(ts_browser_context_t ctx,
+                                         const char* url,
+                                         int width,
+                                         int height,
+                                         bool dark) {
+  if (!g_main_parts) return nullptr;
+  return g_main_parts->CreateTab(ctx, url, width, height, dark);
+}
+
+ts_web_contents_t ts_create_devtools_web_contents(
+    ts_browser_context_t ctx,
+    int inspected_tab_id,
+    int width,
+    int height,
+    bool dark) {
+  if (!g_main_parts) return nullptr;
+  return g_main_parts->CreateDevToolsTab(ctx, inspected_tab_id, width, height, dark);
+}
+
+void ts_destroy_web_contents(ts_web_contents_t wc) {
+  if (!g_main_parts) return;
+  g_main_parts->DestroyTab(wc);
+}
+
+void ts_load_url(ts_web_contents_t wc, const char* url) {
+  if (!g_main_parts) return;
+  g_main_parts->NavigateTab(wc, url);
+}
+
+void ts_forward_mouse_event(ts_web_contents_t wc,
+                            int type,
+                            int button,
+                            int x,
+                            int y,
+                            int click_count,
+                            int modifiers) {
+  if (!g_main_parts) return;
+  g_main_parts->ForwardMouseEvent(wc, type, button, x, y, click_count,
+                                  modifiers);
+}
+
+void ts_forward_mouse_move(ts_web_contents_t wc,
+                           int x,
+                           int y,
+                           int modifiers) {
+  if (!g_main_parts) return;
+  g_main_parts->ForwardMouseMove(wc, x, y, modifiers);
+}
+
+void ts_forward_scroll_event(ts_web_contents_t wc,
+                             int x,
+                             int y,
+                             float delta_x,
+                             float delta_y,
+                             int phase,
+                             int momentum_phase,
+                             bool precise,
+                             int modifiers) {
+  if (!g_main_parts) return;
+  g_main_parts->ForwardScrollEvent(wc, x, y, delta_x, delta_y, phase,
+                                   momentum_phase, precise, modifiers);
+}
+
+void ts_forward_key_event(ts_web_contents_t wc,
+                          int type,
+                          int keycode,
+                          const char* utf8,
+                          int modifiers) {
+  if (!g_main_parts) return;
+  g_main_parts->ForwardKeyEvent(wc, type, keycode, utf8 ? utf8 : "",
+                                modifiers);
+}
+
+void ts_set_focus(ts_web_contents_t wc, bool focused) {
+  if (!g_main_parts) return;
+  g_main_parts->SetFocus(wc, focused);
+}
+
+void ts_set_color_scheme(ts_web_contents_t wc, bool dark) {
+  if (!g_main_parts) return;
+  g_main_parts->SetColorScheme(wc, dark);
+}
+
+void ts_set_view_size(ts_web_contents_t wc, int width, int height) {
+  if (!g_main_parts) return;
+  g_main_parts->ResizeTab(wc, width, height);
+}
+
+void ts_set_on_tab_ready(
+    void (*cb)(ts_web_contents_t wc, int tab_id, void* user_data),
+    void* user_data) {
+  g_on_tab_ready = cb;
+  g_on_tab_ready_data = user_data;
+}
+
+void ts_set_on_ca_context_id(
+    void (*cb)(ts_web_contents_t wc, uint32_t ca_context_id,
+               int width, int height, void* user_data),
+    void* user_data) {
+  g_on_ca_context_id = cb;
+  g_on_ca_context_id_data = user_data;
+}
+
+void ts_set_on_url_changed(
+    void (*cb)(ts_web_contents_t wc, const char* url, void* user_data),
+    void* user_data) {
+  g_on_url_changed = cb;
+  g_on_url_changed_data = user_data;
+}
+
+void ts_set_on_loading_state(
+    void (*cb)(ts_web_contents_t wc, const char* state, int progress,
+               void* user_data),
+    void* user_data) {
+  g_on_loading_state = cb;
+  g_on_loading_state_data = user_data;
+}
+
+void ts_set_on_title_changed(
+    void (*cb)(ts_web_contents_t wc, const char* title, void* user_data),
+    void* user_data) {
+  g_on_title_changed = cb;
+  g_on_title_changed_data = user_data;
+}
+
+void ts_set_on_cursor_changed(
+    void (*cb)(ts_web_contents_t wc, int cursor_type, void* user_data),
+    void* user_data) {
+  g_on_cursor_changed = cb;
+  g_on_cursor_changed_data = user_data;
+}
diff --git a/content/libtermsurf_chromium/libtermsurf_chromium.h b/content/libtermsurf_chromium/libtermsurf_chromium.h
new file mode 100644
index 0000000000000..b1fcfc118b9ec
--- /dev/null
+++ b/content/libtermsurf_chromium/libtermsurf_chromium.h
@@ -0,0 +1,175 @@
+// Copyright 2025 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CONTENT_LIBTERMSURF_CONTENT_LIBTERMSURF_CHROMIUM_H_
+#define CONTENT_LIBTERMSURF_CONTENT_LIBTERMSURF_CHROMIUM_H_
+
+#include <stdbool.h>
+#include <stdint.h>
+
+/* Export macro for shared library builds. */
+#if defined(COMPONENT_BUILD)
+#define TS_EXPORT __attribute__((visibility("default")))
+#else
+#define TS_EXPORT
+#endif
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+/* Opaque handles.
+   WARNING: These are C++ pointers (WebContents*, ShellBrowserContext*) cast to
+   void*. They are safe to use synchronously — pass them in and they are used
+   immediately. NEVER store them for asynchronous use (e.g., to be dereferenced
+   later by a callback or observer). Passing a WebContents* through this
+   boundary for async use caused a SEGV in DevTools (Issue 706). For async
+   cases, pass an integer ID (like inspected_tab_id) and look up the pointer
+   internally inside TsBrowserMainParts. */
+typedef void* ts_browser_context_t;
+typedef void* ts_web_contents_t;
+
+/* --- Lifecycle --- */
+
+/* Initialize Chromium and run the message loop. Blocks until shutdown.
+   Call ts_set_on_initialized() before this to get a callback when ready.
+   argc/argv are forwarded to Chromium's ContentMain(). */
+TS_EXPORT int ts_content_main(int argc, const char** argv);
+
+/* Called on the UI thread when the browser is initialized and ready
+   for profile/tab creation. */
+TS_EXPORT void ts_set_on_initialized(void (*callback)(void* user_data),
+                                     void* user_data);
+
+/* Post a task to the UI thread. Thread-safe -- call from any thread.
+   This is how bindings marshal socket messages onto the UI thread. */
+TS_EXPORT void ts_post_task(void (*task)(void* user_data), void* user_data);
+
+/* Shut down Chromium and exit the message loop. */
+TS_EXPORT void ts_quit(void);
+
+/* --- Profiles --- */
+
+/* Create a BrowserContext with persistent storage at the given path.
+   Returns an opaque handle. Synchronous — safe. */
+TS_EXPORT ts_browser_context_t ts_create_browser_context(const char* path);
+
+/* Destroy a BrowserContext and release its resources. Synchronous — safe. */
+TS_EXPORT void ts_destroy_browser_context(ts_browser_context_t ctx);
+
+/* --- Tabs --- */
+
+/* Create a WebContents (tab) in the given BrowserContext.
+   Navigates to url. Sets initial viewport to width x height pixels.
+   dark=true sets prefers-color-scheme:dark.
+   Returns an opaque handle. Synchronous — safe.
+   The on_ca_context_id callback fires when the tab's CAContext is ready. */
+TS_EXPORT ts_web_contents_t ts_create_web_contents(ts_browser_context_t ctx,
+                                                    const char* url,
+                                                    int width,
+                                                    int height,
+                                                    bool dark);
+
+/* Create a DevTools WebContents inspecting the tab with the given ID.
+   The inspected tab is looked up internally — no pointer crosses the C boundary
+   (Issue 706 Exp 2). */
+TS_EXPORT ts_web_contents_t ts_create_devtools_web_contents(
+    ts_browser_context_t ctx,
+    int inspected_tab_id,
+    int width,
+    int height,
+    bool dark);
+
+/* Close and destroy a WebContents. Synchronous — safe. */
+TS_EXPORT void ts_destroy_web_contents(ts_web_contents_t wc);
+
+/* --- Navigation --- */
+
+/* Synchronous — safe. */
+TS_EXPORT void ts_load_url(ts_web_contents_t wc, const char* url);
+
+/* --- Input --- */
+
+/* type: 0=down, 1=up. button: 0=left, 1=right, 2=middle. Synchronous — safe. */
+TS_EXPORT void ts_forward_mouse_event(ts_web_contents_t wc,
+                                      int type,
+                                      int button,
+                                      int x,
+                                      int y,
+                                      int click_count,
+                                      int modifiers);
+
+/* Synchronous — safe. */
+TS_EXPORT void ts_forward_mouse_move(ts_web_contents_t wc,
+                                     int x,
+                                     int y,
+                                     int modifiers);
+
+/* phase/momentum_phase: 0=none, 1=began, 2=changed, 3=ended.
+   Synchronous — safe. */
+TS_EXPORT void ts_forward_scroll_event(ts_web_contents_t wc,
+                                       int x,
+                                       int y,
+                                       float delta_x,
+                                       float delta_y,
+                                       int phase,
+                                       int momentum_phase,
+                                       bool precise,
+                                       int modifiers);
+
+/* type: 0=down, 1=up, 2=repeat. keycode is Windows VK code.
+   Synchronous — safe. */
+TS_EXPORT void ts_forward_key_event(ts_web_contents_t wc,
+                                    int type,
+                                    int keycode,
+                                    const char* utf8,
+                                    int modifiers);
+
+/* --- State (all synchronous — safe) --- */
+
+TS_EXPORT void ts_set_focus(ts_web_contents_t wc, bool focused);
+TS_EXPORT void ts_set_color_scheme(ts_web_contents_t wc, bool dark);
+TS_EXPORT void ts_set_view_size(ts_web_contents_t wc, int width, int height);
+
+/* --- Callbacks --- */
+
+/* All callbacks fire on the UI thread. The wc parameter identifies which tab
+   changed. Bindings use these to send responses over the socket. */
+
+TS_EXPORT void ts_set_on_tab_ready(
+    void (*cb)(ts_web_contents_t wc, int tab_id, void* user_data),
+    void* user_data);
+
+TS_EXPORT void ts_set_on_ca_context_id(
+    void (*cb)(ts_web_contents_t wc,
+               uint32_t ca_context_id,
+               int width,
+               int height,
+               void* user_data),
+    void* user_data);
+
+TS_EXPORT void ts_set_on_url_changed(
+    void (*cb)(ts_web_contents_t wc, const char* url, void* user_data),
+    void* user_data);
+
+TS_EXPORT void ts_set_on_loading_state(
+    void (*cb)(ts_web_contents_t wc,
+               const char* state,
+               int progress,
+               void* user_data),
+    void* user_data);
+
+TS_EXPORT void ts_set_on_title_changed(
+    void (*cb)(ts_web_contents_t wc, const char* title, void* user_data),
+    void* user_data);
+
+TS_EXPORT void ts_set_on_cursor_changed(
+    void (*cb)(ts_web_contents_t wc, int cursor_type, void* user_data),
+    void* user_data);
+
+#ifdef __cplusplus
+}
+#endif
+
+#endif  /* CONTENT_LIBTERMSURF_CONTENT_LIBTERMSURF_CHROMIUM_H_ */
diff --git a/content/libtermsurf_chromium/test_main.cc b/content/libtermsurf_chromium/test_main.cc
new file mode 100644
index 0000000000000..36b3cdc1149a9
--- /dev/null
+++ b/content/libtermsurf_chromium/test_main.cc
@@ -0,0 +1,17 @@
+// Copyright 2025 TermSurf
+// Minimal test: initialize libtermsurf_chromium and quit.
+
+#include <stdio.h>
+#include "content/libtermsurf_chromium/libtermsurf_chromium.h"
+
+static void on_initialized(void* user_data) {
+  printf("[test_main] Chromium initialized, quitting.\n");
+  ts_quit();
+}
+
+int main(int argc, const char** argv) {
+  ts_set_on_initialized(on_initialized, nullptr);
+  int result = ts_content_main(argc, argv);
+  printf("[test_main] Exited with code %d\n", result);
+  return result;
+}
diff --git a/content/libtermsurf_chromium/ts_browser_client.cc b/content/libtermsurf_chromium/ts_browser_client.cc
new file mode 100644
index 0000000000000..7464404408060
--- /dev/null
+++ b/content/libtermsurf_chromium/ts_browser_client.cc
@@ -0,0 +1,84 @@
+// Copyright 2025 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/libtermsurf_chromium/ts_browser_client.h"
+
+#include "content/libtermsurf_chromium/ts_browser_main_parts.h"
+#include "content/public/browser/render_frame_host.h"
+#include "content/public/browser/site_instance.h"
+#include "content/public/browser/web_contents.h"
+#include "third_party/blink/public/common/web_preferences/web_preferences.h"
+#include "third_party/blink/public/mojom/css/preferred_color_scheme.mojom.h"
+#include "mojo/public/cpp/bindings/binder_map.h"
+#include "mojo/public/cpp/bindings/pending_receiver.h"
+#include "mojo/public/cpp/bindings/receiver_set.h"
+#include "third_party/blink/public/mojom/badging/badging.mojom.h"
+
+namespace content {
+
+// Stub BadgeService — accepts and ignores Badging API calls (Issue 655).
+// Prevents renderer kills on navigator.setAppBadge().
+class TsBrowserClient::StubBadgeService
+    : public blink::mojom::BadgeService {
+ public:
+  StubBadgeService() = default;
+  ~StubBadgeService() override = default;
+
+  void Bind(mojo::PendingReceiver<blink::mojom::BadgeService> receiver) {
+    receivers_.Add(this, std::move(receiver));
+  }
+
+  // blink::mojom::BadgeService:
+  void SetBadge(blink::mojom::BadgeValuePtr value) override {}
+  void ClearBadge() override {}
+
+ private:
+  mojo::ReceiverSet<blink::mojom::BadgeService> receivers_;
+};
+
+TsBrowserClient::TsBrowserClient() = default;
+TsBrowserClient::~TsBrowserClient() = default;
+
+std::unique_ptr<BrowserMainParts> TsBrowserClient::CreateBrowserMainParts(
+    bool /* is_integration_test */) {
+  auto parts = std::make_unique<TsBrowserMainParts>();
+  set_browser_main_parts(parts.get());
+  return parts;
+}
+
+void TsBrowserClient::RegisterBrowserInterfaceBindersForFrame(
+    RenderFrameHost* render_frame_host,
+    mojo::BinderMapWithContext<RenderFrameHost*>* map) {
+  // Call base class first to get NetworkHintsHandler etc.
+  ShellContentBrowserClient::RegisterBrowserInterfaceBindersForFrame(
+      render_frame_host, map);
+  // Add BadgeService stub (Issue 655).
+  map->Add<blink::mojom::BadgeService>(base::BindRepeating(
+      [](TsBrowserClient* self, RenderFrameHost*,
+         mojo::PendingReceiver<blink::mojom::BadgeService> receiver) {
+        if (!self->stub_badge_service_)
+          self->stub_badge_service_ = std::make_unique<StubBadgeService>();
+        self->stub_badge_service_->Bind(std::move(receiver));
+      },
+      base::Unretained(this)));
+}
+
+void TsBrowserClient::OverrideWebPreferences(
+    WebContents* web_contents,
+    SiteInstance& main_frame_site,
+    blink::web_pref::WebPreferences* prefs) {
+  auto* main_parts = static_cast<TsBrowserMainParts*>(
+      shell_browser_main_parts());
+  if (main_parts) {
+    auto scheme = main_parts->GetColorSchemeForWebContents(web_contents);
+    if (scheme.has_value()) {
+      prefs->preferred_color_scheme = scheme.value();
+    } else {
+      prefs->preferred_color_scheme =
+          blink::mojom::PreferredColorScheme::kDark;
+    }
+  }
+}
+
+}  // namespace content
