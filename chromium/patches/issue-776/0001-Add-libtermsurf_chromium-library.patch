+class TsMainDelegate : public ShellMainDelegate {
+ public:
+  TsMainDelegate();
+  ~TsMainDelegate() override;
+
+  TsMainDelegate(const TsMainDelegate&) = delete;
+  TsMainDelegate& operator=(const TsMainDelegate&) = delete;
