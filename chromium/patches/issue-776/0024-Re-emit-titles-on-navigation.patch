From a7152c100b5650d93e1ae1694cc398a06f920944 Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Sat, 23 May 2026 19:55:37 -0500
Subject: [PATCH 24/25] Re-emit titles on navigation

Back went home in borrowed clothes,
The URL knew where it had been.
Now history hands back its name,
And stale titles leave the scene.
---
 content/libtermsurf_chromium/ts_tab_observer.cc | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/content/libtermsurf_chromium/ts_tab_observer.cc b/content/libtermsurf_chromium/ts_tab_observer.cc
index 1ca1bbf4d7c22..e12661e5121bf 100644
--- a/content/libtermsurf_chromium/ts_tab_observer.cc
+++ b/content/libtermsurf_chromium/ts_tab_observer.cc
@@ -9,6 +9,7 @@
 #include "base/logging.h"
 #include "base/strings/stringprintf.h"
 #include "base/strings/utf_string_conversions.h"
+#include "content/public/browser/navigation_controller.h"
 #include "content/public/browser/navigation_entry.h"
 #include "content/public/browser/render_frame_host.h"
 #include "content/public/browser/render_view_host.h"
@@ -59,6 +60,13 @@ void TsTabObserver::DidFinishNavigation(
   }
 
   TsNotifyUrlChanged(reinterpret_cast<void*>(handle_), url.c_str());
+
+  NavigationEntry* entry =
+      web_contents()->GetController().GetLastCommittedEntry();
+  if (entry) {
+    std::string title = base::UTF16ToUTF8(entry->GetTitleForDisplay());
+    TsNotifyTitleChanged(reinterpret_cast<void*>(handle_), title.c_str());
+  }
 #endif
 }
 
