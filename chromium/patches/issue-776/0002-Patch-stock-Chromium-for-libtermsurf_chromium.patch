diff --git a/content/browser/renderer_host/render_widget_host_impl.cc b/content/browser/renderer_host/render_widget_host_impl.cc
index fe46ebe4e5bcd..63793ba5ed143 100644
--- a/content/browser/renderer_host/render_widget_host_impl.cc
+++ b/content/browser/renderer_host/render_widget_host_impl.cc
@@ -2058,7 +2058,14 @@ void RenderWidgetHostImpl::FilterDropData(DropData* drop_data) {
   }
 }
 
+void RenderWidgetHostImpl::SetCursorChangedCallback(
+    CursorChangedCallback callback) {
+  cursor_changed_callback_ = std::move(callback);
+}
+
 void RenderWidgetHostImpl::SetCursor(const ui::Cursor& cursor) {
+  if (cursor_changed_callback_)
+    cursor_changed_callback_.Run(cursor);
   if (view_) {
     view_->UpdateCursor(cursor);
   }
diff --git a/content/browser/renderer_host/render_widget_host_impl.h b/content/browser/renderer_host/render_widget_host_impl.h
index 37b2ca1000ead..961aa2ae792b1 100644
--- a/content/browser/renderer_host/render_widget_host_impl.h
+++ b/content/browser/renderer_host/render_widget_host_impl.h
@@ -317,6 +317,12 @@ class CONTENT_EXPORT RenderWidgetHostImpl
   void DragSourceSystemDragEnded() override;
   void FilterDropData(DropData* drop_data) override;
   void SetCursor(const ui::Cursor& cursor) override;
+
+  // Cursor change callback for out-of-process embedders (TermSurf).
+  using CursorChangedCallback =
+      base::RepeatingCallback<void(const ui::Cursor&)>;
+  void SetCursorChangedCallback(CursorChangedCallback callback);
+
   void ShowContextMenuAtPoint(
       const gfx::Point& point,
       const ui::mojom::MenuSourceType source_type) override;
@@ -1479,6 +1485,9 @@ class CONTENT_EXPORT RenderWidgetHostImpl
   // to ESC being pressed by the user, this will be false.
   bool is_last_unlocked_by_target_ = false;
 
+  // Cursor change callback for out-of-process embedders (TermSurf).
+  CursorChangedCallback cursor_changed_callback_;
+
   // True when the cursor has entered the autoscroll mode. A GSB is not
   // necessarily sent yet.
   bool autoscroll_in_progress_ = false;
diff --git a/content/browser/renderer_host/render_widget_host_view_mac.h b/content/browser/renderer_host/render_widget_host_view_mac.h
index d4320df856533..c8d6231fe7db0 100644
--- a/content/browser/renderer_host/render_widget_host_view_mac.h
+++ b/content/browser/renderer_host/render_widget_host_view_mac.h
@@ -35,6 +35,7 @@
 #include "ui/base/mojom/attributed_string.mojom-forward.h"
 #include "ui/display/display_list.h"
 #include "ui/events/gesture_detection/filtered_gesture_provider.h"
+#include "ui/gfx/ca_layer_params.h"
 
 namespace remote_cocoa {
 namespace mojom {
@@ -104,6 +105,11 @@ class CONTENT_EXPORT RenderWidgetHostViewMac
     return ns_view_;
   }
 
+  // CALayerParams change callback for out-of-process embedders (TermSurf).
+  using CALayerParamsCallback =
+      base::RepeatingCallback<void(const gfx::CALayerParams&)>;
+  void SetCALayerParamsCallback(CALayerParamsCallback callback);
+
   // |delegate| is used to separate out the logic from the NSResponder delegate.
   // |delegate| is retained by this class.
   // |delegate| should be set at most once.
@@ -709,6 +715,9 @@ class CONTENT_EXPORT RenderWidgetHostViewMac
   // details.
   base::OneShotTimer update_windows_timer_;
 
+  // CALayerParams change callback for out-of-process embedders (TermSurf).
+  CALayerParamsCallback ca_layer_params_callback_;
+
   // Factory used to safely scope delayed calls to ShutdownHost().
   base::WeakPtrFactory<RenderWidgetHostViewMac> weak_factory_;
 };
diff --git a/content/browser/renderer_host/render_widget_host_view_mac.mm b/content/browser/renderer_host/render_widget_host_view_mac.mm
index 63041c4311293..025d2ce065604 100644
--- a/content/browser/renderer_host/render_widget_host_view_mac.mm
+++ b/content/browser/renderer_host/render_widget_host_view_mac.mm
@@ -171,6 +171,11 @@
 ////////////////////////////////////////////////////////////////////////////////
 // AcceleratedWidgetMacNSView, public:
 
+void RenderWidgetHostViewMac::SetCALayerParamsCallback(
+    CALayerParamsCallback callback) {
+  ca_layer_params_callback_ = std::move(callback);
+}
+
 void RenderWidgetHostViewMac::AcceleratedWidgetCALayerParamsUpdated() {
   // Set the background color for the root layer from the frame that just
   // swapped. See RenderWidgetHostViewAura for more details. Note that this is
@@ -181,8 +186,11 @@
   // Update the contents that the NSView is displaying.
   const gfx::CALayerParams* ca_layer_params =
       browser_compositor_->GetLastCALayerParams();
-  if (ca_layer_params)
+  if (ca_layer_params) {
     ns_view_->SetCALayerParams(*ca_layer_params);
+    if (ca_layer_params_callback_)
+      ca_layer_params_callback_.Run(*ca_layer_params);
+  }
 }
 
