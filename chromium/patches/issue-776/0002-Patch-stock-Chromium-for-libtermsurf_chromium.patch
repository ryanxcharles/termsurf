diff --git a/content/shell/browser/shell_devtools_frontend.h b/content/shell/browser/shell_devtools_frontend.h
index 820aa06e4a382..14d878c0f3e55 100644
--- a/content/shell/browser/shell_devtools_frontend.h
+++ b/content/shell/browser/shell_devtools_frontend.h
@@ -33,13 +33,16 @@ class ShellDevToolsFrontend : public ShellDevToolsDelegate,
 
   base::WeakPtr<ShellDevToolsFrontend> GetWeakPtr();
 
+  // Construct with an existing Shell. The frontend observes the Shell's
+  // WebContents and attaches DevTools bindings when the DOM loads.
+  ShellDevToolsFrontend(Shell* frontend_shell, WebContents* inspected_contents);
+  ~ShellDevToolsFrontend() override;
+
  private:
   // WebContentsObserver overrides
   void PrimaryMainDocumentElementAvailable() override;
   void WebContentsDestroyed() override;
 
-  ShellDevToolsFrontend(Shell* frontend_shell, WebContents* inspected_contents);
-  ~ShellDevToolsFrontend() override;
   raw_ptr<Shell> frontend_shell_;
   std::unique_ptr<ShellDevToolsBindings> devtools_bindings_;
 
diff --git a/content/shell/browser/shell_platform_delegate_mac.mm b/content/shell/browser/shell_platform_delegate_mac.mm
index 274dffa179ca3..7997fb8925089 100644
--- a/content/shell/browser/shell_platform_delegate_mac.mm
+++ b/content/shell/browser/shell_platform_delegate_mac.mm
@@ -9,6 +9,7 @@
 #include <algorithm>
 
 #import "base/apple/foundation_util.h"
+#include "base/command_line.h"
 #include "base/check_op.h"
 #include "base/memory/raw_ptr.h"
 #include "base/notreached.h"
@@ -20,6 +21,7 @@
 #include "content/public/browser/web_contents.h"
 #include "content/shell/app/resource.h"
 #include "content/shell/browser/shell.h"
+#include "content/shell/common/shell_switches.h"
 #include "ui/gfx/native_ui_types.h"
 #include "url/gurl.h"
 
@@ -201,8 +203,18 @@ void MakeShellButton(NSRect* rect,
     shell_data.url_edit_view = url_edit_view;
   }
 
-  // Show the new window.
-  [window makeKeyAndOrderFront:nil];
+  // Show the new window (unless --hidden).
+  if (base::CommandLine::ForCurrentProcess()->HasSwitch(switches::kHidden)) {
+    // Make the window fully transparent instead of ordering it out.
+    // orderOut: triggers NSWindowDidChangeOcclusionStateNotification which
+    // sets render_widget_host_is_hidden_ = true, detaching the compositor.
+    // setAlphaValue:0 keeps the window in the window list so the compositor
+    // stays active and CAContext survives navigation.
+    [window setAlphaValue:0.0];
+    [window orderWindow:NSWindowBelow relativeTo:0];
+  } else {
+    [window makeKeyAndOrderFront:nil];
+  }
 
   shell_data.delegate = delegate;
 }
diff --git a/content/shell/common/shell_switches.h b/content/shell/common/shell_switches.h
index 8757fa418da94..8f3fd4b3e09fc 100644
--- a/content/shell/common/shell_switches.h
+++ b/content/shell/common/shell_switches.h
@@ -50,6 +50,11 @@ inline constexpr char kIsolatedContextOrigins[] = "isolated-context-origins";
 // risk.
 inline constexpr char kRemoteDebuggingAddress[] = "remote-debugging-address";
 
+// Hide the Content Shell window (make it transparent and order it behind
+// all other windows). Used by TermSurf browser binaries that render via
+// CALayerHost compositing instead of a native window.
+inline constexpr char kHidden[] = "hidden";
+
 // Runs Content Shell in web test mode, injecting test-only behaviour for
 // blink web tests.
 inline constexpr char kRunWebTests[] = "run-web-tests";
