 #include "content/libtermsurf_chromium/ts_compositor_bridge_mac.h"
 #include "content/libtermsurf_chromium/ts_shell_window_mac.h"
@@ -737,6 +738,36 @@ void TsBrowserMainParts::SetFocus(void* wc_handle, bool focused) {
   }
 }
 
+void TsBrowserMainParts::SetGuiActive(void* wc_handle,
+                                      bool active,
+                                      const std::string& reason) {
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+  TabState* tab = FindTab(wc_handle);
+  if (!tab) return;
+
+  auto* web_contents = tab->shell->web_contents();
+  auto* main_frame = web_contents->GetPrimaryMainFrame();
+  auto* render_widget_host =
+      main_frame ? main_frame->GetRenderWidgetHost() : nullptr;
+  if (Issue779TraceEnabled()) {
+    Issue779TraceAnnounce();
+    LOG(INFO) << "[issue-779-trace] pagepopup_alt_tab"
+              << " boundary=chromium_protocol"
+              << " event=set_gui_active"
+              << " active=" << active
+              << " reason=" << reason
+              << " webcontents=" << static_cast<void*>(web_contents)
+              << " render_widget_host="
+              << static_cast<void*>(render_widget_host);
+  }
+  if (!render_widget_host) return;
+
+  auto* render_widget_host_impl =
+      RenderWidgetHostImpl::From(render_widget_host);
+  if (!render_widget_host_impl) return;
+  render_widget_host_impl->SetPageFocus(active);
+}
+
 void TsBrowserMainParts::SetColorScheme(void* wc_handle, bool dark) {
   DCHECK_CURRENTLY_ON(BrowserThread::UI);
   TabState* tab = FindTab(wc_handle);
