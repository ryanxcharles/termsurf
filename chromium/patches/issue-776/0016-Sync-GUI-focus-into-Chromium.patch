From e9d20daea1bf79aed99822b54ce87b6c41d7a6ea Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Sat, 23 May 2026 06:50:33 -0500
Subject: [PATCH 16/25] Sync GUI focus into Chromium

When Wezboard steps out of sight,
The popups bow and quit the light.
When focus wanders back again,
The page remembers where it's been.
---
 .../libtermsurf_chromium.cc                   |  5 +++
 .../libtermsurf_chromium.h                    |  3 ++
 .../ts_browser_main_parts.cc                  | 33 ++++++++++++++++++-
 .../ts_browser_main_parts.h                   |  1 +
 4 files changed, 41 insertions(+), 1 deletion(-)

diff --git a/content/libtermsurf_chromium/libtermsurf_chromium.cc b/content/libtermsurf_chromium/libtermsurf_chromium.cc
index a5167e40812b2..bbdeaae1b380a 100644
--- a/content/libtermsurf_chromium/libtermsurf_chromium.cc
+++ b/content/libtermsurf_chromium/libtermsurf_chromium.cc
@@ -217,6 +217,11 @@ void ts_set_focus(ts_web_contents_t wc, bool focused) {
   g_main_parts->SetFocus(wc, focused);
 }
 
+void ts_set_gui_active(ts_web_contents_t wc, bool active, const char* reason) {
+  if (!g_main_parts) return;
+  g_main_parts->SetGuiActive(wc, active, reason ? reason : "");
+}
+
 void ts_set_color_scheme(ts_web_contents_t wc, bool dark) {
   if (!g_main_parts) return;
   g_main_parts->SetColorScheme(wc, dark);
