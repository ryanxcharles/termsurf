@@ -0,0 +1,64 @@
+// Copyright 2026 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/libtermsurf_chromium/ts_renderer_client.h"
+
+#include "base/logging.h"
+#include "base/strings/utf_string_conversions.h"
+#include "components/pdf/common/constants.h"
+#include "components/pdf/renderer/internal_plugin_renderer_helpers.h"
+#include "pdf/buildflags.h"
+#include "third_party/blink/public/platform/web_string.h"
+#include "third_party/blink/public/web/web_plugin.h"
+#include "third_party/blink/public/web/web_plugin_params.h"
+
+namespace content {
+
+TsRendererClient::TsRendererClient() = default;
+TsRendererClient::~TsRendererClient() = default;
+
+bool TsRendererClient::IsPluginHandledExternally(
+    RenderFrame* embedder_frame,
+    const blink::WebElement& plugin_element,
+    const GURL& original_url,
+    const std::string& original_mime_type) {
+#if BUILDFLAG(ENABLE_PDF)
+  if (original_mime_type == pdf::kPDFMimeType ||
+      original_mime_type == pdf::kInternalPluginMimeType) {
+    LOG(INFO) << "[issue-776] IsPluginHandledExternally mime="
+              << original_mime_type << " url=" << original_url;
+  }
+#endif
+  return ShellContentRendererClient::IsPluginHandledExternally(
+      embedder_frame, plugin_element, original_url, original_mime_type);
+}
+
+bool TsRendererClient::OverrideCreatePlugin(
+    RenderFrame* render_frame,
+    const blink::WebPluginParams& params,
+    blink::WebPlugin** plugin) {
+  if (ShellContentRendererClient::OverrideCreatePlugin(render_frame, params,
+                                                       plugin)) {
+    return true;
+  }
+
+#if BUILDFLAG(ENABLE_PDF)
+  const std::string mime_type = params.mime_type.Utf8();
+  if (mime_type == pdf::kInternalPluginMimeType) {
+    LOG(INFO) << "[issue-776] OverrideCreatePlugin saw PDF mime=" << mime_type;
+    blink::WebPlugin* pdf_plugin =
+        pdf::CreateInternalPlugin(params, render_frame, {});
+    LOG(INFO) << "[issue-776] CreateInternalPlugin returned "
+              << (pdf_plugin ? "plugin" : "nullptr");
+    if (pdf_plugin) {
+      *plugin = pdf_plugin;
+      return true;
+    }
+  }
+#endif
+
+  return false;
+}
+
+}  // namespace content
