From e704f4d7af5d1bbdd94e9fbcfd8dc746191dd562 Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Sat, 21 Feb 2026 16:05:35 -0600
Subject: [PATCH 29/42] Disable Content Shell context menu
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

A phantom menu from Content Shell's past,
Stealing focus, breaking clicks — too long it last.
Commented out, not deleted — just in case,
But for now, right-click shows empty space.

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 .../browser/shell_web_contents_view_delegate_mac.mm        | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/content/chromium_profile_server/browser/shell_web_contents_view_delegate_mac.mm b/content/chromium_profile_server/browser/shell_web_contents_view_delegate_mac.mm
index eac6541b930c8..2a67d436f888f 100644
--- a/content/chromium_profile_server/browser/shell_web_contents_view_delegate_mac.mm
+++ b/content/chromium_profile_server/browser/shell_web_contents_view_delegate_mac.mm
@@ -61,6 +61,7 @@ - (void)itemSelected:(id)sender {
 }
 @end
 
+/*
 namespace {
 
 NSMenuItem* MakeContextMenuItem(NSString* title,
@@ -81,6 +82,7 @@ - (void)itemSelected:(id)sender {
 }
 
 }  // namespace
+*/
 
 namespace content {
 
@@ -99,6 +101,10 @@ - (void)itemSelected:(id)sender {
 void ShellWebContentsViewDelegate::ShowContextMenu(
     RenderFrameHost& render_frame_host,
     const ContextMenuParams& params) {
+  // Context menu disabled — input routed via TUI/XPC (Issue 616 Experiment 9).
+  return;
+
+  /*
   if (switches::IsRunWebTestsSwitchPresent()) {
     return;
   }
@@ -221,6 +227,7 @@ - (void)itemSelected:(id)sender {
   [NSMenu popUpContextMenu:menu
                  withEvent:clickEvent
                    forView:parent_view];
+  */
 }
 
 void ShellWebContentsViewDelegate::ActionPerformed(int tag) {
