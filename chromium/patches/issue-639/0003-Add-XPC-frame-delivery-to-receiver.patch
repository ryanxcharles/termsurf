 namespace content {
 
 class WebContents;
@@ -30,6 +36,12 @@ class ShellVideoConsumer : public viz::mojom::FrameSinkVideoConsumer {
   // a valid RenderWidgetHostView (i.e., navigation must have started).
   void Attach(WebContents* web_contents);
 
+#if BUILDFLAG(IS_MAC)
+  // Connects to an XPC Mach service by name. Once connected, OnFrameCaptured()
+  // will send IOSurface Mach ports to the service every frame.
+  void ConnectToService(const std::string& name);
+#endif
+
   // viz::mojom::FrameSinkVideoConsumer:
   void OnFrameCaptured(
       media::mojom::VideoBufferHandlePtr data,
@@ -47,6 +59,10 @@ class ShellVideoConsumer : public viz::mojom::FrameSinkVideoConsumer {
   std::unique_ptr<viz::ClientFrameSinkVideoCapturer> capturer_;
   int frame_count_ = 0;
   base::TimeTicks last_log_time_;
+
+#if BUILDFLAG(IS_MAC)
+  xpc_connection_t xpc_connection_ = nullptr;
+#endif
 };
 
 }  // namespace content
