From 6de8b097bb38d20ac71623082901dbf214eb529a Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Tue, 24 Feb 2026 06:00:06 -0600
Subject: [PATCH 38/42] Wire persistent compositor's callback bridge
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

The widget had ears but couldn't hear—
No NSView to catch the frame.
Now the bridge sits in its chair,
And ca_context_id stays the same.

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 .../browser/shell_browser_main_parts.cc       | 32 +++++++++++++++++++
 .../browser/shell_browser_main_parts.h        |  2 ++
 .../browser/shell_compositor_bridge_mac.h     | 29 +++++++++++++++++
 .../browser/shell_compositor_bridge_mac.mm    | 20 ++++++++++++
 4 files changed, 83 insertions(+)

diff --git a/content/chromium_profile_server/browser/shell_browser_main_parts.cc b/content/chromium_profile_server/browser/shell_browser_main_parts.cc
index c6ed699d25a78..c46f3133fcfca 100644
--- a/content/chromium_profile_server/browser/shell_browser_main_parts.cc
+++ b/content/chromium_profile_server/browser/shell_browser_main_parts.cc
@@ -394,6 +394,10 @@ void ShellBrowserMainParts::CreateTab(const GURL& url,
     persistent_compositor_->SetRootLayer(persistent_root_layer_.get());
     persistent_compositor_->SetVisible(true);
 
+    // Register bridge to receive CALayerParams callback (Issue 633 Exp 2).
+    persistent_bridge_ = std::make_unique<PersistentCompositorBridge>(
+        persistent_widget_mac_.get());
+
     LOG(INFO) << "[ProfileServer] Created persistent compositor (Issue 633)";
   }
 
@@ -489,6 +493,34 @@ void ShellBrowserMainParts::CreateTab(const GURL& url,
     // after view swap (Issue 630, C2/C3).
     tab_observer->SetCALayerParamsCallback(ca_layer_callback);
     tab_observer->SetLastCAContextIdPtr(last_id);
+
+    // Set callback on persistent bridge (Issue 633 Exp 2).
+    // In UseParentLayerCompositor mode, the per-view callback won't fire.
+    // The persistent bridge receives the stable ca_context_id instead.
+    if (persistent_bridge_) {
+      persistent_bridge_->SetCallback(base::BindRepeating(
+          [](const std::string& pane_id, xpc_connection_t conn,
+             uint32_t* last_id, const gfx::CALayerParams& params) {
+            if (params.ca_context_id == 0 || params.ca_context_id == *last_id)
+              return;
+            *last_id = params.ca_context_id;
+            xpc_object_t msg = xpc_dictionary_create(NULL, NULL, 0);
+            xpc_dictionary_set_string(msg, "action", "ca_context");
+            xpc_dictionary_set_uint64(msg, "ca_context_id",
+                                      params.ca_context_id);
+            xpc_dictionary_set_string(msg, "pane_id", pane_id.c_str());
+            xpc_dictionary_set_uint64(msg, "pixel_width",
+                                      params.pixel_size.width());
+            xpc_dictionary_set_uint64(msg, "pixel_height",
+                                      params.pixel_size.height());
+            xpc_connection_send_message(conn, msg);
+            xpc_release(msg);
+            LOG(INFO) << "[ProfileServer] Persistent compositor ca_context_id="
+                      << params.ca_context_id << " for pane " << pane_id;
+          },
+          cb_pane_id, cb_conn,
+          base::Unretained(last_id)));
+    }
   }
 
   // Store parent ui layer on observer for re-registration (Issue 633).
diff --git a/content/chromium_profile_server/browser/shell_browser_main_parts.h b/content/chromium_profile_server/browser/shell_browser_main_parts.h
index 5e6d1480455b6..dfb0669fad53b 100644
--- a/content/chromium_profile_server/browser/shell_browser_main_parts.h
+++ b/content/chromium_profile_server/browser/shell_browser_main_parts.h
@@ -37,6 +37,7 @@ class ChildExitObserver;
 #endif
 
 namespace content {
+class PersistentCompositorBridge;
 class Shell;
 class ShellPlatformDelegate;
 class ShellTabObserver;
@@ -137,6 +138,7 @@ class ShellBrowserMainParts : public BrowserMainParts {
   std::unique_ptr<ui::AcceleratedWidgetMac> persistent_widget_mac_;
   std::unique_ptr<ui::Compositor> persistent_compositor_;
   std::unique_ptr<ui::Layer> persistent_root_layer_;
+  std::unique_ptr<PersistentCompositorBridge> persistent_bridge_;
 #endif
   std::vector<std::unique_ptr<TabState>> tabs_;
 
diff --git a/content/chromium_profile_server/browser/shell_compositor_bridge_mac.h b/content/chromium_profile_server/browser/shell_compositor_bridge_mac.h
index ae2b93eaa81fd..fa2b159e1a837 100644
--- a/content/chromium_profile_server/browser/shell_compositor_bridge_mac.h
+++ b/content/chromium_profile_server/browser/shell_compositor_bridge_mac.h
@@ -5,6 +5,11 @@
 #ifndef CONTENT_CHROMIUM_PROFILE_SERVER_BROWSER_SHELL_COMPOSITOR_BRIDGE_MAC_H_
 #define CONTENT_CHROMIUM_PROFILE_SERVER_BROWSER_SHELL_COMPOSITOR_BRIDGE_MAC_H_
 
+#include "base/functional/callback.h"
+#include "base/memory/raw_ptr.h"
+#include "ui/accelerated_widget_mac/accelerated_widget_mac.h"
+#include "ui/gfx/ca_layer_params.h"
+
 namespace ui { class Layer; }
 
 namespace content {
@@ -13,6 +18,30 @@ class RenderWidgetHostView;
 
 void SetParentUiLayerOnView(RenderWidgetHostView* view, ui::Layer* layer);
 
+// Receives CALayerParams from a persistent AcceleratedWidgetMac and forwards
+// them via a callback. Used to extract the stable ca_context_id from the
+// persistent compositor (Issue 633).
+class PersistentCompositorBridge : public ui::AcceleratedWidgetMacNSView {
+ public:
+  using CALayerParamsCallback =
+      base::RepeatingCallback<void(const gfx::CALayerParams&)>;
+
+  explicit PersistentCompositorBridge(ui::AcceleratedWidgetMac* widget);
+  virtual ~PersistentCompositorBridge();
+
+  PersistentCompositorBridge(const PersistentCompositorBridge&) = delete;
+  PersistentCompositorBridge& operator=(const PersistentCompositorBridge&) = delete;
+
+  void SetCallback(CALayerParamsCallback callback);
+
+  // ui::AcceleratedWidgetMacNSView:
+  void AcceleratedWidgetCALayerParamsUpdated() override;
+
+ private:
+  raw_ptr<ui::AcceleratedWidgetMac> widget_;
+  CALayerParamsCallback callback_;
+};
+
 }  // namespace content
 
 #endif
diff --git a/content/chromium_profile_server/browser/shell_compositor_bridge_mac.mm b/content/chromium_profile_server/browser/shell_compositor_bridge_mac.mm
index 1f2863826e9c7..2488b39d8bb31 100644
--- a/content/chromium_profile_server/browser/shell_compositor_bridge_mac.mm
+++ b/content/chromium_profile_server/browser/shell_compositor_bridge_mac.mm
@@ -12,4 +12,24 @@ void SetParentUiLayerOnView(RenderWidgetHostView* view, ui::Layer* layer) {
   mac_view->SetParentUiLayer(layer);
 }
 
+PersistentCompositorBridge::PersistentCompositorBridge(
+    ui::AcceleratedWidgetMac* widget)
+    : widget_(widget) {
+  widget_->SetNSView(this);
+}
+
+PersistentCompositorBridge::~PersistentCompositorBridge() {
+  widget_->ResetNSView();
+}
+
+void PersistentCompositorBridge::SetCallback(CALayerParamsCallback callback) {
+  callback_ = std::move(callback);
+}
+
+void PersistentCompositorBridge::AcceleratedWidgetCALayerParamsUpdated() {
+  const auto* params = widget_->GetCALayerParams();
+  if (params && callback_)
+    callback_.Run(*params);
+}
+
 }  // namespace content
