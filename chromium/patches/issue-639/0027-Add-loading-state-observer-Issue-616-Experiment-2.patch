 #if BUILDFLAG(IS_MAC)
   // Sets the XPC connection to use for sending IOSurface frames.
@@ -85,6 +91,10 @@ class ShellVideoConsumer : public viz::mojom::FrameSinkVideoConsumer,
   void OnLog(const std::string& message) override;
 
  private:
+#if BUILDFLAG(IS_MAC)
+  void SendLoadingState(const char* state, int progress);
+#endif
+
   std::unique_ptr<viz::ClientFrameSinkVideoCapturer> capturer_;
   raw_ptr<RenderWidgetHost> current_host_ = nullptr;
   int frame_count_ = 0;
