+    }
+  }
+
+  tweak_info_plist("one_profile_framework_plist") {
+    testonly = true
+    info_plist = "app/framework-Info.plist"
+    args = [
+      "--breakpad=0",
+      "--keystone=0",
+      "--scm=1",
+      "--version",
+      one_profile_version,
+      "--branding",
+      one_profile_product_name,
+    ]
+  }
+
+  mac_framework_bundle("one_profile_framework") {
+    testonly = true
+
+    output_name = one_profile_framework_name
+
+    framework_version = "C"
+
+    framework_contents = [
+      "Helpers",
+      "Libraries",
+      "Resources",
+    ]
+
+    sources = [
+      "app/shell_content_main.cc",
+      "app/shell_content_main.h",
+    ]
+
+    deps = [
+      ":one_profile_app",
+      "//content/public/app",
+      "//content/public/common",
+      "//third_party/icu:icudata",
+    ]
+
+    if (!use_static_angle) {
+      deps += [ ":one_profile_angle_binaries" ]
+    }
+
+    bundle_deps = [
+      ":one_profile_framework_helpers",
+      ":one_profile_framework_resources",
+      ":one_profile_swiftshader_binaries",
+    ]
+
+    if (!is_component_build) {
+      # Specify a sensible install_name for static builds. The library is
+      # dlopen()ed so this is not used to resolve the module.
+      ldflags = [ "-Wl,-install_name,@executable_path/../Frameworks/$output_name.framework/$output_name" ]
+      deps += [ "//base/test:test_trace_processor_bundle_data" ]
+    } else {
+      # Both the main :one_profile and :one_profile_helper_app executables
+      # need to link the framework. Because they are at different directory
+      # depths, using @executable_path as the install_name would require using
+      # install_name_tool on one of the executables. However install_name_tool
+      # only operates in-place, which is problematic to express in GN. Instead,
+      # use rpath-based loading.
+      ldflags =
+          [ "-Wl,-install_name,@rpath/$output_name.framework/$output_name" ]
+
+      # Set up the rpath for the framework so that it can find dylibs in the
+      # root output directory. The framework is at
+      # One Profile.app/Contents/Frameworks/One Profile Framework.framework/Versions/C/One Profile Framework
+      # so use loader_path to go back to the root output directory.
+      ldflags += [ "-Wl,-rpath,@loader_path/../../../../../.." ]
+    }
+
+    info_plist_target = ":one_profile_framework_plist"
+  }
+
+  tweak_info_plist("one_profile_helper_plist") {
+    testonly = true
+    info_plist = "app/helper-Info.plist"
+    args = [
+      "--breakpad=0",
+      "--keystone=0",
+      "--scm=0",
+      "--version",
+      one_profile_version,
+    ]
+  }
+
+  template("one_profile_helper_app") {
+    mac_app_bundle(target_name) {
+      assert(defined(invoker.helper_name_suffix))
+      assert(defined(invoker.helper_bundle_id_suffix))
+
+      testonly = true
+
+      output_name = one_profile_helper_name + invoker.helper_name_suffix
+
+      sources = [ "app/shell_main_mac.cc" ]
+      defines = [
+        "HELPER_EXECUTABLE",
+        "SHELL_PRODUCT_NAME=\"$one_profile_product_name\"",
+      ]
+      extra_substitutions = [
+        "CONTENT_ONE_PROFILE_HELPER_SUFFIX=${invoker.helper_name_suffix}",
+        "CONTENT_ONE_PROFILE_HELPER_BUNDLE_ID_SUFFIX=${invoker.helper_bundle_id_suffix}",
+      ]
+      deps = [
+        "//base/allocator:early_zone_registration_apple",
+        "//sandbox/mac:seatbelt",
+      ]
+
+      info_plist_target = ":one_profile_helper_plist"
+
+      if (is_component_build) {
+        ldflags = [
+          # The helper is in One Profile.app/Contents/Frameworks/One Profile Framework.framework/Versions/C/Helpers/One Profile Helper.app/Contents/MacOS
+
+          # Set up an rpath to the Contents/Frameworks/ directory so that
+          # One Profile Framework.framework will be found there. This matches
+          # the path that app_shell_main.cc uses with `dlopen` and avoids
+          # loading the framework into memory twice.
+          "-Wl,-rpath,@executable_path/../../../../../../..",
+
+          # Add an rpath up to the base for all other libraries.
+          "-Wl,-rpath,@executable_path/../../../../../../../../../..",
+        ]
