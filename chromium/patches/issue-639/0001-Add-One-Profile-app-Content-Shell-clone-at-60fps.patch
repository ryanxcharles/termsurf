+} else if (is_ios) {
+  declare_args() {
+    # The bundle identifier. Overriding this will affect the provisioning profile
+    # used, and hence will affect the app's capabilities.
+    ios_one_profile_bundle_identifier = shared_bundle_id_for_test_apps
+
+    # Path to an entitlements file used in ios_one_profile. Can be overridden
