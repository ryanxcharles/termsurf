+    if (target_platform == "iphoneos") {
+      ios_one_profile_entitlements_path =
+          "//content/app/ios/appex/app.entitlements"
+    } else {
+      ios_one_profile_entitlements_path =
+          "//build/config/ios/entitlements.plist"
+    }
+  }
+
+  declare_args() {
+    ios_content_process_bundle_identifier =
+        "$ios_one_profile_bundle_identifier.ContentProcessExtension"
+    ios_network_process_bundle_identifier =
+        "$ios_one_profile_bundle_identifier.NetworkProcessExtension"
+    ios_gpu_process_bundle_identifier =
+        "$ios_one_profile_bundle_identifier.GPUProcessExtension"
+  }
+
+  ios_app_bundle("one_profile") {
+    info_plist = "app/ios/ios-app.plist"
+    testonly = true
+
+    sources = [ "app/ios/shell_main_trampoline.cc" ]
+
+    deps = [ ":one_profile_framework+link" ]
+
+    if (target_platform == "iphoneos") {
+      deps += [
+        ":content_process_bundle",
+        ":gpu_process_bundle",
+        ":network_process_bundle",
