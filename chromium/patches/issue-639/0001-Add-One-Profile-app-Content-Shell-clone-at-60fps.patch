+- (void)startTracingWithCategories:(const char*)categories {
+  __weak OneProfileWindowDelegate* weakSelf = self;
+  [_tracingHandler
+      startWithHandler:^{
+        [weakSelf updateBackground];
+      }
+      stopHandler:^{
