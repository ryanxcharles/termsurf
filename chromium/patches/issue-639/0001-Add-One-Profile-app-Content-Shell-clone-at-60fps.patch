+#ifndef CONTENT_ONE_PROFILE_BROWSER_SHELL_SPEECH_RECOGNITION_MANAGER_DELEGATE_H_
+#define CONTENT_ONE_PROFILE_BROWSER_SHELL_SPEECH_RECOGNITION_MANAGER_DELEGATE_H_
+
