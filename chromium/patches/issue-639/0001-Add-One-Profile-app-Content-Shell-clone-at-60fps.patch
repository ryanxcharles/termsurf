+if (is_mac) {
+  one_profile_framework_name = "$one_profile_product_name Framework"
+  one_profile_helper_name = "$one_profile_product_name Helper"
+
+  bundle_data("one_profile_framework_helpers") {
+    testonly = true
+    sources = [ "$root_out_dir/chrome_crashpad_handler" ]
