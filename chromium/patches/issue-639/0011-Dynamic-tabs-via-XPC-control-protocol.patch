+#if BUILDFLAG(IS_MAC)
+void ShellBrowserMainParts::StartDynamicMode(const std::string& service_name) {
+  xpc_service_name_ = service_name;
+
+  // Open control connection to the compositor's Mach service.
+  control_connection_ = xpc_connection_create_mach_service(
+      service_name.c_str(), nullptr, 0);
+
+  ShellBrowserMainParts* self = this;
+
+  xpc_connection_set_event_handler(control_connection_, ^(xpc_object_t event) {
+    if (xpc_get_type(event) == XPC_TYPE_DICTIONARY) {
+      const char* action = xpc_dictionary_get_string(event, "action");
+      if (action && std::string_view(action) == "create_tab") {
+        const char* url_str = xpc_dictionary_get_string(event, "url");
+        const char* tab_id_str = xpc_dictionary_get_string(event, "tab_id");
+        std::string url(url_str ? url_str : "about:blank");
+        std::string tab_id(tab_id_str ? tab_id_str : "");
+        content::GetUIThreadTaskRunner({})->PostTask(
+            FROM_HERE,
+            base::BindOnce(&ShellBrowserMainParts::CreateTab,
+                           base::Unretained(self), GURL(url), tab_id));
+      }
+    } else if (xpc_get_type(event) == XPC_TYPE_ERROR) {
+      if (event == XPC_ERROR_CONNECTION_INVALID) {
+        LOG(ERROR) << "[ProfileServer] Control connection invalid";
+      } else if (event == XPC_ERROR_CONNECTION_INTERRUPTED) {
+        LOG(ERROR) << "[ProfileServer] Control connection interrupted";
+      }
+    }
+  });
+
+  xpc_connection_resume(control_connection_);
+  LOG(INFO) << "[ProfileServer] Connected to compositor: " << service_name;
+
+  // Send register message with profile name derived from user-data-dir.
+  std::string profile_name = "unknown";
+  base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+  if (cmd->HasSwitch(switches::kChromiumProfileServerUserDataDir)) {
+    base::FilePath data_dir(
+        cmd->GetSwitchValueASCII(switches::kChromiumProfileServerUserDataDir));
+    profile_name = data_dir.BaseName().value();
+  }
 
-  // Observe the WebContents and attach the capturer when the
-  // RenderWidgetHostView is ready (via RenderViewReady callback).
-  video_consumer_->ObserveContents(shell->web_contents());
+  xpc_object_t msg = xpc_dictionary_create(NULL, NULL, 0);
+  xpc_dictionary_set_string(msg, "action", "register");
+  xpc_dictionary_set_string(msg, "profile", profile_name.c_str());
+  xpc_connection_send_message(control_connection_, msg);
+  xpc_release(msg);
+  LOG(INFO) << "[ProfileServer] Registered as profile: " << profile_name;
 }
 
+void ShellBrowserMainParts::CreateTab(const GURL& url,
+                                      const std::string& tab_id) {
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+
+  // Create a new Shell + WebContents.
+  Shell* shell = Shell::CreateNewWindow(browser_context_.get(), url,
+                                        nullptr, gfx::Size());
+  LOG(INFO) << "[ProfileServer] Created tab '" << tab_id
+            << "' for URL: " << url.spec();
+
+  // Create a ShellVideoConsumer for this tab.
+  auto video_consumer = std::make_unique<ShellVideoConsumer>();
+
+  // Open a new connection to the compositor for this tab's frames.
+  xpc_connection_t tab_conn = xpc_connection_create_mach_service(
+      xpc_service_name_.c_str(), nullptr, 0);
+
+  ShellBrowserMainParts* self = this;
+
+  xpc_connection_set_event_handler(tab_conn, ^(xpc_object_t event) {
+    if (xpc_get_type(event) == XPC_TYPE_ERROR) {
+      if (event == XPC_ERROR_CONNECTION_INVALID ||
+          event == XPC_ERROR_CONNECTION_INTERRUPTED) {
+        xpc_connection_t conn = tab_conn;
+        content::GetUIThreadTaskRunner({})->PostTask(
+            FROM_HERE,
+            base::BindOnce(&ShellBrowserMainParts::CloseTab,
+                           base::Unretained(self), conn));
+      }
+    }
+  });
+
+  xpc_connection_resume(tab_conn);
+
+  // Send tab_ready message so the compositor can map this connection to a pane.
+  xpc_object_t msg = xpc_dictionary_create(NULL, NULL, 0);
+  xpc_dictionary_set_string(msg, "action", "tab_ready");
+  xpc_dictionary_set_string(msg, "tab_id", tab_id.c_str());
+  xpc_connection_send_message(tab_conn, msg);
+  xpc_release(msg);
+
+  // Hand the connection to the video consumer and start observing.
+  video_consumer->SetConnection(tab_conn);
+  video_consumer->ObserveContents(shell->web_contents());
+
+  // Store tab state.
+  auto tab = std::make_unique<TabState>();
+  tab->shell = shell;
+  tab->video_consumer = std::move(video_consumer);
+  tab->tab_connection = tab_conn;
+  tabs_.push_back(std::move(tab));
+
+  LOG(INFO) << "[ProfileServer] Tab '" << tab_id << "' ready, "
+            << tabs_.size() << " tab(s) active";
+}
+
+void ShellBrowserMainParts::CloseTab(xpc_connection_t conn) {
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+
+  for (auto it = tabs_.begin(); it != tabs_.end(); ++it) {
+    if ((*it)->tab_connection == conn) {
+      LOG(INFO) << "[ProfileServer] Closing tab, "
+                << (tabs_.size() - 1) << " tab(s) remaining";
+      (*it)->video_consumer.reset();
+      (*it)->shell->Close();
+      xpc_connection_cancel(conn);
+      xpc_release(conn);
+      tabs_.erase(it);
+      return;
+    }
+  }
+}
