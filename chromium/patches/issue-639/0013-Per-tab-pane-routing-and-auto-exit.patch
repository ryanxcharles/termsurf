-void ShellBrowserMainParts::ResizeCapture(int pixel_width, int pixel_height) {
+void ShellBrowserMainParts::ResizeCapture(const std::string& pane_id,
+                                          int pixel_width,
+                                          int pixel_height) {
   DCHECK_CURRENTLY_ON(BrowserThread::UI);
 
