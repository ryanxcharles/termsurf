-  auto& tab = tabs_[0];
+  // Find the tab for this pane.
+  TabState* tab = nullptr;
+  for (auto& t : tabs_) {
+    if (t->pane_id == pane_id) {
+      tab = t.get();
+      break;
+    }
+  }
+  if (!tab)
+    return;
 
   // Resize the WebContents view (logical pixels).
   RenderWidgetHostView* view =
@@ -334,7 +350,8 @@ void ShellBrowserMainParts::ResizeCapture(int pixel_width, int pixel_height) {
         static_cast<int>(std::ceil(pixel_width / scale)),
         static_cast<int>(std::ceil(pixel_height / scale)));
     view->SetSize(logical);
-    LOG(INFO) << "[ProfileServer] Resized view to " << logical.ToString()
+    LOG(INFO) << "[ProfileServer] Resized pane " << pane_id << " to "
+              << logical.ToString()
               << " (physical " << pixel_width << "x" << pixel_height << ")";
   }
 
@@ -347,13 +364,19 @@ void ShellBrowserMainParts::CloseTab(xpc_connection_t conn) {
 
   for (auto it = tabs_.begin(); it != tabs_.end(); ++it) {
     if ((*it)->tab_connection == conn) {
-      LOG(INFO) << "[ProfileServer] Closing tab, "
-                << (tabs_.size() - 1) << " tab(s) remaining";
+      LOG(INFO) << "[ProfileServer] Closing tab for pane " << (*it)->pane_id
+                << ", " << (tabs_.size() - 1) << " tab(s) remaining";
       (*it)->video_consumer.reset();
       (*it)->shell->Close();
       xpc_connection_cancel(conn);
       xpc_release(conn);
       tabs_.erase(it);
+
+      // Auto-exit when last tab closes.
+      if (tabs_.empty()) {
+        LOG(INFO) << "[ProfileServer] No tabs remaining, exiting";
+        Shell::Shutdown();
+      }
       return;
     }
   }
