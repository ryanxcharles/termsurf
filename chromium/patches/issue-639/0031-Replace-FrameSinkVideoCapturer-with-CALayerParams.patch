diff --git a/content/chromium_profile_server/browser/shell_tab_observer.cc b/content/chromium_profile_server/browser/shell_tab_observer.cc
new file mode 100644
index 0000000000000..7258a72d47c3b
--- /dev/null
+++ b/content/chromium_profile_server/browser/shell_tab_observer.cc
@@ -0,0 +1,121 @@
+// Copyright 2025 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/chromium_profile_server/browser/shell_tab_observer.h"
+
+#include <cmath>
+
+#include "base/logging.h"
+#include "content/public/browser/render_frame_host.h"
+#include "content/public/browser/render_widget_host.h"
+#include "content/public/browser/render_widget_host_view.h"
+#include "content/public/browser/web_contents.h"
+
+namespace content {
+
+ShellTabObserver::ShellTabObserver() = default;
+
+ShellTabObserver::~ShellTabObserver() = default;
+
+#if BUILDFLAG(IS_MAC)
+void ShellTabObserver::SetConnection(xpc_connection_t conn) {
+  xpc_connection_ = conn;
+}
+
+void ShellTabObserver::SetPaneId(const std::string& pane_id) {
+  pane_id_ = pane_id;
+}
+
+void ShellTabObserver::OnCursorChanged(const ui::Cursor& cursor) {
+  if (!xpc_connection_)
+    return;
+  xpc_object_t msg = xpc_dictionary_create(NULL, NULL, 0);
+  xpc_dictionary_set_string(msg, "action", "cursor_changed");
+  xpc_dictionary_set_string(msg, "pane_id", pane_id_.c_str());
+  xpc_dictionary_set_int64(msg, "cursor_type",
+                           static_cast<int64_t>(cursor.type()));
+  xpc_connection_send_message(xpc_connection_, msg);
+  xpc_release(msg);
+}
+#endif
+
+void ShellTabObserver::ObserveContents(WebContents* web_contents) {
+  Observe(web_contents);
+}
+
+void ShellTabObserver::DidFinishNavigation(
+    NavigationHandle* navigation_handle) {
+  if (!navigation_handle->HasCommitted())
+    return;
+  if (!navigation_handle->IsInPrimaryMainFrame())
+    return;
+
+#if BUILDFLAG(IS_MAC)
+  if (!xpc_connection_)
+    return;
+
+  const std::string& url = navigation_handle->GetURL().spec();
+
+  LOG(INFO) << "[ShellTabObserver] Navigation committed:"
+            << " url=" << url
+            << " pane=" << pane_id_;
+
+  xpc_object_t msg = xpc_dictionary_create(NULL, NULL, 0);
+  xpc_dictionary_set_string(msg, "action", "url_changed");
+  xpc_dictionary_set_string(msg, "pane_id", pane_id_.c_str());
+  xpc_dictionary_set_string(msg, "url", url.c_str());
+  xpc_connection_send_message(xpc_connection_, msg);
+  xpc_release(msg);
+#endif
+}
+
+#if BUILDFLAG(IS_MAC)
+void ShellTabObserver::SendLoadingState(const char* state, int progress) {
+  if (!xpc_connection_)
+    return;
+  xpc_object_t msg = xpc_dictionary_create(NULL, NULL, 0);
+  xpc_dictionary_set_string(msg, "action", "loading_state");
+  xpc_dictionary_set_string(msg, "pane_id", pane_id_.c_str());
+  xpc_dictionary_set_string(msg, "state", state);
+  xpc_dictionary_set_uint64(msg, "progress", progress);
+  xpc_connection_send_message(xpc_connection_, msg);
+  xpc_release(msg);
+}
+#endif
+
+void ShellTabObserver::DidStartLoading() {
+#if BUILDFLAG(IS_MAC)
+  LOG(INFO) << "[ShellTabObserver] DidStartLoading pane=" << pane_id_;
+  SendLoadingState("loading", 0);
+#endif
+}
+
+void ShellTabObserver::DidStopLoading() {
+#if BUILDFLAG(IS_MAC)
+  LOG(INFO) << "[ShellTabObserver] DidStopLoading pane=" << pane_id_;
+  SendLoadingState("done", 100);
+#endif
+}
+
+void ShellTabObserver::LoadProgressChanged(double progress) {
+#if BUILDFLAG(IS_MAC)
+  int pct = static_cast<int>(progress * 100);
+  if (pct >= 100) return;  // DidStopLoading sends "done"
+  SendLoadingState("progress", pct);
+#endif
+}
+
+void ShellTabObserver::DidFailLoad(RenderFrameHost* render_frame_host,
+                                    const GURL& validated_url,
+                                    int error_code) {
+#if BUILDFLAG(IS_MAC)
+  if (!render_frame_host->IsInPrimaryMainFrame())
+    return;
+  LOG(INFO) << "[ShellTabObserver] DidFailLoad url=" << validated_url.spec()
+            << " error=" << error_code << " pane=" << pane_id_;
+  SendLoadingState("error", 0);
+#endif
+}
+
+}  // namespace content
