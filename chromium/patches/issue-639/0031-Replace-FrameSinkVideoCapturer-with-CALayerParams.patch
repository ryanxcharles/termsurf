+class ShellTabObserver : public WebContentsObserver {
+ public:
+  ShellTabObserver();
+  ~ShellTabObserver() override;
+
+  ShellTabObserver(const ShellTabObserver&) = delete;
+  ShellTabObserver& operator=(const ShellTabObserver&) = delete;
+
+  void ObserveContents(WebContents* web_contents);
+
+  // WebContentsObserver:
+  void DidFinishNavigation(NavigationHandle* navigation_handle) override;
+  void DidStartLoading() override;
+  void DidStopLoading() override;
+  void LoadProgressChanged(double progress) override;
+  void DidFailLoad(RenderFrameHost* render_frame_host,
+                   const GURL& validated_url,
+                   int error_code) override;
+
+#if BUILDFLAG(IS_MAC)
+  void SetConnection(xpc_connection_t conn);
+  void SetPaneId(const std::string& pane_id);
+  void OnCursorChanged(const ui::Cursor& cursor);
+#endif
+
+ private:
+#if BUILDFLAG(IS_MAC)
+  void SendLoadingState(const char* state, int progress);
+
+  xpc_connection_t xpc_connection_ = nullptr;
+  std::string pane_id_;
+#endif
+};
+
+}  // namespace content
