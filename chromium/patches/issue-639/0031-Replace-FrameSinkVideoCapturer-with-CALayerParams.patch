-void ShellVideoConsumer::Attach(WebContents* web_contents) {
-  RenderWidgetHostView* view = web_contents->GetRenderWidgetHostView();
-  if (!view) {
-    LOG(ERROR) << "[ShellVideoConsumer] No RenderWidgetHostView available";
-    return;
-  }
-
-  RenderWidgetHost* host = view->GetRenderWidgetHost();
-  if (!host) {
-    LOG(ERROR) << "[ShellVideoConsumer] No RenderWidgetHost available";
-    return;
-  }
-
-  // Destroy old capturer before creating a new one (Issue 608 Experiment 2).
-  capturer_.reset();
-  current_host_ = host;
-
-  viz::HostFrameSinkManager* manager = GetHostFrameSinkManager();
-  if (!manager) {
-    LOG(ERROR) << "[ShellVideoConsumer] No HostFrameSinkManager available";
-    return;
-  }
-
-  capturer_ = manager->CreateVideoCapturer();
-
-  // Configure for 120fps ARGB capture (Issue 512: oversample at 2x display
-  // rate so there is always a fresh frame at every 60Hz vsync).
-  capturer_->SetFormat(media::PIXEL_FORMAT_ARGB);
-  capturer_->SetMinCapturePeriod(base::Milliseconds(8));
-  capturer_->SetAutoThrottlingEnabled(false);
-
-  // Capture at physical pixel resolution (Retina-correct).
-  gfx::Size physical_size;
-  if (initial_width_ > 0 && initial_height_ > 0) {
-    // Use dimensions from the app (sent via create_tab).
-    physical_size = gfx::Size(initial_width_, initial_height_);
-  } else {
-    // Fallback: derive from the view's logical size × device scale.
-    gfx::Size view_size = view->GetVisibleViewportSize();
-    float scale = view->GetDeviceScaleFactor();
-    physical_size = gfx::Size(
-        static_cast<int>(std::ceil(view_size.width() * scale)),
-        static_cast<int>(std::ceil(view_size.height() * scale)));
-  }
-  capturer_->SetResolutionConstraints(physical_size, physical_size,
-                                      /*use_fixed_aspect_ratio=*/false);
-
-  // Target the WebContents' frame sink.
-  const viz::FrameSinkId& frame_sink_id = host->GetFrameSinkId();
-  capturer_->ChangeTarget(viz::VideoCaptureTarget(frame_sink_id),
-                          /*sub_capture_target_version=*/0);
-
-  LOG(INFO) << "[ShellVideoConsumer] Attached to FrameSinkId "
-            << frame_sink_id.ToString() << ", starting capture";
-
-  last_log_time_ = base::TimeTicks::Now();
-  frame_count_ = 0;
-
-  // Request GPU memory buffers (IOSurfaces on macOS).
-  capturer_->Start(
-      this, viz::mojom::BufferFormatPreference::kPreferMappableSharedImage);
-}
-
-void ShellVideoConsumer::OnFrameCaptured(
-    media::mojom::VideoBufferHandlePtr data,
-    media::mojom::VideoFrameInfoPtr info,
-    const gfx::Rect& content_rect,
-    mojo::PendingRemote<viz::mojom::FrameSinkVideoConsumerFrameCallbacks>
-        callbacks) {
-  frame_count_++;
-
-  if (data->is_gpu_memory_buffer_handle()) {
-    auto& gmb_handle = data->get_gpu_memory_buffer_handle();
-
-#if BUILDFLAG(IS_MAC)
-    IOSurfaceRef io_surface = gmb_handle.io_surface().get();
-    if (io_surface) {
-      size_t width = IOSurfaceGetWidth(io_surface);
-      size_t height = IOSurfaceGetHeight(io_surface);
-
-      // Send IOSurface Mach port via XPC if connected.
-      if (xpc_connection_) {
-        mach_port_t port = IOSurfaceCreateMachPort(io_surface);
-        if (port != MACH_PORT_NULL) {
-          xpc_object_t msg = xpc_dictionary_create(NULL, NULL, 0);
-          xpc_dictionary_set_string(msg, "action", "display_surface");
-          xpc_dictionary_set_mach_send(msg, "iosurface_port", port);
-          if (!pane_id_.empty()) {
-            xpc_dictionary_set_string(msg, "pane_id", pane_id_.c_str());
-          }
-          xpc_connection_send_message(xpc_connection_, msg);
-          xpc_release(msg);
-          mach_port_deallocate(mach_task_self(), port);
-        } else {
-          LOG(WARNING) << "[ShellVideoConsumer] IOSurfaceCreateMachPort failed";
-        }
-      }
-
-      // Log fps once per second.
-      base::TimeTicks now = base::TimeTicks::Now();
-      base::TimeDelta elapsed = now - last_log_time_;
-      if (elapsed >= base::Seconds(1)) {
-        double fps = frame_count_ / elapsed.InSecondsF();
-        LOG(INFO) << "[ShellVideoConsumer] " << frame_count_
-                  << " frames in " << elapsed.InSecondsF()
-                  << "s (" << fps << " fps)"
-                  << " | IOSurface " << width << "x" << height;
-        frame_count_ = 0;
-        last_log_time_ = now;
-      }
-    } else {
-      LOG(WARNING) << "[ShellVideoConsumer] gpu_memory_buffer_handle but "
-                   << "IOSurface is null";
-    }
-#else
-    // Log fps once per second (non-macOS).
-    base::TimeTicks now = base::TimeTicks::Now();
-    base::TimeDelta elapsed = now - last_log_time_;
-    if (elapsed >= base::Seconds(1)) {
-      double fps = frame_count_ / elapsed.InSecondsF();
-      LOG(INFO) << "[ShellVideoConsumer] " << frame_count_
-                << " frames in " << elapsed.InSecondsF()
-                << "s (" << fps << " fps)"
-                << " | coded_size " << info->coded_size.ToString();
-      frame_count_ = 0;
-      last_log_time_ = now;
-    }
-#endif
-  } else {
-    LOG(WARNING) << "[ShellVideoConsumer] Frame is NOT a "
-                 << "gpu_memory_buffer_handle (got shared memory instead)";
-  }
-
-  // Signal done immediately to return the buffer to the pool.
-  mojo::Remote<viz::mojom::FrameSinkVideoConsumerFrameCallbacks> cb_remote(
-      std::move(callbacks));
-  cb_remote->Done();
-}
