From d583c5f0617cb7d5b34ae03e0c3db9d3792a419c Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Tue, 17 Feb 2026 18:13:51 -0600
Subject: [PATCH 19/42] Add cursor change callback via XPC
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

The cursor spoke but none could hear,
Trapped in a window hidden from sight.
A callback now relays its cheer—
Hand, beam, or arrow, to the light.
Five files touched, from host to shell,
So NSCursor has a tale to tell.

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 .../browser/renderer_host/render_widget_host_impl.cc |  7 +++++++
 .../browser/renderer_host/render_widget_host_impl.h  |  9 +++++++++
 .../browser/shell_browser_main_parts.cc              | 10 ++++++++++
 .../browser/shell_video_consumer.cc                  | 12 ++++++++++++
 .../browser/shell_video_consumer.h                   |  5 +++++
 5 files changed, 43 insertions(+)

diff --git a/content/browser/renderer_host/render_widget_host_impl.cc b/content/browser/renderer_host/render_widget_host_impl.cc
index 93fe27d2e7cf5..cd3b6c2c00267 100644
--- a/content/browser/renderer_host/render_widget_host_impl.cc
+++ b/content/browser/renderer_host/render_widget_host_impl.cc
@@ -2071,7 +2071,14 @@ void RenderWidgetHostImpl::FilterDropData(DropData* drop_data) {
   }
 }
 
+void RenderWidgetHostImpl::SetCursorChangedCallback(
+    CursorChangedCallback callback) {
+  cursor_changed_callback_ = std::move(callback);
+}
+
 void RenderWidgetHostImpl::SetCursor(const ui::Cursor& cursor) {
+  if (cursor_changed_callback_)
+    cursor_changed_callback_.Run(cursor);
   if (view_) {
     view_->UpdateCursor(cursor);
   }
diff --git a/content/browser/renderer_host/render_widget_host_impl.h b/content/browser/renderer_host/render_widget_host_impl.h
index bffb574713aae..aa627bb64a1d0 100644
--- a/content/browser/renderer_host/render_widget_host_impl.h
+++ b/content/browser/renderer_host/render_widget_host_impl.h
@@ -313,6 +313,12 @@ class CONTENT_EXPORT RenderWidgetHostImpl
   void DragSourceSystemDragEnded() override;
   void FilterDropData(DropData* drop_data) override;
   void SetCursor(const ui::Cursor& cursor) override;
+
+  // Cursor change callback for out-of-process embedders (TermSurf).
+  using CursorChangedCallback =
+      base::RepeatingCallback<void(const ui::Cursor&)>;
+  void SetCursorChangedCallback(CursorChangedCallback callback);
+
   void ShowContextMenuAtPoint(
       const gfx::Point& point,
       const ui::mojom::MenuSourceType source_type) override;
@@ -1469,6 +1475,9 @@ class CONTENT_EXPORT RenderWidgetHostImpl
   // to ESC being pressed by the user, this will be false.
   bool is_last_unlocked_by_target_ = false;
 
+  // Cursor change callback for out-of-process embedders (TermSurf).
+  CursorChangedCallback cursor_changed_callback_;
+
   // True when the cursor has entered the autoscroll mode. A GSB is not
   // necessarily sent yet.
   bool autoscroll_in_progress_ = false;
diff --git a/content/chromium_profile_server/browser/shell_browser_main_parts.cc b/content/chromium_profile_server/browser/shell_browser_main_parts.cc
index 09c1bb56c8bb2..cce4d10e36300 100644
--- a/content/chromium_profile_server/browser/shell_browser_main_parts.cc
+++ b/content/chromium_profile_server/browser/shell_browser_main_parts.cc
@@ -80,6 +80,7 @@
 
 #if BUILDFLAG(IS_MAC)
 #include <xpc/xpc.h>
+#include "content/browser/renderer_host/render_widget_host_impl.h"
 #include "third_party/blink/public/common/input/web_mouse_event.h"
 #include "third_party/blink/public/common/input/web_mouse_wheel_event.h"
 #include "ui/events/types/scroll_types.h"
@@ -356,6 +357,15 @@ void ShellBrowserMainParts::CreateTab(const GURL& url,
   video_consumer->SetConnection(tab_conn);
   video_consumer->ObserveContents(shell->web_contents());
 
+  // Register cursor change callback so the app can update NSCursor.
+  if (auto* view = shell->web_contents()->GetRenderWidgetHostView()) {
+    auto* rwhi = static_cast<RenderWidgetHostImpl*>(
+        view->GetRenderWidgetHost());
+    rwhi->SetCursorChangedCallback(base::BindRepeating(
+        &ShellVideoConsumer::OnCursorChanged,
+        base::Unretained(video_consumer.get())));
+  }
+
   // Store tab state.
   auto tab = std::make_unique<TabState>();
   tab->shell = shell;
diff --git a/content/chromium_profile_server/browser/shell_video_consumer.cc b/content/chromium_profile_server/browser/shell_video_consumer.cc
index cd1055b66316e..e023f1b3abf36 100644
--- a/content/chromium_profile_server/browser/shell_video_consumer.cc
+++ b/content/chromium_profile_server/browser/shell_video_consumer.cc
@@ -53,6 +53,18 @@ void ShellVideoConsumer::SetResolution(int width, int height) {
     LOG(INFO) << "[ShellVideoConsumer] Resized to " << width << "x" << height;
   }
 }
+
+void ShellVideoConsumer::OnCursorChanged(const ui::Cursor& cursor) {
+  if (!xpc_connection_)
+    return;
+  xpc_object_t msg = xpc_dictionary_create(NULL, NULL, 0);
+  xpc_dictionary_set_string(msg, "action", "cursor_changed");
+  xpc_dictionary_set_string(msg, "pane_id", pane_id_.c_str());
+  xpc_dictionary_set_int64(msg, "cursor_type",
+                           static_cast<int64_t>(cursor.type()));
+  xpc_connection_send_message(xpc_connection_, msg);
+  xpc_release(msg);
+}
 #endif
 
 void ShellVideoConsumer::ObserveContents(WebContents* web_contents) {
diff --git a/content/chromium_profile_server/browser/shell_video_consumer.h b/content/chromium_profile_server/browser/shell_video_consumer.h
index c26a50a049c2a..a1140d7e328a4 100644
--- a/content/chromium_profile_server/browser/shell_video_consumer.h
+++ b/content/chromium_profile_server/browser/shell_video_consumer.h
@@ -10,6 +10,7 @@
 
 #include "base/time/time.h"
 #include "build/build_config.h"
+#include "ui/base/cursor/cursor.h"
 #include "components/viz/host/client_frame_sink_video_capturer.h"
 #include "content/public/browser/navigation_handle.h"
 #include "content/public/browser/web_contents_observer.h"
@@ -60,6 +61,10 @@ class ShellVideoConsumer : public viz::mojom::FrameSinkVideoConsumer,
 
   // Updates the capture resolution on a running capturer (physical pixels).
   void SetResolution(int width, int height);
+
+  // Called when the renderer changes the cursor type. Sends cursor_changed
+  // via XPC so the app can update NSCursor.
+  void OnCursorChanged(const ui::Cursor& cursor);
 #endif
 
   // viz::mojom::FrameSinkVideoConsumer:
