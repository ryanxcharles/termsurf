+
+namespace content {
+
+TwoProfilesContentBrowserClient::TwoProfilesContentBrowserClient() = default;
+TwoProfilesContentBrowserClient::~TwoProfilesContentBrowserClient() = default;
+
+std::unique_ptr<BrowserMainParts>
+TwoProfilesContentBrowserClient::CreateBrowserMainParts(
+    bool /* is_integration_test */) {
+  auto main_parts = std::make_unique<TwoProfilesMainParts>();
