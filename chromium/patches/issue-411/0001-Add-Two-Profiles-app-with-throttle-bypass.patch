+// Copyright 2025 TermSurf. Based on Chromium's content/shell/app/shell_content_main.cc.
+
+#include "content/two_profiles/two_profiles_content_main.h"
+
+#include "base/compiler_specific.h"
+#include "build/build_config.h"
+#include "content/public/app/content_main.h"
+#include "content/two_profiles/two_profiles_main_delegate.h"
+#include "content/two_profiles/two_profiles_paths_apple.h"
+
+#if BUILDFLAG(IS_MAC)
+int ContentMain(int argc, const char** argv) {
+  content::TwoProfilesMainDelegate delegate;
+  content::ContentMainParams params(&delegate);
+  params.argc = argc;
+  params.argv = argv;
+
+  TwoProfilesOverrideFrameworkBundlePath();
+  TwoProfilesOverrideOuterBundlePath();
+  TwoProfilesOverrideChildProcessPath();
+  TwoProfilesOverrideSourceRootPath();
+  TwoProfilesOverrideBundleID();
+
+  return content::ContentMain(std::move(params));
+}
+#endif  // BUILDFLAG(IS_MAC)
