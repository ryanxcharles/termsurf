+// Copyright 2025 TermSurf. Based on Chromium's content/shell/app/paths_apple.mm.
+
+#include "content/two_profiles/two_profiles_paths_apple.h"
+
+#include "base/apple/bundle_locations.h"
+#include "base/apple/foundation_util.h"
+#include "base/base_paths.h"
+#include "base/path_service.h"
+#include "base/strings/sys_string_conversions.h"
+#include "content/public/common/content_paths.h"
+
+namespace {
+
+base::FilePath GetContentsPath() {
+  base::FilePath path;
+  base::PathService::Get(base::FILE_EXE, &path);
+
+  if (base::apple::IsBackgroundOnlyProcess()) {
+    // Helper: go up nine levels to main bundle Contents.
+    path = path.DirName()
+               .DirName()
+               .DirName()
+               .DirName()
+               .DirName()
+               .DirName()
+               .DirName()
+               .DirName()
+               .DirName();
+  } else {
+    path = path.DirName().DirName();
+  }
+  DCHECK_EQ("Contents", path.BaseName().value());
+  return path;
+}
+
+base::FilePath GetFrameworksPath() {
+  return GetContentsPath().Append("Frameworks");
+}
+
+}  // namespace
+
+void TwoProfilesOverrideFrameworkBundlePath() {
+  base::FilePath helper_path =
+      GetFrameworksPath().Append("Two Profiles Framework.framework");
+  base::apple::SetOverrideFrameworkBundlePath(helper_path);
+}
+
+void TwoProfilesOverrideOuterBundlePath() {
+  base::FilePath path = GetContentsPath().DirName();
+  base::apple::SetOverrideOuterBundlePath(path);
+}
+
+void TwoProfilesOverrideChildProcessPath() {
+  base::FilePath helper_path = base::apple::FrameworkBundlePath()
+                                   .Append("Helpers")
+                                   .Append("Two Profiles Helper.app")
+                                   .Append("Contents")
+                                   .Append("MacOS")
+                                   .Append("Two Profiles Helper");
+  base::PathService::OverrideAndCreateIfNeeded(
+      content::CHILD_PROCESS_EXE, helper_path, /*is_absolute=*/true,
+      /*create=*/false);
+}
+
+void TwoProfilesOverrideSourceRootPath() {
+  base::PathService::Override(
+      base::DIR_SRC_TEST_DATA_ROOT,
+      GetFrameworksPath().DirName().DirName().DirName().DirName().DirName());
+}
+
+base::FilePath TwoProfilesGetResourcesPakFilePath() {
+  NSString* pak_path =
+      [base::apple::FrameworkBundle() pathForResource:@"content_shell"
+                                               ofType:@"pak"];
+  return base::FilePath([pak_path fileSystemRepresentation]);
+}
+
+base::FilePath TwoProfilesGetInfoPlistPath() {
+  return GetContentsPath().Append("Info.plist");
+}
+
+void TwoProfilesOverrideBundleID() {
+  NSBundle* bundle = base::apple::OuterBundle();
+  base::apple::SetBaseBundleIDOverride(
+      base::SysNSStringToUTF8(bundle.bundleIdentifier));
+}
