diff --git a/content/two_profiles/BUILD.gn b/content/two_profiles/BUILD.gn
new file mode 100644
index 0000000000000..12290abe18714
--- /dev/null
+++ b/content/two_profiles/BUILD.gn
@@ -0,0 +1,235 @@
+# Copyright 2025 TermSurf. Based on content/shell/BUILD.gn.
+# "Two Profiles" — a minimal Content API app that renders two browser profiles
+# side by side in one window. Reuses content_shell_lib for all browser
+# infrastructure.
+
+import("//build/apple/tweak_info_plist.gni")
+import("//build/config/mac/rules.gni")
+import("//content/public/app/mac_helpers.gni")
+import("//ui/gl/features.gni")
+
+assert(is_mac, "Two Profiles is currently macOS-only")
+
+two_profiles_product_name = "Two Profiles"
+two_profiles_version = "1.0.0.0"
+two_profiles_framework_name = "$two_profiles_product_name Framework"
+two_profiles_helper_name = "$two_profiles_product_name Helper"
+
+# Static library with our custom classes.
+source_set("two_profiles_lib") {
+  testonly = true
+  sources = [
+    "two_profiles_content_browser_client.cc",
+    "two_profiles_content_browser_client.h",
+    "two_profiles_main_delegate.cc",
+    "two_profiles_main_delegate.h",
+    "two_profiles_main_parts.mm",
+    "two_profiles_main_parts.h",
+    "two_profiles_paths_apple.h",
+    "two_profiles_paths_apple.mm",
+  ]
+
+  deps = [
+    "//base",
+    "//content/public/app",
+    "//content/public/browser",
+    "//content/public/common",
+    "//content/shell:content_shell_lib",
+    "//url",
+  ]
+
+  frameworks = [
+    "AppKit.framework",
+    "Foundation.framework",
+  ]
+}
+
+# --- macOS bundle structure ---
+
+# Info.plist for the main app bundle.
+tweak_info_plist("two_profiles_plist") {
+  testonly = true
+  info_plist = "app-Info.plist"
+  args = [
+    "--scm=1",
+    "--version",
+    two_profiles_version,
+  ]
+}
+
+# Info.plist for the framework.
+tweak_info_plist("two_profiles_framework_plist") {
+  testonly = true
+  info_plist = "framework-Info.plist"
+  args = [
+    "--breakpad=0",
+    "--keystone=0",
+    "--scm=1",
+    "--version",
+    two_profiles_version,
+    "--branding",
+    two_profiles_product_name,
+  ]
+}
+
+# Info.plist for helper apps.
+tweak_info_plist("two_profiles_helper_plist") {
+  testonly = true
+  info_plist = "helper-Info.plist"
+  args = [
+    "--breakpad=0",
+    "--keystone=0",
+    "--scm=0",
+    "--version",
+    two_profiles_version,
+  ]
+}
+
+# Helper app template — compiles shell_main_mac.cc with our product name.
+template("two_profiles_helper_app") {
+  mac_app_bundle(target_name) {
+    assert(defined(invoker.helper_name_suffix))
+    assert(defined(invoker.helper_bundle_id_suffix))
+
+    testonly = true
+
+    output_name = two_profiles_helper_name + invoker.helper_name_suffix
+
+    sources = [ "//content/shell/app/shell_main_mac.cc" ]
+    defines = [
+      "HELPER_EXECUTABLE",
+      "SHELL_PRODUCT_NAME=\"$two_profiles_product_name\"",
+    ]
+    extra_substitutions = [
+      "CONTENT_SHELL_HELPER_SUFFIX=${invoker.helper_name_suffix}",
+      "CONTENT_SHELL_HELPER_BUNDLE_ID_SUFFIX=${invoker.helper_bundle_id_suffix}",
+    ]
+    deps = [
+      "//base/allocator:early_zone_registration_apple",
+      "//sandbox/mac:seatbelt",
+    ]
+
+    info_plist_target = ":two_profiles_helper_plist"
+
+    if (is_component_build) {
+      ldflags = [
+        "-Wl,-rpath,@executable_path/../../../../../../..",
+        "-Wl,-rpath,@executable_path/../../../../../../../../../..",
+      ]
+      deps += [ ":two_profiles_framework+link_nested" ]
+    }
+  }
+}
+
+# Create all helper variants (default, renderer, gpu, plugin).
+foreach(helper_params, content_mac_helpers) {
+  _helper_target = helper_params[0]
+  _helper_bundle_id = helper_params[1]
+  _helper_suffix = helper_params[2]
+  two_profiles_helper_app("two_profiles_helper_app_${_helper_target}") {
+    helper_name_suffix = _helper_suffix
+    helper_bundle_id_suffix = _helper_bundle_id
+  }
+}
+
+# Bundle the helpers + crashpad handler into the framework.
+bundle_data("two_profiles_framework_helpers") {
+  testonly = true
+  sources = [ "$root_out_dir/chrome_crashpad_handler" ]
+  outputs = [ "{{bundle_contents_dir}}/Helpers/{{source_file_part}}" ]
+  public_deps = [ "//components/crash/core/app:chrome_crashpad_handler" ]
+  foreach(helper_params, content_mac_helpers) {
+    sources += [
+      "$root_out_dir/${two_profiles_helper_name}${helper_params[2]}.app",
+    ]
+    public_deps += [ ":two_profiles_helper_app_${helper_params[0]}" ]
+  }
+}
+
+# The framework bundle — contains all browser logic.
+mac_framework_bundle("two_profiles_framework") {
+  testonly = true
+
+  output_name = two_profiles_framework_name
+
+  framework_version = "C"
+
+  framework_contents = [
+    "Helpers",
+    "Libraries",
+    "Resources",
+  ]
+
+  sources = [
+    "two_profiles_content_main.cc",
+    "two_profiles_content_main.h",
+  ]
+
+  deps = [
+    ":two_profiles_lib",
+    "//content/shell:content_shell_app",
+    "//content/public/app",
+    "//content/public/common",
+    "//third_party/icu:icudata",
+  ]
+
+  if (!use_static_angle) {
+    deps += [ "//content/shell:content_shell_angle_binaries" ]
+  }
+
+  bundle_deps = [
+    ":two_profiles_framework_helpers",
+    "//content/shell:content_shell_framework_resources",
+    "//content/shell:content_shell_swiftshader_binaries",
+  ]
+
+  if (!is_component_build) {
+    ldflags = [ "-Wl,-install_name,@executable_path/../Frameworks/$output_name.framework/$output_name" ]
+    deps += [ "//base/test:test_trace_processor_bundle_data" ]
+  } else {
+    ldflags = [ "-Wl,-install_name,@rpath/$output_name.framework/$output_name" ]
+    ldflags += [ "-Wl,-rpath,@loader_path/../../../../../.." ]
+  }
+
+  info_plist_target = ":two_profiles_framework_plist"
+}
+
+# Bundle data to embed the framework in the app.
+bundle_data("two_profiles_framework_bundle_data") {
+  testonly = true
+  sources = [ "$root_out_dir/$two_profiles_framework_name.framework" ]
+  outputs = [ "{{bundle_contents_dir}}/Frameworks/{{source_file_part}}" ]
+  if (is_component_build) {
+    public_deps = [ ":two_profiles_framework+link" ]
+  } else {
+    public_deps = [ ":two_profiles_framework" ]
+  }
+}
+
+# Reuse content_shell's icon.
+bundle_data("two_profiles_resources_bundle_data") {
+  testonly = true
+  sources = [ "//content/shell/app/app.icns" ]
+  outputs = [ "{{bundle_resources_dir}}/{{source_file_part}}" ]
+}
+
+# The main app bundle — thin loader that dlopen()s the framework.
+mac_app_bundle("two_profiles") {
+  testonly = true
+  output_name = two_profiles_product_name
+  sources = [ "//content/shell/app/shell_main_mac.cc" ]
+  defines = [ "SHELL_PRODUCT_NAME=\"$two_profiles_product_name\"" ]
+
+  deps = [
+    ":two_profiles_framework_bundle_data",
+    ":two_profiles_resources_bundle_data",
+    "//base/allocator:early_zone_registration_apple",
+    "//sandbox/mac:seatbelt",
+  ]
+  info_plist_target = ":two_profiles_plist"
+  data_deps = [ ":two_profiles_lib" ]
+
+  if (is_component_build) {
+    ldflags = [ "-Wl,-rpath,@executable_path/../Frameworks" ]
+  }
+}
