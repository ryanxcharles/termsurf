+#include "base/path_service.h"
+#include "content/browser/renderer_host/render_widget_host_impl.h"
+#include "content/public/browser/render_view_host.h"
+#include "content/public/browser/web_contents.h"
+#include "content/shell/browser/shell.h"
+#include "content/shell/browser/shell_browser_context.h"
+#include "content/shell/common/shell_paths.h"
+#include "url/gurl.h"
+
+#if BUILDFLAG(IS_MAC)
+#import <Cocoa/Cocoa.h>
+#include "content/public/browser/render_widget_host_view.h"
+#endif
+
+namespace content {
+
+namespace {
+
+const char kTestPageURL[] = "http://localhost:9407";
+
+base::FilePath GetProfilePath(const std::string& name) {
+  base::FilePath home_dir;
+  base::PathService::Get(base::DIR_HOME, &home_dir);
+  return home_dir.Append(".config")
+                 .Append("termsurf")
+                 .Append("poc")
+                 .Append(name);
+}
+
+}  // namespace
+
+TwoProfilesMainParts::TwoProfilesMainParts() = default;
+TwoProfilesMainParts::~TwoProfilesMainParts() = default;
+
+void TwoProfilesMainParts::InitializeBrowserContexts() {
+  // Override the user data path before creating each context.
+  // ShellBrowserContext reads SHELL_DIR_USER_DATA in its constructor.
+
+  base::PathService::Override(SHELL_DIR_USER_DATA, GetProfilePath("profile-a"));
+  set_browser_context(new ShellBrowserContext(false));
+
+  base::PathService::Override(SHELL_DIR_USER_DATA, GetProfilePath("profile-b"));
+  browser_context_b_ = std::make_unique<ShellBrowserContext>(false);
+}
+
+void TwoProfilesMainParts::InitializeMessageLoopContext() {
+  GURL url(kTestPageURL);
+
+  // Create Shell A (profile A) — this creates a window with toolbar.
+  Shell* shell_a = Shell::CreateNewWindow(
+      browser_context(), url, nullptr, gfx::Size(1200, 600));
+
+  // Create WebContents B (profile B) — no Shell, just a WebContents.
+  WebContents::CreateParams params_b(browser_context_b_.get());
+  web_contents_b_ = WebContents::Create(params_b);
+
+  // Navigate WebContents B to the test page.
+  NavigationController::LoadURLParams load_params(url);
+  load_params.transition_type = ui::PAGE_TRANSITION_TYPED;
+  web_contents_b_->GetController().LoadURLWithParams(load_params);
+
+#if BUILDFLAG(IS_MAC)
+  // Arrange both WebContents side by side in Shell A's window.
+  NSView* view_a =
+      shell_a->web_contents()->GetNativeView().GetNativeNSView();
+  NSView* view_b =
+      web_contents_b_->GetNativeView().GetNativeNSView();
+  NSView* container = [view_a superview];
+
+  if (container) {
+    // Add view_b to the same container.
+    [container addSubview:view_b];
+
+    // Layout: left half / right half.
+    CGFloat width = container.bounds.size.width;
+    CGFloat height = container.bounds.size.height;
+
+    view_a.frame = NSMakeRect(0, 0, width / 2, height);
+    view_b.frame = NSMakeRect(width / 2, 0, width / 2, height);
+
+    view_a.autoresizingMask = NSViewWidthSizable | NSViewHeightSizable;
+    view_b.autoresizingMask = NSViewWidthSizable | NSViewHeightSizable;
+  }
+
+  // Disable all three throttling layers for both WebContents.
+  // Layer 1: Prevent RenderWidgetHost from treating views as hidden.
+  auto* rwh_a = static_cast<RenderWidgetHostImpl*>(
+      shell_a->web_contents()->GetRenderWidgetHostView()->GetRenderWidgetHost());
+  rwh_a->disable_hidden_ = true;
+  auto* rwh_b = static_cast<RenderWidgetHostImpl*>(
+      web_contents_b_->GetRenderWidgetHostView()->GetRenderWidgetHost());
+  rwh_b->disable_hidden_ = true;
+
+  // Layer 2: Disable Blink's scheduler throttling per RenderView.
+  shell_a->web_contents()->GetRenderViewHost()->SetSchedulerThrottling(false);
+  web_contents_b_->GetRenderViewHost()->SetSchedulerThrottling(false);
+#endif
+}
+
+void TwoProfilesMainParts::PostMainMessageLoopRun() {
+  web_contents_b_.reset();
+  browser_context_b_.reset();
+  ShellBrowserMainParts::PostMainMessageLoopRun();
+}
+
+}  // namespace content
