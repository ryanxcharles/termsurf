diff --git a/content/shell/renderer/shell_content_renderer_client.cc b/content/shell/renderer/shell_content_renderer_client.cc
index 089e88acf3cb0..26277e4794b71 100644
--- a/content/shell/renderer/shell_content_renderer_client.cc
+++ b/content/shell/renderer/shell_content_renderer_client.cc
@@ -5,11 +5,13 @@
 #include "content/shell/renderer/shell_content_renderer_client.h"
 
 #include <cstdlib>
+#include <memory>
 #include <string>
 
 #include "base/base_switches.h"
 #include "base/check_op.h"
 #include "base/command_line.h"
+#include "base/feature_list.h"
 #include "base/files/file.h"
 #include "base/functional/bind.h"
 #include "base/immediate_crash.h"
@@ -19,6 +21,9 @@
 #include "base/task/sequenced_task_runner.h"
 #include "base/task/single_thread_task_runner.h"
 #include "base/types/pass_key.h"
+#include "components/autofill/content/renderer/autofill_agent.h"
+#include "components/autofill/content/renderer/password_autofill_agent.h"
+#include "components/autofill/content/renderer/password_generation_agent.h"
 #include "components/cdm/renderer/external_clear_key_key_system_info.h"
 #include "components/network_hints/renderer/web_prescient_networking_impl.h"
 #include "components/surface_embed/buildflags/buildflags.h"
@@ -42,6 +47,7 @@
 #include "net/base/net_errors.h"
 #include "sandbox/policy/sandbox.h"
 #include "third_party/blink/public/platform/url_loader_throttle_provider.h"
+#include "third_party/blink/public/common/features.h"
 #include "third_party/blink/public/platform/web_url_error.h"
 #include "third_party/blink/public/web/modules/credentialmanagement/throttle_helper.h"
 #include "third_party/blink/public/web/web_local_frame.h"
@@ -51,7 +57,6 @@
 #include "v8/include/v8.h"
 
 #if BUILDFLAG(ENABLE_MOJO_CDM)
-#include "base/feature_list.h"
 #include "media/base/media_switches.h"
 #endif
 
@@ -352,6 +357,38 @@ void ShellContentRendererClient::RenderFrameCreated(RenderFrame* render_frame) {
   // browser tests. If we only create that for browser tests then the override
   // of this method in WebTestContentRendererClient would not be needed.
   new ShellRenderFrameObserver(render_frame);
+
+  if (!render_frame->IsInFencedFrameTree() ||
+      base::FeatureList::IsEnabled(blink::features::kFencedFramesAPIChanges)) {
+    blink::AssociatedInterfaceRegistry* associated_interfaces =
+        render_frame->GetAssociatedInterfaceRegistry();
+    auto password_autofill_agent =
+        std::make_unique<autofill::PasswordAutofillAgent>(
+            render_frame, associated_interfaces);
+    auto password_generation_agent =
+        std::make_unique<autofill::PasswordGenerationAgent>(
+            render_frame, password_autofill_agent.get(), associated_interfaces);
+    new autofill::AutofillAgent(render_frame,
+                                std::move(password_autofill_agent),
+                                std::move(password_generation_agent),
+                                associated_interfaces);
+    if (Issue779TraceEnabled()) {
+      Issue779TraceAnnounce();
+      LOG(INFO) << "[issue-779-trace] datalist_autofill"
+                << " event=ShellContentRendererClient::RenderFrameCreated."
+                   "autofill_installed"
+                << " render_frame=" << static_cast<void*>(render_frame)
+                << " associated_interfaces="
+                << static_cast<void*>(associated_interfaces);
+    }
+  } else if (Issue779TraceEnabled()) {
+    Issue779TraceAnnounce();
+    LOG(INFO) << "[issue-779-trace] datalist_autofill"
+              << " event=ShellContentRendererClient::RenderFrameCreated."
+                 "autofill_skipped"
+              << " reason=fenced_frame"
+              << " render_frame=" << static_cast<void*>(render_frame);
+  }
 }
 
 bool ShellContentRendererClient::OverrideCreatePlugin(
