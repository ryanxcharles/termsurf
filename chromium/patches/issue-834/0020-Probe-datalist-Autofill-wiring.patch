From bf7407ee836afe5b92f22d498ca640c1717bdf5a Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Sat, 23 May 2026 09:11:24 -0500
Subject: [PATCH 20/73] Probe datalist Autofill wiring
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

A datalist knocked on Blink’s small door,
We taught a client to answer once more.
The popup stayed coy, the trail stayed bright,
A failed little lantern for the next night.
---
 .../content_autofill_driver_factory.cc        | 39 +++++++++++++++++++
 .../content/renderer/autofill_agent.cc        |  2 +-
 content/shell/BUILD.gn                        |  1 +
 .../renderer/shell_content_renderer_client.cc | 39 ++++++++++++++++++-
 4 files changed, 79 insertions(+), 2 deletions(-)

diff --git a/components/autofill/content/browser/content_autofill_driver_factory.cc b/components/autofill/content/browser/content_autofill_driver_factory.cc
index da9e79440c1ce..19df5e050a3e7 100644
--- a/components/autofill/content/browser/content_autofill_driver_factory.cc
+++ b/components/autofill/content/browser/content_autofill_driver_factory.cc
@@ -4,6 +4,7 @@
 
 #include "components/autofill/content/browser/content_autofill_driver_factory.h"
 
+#include <cstdlib>
 #include <memory>
 #include <utility>
 #include <vector>
@@ -29,6 +30,25 @@ namespace autofill {
 
 class ScopedAutofillManagersObservation;
 
+namespace {
+
+bool Issue779TraceEnabled() {
+  static const bool enabled =
+      std::getenv("TERMSURF_ISSUE_779_TRACE") != nullptr;
+  return enabled;
+}
+
+void Issue779TraceAnnounce() {
+  static bool announced = false;
+  if (!announced) {
+    announced = true;
+    LOG(INFO)
+        << "[issue-779-trace] trace_enabled component=autofill-driver-factory";
+  }
+}
+
+}  // namespace
+
 void ContentAutofillDriverFactory::Observer::OnAutofillDriverFactoryDestroyed(
     AutofillDriverFactory& factory) {
   OnContentAutofillDriverFactoryDestroyed(
@@ -76,12 +96,31 @@ void ContentAutofillDriverFactory::BindAutofillDriver(
 
   ContentAutofillDriverFactory* factory = FromWebContents(web_contents);
   if (!factory) {
+    if (Issue779TraceEnabled()) {
+      Issue779TraceAnnounce();
+      LOG(INFO) << "[issue-779-trace] datalist_autofill"
+                << " event=ContentAutofillDriverFactory::BindAutofillDriver."
+                   "missing_client"
+                << " render_frame_host="
+                << static_cast<void*>(render_frame_host)
+                << " web_contents=" << static_cast<void*>(web_contents);
+    }
     // The message pipe will be closed and raise a connection error to peer
     // side. The peer side can reconnect later when needed.
     return;
   }
 
   if (auto* driver = factory->DriverForFrame(render_frame_host)) {
+    if (Issue779TraceEnabled()) {
+      Issue779TraceAnnounce();
+      LOG(INFO) << "[issue-779-trace] datalist_autofill"
+                << " event=ContentAutofillDriverFactory::BindAutofillDriver."
+                   "bind"
+                << " render_frame_host="
+                << static_cast<void*>(render_frame_host)
+                << " web_contents=" << static_cast<void*>(web_contents)
+                << " driver=" << static_cast<void*>(driver);
+    }
     driver->BindPendingReceiver(std::move(pending_receiver));
   }
 }
diff --git a/components/autofill/content/renderer/autofill_agent.cc b/components/autofill/content/renderer/autofill_agent.cc
index 984558ca848be..5112169500ed4 100644
--- a/components/autofill/content/renderer/autofill_agent.cc
+++ b/components/autofill/content/renderer/autofill_agent.cc
@@ -1021,7 +1021,7 @@ void AutofillAgent::OpenTextDataListChooser(const WebInputElement& element) {
               << " event=AutofillAgent::OpenTextDataListChooser"
               << " agent=" << static_cast<void*>(this)
               << " render_frame=" << static_cast<void*>(unsafe_render_frame())
-              << " element=" << static_cast<void*>(&element)
+              << " element=" << static_cast<const void*>(&element)
               << " value_length=" << element.Value().length();
   }
   ShowSuggestions(
