+mojo::PendingRemote<network::mojom::URLLoaderFactory>
+TsBrowserClient::CreateNonNetworkNavigationURLLoaderFactory(
+    const std::string& scheme,
+    FrameTreeNodeId frame_tree_node_id) {
+  if (scheme == extensions::kExtensionScheme) {
+    WebContents* web_contents =
+        WebContents::FromFrameTreeNodeId(frame_tree_node_id);
+    LOG(INFO) << "[issue-792-exp5] extension-factory"
+              << " scheme=chrome-extension type=navigation";
+    return extensions::CreateExtensionNavigationURLLoaderFactory(
+        web_contents->GetBrowserContext(), false);
+  }
+  return ShellContentBrowserClient::CreateNonNetworkNavigationURLLoaderFactory(
+      scheme, frame_tree_node_id);
+}
+
+void TsBrowserClient::RegisterNonNetworkWorkerMainResourceURLLoaderFactories(
+    BrowserContext* browser_context,
+    NonNetworkURLLoaderFactoryMap* factories) {
+  ShellContentBrowserClient::
+      RegisterNonNetworkWorkerMainResourceURLLoaderFactories(browser_context,
+                                                             factories);
+  LOG(INFO) << "[issue-792-exp5] extension-factory"
+            << " scheme=chrome-extension type=worker-main";
+  factories->emplace(
+      extensions::kExtensionScheme,
+      extensions::CreateExtensionWorkerMainResourceURLLoaderFactory(
+          browser_context));
+}
+
+void TsBrowserClient::RegisterNonNetworkServiceWorkerUpdateURLLoaderFactories(
+    BrowserContext* browser_context,
+    NonNetworkURLLoaderFactoryMap* factories) {
+  ShellContentBrowserClient::
+      RegisterNonNetworkServiceWorkerUpdateURLLoaderFactories(browser_context,
+                                                              factories);
+  LOG(INFO) << "[issue-792-exp5] extension-factory"
+            << " scheme=chrome-extension type=service-worker";
+  factories->emplace(
+      extensions::kExtensionScheme,
+      extensions::CreateExtensionServiceWorkerScriptURLLoaderFactory(
+          browser_context));
+}
+
+void TsBrowserClient::RegisterNonNetworkSubresourceURLLoaderFactories(
+    int render_process_id,
+    int render_frame_id,
+    const std::optional<url::Origin>& request_initiator_origin,
+    NonNetworkURLLoaderFactoryMap* factories) {
+  ShellContentBrowserClient::RegisterNonNetworkSubresourceURLLoaderFactories(
+      render_process_id, render_frame_id, request_initiator_origin, factories);
+  LOG(INFO) << "[issue-792-exp5] extension-factory"
+            << " scheme=chrome-extension type=subresource";
+  factories->emplace(extensions::kExtensionScheme,
+                     extensions::CreateExtensionURLLoaderFactory(
+                         render_process_id, render_frame_id));
+}
