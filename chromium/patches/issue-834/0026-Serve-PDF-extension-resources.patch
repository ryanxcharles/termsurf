+namespace content {
+namespace {
+
+bool IsHtmlMimeType(std::string_view mime_type) {
+  return base::EqualsCaseInsensitiveASCII(mime_type, "text/html") ||
+         base::EqualsCaseInsensitiveASCII(mime_type, "text/css");
+}
+
+bool IsJavaScriptMimeType(std::string_view mime_type) {
+  return base::EqualsCaseInsensitiveASCII(mime_type, "text/javascript") ||
+         base::EqualsCaseInsensitiveASCII(mime_type, "application/javascript");
+}
+
+bool IsTextLikeMimeType(std::string_view mime_type) {
+  return base::StartsWith(mime_type, "text/",
+                          base::CompareCase::INSENSITIVE_ASCII) ||
+         IsJavaScriptMimeType(mime_type);
+}
+
+std::string MimeTypeForPath(const base::FilePath& path) {
+  std::string mime_type;
+  if (!net::GetWellKnownMimeTypeFromFile(path, &mime_type)) {
+    mime_type = "application/octet-stream";
+  }
+  return mime_type;
+}
+
+std::string LoadResourceBody(int resource_id,
+                             const extensions::ExtensionId& extension_id,
+                             std::string_view mime_type) {
+  const ui::ResourceBundle& bundle = ui::ResourceBundle::GetSharedInstance();
+  std::string body = bundle.LoadDataResourceString(resource_id);
+  if (body.empty()) {
+    return body;
+  }
+
+  auto* replacements =
+      extensions::ExtensionsBrowserClient::Get()
+              ->GetComponentExtensionResourceManager()
+          ? extensions::ExtensionsBrowserClient::Get()
+                ->GetComponentExtensionResourceManager()
+                ->GetTemplateReplacementsForExtension(extension_id)
+          : nullptr;
+  if (!replacements || replacements->empty()) {
+    return body;
+  }
+
+  if (IsHtmlMimeType(mime_type)) {
+    return ui::ReplaceTemplateExpressions(
+        body, *replacements, true /* skip_unexpected_placeholder_check */);
+  }
+  if (IsJavaScriptMimeType(mime_type)) {
+    std::string replaced_body;
+    if (ui::ReplaceTemplateExpressionsInJS(body, *replacements,
+                                           &replaced_body)) {
+      return replaced_body;
+    }
+    LOG(ERROR) << "[issue-792-exp5] bundle-resource-load"
+               << " path= resource_id=" << resource_id << " bytes=0"
+               << " mime=" << mime_type << " ok=0";
+    return {};
+  }
+  return body;
+}
+
+class TsResourceBundleFileLoader : public network::mojom::URLLoader {
+ public:
+  TsResourceBundleFileLoader(const TsResourceBundleFileLoader&) = delete;
+  TsResourceBundleFileLoader& operator=(const TsResourceBundleFileLoader&) =
+      delete;
+
+  static void CreateAndStart(
+      const network::ResourceRequest& request,
+      mojo::PendingReceiver<network::mojom::URLLoader> loader,
+      mojo::PendingRemote<network::mojom::URLLoaderClient> client,
+      const base::FilePath& resource_relative_path,
+      int resource_id,
+      scoped_refptr<net::HttpResponseHeaders> headers) {
+    auto* bundle_loader = new TsResourceBundleFileLoader(
+        resource_relative_path, resource_id, std::move(headers));
+    bundle_loader->Start(request, std::move(loader), std::move(client));
+  }
+
+  // network::mojom::URLLoader:
+  void FollowRedirect(
+      const std::vector<std::string>& removed_headers,
+      const net::HttpRequestHeaders& modified_headers,
+      const net::HttpRequestHeaders& modified_cors_exempt_headers,
+      const std::optional<GURL>& new_url) override {
+    NOTREACHED() << "No redirects for resource bundle loads.";
+  }
+
+  void SetPriority(net::RequestPriority priority,
+                   int32_t intra_priority_value) override {}
+
+ private:
+  TsResourceBundleFileLoader(base::FilePath resource_relative_path,
+                             int resource_id,
+                             scoped_refptr<net::HttpResponseHeaders> headers)
+      : resource_relative_path_(std::move(resource_relative_path)),
+        resource_id_(resource_id),
+        headers_(std::move(headers)) {}
+
+  ~TsResourceBundleFileLoader() override = default;
+
+  void Start(const network::ResourceRequest& request,
+             mojo::PendingReceiver<network::mojom::URLLoader> loader,
+             mojo::PendingRemote<network::mojom::URLLoaderClient> client) {
+    client_.Bind(std::move(client));
+    receiver_.Bind(std::move(loader));
+    receiver_.set_disconnect_handler(
+        base::BindOnce(&TsResourceBundleFileLoader::OnReceiverDisconnect,
+                       base::Unretained(this)));
+    client_.set_disconnect_handler(
+        base::BindOnce(&TsResourceBundleFileLoader::OnClientDisconnect,
+                       base::Unretained(this)));
+
+    const std::string mime_type = MimeTypeForPath(resource_relative_path_);
+    std::string body =
+        LoadResourceBody(resource_id_, std::string(request.url.host()),
+                         mime_type);
+    const bool ok = !body.empty();
+    LOG(INFO) << "[issue-792-exp5] bundle-resource-load"
+              << " path=" << resource_relative_path_.AsUTF8Unsafe()
+              << " resource_id=" << resource_id_ << " bytes=" << body.size()
+              << " mime=" << mime_type << " ok=" << ok;
+    if (!ok) {
+      CompleteAndDelete(net::ERR_FAILED);
+      return;
+    }
+
+    auto head = network::mojom::URLResponseHead::New();
+    head->request_start = base::TimeTicks::Now();
+    head->response_start = base::TimeTicks::Now();
+    head->content_length = body.size();
+    head->mime_type = mime_type;
+    if (IsTextLikeMimeType(mime_type)) {
+      head->charset = "utf-8";
+    }
+    head->headers = headers_;
+    head->headers->AddHeader(net::HttpRequestHeaders::kContentLength,
+                             base::NumberToString(head->content_length));
+    head->headers->AddHeader(net::HttpRequestHeaders::kContentType,
+                             mime_type.c_str());
+
+    mojo::ScopedDataPipeProducerHandle producer_handle;
+    mojo::ScopedDataPipeConsumerHandle consumer_handle;
+    if (mojo::CreateDataPipe(body.size(), producer_handle, consumer_handle) !=
+        MOJO_RESULT_OK) {
+      CompleteAndDelete(net::ERR_FAILED);
+      return;
+    }
+
+    size_t actually_written_bytes = 0;
+    MojoResult result = producer_handle->WriteData(
+        base::as_byte_span(body), MOJO_WRITE_DATA_FLAG_NONE,
+        actually_written_bytes);
+    if (result != MOJO_RESULT_OK || actually_written_bytes != body.size()) {
+      CompleteAndDelete(net::ERR_FAILED);
+      return;
+    }
+
+    client_->OnReceiveResponse(std::move(head), std::move(consumer_handle),
+                               std::nullopt);
+    CompleteAndDelete(net::OK);
+  }
+
+  void CompleteAndDelete(int error_code) {
+    if (client_) {
+      client_->OnComplete(network::URLLoaderCompletionStatus(error_code));
+      client_.reset();
+    }
+    MaybeDeleteSelf();
+  }
+
+  void OnReceiverDisconnect() {
+    receiver_.reset();
+    MaybeDeleteSelf();
+  }
+
+  void OnClientDisconnect() {
+    client_.reset();
+    MaybeDeleteSelf();
+  }
+
+  void MaybeDeleteSelf() {
+    if (!receiver_.is_bound() && !client_.is_bound()) {
+      delete this;
+    }
+  }
+
+  mojo::Receiver<network::mojom::URLLoader> receiver_{this};
+  mojo::Remote<network::mojom::URLLoaderClient> client_;
+  base::FilePath resource_relative_path_;
+  int resource_id_ = 0;
+  scoped_refptr<net::HttpResponseHeaders> headers_;
+};
+
+}  // namespace
+
+void LoadTsExtensionResourceFromBundle(
+    const network::ResourceRequest& request,
+    mojo::PendingReceiver<network::mojom::URLLoader> loader,
+    mojo::PendingRemote<network::mojom::URLLoaderClient> client,
+    const base::FilePath& resource_relative_path,
+    int resource_id,
+    scoped_refptr<net::HttpResponseHeaders> headers) {
+  TsResourceBundleFileLoader::CreateAndStart(
+      request, std::move(loader), std::move(client), resource_relative_path,
+      resource_id, std::move(headers));
+}
+
+}  // namespace content
