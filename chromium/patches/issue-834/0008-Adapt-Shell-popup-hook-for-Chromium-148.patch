From f669626531aa44d01324c5129971875bffdb6a8a Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Mon, 18 May 2026 08:38:27 -0500
Subject: [PATCH 08/73] Adapt Shell popup hook for Chromium 148

Two new args knocked at Shell,
Old override lost its hat.
We let them pass unused,
And sent popups to the mat.
---
 content/shell/browser/shell.cc | 2 ++
 content/shell/browser/shell.h  | 2 ++
 2 files changed, 4 insertions(+)

diff --git a/content/shell/browser/shell.cc b/content/shell/browser/shell.cc
index 9e91ec368fafa..41798560ab9ca 100644
--- a/content/shell/browser/shell.cc
+++ b/content/shell/browser/shell.cc
@@ -373,6 +373,8 @@ WebContents* Shell::CreateCustomWebContents(
     const GURL& opener_url,
     const std::string& frame_name,
     const GURL& target_url,
+    WindowOpenDisposition disposition,
+    const blink::mojom::WindowFeatures& window_features,
     const StoragePartitionConfig& partition_config,
     SessionStorageNamespace* session_storage_namespace) {
   // Issue 750: No custom WebContents — creation is fully suppressed.
diff --git a/content/shell/browser/shell.h b/content/shell/browser/shell.h
index 4edb2c4dcc054..83c0df7f00ca2 100644
--- a/content/shell/browser/shell.h
+++ b/content/shell/browser/shell.h
@@ -137,6 +137,8 @@ class Shell : public WebContentsDelegate, public WebContentsObserver {
       const GURL& opener_url,
       const std::string& frame_name,
       const GURL& target_url,
+      WindowOpenDisposition disposition,
+      const blink::mojom::WindowFeatures& window_features,
       const StoragePartitionConfig& partition_config,
       SessionStorageNamespace* session_storage_namespace) override;
   void LoadingStateChanged(WebContents* source,
