+std::string Issue779TopLeftScreenRectToString(NSRect rect, NSScreen* screen) {
+  if (!screen) {
+    return "null";
+  }
+  NSRect screen_frame = screen.frame;
+  CGFloat top_left_y = NSMaxY(screen_frame) - NSMaxY(rect);
+  return base::SysNSStringToUTF8([NSString
+      stringWithFormat:@"{{%.1f, %.1f}, {%.1f, %.1f}}", rect.origin.x,
+                       top_left_y, rect.size.width, rect.size.height]);
+}
+
+std::string Issue779ViewScreenFrame(NSView* view) {
+  if (!view || !view.window || !view.window.screen) {
+    return "null";
+  }
+  return Issue779NSRectToString(view.window.screen.frame);
+}
+
+std::string Issue779ViewVisibleFrame(NSView* view) {
+  if (!view || !view.window || !view.window.screen) {
+    return "null";
+  }
+  return Issue779NSRectToString(view.window.screen.visibleFrame);
+}
+
+std::string Issue779FirstResponder(NSWindow* window) {
+  if (!window || !window.firstResponder) {
+    return "null";
+  }
+  return base::SysNSStringToUTF8(
+      NSStringFromClass([window.firstResponder class]));
+}
+
+std::string Issue779CurrentEventType() {
+  NSEvent* event = NSApp.currentEvent;
+  if (!event) {
+    return "null";
+  }
+  return base::SysNSStringToUTF8(
+      [NSString stringWithFormat:@"%ld", static_cast<long>(event.type)]);
+}
+
+NSString* Issue779BoolString(BOOL value) {
+  return value ? @"true" : @"false";
+}
+
+std::string Issue779WindowSummary(NSWindow* window) {
+  if (!window) {
+    return "window=null";
+  }
+  NSMutableArray<NSString*>* child_parts = [NSMutableArray array];
+  for (NSWindow* child in window.childWindows) {
+    [child_parts
+        addObject:[NSString
+                      stringWithFormat:@"%@:%p:%ld:%@:%ld:%@:%@",
+                                       NSStringFromClass(child.class), child,
+                                       static_cast<long>(child.windowNumber),
+                                       NSStringFromRect(child.frame),
+                                       static_cast<long>(child.level),
+                                       Issue779BoolString(child.isVisible),
+                                       Issue779BoolString(
+                                           child.ignoresMouseEvents)]];
+  }
+  return base::SysNSStringToUTF8([NSString
+      stringWithFormat:
+          @"window=%p window_class=%@ window_number=%ld window_frame=%@ "
+           "window_screen=%@ window_level=%ld collection_behavior=%lu "
+           "style_mask=%lu alpha=%.3f is_visible=%@ ignoresMouseEvents=%@ "
+           "is_key=%@ is_main=%@ content_view=%p content_view_class=%@ "
+           "first_responder=%@ parent_window=%p child_window_count=%lu "
+           "child_windows=%@",
+          window, NSStringFromClass(window.class),
+          static_cast<long>(window.windowNumber), NSStringFromRect(window.frame),
+          window.screen ? NSStringFromRect(window.screen.frame) : @"null",
+          static_cast<long>(window.level),
+          static_cast<unsigned long>(window.collectionBehavior),
+          static_cast<unsigned long>(window.styleMask), window.alphaValue,
+          Issue779BoolString(window.isVisible),
+          Issue779BoolString(window.ignoresMouseEvents),
+          Issue779BoolString(window.isKeyWindow),
+          Issue779BoolString(window.isMainWindow), window.contentView,
+          window.contentView ? NSStringFromClass(window.contentView.class)
+                             : @"null",
+          window.firstResponder ? NSStringFromClass(window.firstResponder.class) : @"null", window.parentWindow,
+          static_cast<unsigned long>(window.childWindows.count),
+          [child_parts componentsJoinedByString:@"|"]]);
+}
+
+std::string Issue779OrderedWindowsSummary() {
+  NSArray<NSWindow*>* windows = NSApp.orderedWindows;
+  NSMutableArray<NSString*>* parts = [NSMutableArray array];
+  NSUInteger limit = std::min<NSUInteger>(windows.count, 3);
+  for (NSUInteger index = 0; index < limit; ++index) {
+    NSWindow* window = windows[index];
+    [parts addObject:[NSString
+                         stringWithFormat:
+                             @"%lu:%p:%@:%ld:%@:%ld:%@:%@",
+                             static_cast<unsigned long>(index), window,
+                             NSStringFromClass(window.class),
+                             static_cast<long>(window.windowNumber),
+                             NSStringFromRect(window.frame),
+                             static_cast<long>(window.level),
+                             Issue779BoolString(window.isVisible),
+                             Issue779BoolString(window.ignoresMouseEvents)]];
+  }
+  return base::SysNSStringToUTF8([NSString
+      stringWithFormat:@"ordered_windows_count=%lu ordered_windows_top3=%@",
+                       static_cast<unsigned long>(windows.count),
+                       [parts componentsJoinedByString:@"|"]]);
+}
+
+void Issue779TraceShellWindowState(NSString* boundary,
+                                   NSString* phase,
+                                   NSView* view,
+                                   WebMenuRunner* runner) {
+  if (!Issue779TraceEnabled()) {
+    return;
+  }
+  Issue779TraceAnnounce();
+  NSWindow* window = view.window;
+  LOG(INFO) << "[issue-779-trace] chromium_shell_window_state"
+            << " boundary=" << base::SysNSStringToUTF8(boundary)
+            << " phase=" << base::SysNSStringToUTF8(phase)
+            << " path=select"
+            << " runner=" << (__bridge void*)runner
+            << " view=" << (__bridge void*)view
+            << " window=" << (__bridge void*)window
+            << " key_window=" << (__bridge void*)NSApp.keyWindow
+            << " main_window=" << (__bridge void*)NSApp.mainWindow
+            << " modal_window=" << (__bridge void*)NSApp.modalWindow
+            << " app_is_active=" << Issue779BoolString(NSApp.isActive)
+            << " currentEvent=" << Issue779CurrentEventType()
+            << " shell_window_summary=\"" << Issue779WindowSummary(window)
+            << "\" key_window_summary=\""
+            << Issue779WindowSummary(NSApp.keyWindow)
+            << "\" main_window_summary=\""
+            << Issue779WindowSummary(NSApp.mainWindow)
+            << "\" modal_window_summary=\""
+            << Issue779WindowSummary(NSApp.modalWindow)
+            << "\" " << Issue779OrderedWindowsSummary();
+}
+
 }  // namespace
 
