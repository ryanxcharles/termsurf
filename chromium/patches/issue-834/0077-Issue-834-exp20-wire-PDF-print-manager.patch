+namespace termsurf {
+
+class TsPdfPrintManager
+    : public printing::PrintManager,
+      public content::WebContentsUserData<TsPdfPrintManager> {
+ public:
+  TsPdfPrintManager(const TsPdfPrintManager&) = delete;
+  TsPdfPrintManager& operator=(const TsPdfPrintManager&) = delete;
+  ~TsPdfPrintManager() override;
+
+  static void BindPrintManagerHost(
+      mojo::PendingAssociatedReceiver<printing::mojom::PrintManagerHost>
+          receiver,
+      content::RenderFrameHost* render_frame_host);
+
+ private:
+  friend class content::WebContentsUserData<TsPdfPrintManager>;
+
+  struct PrintRequest;
+
+  explicit TsPdfPrintManager(content::WebContents* web_contents);
+
+  static void OnScriptedPrintSettingsReady(
+      std::unique_ptr<PrintRequest> request,
+      printing::mojom::ScriptedPrintParamsPtr params,
+      printing::mojom::PrintManagerHost::ScriptedPrintCallback callback,
+      printing::mojom::ResultCode result);
+
+  void GetDefaultPrintSettings(
+      GetDefaultPrintSettingsCallback callback) override;
+  void ScriptedPrint(printing::mojom::ScriptedPrintParamsPtr params,
+                     ScriptedPrintCallback callback) override;
+
+#if BUILDFLAG(ENABLE_PRINT_PREVIEW)
+  void UpdatePrintSettings(base::DictValue job_settings,
+                           UpdatePrintSettingsCallback callback) override;
+  void SetupScriptedPrintPreview(
+      SetupScriptedPrintPreviewCallback callback) override;
+  void ShowScriptedPrintPreview(bool source_is_modifiable) override;
+  void RequestPrintPreview(
+      printing::mojom::RequestPrintPreviewParamsPtr params) override;
+  void CheckForCancel(int32_t preview_ui_id,
+                      int32_t request_id,
+                      CheckForCancelCallback callback) override;
+  void SetAccessibilityTree(
+      int32_t cookie,
+      const ui::AXTreeUpdate& accessibility_tree) override;
+#endif
+
+  std::map<int, std::unique_ptr<PrintRequest>> pending_print_requests_;
+
+  WEB_CONTENTS_USER_DATA_KEY_DECL();
+};
+
+}  // namespace termsurf
