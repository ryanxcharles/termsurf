index 0000000000..371c80a3fe
--- /dev/null
+++ b/content/libtermsurf_chromium/ts_pdf_print_manager.cc
@@ -0,0 +1,203 @@
+// Copyright 2025 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/libtermsurf_chromium/ts_pdf_print_manager.h"
+
+#include <memory>
+#include <string>
+
+#include "base/functional/bind.h"
+#include "components/printing/browser/print_manager_utils.h"
+#include "content/public/browser/render_frame_host.h"
+#include "content/public/browser/web_contents.h"
+#include "printing/mojom/print.mojom.h"
+#include "printing/print_settings.h"
+#include "printing/printing_context.h"
+#include "ui/gfx/native_ui_types.h"
+
+namespace termsurf {
+namespace {
+
+class TsPrintingContextDelegate : public printing::PrintingContext::Delegate {
+ public:
+  explicit TsPrintingContextDelegate(content::WebContents* web_contents)
+      : web_contents_(web_contents) {}
+
+  gfx::NativeView GetParentView() override {
+    return web_contents_ ? web_contents_->GetNativeView() : gfx::NativeView();
+  }
+
+  std::string GetAppLocale() override { return "en-US"; }
+
+ private:
+  const raw_ptr<content::WebContents> web_contents_;
+};
+
+}  // namespace
+
+struct TsPdfPrintManager::PrintRequest {
+  explicit PrintRequest(content::WebContents* web_contents)
+      : delegate(web_contents),
+        context(printing::PrintingContext::Create(
+            &delegate,
+            printing::PrintingContext::OutOfProcessBehavior::kDisabled)) {}
+
+  TsPrintingContextDelegate delegate;
+  std::unique_ptr<printing::PrintingContext> context;
+};
+
+namespace {
+
+printing::mojom::PrintParamsPtr CreatePrintParamsFromSettings(
+    const printing::PrintSettings& settings,
+    int document_cookie) {
+  auto params = printing::mojom::PrintParams::New();
+  printing::RenderParamsFromPrintSettings(settings, params.get());
+  params->document_cookie = document_cookie;
+  return params;
+}
+
+}  // namespace
+
+TsPdfPrintManager::TsPdfPrintManager(content::WebContents* web_contents)
+    : printing::PrintManager(web_contents),
+      content::WebContentsUserData<TsPdfPrintManager>(*web_contents) {}
+
+TsPdfPrintManager::~TsPdfPrintManager() = default;
+
+// static
+void TsPdfPrintManager::OnScriptedPrintSettingsReady(
+    std::unique_ptr<PrintRequest> request,
+    printing::mojom::ScriptedPrintParamsPtr params,
+    printing::mojom::PrintManagerHost::ScriptedPrintCallback callback,
+    printing::mojom::ResultCode result) {
+  if (result != printing::mojom::ResultCode::kSuccess) {
+    std::move(callback).Run(nullptr);
+    return;
+  }
+
+  auto settings = request->context->TakeAndResetSettings();
+  if (!settings) {
+    std::move(callback).Run(nullptr);
+    return;
+  }
+
+  auto print_pages_params = printing::mojom::PrintPagesParams::New();
+  print_pages_params->params = CreatePrintParamsFromSettings(
+      *settings, printing::PrintSettings::NewCookie());
+  if (!print_pages_params->params) {
+    std::move(callback).Run(nullptr);
+    return;
+  }
+  print_pages_params->pages = settings->ranges();
+
+  std::move(callback).Run(std::move(print_pages_params));
+}
+
+// static
+void TsPdfPrintManager::BindPrintManagerHost(
+    mojo::PendingAssociatedReceiver<printing::mojom::PrintManagerHost> receiver,
+    content::RenderFrameHost* render_frame_host) {
+  content::WebContents* web_contents =
+      content::WebContents::FromRenderFrameHost(render_frame_host);
+  if (!web_contents) {
+    return;
+  }
+
+  TsPdfPrintManager* print_manager =
+      TsPdfPrintManager::FromWebContents(web_contents);
+  if (!print_manager) {
+    return;
+  }
+
+  print_manager->BindReceiver(std::move(receiver), render_frame_host);
+}
+
+void TsPdfPrintManager::GetDefaultPrintSettings(
+    GetDefaultPrintSettingsCallback callback) {
+  auto request = std::make_unique<PrintRequest>(web_contents());
+  if (!request->context) {
+    std::move(callback).Run(nullptr);
+    return;
+  }
+
+  request->context->set_margin_type(
+      printing::mojom::MarginType::kDefaultMargins);
+  printing::mojom::ResultCode result = request->context->UseDefaultSettings();
+  if (result != printing::mojom::ResultCode::kSuccess) {
+    std::move(callback).Run(nullptr);
+    return;
+  }
+
+  const printing::PrintSettings& settings = request->context->settings();
+  if (!settings.dpi()) {
+    std::move(callback).Run(nullptr);
+    return;
+  }
+
+  int document_cookie = printing::PrintSettings::NewCookie();
+  set_cookie(document_cookie);
+  auto print_params =
+      CreatePrintParamsFromSettings(request->context->settings(),
+                                    document_cookie);
+  pending_print_requests_[document_cookie] = std::move(request);
+  std::move(callback).Run(std::move(print_params));
+}
+
+void TsPdfPrintManager::ScriptedPrint(
+    printing::mojom::ScriptedPrintParamsPtr params,
+    ScriptedPrintCallback callback) {
+  auto request_iter = pending_print_requests_.find(params->cookie);
+  if (request_iter == pending_print_requests_.end()) {
+    std::move(callback).Run(nullptr);
+    return;
+  }
+
+  std::unique_ptr<PrintRequest> request = std::move(request_iter->second);
+  pending_print_requests_.erase(request_iter);
+  if (!request->context) {
+    std::move(callback).Run(nullptr);
+    return;
+  }
+
+  request->context->set_margin_type(params->margin_type);
+  request->context->AskUserForSettings(
+      static_cast<int>(params->expected_pages_count), params->has_selection,
+      params->is_scripted,
+      base::BindOnce(&TsPdfPrintManager::OnScriptedPrintSettingsReady,
+                     std::move(request), std::move(params),
+                     std::move(callback)));
+}
+
+#if BUILDFLAG(ENABLE_PRINT_PREVIEW)
+void TsPdfPrintManager::UpdatePrintSettings(
+    base::DictValue job_settings,
+    UpdatePrintSettingsCallback callback) {
+  std::move(callback).Run(nullptr);
+}
+
+void TsPdfPrintManager::SetupScriptedPrintPreview(
+    SetupScriptedPrintPreviewCallback callback) {
+  std::move(callback).Run();
+}
+
+void TsPdfPrintManager::ShowScriptedPrintPreview(bool source_is_modifiable) {}
+
+void TsPdfPrintManager::RequestPrintPreview(
+    printing::mojom::RequestPrintPreviewParamsPtr params) {}
+
+void TsPdfPrintManager::CheckForCancel(int32_t preview_ui_id,
+                                       int32_t request_id,
+                                       CheckForCancelCallback callback) {
+  std::move(callback).Run(true);
+}
+
+void TsPdfPrintManager::SetAccessibilityTree(
+    int32_t cookie,
+    const ui::AXTreeUpdate& accessibility_tree) {}
+#endif
+
+WEB_CONTENTS_USER_DATA_KEY_IMPL(TsPdfPrintManager);
+
+}  // namespace termsurf
