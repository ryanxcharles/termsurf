 }
 
+bool TsBrowserClient::ShouldUseProcessPerSite(BrowserContext* browser_context,
+                                              const GURL& site_url) {
+  if (!site_url.SchemeIs(extensions::kExtensionScheme)) {
+    return ShellContentBrowserClient::ShouldUseProcessPerSite(browser_context,
+                                                              site_url);
+  }
+
+  auto* registry = extensions::ExtensionRegistry::Get(browser_context);
+  if (!registry) {
+    return false;
+  }
+
+  const extensions::Extension* extension =
+      registry->enabled_extensions().GetByID(site_url.GetHost());
+  if (!extension) {
+    return false;
+  }
+
+  LOG(INFO) << "[issue-792-exp6] process-per-site extension_id="
+            << extension->id() << " effective_url=" << site_url;
+  return true;
+}
+
+bool TsBrowserClient::IsHandledURL(const GURL& url) {
+  if (url.SchemeIs(extensions::kExtensionScheme)) {
+    static bool logged_once = false;
+    if (!logged_once) {
+      logged_once = true;
+      LOG(INFO) << "[issue-792-exp6] handled-url url=" << url;
+    }
+    return true;
+  }
+
+  return ShellContentBrowserClient::IsHandledURL(url);
+}
+
+void TsBrowserClient::SiteInstanceGotProcessAndSite(
+    SiteInstance* site_instance) {
+  BrowserContext* browser_context = site_instance->GetBrowserContext();
+  if (browser_context->IsOffTheRecord()) {
+    return;
+  }
+
+  auto* registry = extensions::ExtensionRegistry::Get(browser_context);
+  if (!registry) {
+    return;
+  }
+
+  const extensions::Extension* extension =
+      registry->enabled_extensions().GetExtensionOrAppByURL(
+          site_instance->GetSiteURL());
+  if (!extension) {
+    if (site_instance->GetSiteURL().SchemeIs(extensions::kExtensionScheme)) {
+      LOG(INFO) << "[issue-792-exp6] process-map-miss site_url="
+                << site_instance->GetSiteURL();
+    }
+    return;
+  }
+
+  if (site_instance->GetSecurityPrincipal().IsSandboxed()) {
+    return;
+  }
+
+  const int process_id = site_instance->GetProcess()->GetDeprecatedID();
+  extensions::ProcessMap::Get(browser_context)
+      ->Insert(extension->id(), process_id);
+  LOG(INFO) << "[issue-792-exp6] process-map-insert extension_id="
+            << extension->id() << " process_id=" << process_id
+            << " site_url=" << site_instance->GetSiteURL();
+}
