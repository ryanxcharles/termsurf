 void RendererStartupHelper::ActivateExtensionInProcess(
     const Extension& extension,
     content::RenderProcessHost* process) {
+  const bool is_pdf_extension =
+      extension.id() == extension_misc::kPdfExtensionId;
   // The extension should have been loaded already. Dump without crashing to
   // debug crbug.com/40434302.
   if (!extension_process_map_.contains(extension.id())) {
+    if (is_pdf_extension) {
+      LOG(INFO) << "[issue-792-exp9] renderer-startup-activate extension_id="
+                << extension.id()
+                << " process_id=" << process->GetDeprecatedID()
+                << " remote=0 pending=0 missing_process_map=1";
+    }
     DUMP_WILL_BE_NOTREACHED()
         << "Extension " << extension.id() << " activated before loading";
     return;
   }
 
   if (!util::IsExtensionVisibleToContext(extension,
-                                         process->GetBrowserContext()))
+                                         process->GetBrowserContext())) {
     return;
+  }
 
   // Populate NetworkContext's OriginAccessList for this extension.
   //
@@ -474,8 +486,20 @@ void RendererStartupHelper::ActivateExtensionInProcess(
   if (remote != process_mojo_map_.end()) {
     DCHECK(extension_process_map_[extension.id()].contains(process));
     remote->second->ActivateExtension(extension.id());
+    if (is_pdf_extension) {
+      LOG(INFO) << "[issue-792-exp9] renderer-startup-activate extension_id="
+                << extension.id()
+                << " process_id=" << process->GetDeprecatedID()
+                << " remote=1 pending=0";
+    }
   } else {
     pending_active_extensions_[process].insert(extension.id());
+    if (is_pdf_extension) {
+      LOG(INFO) << "[issue-792-exp9] renderer-startup-activate extension_id="
+                << extension.id()
+                << " process_id=" << process->GetDeprecatedID()
+                << " remote=0 pending=1";
+    }
   }
 }
 
