diff --git a/content/libtermsurf_chromium/ts_http_auth_delegate.cc b/content/libtermsurf_chromium/ts_http_auth_delegate.cc
new file mode 100644
index 0000000000..aadb1ed631
--- /dev/null
+++ b/content/libtermsurf_chromium/ts_http_auth_delegate.cc
@@ -0,0 +1,131 @@
+// Copyright 2025 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/libtermsurf_chromium/ts_http_auth_delegate.h"
+
+#include <map>
+#include <memory>
+#include <optional>
+#include <utility>
+
+#include "base/strings/string_util.h"
+#include "content/public/browser/web_contents.h"
+#include "net/base/auth.h"
+#include "url/gurl.h"
+
+namespace content {
+namespace {
+
+using PendingKey = std::pair<WebContents*, uint64_t>;
+
+std::map<PendingKey, TsHttpAuthDelegate*>& PendingAuthRequests() {
+  static auto* pending = new std::map<PendingKey, TsHttpAuthDelegate*>();
+  return *pending;
+}
+
+uint64_t NextRequestId() {
+  static uint64_t next_request_id = 1;
+  return next_request_id++;
+}
+
+bool IsSupportedChallenge(const net::AuthChallengeInfo& auth_info,
+                          WebContents* web_contents) {
+  return web_contents && !auth_info.is_proxy &&
+         base::EqualsCaseInsensitiveASCII(auth_info.scheme, "basic");
+}
+
+}  // namespace
+
+TsHttpAuthDelegate::TsHttpAuthDelegate(
+    WebContents* web_contents,
+    const net::AuthChallengeInfo& auth_info,
+    bool is_primary_main_frame_navigation,
+    bool is_navigation,
+    const GURL& url,
+    bool first_auth_attempt,
+    LoginDelegate::LoginAuthRequiredCallback auth_required_callback)
+    : WebContentsObserver(web_contents),
+      request_id_(NextRequestId()),
+      web_contents_(web_contents),
+      auth_required_callback_(std::move(auth_required_callback)) {
+  PendingAuthRequests()[{web_contents_, request_id_}] = this;
+  TsNotifyHttpAuthRequest(
+      static_cast<void*>(web_contents_), request_id_, url.spec().c_str(),
+      auth_info.scheme.c_str(), auth_info.challenger.Serialize().c_str(),
+      auth_info.realm.c_str(), auth_info.is_proxy, first_auth_attempt,
+      is_primary_main_frame_navigation, is_navigation);
+}
+
+TsHttpAuthDelegate::~TsHttpAuthDelegate() {
+  // Chromium's LoginDelegate contract says destruction means the request was
+  // canceled by //content; do not run the callback from this path.
+  Unregister();
+}
+
+std::unique_ptr<LoginDelegate> TsHttpAuthDelegate::MaybeCreate(
+    const net::AuthChallengeInfo& auth_info,
+    WebContents* web_contents,
+    bool is_primary_main_frame_navigation,
+    bool is_navigation,
+    const GURL& url,
+    bool first_auth_attempt,
+    LoginDelegate::LoginAuthRequiredCallback auth_required_callback) {
+  if (!IsSupportedChallenge(auth_info, web_contents)) {
+    return nullptr;
+  }
+
+  return std::make_unique<TsHttpAuthDelegate>(
+      web_contents, auth_info, is_primary_main_frame_navigation, is_navigation,
+      url, first_auth_attempt, std::move(auth_required_callback));
+}
+
+bool TsHttpAuthDelegate::Reply(WebContents* web_contents,
+                               uint64_t request_id,
+                               bool accepted,
+                               const std::u16string& username,
+                               const std::u16string& password) {
+  auto& pending = PendingAuthRequests();
+  const auto key = std::make_pair(web_contents, request_id);
+  auto it = pending.find(key);
+  if (it == pending.end()) {
+    return false;
+  }
+  return it->second->Reply(accepted, username, password);
+}
+
+void TsHttpAuthDelegate::WebContentsDestroyed() {
+  // The WebContents lifetime ended before a protocol reply. Invalidate only;
+  // do not run the auth callback from destruction.
+  Unregister();
+  web_contents_ = nullptr;
+  Observe(nullptr);
+}
+
+bool TsHttpAuthDelegate::Reply(bool accepted,
+                               const std::u16string& username,
+                               const std::u16string& password) {
+  if (!auth_required_callback_) {
+    return false;
+  }
+
+  auto callback = std::move(auth_required_callback_);
+  Unregister();
+
+  if (!accepted) {
+    std::move(callback).Run(std::nullopt);
+    return true;
+  }
+
+  std::move(callback).Run(net::AuthCredentials(username, password));
+  return true;
+}
+
+void TsHttpAuthDelegate::Unregister() {
+  if (!web_contents_) {
+    return;
+  }
+  PendingAuthRequests().erase({web_contents_, request_id_});
+}
+
+}  // namespace content
