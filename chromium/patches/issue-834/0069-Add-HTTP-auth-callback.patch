+#ifndef CONTENT_LIBTERMSURF_CONTENT_TS_HTTP_AUTH_DELEGATE_H_
+#define CONTENT_LIBTERMSURF_CONTENT_TS_HTTP_AUTH_DELEGATE_H_
+
+#include <memory>
+#include <string>
+
+#include "base/memory/raw_ptr.h"
+#include "content/public/browser/content_browser_client.h"
+#include "content/public/browser/login_delegate.h"
+#include "content/public/browser/web_contents_observer.h"
+
+namespace content {
+
+void TsNotifyHttpAuthRequest(void* wc_handle,
+                             uint64_t request_id,
+                             const char* url,
+                             const char* auth_scheme,
+                             const char* challenger,
+                             const char* realm,
+                             bool is_proxy,
+                             bool first_auth_attempt,
+                             bool is_primary_main_frame_navigation,
+                             bool is_navigation);
+
+class TsHttpAuthDelegate : public LoginDelegate, public WebContentsObserver {
+ public:
+  TsHttpAuthDelegate(
+      WebContents* web_contents,
+      const net::AuthChallengeInfo& auth_info,
+      bool is_primary_main_frame_navigation,
+      bool is_navigation,
+      const GURL& url,
+      bool first_auth_attempt,
+      LoginDelegate::LoginAuthRequiredCallback auth_required_callback);
+  ~TsHttpAuthDelegate() override;
+
+  TsHttpAuthDelegate(const TsHttpAuthDelegate&) = delete;
+  TsHttpAuthDelegate& operator=(const TsHttpAuthDelegate&) = delete;
+
+  static std::unique_ptr<LoginDelegate> MaybeCreate(
+      const net::AuthChallengeInfo& auth_info,
+      WebContents* web_contents,
+      bool is_primary_main_frame_navigation,
+      bool is_navigation,
+      const GURL& url,
+      bool first_auth_attempt,
+      LoginDelegate::LoginAuthRequiredCallback auth_required_callback);
+
+  static bool Reply(WebContents* web_contents,
+                    uint64_t request_id,
+                    bool accepted,
+                    const std::u16string& username,
+                    const std::u16string& password);
+
+  uint64_t request_id() const { return request_id_; }
+
+ private:
+  // WebContentsObserver:
+  void WebContentsDestroyed() override;
+
+  bool Reply(bool accepted,
+             const std::u16string& username,
+             const std::u16string& password);
+  void Unregister();
+
+  const uint64_t request_id_;
+  raw_ptr<WebContents> web_contents_;
+  LoginDelegate::LoginAuthRequiredCallback auth_required_callback_;
+};
+
+}  // namespace content
+
+#endif  // CONTENT_LIBTERMSURF_CONTENT_TS_HTTP_AUTH_DELEGATE_H_
