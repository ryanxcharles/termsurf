+bool ts_reply_http_auth(ts_web_contents_t wc,
+                        uint64_t request_id,
+                        bool accepted,
+                        const char* username,
+                        const char* password) {
+  if (!wc) {
+    return false;
+  }
+  auto* web_contents = static_cast<content::WebContents*>(wc);
+  return content::TsHttpAuthDelegate::Reply(
+      web_contents, request_id, accepted,
+      base::UTF8ToUTF16(username ? username : ""),
+      base::UTF8ToUTF16(password ? password : ""));
+}
