+#ifndef CONTENT_LIBTERMSURF_CONTENT_TS_MIME_HANDLER_BINDERS_H_
+#define CONTENT_LIBTERMSURF_CONTENT_TS_MIME_HANDLER_BINDERS_H_
+
+#include "extensions/common/api/mime_handler.mojom-forward.h"
+#include "mojo/public/cpp/bindings/pending_receiver.h"
+
+namespace content {
+
+class RenderFrameHost;
+
+void BindTsMimeHandlerService(
+    RenderFrameHost* render_frame_host,
+    mojo::PendingReceiver<extensions::mime_handler::MimeHandlerService>
+        receiver);
+
+void BindTsBeforeUnloadControl(
+    RenderFrameHost* render_frame_host,
+    mojo::PendingReceiver<extensions::mime_handler::BeforeUnloadControl>
+        receiver);
+
+}  // namespace content
+
+#endif  // CONTENT_LIBTERMSURF_CONTENT_TS_MIME_HANDLER_BINDERS_H_
