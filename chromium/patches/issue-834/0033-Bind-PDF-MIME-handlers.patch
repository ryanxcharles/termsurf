diff --git a/content/libtermsurf_chromium/ts_mime_handler_binders.cc b/content/libtermsurf_chromium/ts_mime_handler_binders.cc
new file mode 100644
index 0000000000..d4a03d5db9
--- /dev/null
+++ b/content/libtermsurf_chromium/ts_mime_handler_binders.cc
@@ -0,0 +1,130 @@
+// Copyright 2025 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/libtermsurf_chromium/ts_mime_handler_binders.h"
+
+#include <memory>
+#include <string>
+#include <utility>
+
+#include "base/logging.h"
+#include "content/public/browser/render_frame_host.h"
+#include "content/public/browser/site_instance.h"
+#include "extensions/common/api/mime_handler.mojom.h"
+#include "extensions/common/constants.h"
+#include "mojo/public/cpp/bindings/self_owned_receiver.h"
+#include "url/gurl.h"
+
+namespace content {
+namespace {
+
+bool IsPdfExtensionFrame(RenderFrameHost* render_frame_host) {
+  const GURL& url = render_frame_host->GetLastCommittedURL();
+  return url.SchemeIs(extensions::kExtensionScheme) &&
+         url.host() == extension_misc::kPdfExtensionId;
+}
+
+std::string FrameUrl(RenderFrameHost* render_frame_host) {
+  return render_frame_host->GetLastCommittedURL().spec();
+}
+
+std::string SiteUrl(RenderFrameHost* render_frame_host) {
+  return render_frame_host->GetSiteInstance()->GetSiteURL().spec();
+}
+
+class TsMimeHandlerService
+    : public extensions::mime_handler::MimeHandlerService {
+ public:
+  explicit TsMimeHandlerService(std::string frame_url)
+      : frame_url_(std::move(frame_url)) {}
+
+  TsMimeHandlerService(const TsMimeHandlerService&) = delete;
+  TsMimeHandlerService& operator=(const TsMimeHandlerService&) = delete;
+
+  ~TsMimeHandlerService() override = default;
+
+  void GetStreamInfo(GetStreamInfoCallback callback) override {
+    LOG(INFO) << "[issue-792-exp12] mime-handler-get-stream-info frame_url="
+              << frame_url_ << " stream_info=null";
+    std::move(callback).Run(extensions::mime_handler::StreamInfoPtr());
+  }
+
+  void SetPdfPluginAttributes(
+      extensions::mime_handler::PdfPluginAttributesPtr pdf_plugin_attributes)
+      override {
+    LOG(INFO)
+        << "[issue-792-exp12] mime-handler-set-pdf-plugin-attributes frame_url="
+        << frame_url_;
+  }
+
+ private:
+  std::string frame_url_;
+};
+
+class TsBeforeUnloadControl
+    : public extensions::mime_handler::BeforeUnloadControl {
+ public:
+  explicit TsBeforeUnloadControl(std::string frame_url)
+      : frame_url_(std::move(frame_url)) {}
+
+  TsBeforeUnloadControl(const TsBeforeUnloadControl&) = delete;
+  TsBeforeUnloadControl& operator=(const TsBeforeUnloadControl&) = delete;
+
+  ~TsBeforeUnloadControl() override = default;
+
+  void SetShowBeforeUnloadDialog(
+      bool show_dialog,
+      SetShowBeforeUnloadDialogCallback callback) override {
+    LOG(INFO) << "[issue-792-exp12] before-unload-set-show frame_url="
+              << frame_url_ << " show=" << show_dialog;
+    std::move(callback).Run();
+  }
+
+ private:
+  std::string frame_url_;
+};
+
+}  // namespace
+
+void BindTsMimeHandlerService(
+    RenderFrameHost* render_frame_host,
+    mojo::PendingReceiver<extensions::mime_handler::MimeHandlerService>
+        receiver) {
+  const std::string frame_url = FrameUrl(render_frame_host);
+  const std::string site_url = SiteUrl(render_frame_host);
+
+  if (!IsPdfExtensionFrame(render_frame_host)) {
+    LOG(INFO)
+        << "[issue-792-exp12] mime-handler-service-binder-reject frame_url="
+        << frame_url << " site_url=" << site_url;
+    return;
+  }
+
+  LOG(INFO) << "[issue-792-exp12] mime-handler-service-binder frame_url="
+            << frame_url << " site_url=" << site_url;
+  mojo::MakeSelfOwnedReceiver(std::make_unique<TsMimeHandlerService>(frame_url),
+                              std::move(receiver));
+}
+
+void BindTsBeforeUnloadControl(
+    RenderFrameHost* render_frame_host,
+    mojo::PendingReceiver<extensions::mime_handler::BeforeUnloadControl>
+        receiver) {
+  const std::string frame_url = FrameUrl(render_frame_host);
+  const std::string site_url = SiteUrl(render_frame_host);
+
+  if (!IsPdfExtensionFrame(render_frame_host)) {
+    LOG(INFO)
+        << "[issue-792-exp12] before-unload-control-binder-reject frame_url="
+        << frame_url << " site_url=" << site_url;
+    return;
+  }
+
+  LOG(INFO) << "[issue-792-exp12] before-unload-control-binder frame_url="
+            << frame_url << " site_url=" << site_url;
+  mojo::MakeSelfOwnedReceiver(
+      std::make_unique<TsBeforeUnloadControl>(frame_url), std::move(receiver));
+}
+
+}  // namespace content
diff --git a/content/libtermsurf_chromium/ts_mime_handler_binders.h b/content/libtermsurf_chromium/ts_mime_handler_binders.h
