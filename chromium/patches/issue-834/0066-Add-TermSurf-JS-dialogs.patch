diff --git a/content/libtermsurf_chromium/ts_javascript_dialog_manager.cc b/content/libtermsurf_chromium/ts_javascript_dialog_manager.cc
new file mode 100644
index 0000000000000..d006de0adad2f
--- /dev/null
+++ b/content/libtermsurf_chromium/ts_javascript_dialog_manager.cc
@@ -0,0 +1,188 @@
+// Copyright 2026 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/libtermsurf_chromium/ts_javascript_dialog_manager.h"
+
+#include <map>
+#include <utility>
+
+#include "base/check.h"
+#include "base/logging.h"
+#include "base/strings/utf_string_conversions.h"
+#include "content/public/browser/render_frame_host.h"
+#include "content/public/browser/web_contents.h"
+#include "url/gurl.h"
+
+namespace content {
+namespace {
+
+struct PendingDialog {
+  PendingDialog(uint64_t request_id,
+                JavaScriptDialogManager::DialogClosedCallback callback)
+      : request_id(request_id), callback(std::move(callback)) {}
+
+  PendingDialog(PendingDialog&&) = default;
+  PendingDialog& operator=(PendingDialog&&) = default;
+
+  uint64_t request_id;
+  JavaScriptDialogManager::DialogClosedCallback callback;
+};
+
+std::map<WebContents*, PendingDialog>& PendingDialogs() {
+  static auto* pending = new std::map<WebContents*, PendingDialog>();
+  return *pending;
+}
+
+const char* DialogTypeToString(JavaScriptDialogType type) {
+  switch (type) {
+    case JAVASCRIPT_DIALOG_TYPE_ALERT:
+      return "alert";
+    case JAVASCRIPT_DIALOG_TYPE_CONFIRM:
+      return "confirm";
+    case JAVASCRIPT_DIALOG_TYPE_PROMPT:
+      return "prompt";
+  }
+}
+
+std::string OriginUrlFor(RenderFrameHost* render_frame_host) {
+  if (!render_frame_host) {
+    return std::string();
+  }
+  return render_frame_host->GetLastCommittedOrigin().GetURL().spec();
+}
+
+void RequestDialog(WebContents* web_contents,
+                   RenderFrameHost* render_frame_host,
+                   uint64_t request_id,
+                   const char* dialog_type,
+                   const std::u16string& message_text,
+                   const std::u16string& default_prompt_text,
+                   JavaScriptDialogManager::DialogClosedCallback callback) {
+  auto& pending = PendingDialogs();
+  auto [it, inserted] = pending.emplace(
+      web_contents, PendingDialog(request_id, std::move(callback)));
+  CHECK(inserted);
+
+  std::string origin_url = OriginUrlFor(render_frame_host);
+  std::string message = base::UTF16ToUTF8(message_text);
+  std::string default_prompt = base::UTF16ToUTF8(default_prompt_text);
+
+  LOG(INFO) << "[termsurf-js-dialog] request wc=" << web_contents
+            << " request_id=" << request_id << " type=" << dialog_type
+            << " origin=" << origin_url;
+
+  TsNotifyJavaScriptDialogRequest(static_cast<void*>(web_contents), request_id,
+                                  dialog_type, origin_url.c_str(),
+                                  message.c_str(), default_prompt.c_str());
+}
+
+}  // namespace
+
+TsJavaScriptDialogManager::TsJavaScriptDialogManager() = default;
+TsJavaScriptDialogManager::~TsJavaScriptDialogManager() = default;
+
+void TsJavaScriptDialogManager::RunJavaScriptDialog(
+    WebContents* web_contents,
+    RenderFrameHost* render_frame_host,
+    JavaScriptDialogType dialog_type,
+    const std::u16string& message_text,
+    const std::u16string& default_prompt_text,
+    DialogClosedCallback callback,
+    bool* did_suppress_message) {
+  *did_suppress_message = false;
+
+  auto& pending = PendingDialogs();
+  if (pending.contains(web_contents)) {
+    *did_suppress_message = true;
+    return;
+  }
+
+  RequestDialog(web_contents, render_frame_host, next_request_id_++,
+                DialogTypeToString(dialog_type), message_text,
+                default_prompt_text, std::move(callback));
+}
+
+void TsJavaScriptDialogManager::RunBeforeUnloadDialog(
+    WebContents* web_contents,
+    RenderFrameHost* render_frame_host,
+    bool is_reload,
+    DialogClosedCallback callback) {
+  auto& pending = PendingDialogs();
+  if (pending.contains(web_contents)) {
+    std::move(callback).Run(true, std::u16string());
+    return;
+  }
+
+  RequestDialog(web_contents, render_frame_host, next_request_id_++,
+                "beforeunload", u"Is it OK to leave this page?",
+                std::u16string(), std::move(callback));
+}
+
+bool TsJavaScriptDialogManager::HandleJavaScriptDialog(
+    WebContents* web_contents,
+    bool accept,
+    const std::u16string* prompt_override) {
+  auto& pending = PendingDialogs();
+  auto it = pending.find(web_contents);
+  if (it == pending.end()) {
+    return false;
+  }
+
+  std::u16string prompt_text;
+  if (prompt_override) {
+    prompt_text = *prompt_override;
+  }
+
+  auto callback = std::move(it->second.callback);
+  uint64_t request_id = it->second.request_id;
+  pending.erase(it);
+  LOG(INFO) << "[termsurf-js-dialog] handle wc=" << web_contents
+            << " request_id=" << request_id << " accepted=" << accept;
+  std::move(callback).Run(accept, prompt_text);
+  return true;
+}
+
+void TsJavaScriptDialogManager::CancelDialogs(WebContents* web_contents,
+                                              bool reset_state) {
+  Reply(web_contents, 0, false, std::u16string());
+}
+
+bool TsJavaScriptDialogManager::Reply(WebContents* web_contents,
+                                      uint64_t request_id,
+                                      bool accepted,
+                                      const std::u16string& prompt_text) {
+  auto& pending = PendingDialogs();
+  auto it = pending.find(web_contents);
+  if (it == pending.end()) {
+    LOG(WARNING) << "[termsurf-js-dialog] reply-missing wc=" << web_contents
+                 << " request_id=" << request_id;
+    return false;
+  }
+
+  if (request_id != 0 && it->second.request_id != request_id) {
+    LOG(WARNING) << "[termsurf-js-dialog] reply-mismatch wc=" << web_contents
+                 << " expected=" << it->second.request_id
+                 << " got=" << request_id;
+    return false;
+  }
+
+  auto callback = std::move(it->second.callback);
+  uint64_t stored_request_id = it->second.request_id;
+  pending.erase(it);
+  LOG(INFO) << "[termsurf-js-dialog] reply wc=" << web_contents
+            << " request_id=" << stored_request_id
+            << " accepted=" << accepted;
+  std::move(callback).Run(accepted, prompt_text);
+  return true;
+}
+
+TsShellPlatformDelegate::TsShellPlatformDelegate() = default;
+TsShellPlatformDelegate::~TsShellPlatformDelegate() = default;
+
+std::unique_ptr<JavaScriptDialogManager>
+TsShellPlatformDelegate::CreateJavaScriptDialogManager(Shell* shell) {
+  return std::make_unique<TsJavaScriptDialogManager>();
+}
+
+}  // namespace content
