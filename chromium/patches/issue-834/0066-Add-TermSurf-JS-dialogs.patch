+class TsJavaScriptDialogManager : public JavaScriptDialogManager {
+ public:
+  TsJavaScriptDialogManager();
+  ~TsJavaScriptDialogManager() override;
+
+  TsJavaScriptDialogManager(const TsJavaScriptDialogManager&) = delete;
+  TsJavaScriptDialogManager& operator=(const TsJavaScriptDialogManager&) =
+      delete;
+
+  void RunJavaScriptDialog(WebContents* web_contents,
+                           RenderFrameHost* render_frame_host,
+                           JavaScriptDialogType dialog_type,
+                           const std::u16string& message_text,
+                           const std::u16string& default_prompt_text,
+                           DialogClosedCallback callback,
+                           bool* did_suppress_message) override;
+  void RunBeforeUnloadDialog(WebContents* web_contents,
+                             RenderFrameHost* render_frame_host,
+                             bool is_reload,
+                             DialogClosedCallback callback) override;
+  bool HandleJavaScriptDialog(WebContents* web_contents,
+                              bool accept,
+                              const std::u16string* prompt_override) override;
+  void CancelDialogs(WebContents* web_contents, bool reset_state) override;
+
+  static bool Reply(WebContents* web_contents,
+                    uint64_t request_id,
+                    bool accepted,
+                    const std::u16string& prompt_text);
+
+ private:
+  uint64_t next_request_id_ = 1;
+};
+
+class TsShellPlatformDelegate : public ShellPlatformDelegate {
+ public:
+  TsShellPlatformDelegate();
+  ~TsShellPlatformDelegate() override;
+
+  std::unique_ptr<JavaScriptDialogManager> CreateJavaScriptDialogManager(
+      Shell* shell) override;
+};
+
+}  // namespace content
