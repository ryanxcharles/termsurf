@@ -0,0 +1,71 @@
+// Copyright 2026 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/libtermsurf_chromium/extensions/ts_component_extension_resource_manager.h"
+
+#include "base/logging.h"
+#include "chrome/grit/pdf_resources_map.h"
+#include "extensions/common/constants.h"
+
+namespace content {
+namespace {
+
+base::FilePath NormalizeAsciiPath(const char* path) {
+  return base::FilePath().AppendASCII(path).NormalizePathSeparators();
+}
+
+}  // namespace
+
+TsComponentExtensionResourceManager::TsComponentExtensionResourceManager() {
+  for (const auto& resource : kPdfResources) {
+    path_to_resource_id_[NormalizeAsciiPath(resource.path)] = resource.id;
+  }
+
+  LOG(INFO) << "[issue-792-exp3] pdf-resource-manager-ready count="
+            << path_to_resource_id_.size() << " manifest_parsed=0";
+}
+
+TsComponentExtensionResourceManager::~TsComponentExtensionResourceManager() =
+    default;
+
+bool TsComponentExtensionResourceManager::IsComponentExtensionResource(
+    const base::FilePath& extension_path,
+    const base::FilePath& resource_path,
+    int* resource_id) const {
+  base::FilePath normalized_resource_path =
+      resource_path.NormalizePathSeparators();
+  auto entry = path_to_resource_id_.find(normalized_resource_path);
+  if (entry == path_to_resource_id_.end()) {
+    base::FilePath combined_path =
+        extension_path.Append(resource_path).NormalizePathSeparators();
+    entry = path_to_resource_id_.find(combined_path);
+  }
+
+  const bool found = entry != path_to_resource_id_.end();
+  if (found) {
+    *resource_id = entry->second;
+  }
+  LOG(INFO) << "[issue-792-exp3] pdf-component-resource path="
+            << resource_path.AsUTF8Unsafe() << " resource_id="
+            << (found ? entry->second : 0) << " found=" << found;
+  return found;
+}
+
+const ui::TemplateReplacements*
+TsComponentExtensionResourceManager::GetTemplateReplacementsForExtension(
+    const extensions::ExtensionId& extension_id) const {
+  if (extension_id == extension_misc::kPdfExtensionId) {
+    return &pdf_template_replacements_;
+  }
+  return nullptr;
+}
+
+bool TsComponentExtensionResourceManager::SelfTestPdfResource() const {
+  int resource_id = 0;
+  return IsComponentExtensionResource(
+      base::FilePath(FILE_PATH_LITERAL("pdf")),
+      base::FilePath(FILE_PATH_LITERAL("index.html")), &resource_id);
+}
+
+}  // namespace content
