diff --git a/content/libtermsurf_chromium/extensions/ts_pdf_component_extension.cc b/content/libtermsurf_chromium/extensions/ts_pdf_component_extension.cc
new file mode 100644
index 0000000000..e53142be57
--- /dev/null
+++ b/content/libtermsurf_chromium/extensions/ts_pdf_component_extension.cc
@@ -0,0 +1,186 @@
+// Copyright 2026 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/libtermsurf_chromium/extensions/ts_pdf_component_extension.h"
+
+#include <iterator>
+#include <optional>
+#include <string>
+#include <utility>
+
+#include "base/json/json_reader.h"
+#include "base/logging.h"
+#include "base/strings/string_util.h"
+#include "base/strings/utf_string_conversions.h"
+#include "base/values.h"
+#include "chrome/grit/pdf_resources_map.h"
+#include "content/public/browser/browser_context.h"
+#include "extensions/browser/extension_registry.h"
+#include "extensions/browser/renderer_startup_helper.h"
+#include "extensions/common/constants.h"
+#include "extensions/common/extension.h"
+#include "extensions/common/manifest_constants.h"
+
+namespace content {
+namespace {
+
+constexpr char kPdfExtensionNameTag[] = "<NAME>";
+constexpr char kPdfExtensionName[] = "Chromium PDF Viewer";
+constexpr char kPdfManifestFallback[] = R"({
+  "manifest_version": 2,
+  "key": "MIGfMA0GCSqGSIb3DQEBAQUAA4GNADCBiQKBgQDN6hM0rsDYGbzQPQfOygqlRtQgKUXMfnSjhIBL7LnReAVBEd7ZmKtyN2qmSasMl4HZpMhVe2rPWVVwBDl6iyNE/Kok6E6v6V3vCLGsOpQAuuNVye/3QxzIldzG/jQAdWZiyXReRVapOhZtLjGfywCvlWq7Sl/e3sbc0vWybSDI2QIDAQAB",
+  "name": "<NAME>",
+  "version": "1",
+  "description": "",
+  "offline_enabled": true,
+  "incognito": "split",
+  "permissions": [
+    "chrome://resources/",
+    "chrome://webui-test/",
+    "contentSettings",
+    "metricsPrivate",
+    "pdfViewerPrivate",
+    "resourcesPrivate",
+    "tabs",
+    {"fileSystem": ["write"]}
+  ],
+  "mime_types": [
+    "application/pdf"
+  ],
+  "content_security_policy": "script-src 'self' blob: filesystem: chrome://resources chrome://webui-test; object-src * blob: externalfile: file: filesystem: data:",
+  "mime_types_handler": "index.html",
+  "web_accessible_resources": [
+    "pdf_embedder.css"
+  ]
+})";
+
+std::optional<base::DictValue> LoadPdfManifest(
+    std::vector<std::string>* stripped_manifest_keys) {
+  std::string manifest_contents = kPdfManifestFallback;
+  LOG(INFO) << "[issue-792-exp3] pdf-manifest-source source=static-snapshot";
+
+  if (manifest_contents.find(kPdfExtensionNameTag) == std::string::npos) {
+    LOG(ERROR) << "[issue-792-exp3] pdf-manifest-error reason=missing-name-tag";
+    return std::nullopt;
+  }
+  base::ReplaceFirstSubstringAfterOffset(&manifest_contents, 0,
+                                         kPdfExtensionNameTag,
+                                         kPdfExtensionName);
+
+  std::optional<base::DictValue> manifest = base::JSONReader::ReadDict(
+      manifest_contents, base::JSON_PARSE_CHROMIUM_EXTENSIONS);
+  if (!manifest) {
+    LOG(ERROR) << "[issue-792-exp3] pdf-manifest-error reason=parse-failed";
+    return std::nullopt;
+  }
+
+  if (manifest->Remove("permissions")) {
+    stripped_manifest_keys->push_back("permissions");
+    LOG(INFO) << "[issue-792-exp3] pdf-component-extension-stripped-value"
+              << " key=permissions"
+              << " values=chrome://resources/,chrome://webui-test/,"
+                 "contentSettings,metricsPrivate,pdfViewerPrivate,"
+                 "resourcesPrivate,tabs,fileSystem.write";
+  }
+  if (manifest->Remove("web_accessible_resources")) {
+    stripped_manifest_keys->push_back("web_accessible_resources");
+    LOG(INFO) << "[issue-792-exp3] pdf-component-extension-stripped-value"
+              << " key=web_accessible_resources values=pdf_embedder.css";
+  }
+  LOG(INFO) << "[issue-792-exp3] pdf-resource-manager-ready count="
+            << std::size(kPdfResources) << " manifest_parsed=1";
+
+  return manifest;
+}
+
+}  // namespace
+
+scoped_refptr<const extensions::Extension> CreateTsPdfComponentExtension(
+    const base::FilePath& extension_root,
+    std::vector<std::string>* stripped_manifest_keys,
+    std::u16string* error) {
+  std::optional<base::DictValue> manifest =
+      LoadPdfManifest(stripped_manifest_keys);
+  if (!manifest) {
+    *error = u"Failed to load PDF component extension manifest.";
+    return nullptr;
+  }
+
+  if (!extension_root.IsAbsolute()) {
+    *error = u"PDF component extension root is not absolute.";
+    return nullptr;
+  }
+
+  scoped_refptr<const extensions::Extension> extension =
+      extensions::Extension::Create(
+          extension_root, extensions::mojom::ManifestLocation::kComponent,
+          *manifest, extensions::Extension::REQUIRE_KEY, error);
+  if (!extension) {
+    LOG(ERROR) << "[issue-792-exp3] pdf-component-extension-create-failed error="
+               << base::UTF16ToUTF8(*error);
+    return nullptr;
+  }
+
+  LOG(INFO) << "[issue-792-exp3] pdf-component-extension-created id="
+            << extension->id() << " name=" << extension->name()
+            << " version=" << extension->version().GetString()
+            << " location=" << static_cast<int>(extension->location());
+  return extension;
+}
+
+bool RegisterTsPdfComponentExtension(BrowserContext* browser_context) {
+  if (browser_context->IsOffTheRecord()) {
+    return false;
+  }
+
+  auto* registry = extensions::ExtensionRegistry::Get(browser_context);
+  if (!registry) {
+    LOG(ERROR) << "[issue-792-exp3] pdf-component-extension-register-failed"
+               << " reason=no-registry context=" << browser_context;
+    return false;
+  }
+
+  if (registry->enabled_extensions().Contains(extension_misc::kPdfExtensionId)) {
+    LOG(INFO) << "[issue-792-exp3] pdf-component-extension-registered context="
+              << browser_context << " enabled=1";
+    return true;
+  }
+
+  std::vector<std::string> stripped_manifest_keys;
+  std::u16string error;
+  base::FilePath extension_root =
+      browser_context->GetPath().AppendASCII("termsurf_pdf_component");
+  scoped_refptr<const extensions::Extension> extension =
+      CreateTsPdfComponentExtension(extension_root, &stripped_manifest_keys,
+                                    &error);
+  if (!extension) {
+    LOG(ERROR) << "[issue-792-exp3] pdf-component-extension-register-failed"
+               << " reason=create-failed context=" << browser_context
+               << " error=" << base::UTF16ToUTF8(error);
+    return false;
+  }
+
+  CHECK_EQ(extension_misc::kPdfExtensionId, extension->id());
+  const bool inserted = registry->AddEnabled(extension);
+  if (inserted) {
+    auto* renderer_startup_helper =
+        extensions::RendererStartupHelperFactory::GetForBrowserContext(
+            browser_context);
+    if (renderer_startup_helper) {
+      renderer_startup_helper->OnExtensionLoaded(*extension);
+    }
+  }
+
+  LOG(INFO) << "[issue-792-exp3] pdf-component-extension-stripped-keys count="
+            << stripped_manifest_keys.size() << " keys="
+            << base::JoinString(stripped_manifest_keys, ",");
+  LOG(INFO) << "[issue-792-exp3] pdf-component-extension-registered context="
+            << browser_context << " enabled="
+            << registry->enabled_extensions().Contains(
+                   extension_misc::kPdfExtensionId)
+            << " inserted=" << inserted;
+  return inserted;
+}
+
+}  // namespace content
