+std::optional<std::string> GetTsPdfTraceFileFromEnv(
+    const std::string& enabled_var,
+    const std::string& path_var) {
+  std::unique_ptr<base::Environment> env = base::Environment::Create();
+  std::optional<std::string> enabled = env->GetVar(enabled_var);
+  if (!enabled || *enabled != "1") {
+    return std::nullopt;
+  }
+
+  std::optional<std::string> path = env->GetVar(path_var);
+  if (!path || path->empty()) {
+    return std::nullopt;
+  }
+
+  return path;
+}
+
+bool IsTsPdfComponentExtension(const extensions::Extension* extension) {
+  return extension && extension->id() == extension_misc::kPdfExtensionId &&
+         extensions::Manifest::IsComponentLocation(extension->location());
+}
+
+bool IsTsPdfComponentExtensionUrl(const GURL& url) {
+  return url.SchemeIs(extensions::kExtensionScheme) &&
+         url.host() == extension_misc::kPdfExtensionId;
+}
+
+const extensions::Extension* GetEnabledPdfExtension(
+    content::BrowserContext* browser_context) {
+  auto* registry = extensions::ExtensionRegistry::Get(browser_context);
+  if (!registry) {
+    return nullptr;
+  }
+
+  const extensions::Extension* extension =
+      registry->enabled_extensions().GetByID(extension_misc::kPdfExtensionId);
+  return IsTsPdfComponentExtension(extension) ? extension : nullptr;
+}
+
+const extensions::Extension* GetExtensionForInitiatorOrigin(
+    content::BrowserContext* browser_context,
+    const std::optional<url::Origin>& request_initiator_origin) {
+  if (!request_initiator_origin.has_value()) {
+    return nullptr;
+  }
+
+  auto* registry = extensions::ExtensionRegistry::Get(browser_context);
+  if (!registry) {
+    return nullptr;
+  }
+
+  return registry->enabled_extensions().GetExtensionOrAppByURL(
+      request_initiator_origin->GetURL());
+}
