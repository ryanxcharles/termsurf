diff --git a/content/libtermsurf_chromium/ts_pdf_renderer_support.cc b/content/libtermsurf_chromium/ts_pdf_renderer_support.cc
new file mode 100644
index 0000000000000..4c76fd06e8ed1
--- /dev/null
+++ b/content/libtermsurf_chromium/ts_pdf_renderer_support.cc
@@ -0,0 +1,174 @@
+// Copyright 2026 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/libtermsurf_chromium/ts_pdf_renderer_support.h"
+
+#include <memory>
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/logging.h"
+#include "components/pdf/common/constants.h"
+#include "components/pdf/common/pdf_util.h"
+#include "components/pdf/renderer/internal_plugin_renderer_helpers.h"
+#include "components/printing/renderer/print_render_frame_helper.h"
+#include "content/public/common/url_constants.h"
+#include "content/public/renderer/render_frame.h"
+#include "extensions/common/constants.h"
+#include "extensions/common/mojom/guest_view.mojom.h"
+#include "extensions/renderer/guest_view/mime_handler_view/mime_handler_view_container_manager.h"
+#include "printing/buildflags/buildflags.h"
+#include "services/network/public/mojom/cors_origin_pattern.mojom-shared.h"
+#include "third_party/blink/public/common/associated_interfaces/associated_interface_registry.h"
+#include "third_party/blink/public/platform/web_string.h"
+#include "third_party/blink/public/platform/web_url.h"
+#include "third_party/blink/public/web/web_document.h"
+#include "third_party/blink/public/web/web_element.h"
+#include "third_party/blink/public/web/web_local_frame.h"
+#include "third_party/blink/public/web/web_plugin_params.h"
+#include "third_party/blink/public/web/web_security_policy.h"
+
+namespace content {
+namespace {
+
+#if BUILDFLAG(ENABLE_PRINTING)
+class TsPrintRenderFrameHelperDelegate
+    : public printing::PrintRenderFrameHelper::Delegate {
+ public:
+  TsPrintRenderFrameHelperDelegate() = default;
+  ~TsPrintRenderFrameHelperDelegate() override = default;
+
+  blink::WebElement GetPdfElement(blink::WebLocalFrame* frame) override {
+    return blink::WebElement();
+  }
+
+  bool IsPrintPreviewEnabled() override { return false; }
+
+  bool IsScriptedPrintEnabled() override { return false; }
+
+  bool ShouldGenerateTaggedPDF() override { return false; }
+
+  bool OverridePrint(blink::WebLocalFrame* frame) override { return false; }
+};
+#endif  // BUILDFLAG(ENABLE_PRINTING)
+
+bool HasInternalId(const blink::WebElement& plugin_element) {
+  return plugin_element.HasAttribute(blink::WebString::FromUTF8("internalid"));
+}
+
+}  // namespace
+
+void AllowTsPdfViewerChromeResources() {
+  // Renderer setup cannot consult the ExtensionRegistry, so keep this
+  // process-wide rule keyed to the fixed PDF extension origin.
+  blink::WebURL pdf_viewer_origin =
+      GURL(std::string(extensions::kExtensionScheme) + "://" +
+           extension_misc::kPdfExtensionId);
+  blink::WebSecurityPolicy::AddOriginAccessAllowListEntry(
+      pdf_viewer_origin, blink::WebString::FromUTF8(kChromeUIScheme),
+      blink::WebString::FromUTF8(kChromeUIResourcesHost), /*port=*/0,
+      network::mojom::CorsDomainMatchMode::kDisallowSubdomains,
+      network::mojom::CorsPortMatchMode::kAllowAnyPort,
+      network::mojom::CorsOriginAccessMatchPriority::kMaxPriority);
+  LOG(INFO) << "[termsurf-pdf] chrome-resources-renderer-origin extension_id="
+            << extension_misc::kPdfExtensionId;
+}
+
+void BindTsPdfMimeHandlerView(RenderFrame* render_frame) {
+  render_frame->GetAssociatedInterfaceRegistry()
+      ->AddInterface<extensions::mojom::MimeHandlerViewContainerManager>(
+          base::BindRepeating(
+              &extensions::MimeHandlerViewContainerManager::BindReceiver,
+              base::Unretained(render_frame)));
+  LOG(INFO) << "[termsurf-pdf] mime-handler-container-manager-bound "
+            << "render_frame=" << render_frame;
+}
+
+void CreateTsPdfPrintRenderFrameHelper(RenderFrame* render_frame) {
+#if BUILDFLAG(ENABLE_PRINTING)
+  new printing::PrintRenderFrameHelper(
+      render_frame, std::make_unique<TsPrintRenderFrameHelperDelegate>());
+#endif  // BUILDFLAG(ENABLE_PRINTING)
+}
+
+bool MaybeHandleTsPdfPluginExternally(RenderFrame* render_frame,
+                                      const blink::WebElement& plugin_element,
+                                      const GURL& original_url,
+                                      const std::string& mime_type,
+                                      bool* handled) {
+  if (mime_type == pdf::kInternalPluginMimeType && render_frame &&
+      render_frame->GetWebFrame()) {
+    const bool allowed_origin = IsPdfInternalPluginAllowedOrigin(
+        render_frame->GetWebFrame()->GetSecurityOrigin(), {});
+    LOG(INFO) << "[termsurf-pdf] internal-plugin-external-check "
+              << "document_url=" << TsPdfDocumentUrl(render_frame)
+              << " original_url=" << original_url << " mime_type=" << mime_type
+              << " allowed_origin=" << (allowed_origin ? 1 : 0);
+    if (allowed_origin) {
+      LOG(INFO) << "[termsurf-pdf] internal-plugin-externalized handled=1";
+      *handled = true;
+      return true;
+    }
+
+    LOG(INFO) << "[termsurf-pdf] internal-plugin-externalized "
+              << "handled=0 reason=disallowed-origin";
+  }
+
+  const bool has_internal_id = HasInternalId(plugin_element);
+  const bool is_pdf_mime = mime_type == pdf::kPDFMimeType ||
+                           mime_type == pdf::kInternalPluginMimeType;
+  *handled = has_internal_id && is_pdf_mime;
+
+  LOG(INFO) << "[termsurf-pdf] is-plugin-handled-externally mime_type="
+            << mime_type << " url=" << original_url
+            << " document_url=" << TsPdfDocumentUrl(render_frame)
+            << " has_internal_id=" << has_internal_id
+            << " plugin_lookup=" << (*handled ? "ok" : "missing")
+            << " handled=" << *handled;
+  LOG(INFO) << "[termsurf-pdf] renderer-plugin-external document_url="
+            << TsPdfDocumentUrl(render_frame)
+            << " original_url=" << original_url << " mime_type=" << mime_type
+            << " has_internal_id=" << has_internal_id
+            << " handled=" << *handled;
+
+  return true;
+}
+
+bool MaybeCreateTsPdfPlugin(RenderFrame* render_frame,
+                            const blink::WebPluginParams& params,
+                            blink::WebPlugin** plugin,
+                            bool* handled) {
+  if (params.mime_type.Utf8() != pdf::kInternalPluginMimeType) {
+    *handled = false;
+    return false;
+  }
+
+  const bool has_pdf_renderer = pdf::IsPdfRenderer();
+  LOG(INFO) << "[termsurf-pdf] internal-plugin-create-check "
+            << "document_url=" << TsPdfDocumentUrl(render_frame)
+            << " mime_type=" << params.mime_type.Utf8()
+            << " url=" << GURL(params.url)
+            << " has_pdf_renderer=" << (has_pdf_renderer ? 1 : 0);
+  if (!has_pdf_renderer) {
+    LOG(INFO) << "[termsurf-pdf] internal-plugin-create-skipped "
+              << "reason=missing-pdf-renderer";
+    *handled = false;
+    return true;
+  }
+
+  *plugin = pdf::CreateInternalPlugin(std::move(params), render_frame, {});
+  LOG(INFO) << "[termsurf-pdf] internal-plugin-create-result "
+            << "created=" << (*plugin ? 1 : 0);
+  *handled = true;
+  return true;
+}
+
+std::string TsPdfDocumentUrl(RenderFrame* render_frame) {
+  if (!render_frame || !render_frame->GetWebFrame()) {
+    return "";
+  }
+  return GURL(render_frame->GetWebFrame()->GetDocument().Url()).spec();
+}
+
+}  // namespace content
