+void PopulateTsPdfFeatureFlags(ui::TemplateReplacements* replacements) {
+  (*replacements)["presetZoomFactors"] = zoom::GetPresetZoomFactorsAsJSON();
+  (*replacements)["pdfOopifEnabled"] = "";
+  (*replacements)["printingEnabled"] = "true";
+  (*replacements)["termsurfPdfPrintBridgeTrace"] =
+      IsTermSurfPdfPrintBridgeTraceActive() ? "true" : "false";
+}
+
+void PopulateTsPdfFeatureFlags(base::DictValue* dict) {
+  dict->Set("presetZoomFactors", zoom::GetPresetZoomFactorsAsJSON());
+  dict->Set("pdfOopifEnabled", "");
+  dict->Set("pdfGetSaveDataInBlocks", false);
+  dict->Set("pdfGlicSummarizeEnabled", false);
+  dict->Set("pdfInk2Enabled", false);
+  dict->Set("pdfSaveToDrive", false);
+  dict->Set("pdfSearchifySaveEnabled", false);
+  dict->Set("pdfTextAnnotationsEnabled", false);
+  dict->Set("pdfUseShowSaveFilePicker", false);
+  dict->Set("printingEnabled", true);
+  dict->Set("termsurfPdfPrintBridgeTrace",
+            IsTermSurfPdfPrintBridgeTraceActive());
+}
