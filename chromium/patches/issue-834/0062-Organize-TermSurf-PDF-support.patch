+void PopulateTsPdfTemplateReplacements(ui::TemplateReplacements* replacements) {
+  PopulatePdfLocalizedStrings(replacements);
+
+#if BUILDFLAG(ENABLE_PDF_INK2)
+  std::string edit_string = l10n_util::GetStringUTF8(IDS_EDIT);
+  std::erase(edit_string, '&');
+  (*replacements)["editButton"] = edit_string;
+#endif  // BUILDFLAG(ENABLE_PDF_INK2)
+
+  PopulateTsPdfFeatureFlags(replacements);
+  webui::SetLoadTimeDataDefaults(l10n_util::GetApplicationLocale(std::string()),
+                                 replacements);
+}
+
+base::DictValue GetTsPdfStringsForTermSurf() {
+  base::DictValue dict;
+  PopulatePdfLocalizedStrings(&dict);
+
+#if BUILDFLAG(ENABLE_PDF_INK2)
+  std::u16string edit_string = l10n_util::GetStringUTF16(IDS_EDIT);
+  std::erase(edit_string, u'&');
+  dict.Set("editButton", edit_string);
+#endif  // BUILDFLAG(ENABLE_PDF_INK2)
+
+  PopulateTsPdfFeatureFlags(&dict);
+  webui::SetLoadTimeDataDefaults(
+      extensions::ExtensionsBrowserClient::Get()->GetApplicationLocale(),
+      &dict);
+  return dict;
+}
+
+}  // namespace content
