+void AddTsPdfNavigationThrottles(NavigationThrottleRegistry& registry) {
+  TsPdfIframeNavigationThrottle::MaybeCreateAndAdd(registry);
+  registry.AddThrottle(std::make_unique<pdf::PdfNavigationThrottle>(
+      registry, std::make_unique<TsPdfStreamDelegate>()));
+  NavigationHandle& handle = registry.GetNavigationHandle();
+  LOG(INFO) << "[termsurf-pdf] navigation-throttles frame_tree_node_id="
+            << handle.GetFrameTreeNodeId() << " url=" << handle.GetURL()
+            << " pdf_throttle=1 iframe_throttle="
+            << (handle.IsInMainFrame() ? 0 : 1);
+}
+
+void AddTsPdfURLLoaderThrottles(
+    std::vector<std::unique_ptr<blink::URLLoaderThrottle>>* throttles,
+    const network::ResourceRequest& request,
+    FrameTreeNodeId frame_tree_node_id) {
+  throttles->push_back(
+      std::make_unique<TsPluginResponseInterceptorURLLoaderThrottle>(
+          request.destination, frame_tree_node_id));
+  LOG(INFO) << "[termsurf-pdf] url-loader-throttle destination="
+            << static_cast<int>(request.destination)
+            << " frame_tree_node_id=" << frame_tree_node_id
+            << " plugin_interceptor=1";
+}
+
+void AddTsPdfURLLoaderRequestInterceptors(
+    std::vector<std::unique_ptr<URLLoaderRequestInterceptor>>* interceptors,
+    FrameTreeNodeId frame_tree_node_id) {
+  auto pdf_interceptor =
+      pdf::PdfURLLoaderRequestInterceptor::MaybeCreateInterceptor(
+          frame_tree_node_id, std::make_unique<TsPdfStreamDelegate>());
+  LOG(INFO) << "[termsurf-pdf] pdf-request-interceptor frame_tree_node_id="
+            << frame_tree_node_id << " created=" << (pdf_interceptor ? 1 : 0);
+  if (pdf_interceptor) {
+    interceptors->push_back(std::move(pdf_interceptor));
+  }
+}
+
+base::flat_set<std::string> GetTsPdfExternalPluginMimeTypes(
+    BrowserContext* browser_context) {
+  base::flat_set<std::string> mime_types;
+  auto map = GetTsPluginMimeTypeToExtensionIdMap(browser_context);
+  for (const auto& pair : map) {
+    mime_types.insert(pair.first);
+  }
+  LOG(INFO) << "[termsurf-pdf] external-plugin-mime-types count="
+            << mime_types.size()
+            << " has_pdf=" << (mime_types.contains(pdf::kPDFMimeType) ? 1 : 0);
+  return mime_types;
+}
+
+void RegisterTsPdfBrowserInterfaceBindersForFrame(
+    RenderFrameHost* render_frame_host,
+    mojo::BinderMapWithContext<RenderFrameHost*>* map) {
+  WebContents* web_contents =
+      WebContents::FromRenderFrameHost(render_frame_host);
+  auto* observer =
+      extensions::ExtensionWebContentsObserver::GetForWebContents(web_contents);
+  const extensions::Extension* extension =
+      observer ? observer->GetExtensionFromFrame(render_frame_host, false)
+               : nullptr;
+  const bool is_pdf_extension = IsTsPdfComponentExtension(extension);
+  const std::string frame_url = render_frame_host->GetLastCommittedURL().spec();
+  const std::string site_url =
+      render_frame_host->GetSiteInstance()->GetSiteURL().spec();
+  const std::string extension_id = extension ? extension->id() : "none";
+
+  LOG(INFO) << "[termsurf-pdf] extension-frame-binder-check frame_url="
+            << frame_url << " site_url=" << site_url
+            << " observer=" << (observer ? 1 : 0)
+            << " extension_id=" << extension_id
+            << " is_pdf_extension=" << (is_pdf_extension ? 1 : 0);
+
+  bool populated_extension_binders = false;
+  if (extension) {
+    extensions::ExtensionsBrowserClient::Get()
+        ->RegisterBrowserInterfaceBindersForFrame(map, render_frame_host,
+                                                  extension);
+    populated_extension_binders = true;
+    if (is_pdf_extension) {
+      LOG(INFO) << "[termsurf-pdf] pdf-extension-frame-binders frame_url="
+                << frame_url << " site_url=" << site_url
+                << " extension_id=" << extension->id() << " source=canonical";
+    }
+  }
+
+  if (!populated_extension_binders &&
+      (IsTsPdfComponentExtensionUrl(render_frame_host->GetLastCommittedURL()) ||
+       IsTsPdfComponentExtensionUrl(
+           render_frame_host->GetSiteInstance()->GetSiteURL()))) {
+    const extensions::Extension* pdf_extension = GetEnabledPdfExtension(
+        render_frame_host->GetProcess()->GetBrowserContext());
+    if (pdf_extension) {
+      extensions::PopulateExtensionFrameBinders(map, render_frame_host,
+                                                pdf_extension);
+      LOG(INFO) << "[termsurf-pdf] pdf-extension-frame-binders frame_url="
+                << frame_url << " site_url=" << site_url
+                << " extension_id=" << pdf_extension->id()
+                << " source=direct-populate";
+    }
+  }
+
+  map->Add<help_bubble::mojom::PdfHelpBubbleHandlerFactory>(
+      base::BindRepeating(&pdf::BindTsPdfHelpBubbleHandlerFactory));
+
+  map->Add<extensions::mime_handler::MimeHandlerService>(
+      base::BindRepeating(&BindTsMimeHandlerService));
+  map->Add<extensions::mime_handler::BeforeUnloadControl>(
+      base::BindRepeating(&BindTsBeforeUnloadControl));
+}
+
+void RegisterTsPdfAssociatedInterfaceBindersForRenderFrameHost(
+    RenderFrameHost& render_frame_host,
+    blink::AssociatedInterfaceRegistry& associated_registry) {
+  associated_registry.RemoveInterface(extensions::mojom::LocalFrameHost::Name_);
+  associated_registry.AddInterface<extensions::mojom::LocalFrameHost>(
+      base::BindRepeating(
+          [](RenderFrameHost* render_frame_host,
+             mojo::PendingAssociatedReceiver<extensions::mojom::LocalFrameHost>
+                 receiver) {
+            extensions::ExtensionWebContentsObserver::BindLocalFrameHost(
+                std::move(receiver), render_frame_host);
+          },
+          &render_frame_host));
+  associated_registry.AddInterface<pdf::mojom::PdfHost>(base::BindRepeating(
+      [](RenderFrameHost* render_frame_host,
+         mojo::PendingAssociatedReceiver<pdf::mojom::PdfHost> receiver) {
+        LOG(INFO) << "[termsurf-pdf] pdf-host-binder frame_url="
+                  << render_frame_host->GetLastCommittedURL() << " site_url="
+                  << render_frame_host->GetSiteInstance()->GetSiteURL();
+        pdf::PDFDocumentHelper::BindPdfHost(
+            std::move(receiver), render_frame_host,
+            std::make_unique<pdf::TsPDFDocumentHelperClient>());
+      },
+      &render_frame_host));
+}
+
+void AppendTsPdfRendererCommandLineSwitches(base::CommandLine* command_line) {
+  std::optional<std::string> intercept_file = GetTsPdfTraceFileFromEnv(
+      "TERMSURF_PDF_PRINT_INTERCEPT", "TERMSURF_PDF_PRINT_INTERCEPT_FILE");
+  if (intercept_file) {
+    command_line->AppendSwitch(kTsPdfPrintInterceptSwitch);
+    command_line->AppendSwitchASCII(kTsPdfPrintInterceptFileSwitch,
+                                    *intercept_file);
+  }
+
+  std::optional<std::string> bridge_trace_file =
+      GetTsPdfTraceFileFromEnv("TERMSURF_PDF_PRINT_BRIDGE_TRACE",
+                               "TERMSURF_PDF_PRINT_BRIDGE_TRACE_FILE");
+  if (bridge_trace_file) {
+    command_line->AppendSwitch(kTsPdfPrintBridgeTraceSwitch);
+    command_line->AppendSwitchASCII(kTsPdfPrintBridgeTraceFileSwitch,
+                                    *bridge_trace_file);
+  }
+
+  std::optional<std::string> native_print_trace_file =
+      GetTsPdfTraceFileFromEnv("TERMSURF_PDF_NATIVE_PRINT_TRACE",
+                               "TERMSURF_PDF_NATIVE_PRINT_TRACE_FILE");
+  if (native_print_trace_file) {
+    command_line->AppendSwitch(kTsPdfNativePrintTraceSwitch);
+    command_line->AppendSwitchASCII(kTsPdfNativePrintTraceFileSwitch,
+                                    *native_print_trace_file);
+  }
+}
