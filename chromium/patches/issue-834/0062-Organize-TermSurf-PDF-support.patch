+bool IsTsPdfExtensionScheme(const std::string& scheme) {
+  return scheme == extensions::kExtensionScheme;
+}
+
+mojo::PendingRemote<network::mojom::URLLoaderFactory>
+CreateTsPdfExtensionNavigationURLLoaderFactory(
+    FrameTreeNodeId frame_tree_node_id) {
+  WebContents* web_contents =
+      WebContents::FromFrameTreeNodeId(frame_tree_node_id);
+  LOG(INFO) << "[termsurf-pdf] extension-factory"
+            << " scheme=chrome-extension type=navigation";
+  return extensions::CreateExtensionNavigationURLLoaderFactory(
+      web_contents->GetBrowserContext(), false);
+}
+
+void RegisterTsPdfExtensionWorkerMainResourceURLLoaderFactory(
+    BrowserContext* browser_context,
+    ContentBrowserClient::NonNetworkURLLoaderFactoryMap* factories) {
+  LOG(INFO) << "[termsurf-pdf] extension-factory"
+            << " scheme=chrome-extension type=worker-main";
+  factories->emplace(
+      extensions::kExtensionScheme,
+      extensions::CreateExtensionWorkerMainResourceURLLoaderFactory(
+          browser_context));
+}
+
+void RegisterTsPdfExtensionServiceWorkerUpdateURLLoaderFactory(
+    BrowserContext* browser_context,
+    ContentBrowserClient::NonNetworkURLLoaderFactoryMap* factories) {
+  LOG(INFO) << "[termsurf-pdf] extension-factory"
+            << " scheme=chrome-extension type=service-worker";
+  factories->emplace(
+      extensions::kExtensionScheme,
+      extensions::CreateExtensionServiceWorkerScriptURLLoaderFactory(
+          browser_context));
+}
+
+void RegisterTsPdfExtensionSubresourceURLLoaderFactory(
+    int render_process_id,
+    int render_frame_id,
+    const std::optional<url::Origin>& request_initiator_origin,
+    ContentBrowserClient::NonNetworkURLLoaderFactoryMap* factories) {
+  LOG(INFO) << "[termsurf-pdf] extension-factory"
+            << " scheme=chrome-extension type=subresource";
+  factories->emplace(extensions::kExtensionScheme,
+                     extensions::CreateExtensionURLLoaderFactory(
+                         render_process_id, render_frame_id));
+
+  RenderProcessHost* process_host =
+      RenderProcessHost::FromID(render_process_id);
+  if (!process_host) {
+    return;
+  }
+  RenderFrameHost* frame_host =
+      RenderFrameHost::FromID(render_process_id, render_frame_id);
+  if (!frame_host) {
+    return;
+  }
+  const extensions::Extension* extension = GetExtensionForInitiatorOrigin(
+      process_host->GetBrowserContext(), request_initiator_origin);
+  if (!IsTsPdfComponentExtension(extension)) {
+    return;
+  }
+
+  factories->emplace(kChromeUIScheme,
+                     CreateWebUIURLLoaderFactory(frame_host, kChromeUIScheme,
+                                                 {kChromeUIResourcesHost}));
+  LOG(INFO) << "[termsurf-pdf] chrome-resources-factory extension_id="
+            << extension->id() << " process_id=" << render_process_id
+            << " frame_id=" << render_frame_id;
+}
+
+bool MaybeUseTsPdfProcessPerSite(BrowserContext* browser_context,
+                                 const GURL& site_url,
+                                 bool* use_process_per_site) {
+  if (!site_url.SchemeIs(extensions::kExtensionScheme)) {
+    return false;
+  }
+
+  auto* registry = extensions::ExtensionRegistry::Get(browser_context);
+  if (!registry) {
+    *use_process_per_site = false;
+    return true;
+  }
+
+  const extensions::Extension* extension =
+      registry->enabled_extensions().GetByID(site_url.GetHost());
+  if (!extension) {
+    *use_process_per_site = false;
+    return true;
+  }
+
+  LOG(INFO) << "[termsurf-pdf] process-per-site extension_id="
+            << extension->id() << " effective_url=" << site_url;
+  *use_process_per_site = true;
+  return true;
+}
+
+bool MaybeHandleTsPdfExtensionURL(const GURL& url, bool* handled) {
+  if (!url.SchemeIs(extensions::kExtensionScheme)) {
+    return false;
+  }
+
+  static bool logged_once = false;
+  if (!logged_once) {
+    logged_once = true;
+    LOG(INFO) << "[termsurf-pdf] handled-url url=" << url;
+  }
+  *handled = true;
+  return true;
+}
+
+void MaybeActivateTsPdfSiteInstance(SiteInstance* site_instance) {
+  BrowserContext* browser_context = site_instance->GetBrowserContext();
+  if (browser_context->IsOffTheRecord()) {
+    return;
+  }
+
+  auto* registry = extensions::ExtensionRegistry::Get(browser_context);
+  if (!registry) {
+    return;
+  }
+
+  const extensions::Extension* extension =
+      registry->enabled_extensions().GetExtensionOrAppByURL(
+          site_instance->GetSiteURL());
+  if (!extension) {
+    if (site_instance->GetSiteURL().SchemeIs(extensions::kExtensionScheme)) {
+      LOG(INFO) << "[termsurf-pdf] process-map-miss site_url="
+                << site_instance->GetSiteURL();
+    }
+    return;
+  }
+
+  if (site_instance->GetSecurityPrincipal().IsSandboxed()) {
+    return;
+  }
+
+  const int process_id = site_instance->GetProcess()->GetDeprecatedID();
+  extensions::ProcessMap::Get(browser_context)
+      ->Insert(extension->id(), process_id);
+  LOG(INFO) << "[termsurf-pdf] process-map-insert extension_id="
+            << extension->id() << " process_id=" << process_id
+            << " site_url=" << site_instance->GetSiteURL();
+
+  if (IsTsPdfComponentExtension(extension)) {
+    auto* renderer_startup_helper =
+        extensions::RendererStartupHelperFactory::GetForBrowserContext(
+            browser_context);
+    LOG(INFO) << "[termsurf-pdf] pdf-process-map-helper extension_id="
+              << extension->id() << " process_id=" << process_id
+              << " helper=" << (renderer_startup_helper != nullptr);
+    if (renderer_startup_helper) {
+      renderer_startup_helper->ActivateExtensionInProcess(
+          *extension, site_instance->GetProcess());
+      LOG(INFO) << "[termsurf-pdf] pdf-activate-request extension_id="
+                << extension->id() << " process_id=" << process_id
+                << " called=1";
+    }
+    ChildProcessSecurityPolicy::GetInstance()->GrantRequestOrigin(
+        process_id, url::Origin::CreateFromNormalizedTuple(
+                        kChromeUIScheme, kChromeUIResourcesHost, 0));
+    LOG(INFO) << "[termsurf-pdf] chrome-resources-grant extension_id="
+              << extension->id() << " process_id=" << process_id;
+  }
+}
