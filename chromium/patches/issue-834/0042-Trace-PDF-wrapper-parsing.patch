 #include "third_party/blink/public/common/tokens/tokens.h"
@@ -60,6 +61,23 @@
 
 namespace blink {
 
+namespace {
+
+const char* DocumentTypeForLog(DocumentInit::Type type) {
+  switch (type) {
+    case DocumentInit::Type::kHTML:
+      return "html";
+    case DocumentInit::Type::kPlugin:
+      return "plugin";
+    case DocumentInit::Type::kText:
+      return "text";
+    default:
+      return "other";
+  }
+}
+
+}  // namespace
+
 // static
 DocumentInit DocumentInit::Create() {
   return DocumentInit();
@@ -183,25 +201,48 @@ DocumentInit::Type DocumentInit::ComputeDocumentType(
     return Type::kMedia;
   }
 
-  if (frame && frame->GetPage() && frame->Loader().AllowPlugins())
-      [[unlikely]] {
-    PluginData* plugin_data = GetPluginData(frame);
+  const bool should_log = EqualIgnoringAsciiCase(mime_type, "application/pdf");
+  bool allow_plugins = false;
+  PluginData* plugin_data = nullptr;
+  bool supports_mime = false;
+  bool is_external = false;
+  auto log_check = [&](Type result) {
+    if (!should_log && !is_external) {
+      return;
+    }
+    LOG(INFO) << "[issue-792-exp21] document-type-check mime_type="
+              << mime_type.Utf8() << " has_frame=" << (frame ? 1 : 0)
+              << " allow_plugins=" << allow_plugins
+              << " has_plugin_data=" << (plugin_data ? 1 : 0)
+              << " supports_mime=" << supports_mime
+              << " is_external=" << is_external
+              << " result=" << DocumentTypeForLog(result);
+  };
+
+  allow_plugins = frame && frame->GetPage() && frame->Loader().AllowPlugins();
+  if (allow_plugins) [[unlikely]] {
+    plugin_data = GetPluginData(frame);
 
     // Everything else except text/plain can be overridden by plugins.
     // Disallowing plugins to use text/plain prevents plugins from hijacking a
     // fundamental type that the browser is expected to handle, and also serves
     // as an optimization to prevent loading the plugin database in the common
     // case.
-    if (mime_type != "text/plain" && plugin_data &&
-        plugin_data->SupportsMimeType(mime_type)) {
+    supports_mime = mime_type != "text/plain" && plugin_data &&
+                    plugin_data->SupportsMimeType(mime_type);
+    if (supports_mime) {
       // Plugins handled by MimeHandlerView do not create a PluginDocument. They
       // are rendered inside cross-process frames and the notion of a PluginView
       // (which is associated with PluginDocument) is irrelevant here.
-      if (plugin_data->IsExternalPluginMimeType(mime_type)) {
-        if (is_for_external_handler)
+      is_external = plugin_data->IsExternalPluginMimeType(mime_type);
+      if (is_external) {
+        if (is_for_external_handler) {
           *is_for_external_handler = true;
+        }
+        log_check(Type::kHTML);
         return Type::kHTML;
       }
+      log_check(Type::kPlugin);
       return Type::kPlugin;
     }
   }
@@ -216,6 +257,7 @@ DocumentInit::Type DocumentInit::ComputeDocumentType(
     return Type::kXML;
   }
 
+  log_check(Type::kHTML);
   return Type::kHTML;
 }
 
@@ -228,6 +270,12 @@ DocumentInit& DocumentInit::WithTypeFrom(const String& mime_type) {
   mime_type_ = mime_type;
   type_ = ComputeDocumentType(window_ ? window_->GetFrame() : nullptr,
                               mime_type_, &is_for_external_handler_);
+  if (EqualIgnoringAsciiCase(mime_type_, "application/pdf") ||
+      is_for_external_handler_) {
+    LOG(INFO) << "[issue-792-exp21] document-type-selected mime_type="
+              << mime_type_.Utf8() << " result=" << DocumentTypeForLog(type_)
+              << " is_for_external_handler=" << is_for_external_handler_;
+  }
   return *this;
 }
 
