+++ b/content/libtermsurf_chromium/extensions/ts_resources_private_api.cc
@@ -0,0 +1,102 @@
+// Copyright 2026 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/libtermsurf_chromium/extensions/ts_resources_private_api.h"
+
+#include <optional>
+#include <utility>
+
+#include "base/values.h"
+#include "chrome/common/extensions/api/resources_private.h"
+#include "chrome/grit/generated_resources.h"
+#include "components/strings/grit/components_strings.h"
+#include "components/zoom/page_zoom_constants.h"
+#include "extensions/browser/extensions_browser_client.h"
+#include "ui/base/l10n/l10n_util.h"
+#include "ui/base/webui/web_ui_util.h"
+
+namespace content {
+namespace {
+
+namespace resources_private = extensions::api::resources_private;
+namespace get_strings = resources_private::GetStrings;
+
+base::DictValue GetPdfStringsForTermSurf() {
+  base::DictValue dict;
+
+  static constexpr webui::LocalizedString kPdfResources[] = {
+      {"errorDialogTitle", IDS_PDF_ERROR_DIALOG_TITLE},
+      {"labelPageNumber", IDS_PDF_LABEL_PAGE_NUMBER},
+      {"moreActions", IDS_DOWNLOAD_MORE_ACTIONS},
+      {"pageLoadFailed", IDS_PDF_PAGE_LOAD_FAILED},
+      {"pageLoading", IDS_PDF_PAGE_LOADING},
+      {"pageReload", IDS_PDF_PAGE_RELOAD_BUTTON},
+      {"tooltipDownload", IDS_PDF_TOOLTIP_DOWNLOAD},
+      {"tooltipFitToPage", IDS_PDF_TOOLTIP_FIT_PAGE},
+      {"tooltipFitToWidth", IDS_PDF_TOOLTIP_FIT_WIDTH},
+      {"tooltipPrint", IDS_PDF_TOOLTIP_PRINT},
+      {"tooltipRotateCCW", IDS_PDF_TOOLTIP_ROTATE_CCW},
+      {"tooltipZoomIn", IDS_PDF_TOOLTIP_ZOOM_IN},
+      {"tooltipZoomOut", IDS_PDF_TOOLTIP_ZOOM_OUT},
+      {"twoUpViewEnable", IDS_PDF_TWO_UP_VIEW_ENABLE},
+      {"zoomTextInputAriaLabel", IDS_PDF_ZOOM_TEXT_INPUT_ARIA_LABEL},
+  };
+
+  for (const auto& resource : kPdfResources) {
+    dict.Set(resource.name, l10n_util::GetStringUTF16(resource.id));
+  }
+
+  // This is the load-bearing value for PDF toolbar zoom. Chrome normally
+  // returns it through chrome/browser/pdf/pdf_extension_util.cc, but linking
+  // that target pulls the full Chrome PDF browser stack and duplicates
+  // PdfViewerStreamManager in TermSurf's smaller embedder.
+  dict.Set("presetZoomFactors", zoom::GetPresetZoomFactorsAsJSON());
+
+  // Keep the PDF viewer's feature flags explicit and conservative. These match
+  // the embedder-owned surfaces TermSurf currently supports.
+  dict.Set("pdfGetSaveDataInBlocks", false);
+  dict.Set("pdfGlicSummarizeEnabled", false);
+  dict.Set("pdfInk2Enabled", false);
+  dict.Set("pdfSaveToDrive", false);
+  dict.Set("pdfSearchifySaveEnabled", false);
+  dict.Set("pdfTextAnnotationsEnabled", false);
+  dict.Set("pdfUseShowSaveFilePicker", false);
+  dict.Set("printingEnabled", false);
+
+  return dict;
+}
+
+}  // namespace
+
+TsResourcesPrivateGetStringsFunction::TsResourcesPrivateGetStringsFunction() =
+    default;
+
+TsResourcesPrivateGetStringsFunction::~TsResourcesPrivateGetStringsFunction() =
+    default;
+
+ExtensionFunction::ResponseAction TsResourcesPrivateGetStringsFunction::Run() {
+  std::optional<get_strings::Params> params =
+      get_strings::Params::Create(args());
+  if (!params) {
+    return RespondNow(Error("Invalid resourcesPrivate.getStrings arguments."));
+  }
+
+  base::DictValue dict;
+  switch (params->component) {
+    case resources_private::Component::kPdf:
+      dict = GetPdfStringsForTermSurf();
+      break;
+    case resources_private::Component::kIdentity:
+    case resources_private::Component::kNone:
+      break;
+  }
+
+  webui::SetLoadTimeDataDefaults(
+      extensions::ExtensionsBrowserClient::Get()->GetApplicationLocale(),
+      &dict);
+
+  return RespondNow(WithArguments(std::move(dict)));
+}
+
+}  // namespace content
