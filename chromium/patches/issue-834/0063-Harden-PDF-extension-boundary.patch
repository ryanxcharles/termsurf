diff --git a/content/libtermsurf_chromium/extensions/ts_pdf_extension_identity.cc b/content/libtermsurf_chromium/extensions/ts_pdf_extension_identity.cc
new file mode 100644
index 0000000000..9a76b205d3
--- /dev/null
+++ b/content/libtermsurf_chromium/extensions/ts_pdf_extension_identity.cc
@@ -0,0 +1,34 @@
+// Copyright 2026 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/libtermsurf_chromium/extensions/ts_pdf_extension_identity.h"
+
+#include "extensions/browser/extension_function.h"
+#include "extensions/common/constants.h"
+#include "extensions/common/extension.h"
+#include "extensions/common/manifest.h"
+#include "url/gurl.h"
+
+namespace content {
+
+bool IsTsPdfComponentExtensionId(std::string_view extension_id) {
+  return extension_id == extension_misc::kPdfExtensionId;
+}
+
+bool IsTsPdfComponentExtensionUrl(const GURL& url) {
+  return url.SchemeIs(extensions::kExtensionScheme) &&
+         IsTsPdfComponentExtensionId(url.host());
+}
+
+bool IsTsPdfComponentExtension(const extensions::Extension* extension) {
+  return extension && IsTsPdfComponentExtensionId(extension->id()) &&
+         extensions::Manifest::IsComponentLocation(extension->location());
+}
+
+bool IsTsPdfExtensionFunctionSender(const ExtensionFunction* function) {
+  return function && IsTsPdfComponentExtension(function->extension()) &&
+         IsTsPdfComponentExtensionUrl(function->source_url());
+}
+
+}  // namespace content
