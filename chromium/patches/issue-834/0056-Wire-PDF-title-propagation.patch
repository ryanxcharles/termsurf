@@ -0,0 +1,87 @@
+// Copyright 2026 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/libtermsurf_chromium/extensions/ts_pdf_viewer_private_api.h"
+
+#include <optional>
+#include <string>
+
+#include "base/logging.h"
+#include "base/strings/utf_string_conversions.h"
+#include "chrome/common/extensions/api/pdf_viewer_private.h"
+#include "components/pdf/common/constants.h"
+#include "content/public/browser/navigation_controller.h"
+#include "content/public/browser/navigation_entry.h"
+#include "content/public/browser/web_contents.h"
+
+namespace content {
+namespace {
+
+namespace set_pdf_document_title =
+    extensions::api::pdf_viewer_private::SetPdfDocumentTitle;
+
+}  // namespace
+
+TsPdfViewerPrivateSetPdfDocumentTitleFunction::
+    TsPdfViewerPrivateSetPdfDocumentTitleFunction() = default;
+
+TsPdfViewerPrivateSetPdfDocumentTitleFunction::
+    ~TsPdfViewerPrivateSetPdfDocumentTitleFunction() = default;
+
+ExtensionFunction::ResponseAction
+TsPdfViewerPrivateSetPdfDocumentTitleFunction::Run() {
+  WebContents* web_contents = GetSenderWebContents();
+  if (!web_contents) {
+    LOG(INFO)
+        << "[issue-794-exp15] pdf-set-title success=0 reason=no-web-contents";
+    return RespondNow(Error("Could not find a valid web contents."));
+  }
+
+  const std::string mime_type = web_contents->GetContentsMimeType();
+  if (mime_type != pdf::kPDFMimeType) {
+    LOG(INFO) << "[issue-794-exp15] pdf-set-title success=0 reason=mime-guard"
+              << " mime_type=" << mime_type
+              << " url=" << web_contents->GetLastCommittedURL();
+    EXTENSION_FUNCTION_VALIDATE(false);
+  }
+
+  std::optional<set_pdf_document_title::Params> params =
+      set_pdf_document_title::Params::Create(args());
+  if (!params) {
+    LOG(INFO) << "[issue-794-exp15] pdf-set-title success=0 reason=bad-params"
+              << " mime_type=" << mime_type
+              << " url=" << web_contents->GetLastCommittedURL();
+    EXTENSION_FUNCTION_VALIDATE(false);
+  }
+
+  NavigationEntry* entry =
+      web_contents->GetController().GetLastCommittedEntry();
+  if (!entry) {
+    LOG(INFO) << "[issue-794-exp15] pdf-set-title success=0 reason=no-entry"
+              << " title=" << params->title << " mime_type=" << mime_type
+              << " url=" << web_contents->GetLastCommittedURL();
+    return RespondNow(Error("Could not find a committed navigation entry."));
+  }
+
+  LOG(INFO) << "[issue-794-exp15] pdf-set-title before"
+            << " title=" << params->title << " mime_type=" << mime_type
+            << " url=" << web_contents->GetLastCommittedURL() << " has_entry=1"
+            << " entry_title="
+            << base::UTF16ToUTF8(entry->GetTitleForDisplay());
+
+  web_contents->UpdateTitleForEntry(entry, base::UTF8ToUTF16(params->title));
+
+  NavigationEntry* updated_entry =
+      web_contents->GetController().GetLastCommittedEntry();
+  LOG(INFO) << "[issue-794-exp15] pdf-set-title after success=1"
+            << " title=" << params->title
+            << " has_entry=" << (updated_entry ? 1 : 0) << " entry_title="
+            << (updated_entry
+                    ? base::UTF16ToUTF8(updated_entry->GetTitleForDisplay())
+                    : "");
+
+  return RespondNow(NoArguments());
+}
+
+}  // namespace content
