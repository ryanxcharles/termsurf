     return;
   }
 
-  base::FilePath pak_path = assets_path.AppendASCII("gen")
-                                .AppendASCII("chrome")
-                                .AppendASCII("pdf_resources.pak");
-  const bool found = base::PathExists(pak_path);
-  if (found) {
+  base::FilePath pdf_pak_path =
+      assets_path.AppendASCII("gen").AppendASCII("chrome").AppendASCII(
+          "pdf_resources.pak");
+  const bool pdf_found = base::PathExists(pdf_pak_path);
+  if (pdf_found) {
     ui::ResourceBundle::GetSharedInstance().AddDataPackFromPath(
-        pak_path, ui::kScaleFactorNone);
+        pdf_pak_path, ui::kScaleFactorNone);
   }
 
   std::string index_html;
-  if (found) {
+  if (pdf_found) {
     index_html = ui::ResourceBundle::GetSharedInstance().LoadDataResourceString(
         IDR_PDF_INDEX_HTML);
   }
-  const bool loaded = !index_html.empty();
+  const bool pdf_loaded = !index_html.empty();
   LOG(INFO) << "[issue-792-exp4] pdf-resource-pak path="
-            << pak_path.AsUTF8Unsafe() << " found=" << found
-            << " loaded=" << loaded;
+            << pdf_pak_path.AsUTF8Unsafe() << " found=" << pdf_found
+            << " loaded=" << pdf_loaded;
 
   if (process_type.empty()) {
-    LOG(INFO) << "[issue-792-exp4] pdf-resource-bytes id="
-              << IDR_PDF_INDEX_HTML << " bytes=" << index_html.size()
+    LOG(INFO) << "[issue-792-exp4] pdf-resource-bytes id=" << IDR_PDF_INDEX_HTML
+              << " bytes=" << index_html.size()
               << " html_signature=" << HasHtmlSignature(index_html);
   }
+
+  base::FilePath common_pak_path =
+      assets_path.AppendASCII("gen").AppendASCII("chrome").AppendASCII(
+          "common_resources.pak");
+  const bool common_found = base::PathExists(common_pak_path);
+  if (common_found) {
+    ui::ResourceBundle::GetSharedInstance().AddDataPackFromPath(
+        common_pak_path, ui::kScaleFactorNone);
+  }
+
+  std::string api_features;
+  if (common_found) {
+    api_features =
+        ui::ResourceBundle::GetSharedInstance().LoadDataResourceString(
+            IDR_CHROME_EXTENSION_API_FEATURES);
+  }
+  LOG(INFO) << "[issue-792-exp8] chrome-common-pak path="
