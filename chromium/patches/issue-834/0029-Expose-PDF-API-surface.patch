 .../extensions/ts_extensions_api_provider.cc  | 32 ++++++++++++
 .../extensions/ts_extensions_client.cc        |  4 ++
 .../extensions/ts_pdf_component_extension.cc  | 51 +++++++++++++------
 .../extensions/ts_pdf_resource_bundle.cc      | 45 +++++++++++-----
 5 files changed, 108 insertions(+), 27 deletions(-)

diff --git a/content/libtermsurf_chromium/BUILD.gn b/content/libtermsurf_chromium/BUILD.gn
