@@ -60,6 +60,9 @@ shared_library("libtermsurf_chromium") {
 
   deps = [
     "//chrome/browser/resources/pdf:resources",
+    "//chrome/common:resources",
+    "//chrome/common/extensions",
+    "//chrome/common/extensions/api",
     "//components/custom_handlers",
     "//components/keyed_service/content",
     "//components/keyed_service/core",
diff --git a/content/libtermsurf_chromium/extensions/ts_extensions_api_provider.cc b/content/libtermsurf_chromium/extensions/ts_extensions_api_provider.cc
index 63606adf57ee2..fe767224b2b73 100644
--- a/content/libtermsurf_chromium/extensions/ts_extensions_api_provider.cc
+++ b/content/libtermsurf_chromium/extensions/ts_extensions_api_provider.cc
@@ -4,7 +4,31 @@
 
 #include "content/libtermsurf_chromium/extensions/ts_extensions_api_provider.h"
 
+#include "base/logging.h"
+#include "chrome/common/extensions/api/generated_schemas.h"
+
 namespace content {
+namespace {
+
+bool ShouldLogSchemaRequest(const std::string& name) {
+  static bool pdf_viewer_private_logged = false;
+  static bool resources_private_logged = false;
+
+  bool* logged = nullptr;
+  if (name == "pdfViewerPrivate") {
+    logged = &pdf_viewer_private_logged;
+  } else if (name == "resourcesPrivate") {
+    logged = &resources_private_logged;
+  }
+
+  if (!logged || *logged) {
+    return false;
+  }
+  *logged = true;
+  return true;
+}
+
+}  // namespace
 
 TsExtensionsAPIProvider::TsExtensionsAPIProvider() = default;
 TsExtensionsAPIProvider::~TsExtensionsAPIProvider() = default;
@@ -25,11 +49,19 @@ void TsExtensionsAPIProvider::AddAPIJSONSources(
     extensions::JSONFeatureProviderSource* json_source) {}
 
 bool TsExtensionsAPIProvider::IsAPISchemaGenerated(const std::string& name) {
+  if (ShouldLogSchemaRequest(name)) {
+    LOG(INFO) << "[issue-792-exp8] schema-request name=" << name << " found="
+              << extensions::api::ChromeGeneratedSchemas::IsGenerated(name);
+  }
   return false;
 }
 
 std::string_view TsExtensionsAPIProvider::GetAPISchema(
     const std::string& name) {
+  if (ShouldLogSchemaRequest(name)) {
+    LOG(INFO) << "[issue-792-exp8] schema-request name=" << name << " found="
+              << extensions::api::ChromeGeneratedSchemas::IsGenerated(name);
+  }
   return {};
 }
 
diff --git a/content/libtermsurf_chromium/extensions/ts_extensions_client.cc b/content/libtermsurf_chromium/extensions/ts_extensions_client.cc
