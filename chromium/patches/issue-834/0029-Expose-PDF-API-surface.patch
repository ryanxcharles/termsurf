diff --git a/content/libtermsurf_chromium/extensions/ts_pdf_component_extension.cc b/content/libtermsurf_chromium/extensions/ts_pdf_component_extension.cc
index e53142be57c46..f5ca15c500952 100644
--- a/content/libtermsurf_chromium/extensions/ts_pdf_component_extension.cc
+++ b/content/libtermsurf_chromium/extensions/ts_pdf_component_extension.cc
@@ -55,6 +55,16 @@ constexpr char kPdfManifestFallback[] = R"({
   ]
 })";
 
+std::string DescribePermissionForLog(const base::Value& permission) {
+  if (permission.is_string()) {
+    return permission.GetString();
+  }
+  if (permission.is_dict() && permission.GetDict().contains("fileSystem")) {
+    return "fileSystem.write";
+  }
+  return "<object>";
+}
+
 std::optional<base::DictValue> LoadPdfManifest(
     std::vector<std::string>* stripped_manifest_keys) {
   std::string manifest_contents = kPdfManifestFallback;
@@ -64,9 +74,8 @@ std::optional<base::DictValue> LoadPdfManifest(
     LOG(ERROR) << "[issue-792-exp3] pdf-manifest-error reason=missing-name-tag";
     return std::nullopt;
   }
-  base::ReplaceFirstSubstringAfterOffset(&manifest_contents, 0,
-                                         kPdfExtensionNameTag,
-                                         kPdfExtensionName);
+  base::ReplaceFirstSubstringAfterOffset(
+      &manifest_contents, 0, kPdfExtensionNameTag, kPdfExtensionName);
 
   std::optional<base::DictValue> manifest = base::JSONReader::ReadDict(
       manifest_contents, base::JSON_PARSE_CHROMIUM_EXTENSIONS);
@@ -75,13 +84,23 @@ std::optional<base::DictValue> LoadPdfManifest(
     return std::nullopt;
   }
 
-  if (manifest->Remove("permissions")) {
-    stripped_manifest_keys->push_back("permissions");
-    LOG(INFO) << "[issue-792-exp3] pdf-component-extension-stripped-value"
-              << " key=permissions"
-              << " values=chrome://resources/,chrome://webui-test/,"
-                 "contentSettings,metricsPrivate,pdfViewerPrivate,"
-                 "resourcesPrivate,tabs,fileSystem.write";
+  if (base::ListValue* permissions = manifest->FindList("permissions")) {
+    base::ListValue kept_permissions;
+    std::vector<std::string> stripped_permissions;
+    for (const base::Value& permission : *permissions) {
+      if (permission.is_string() &&
+          (permission.GetString() == "pdfViewerPrivate" ||
+           permission.GetString() == "resourcesPrivate")) {
+        kept_permissions.Append(permission.Clone());
+        continue;
+      }
+      stripped_permissions.push_back(DescribePermissionForLog(permission));
+    }
+    manifest->Set("permissions", std::move(kept_permissions));
+    LOG(INFO) << "[issue-792-exp8] pdf-permissions-kept"
+              << " values=pdfViewerPrivate,resourcesPrivate";
+    LOG(INFO) << "[issue-792-exp8] pdf-permissions-stripped values="
+              << base::JoinString(stripped_permissions, ",");
   }
   if (manifest->Remove("web_accessible_resources")) {
     stripped_manifest_keys->push_back("web_accessible_resources");
@@ -117,8 +136,9 @@ scoped_refptr<const extensions::Extension> CreateTsPdfComponentExtension(
           extension_root, extensions::mojom::ManifestLocation::kComponent,
           *manifest, extensions::Extension::REQUIRE_KEY, error);
   if (!extension) {
-    LOG(ERROR) << "[issue-792-exp3] pdf-component-extension-create-failed error="
-               << base::UTF16ToUTF8(*error);
+    LOG(ERROR)
+        << "[issue-792-exp3] pdf-component-extension-create-failed error="
+        << base::UTF16ToUTF8(*error);
     return nullptr;
   }
 
@@ -141,7 +161,8 @@ bool RegisterTsPdfComponentExtension(BrowserContext* browser_context) {
     return false;
   }
 
-  if (registry->enabled_extensions().Contains(extension_misc::kPdfExtensionId)) {
+  if (registry->enabled_extensions().Contains(
+          extension_misc::kPdfExtensionId)) {
     LOG(INFO) << "[issue-792-exp3] pdf-component-extension-registered context="
               << browser_context << " enabled=1";
     return true;
@@ -173,8 +194,8 @@ bool RegisterTsPdfComponentExtension(BrowserContext* browser_context) {
   }
 
   LOG(INFO) << "[issue-792-exp3] pdf-component-extension-stripped-keys count="
-            << stripped_manifest_keys.size() << " keys="
-            << base::JoinString(stripped_manifest_keys, ",");
+            << stripped_manifest_keys.size()
+            << " keys=" << base::JoinString(stripped_manifest_keys, ",");
   LOG(INFO) << "[issue-792-exp3] pdf-component-extension-registered context="
             << browser_context << " enabled="
             << registry->enabled_extensions().Contains(
diff --git a/content/libtermsurf_chromium/extensions/ts_pdf_resource_bundle.cc b/content/libtermsurf_chromium/extensions/ts_pdf_resource_bundle.cc
