@@ -437,7 +461,11 @@ void PrintingContextMac::AskUserForSettings(int max_pages,
   // Exceptions can also happen when the NSPrintPanel is being
   // deallocated, so it must be autoreleased within this scope.
   @autoreleasepool {
-    DCHECK(NSThread.isMainThread);
+    const bool is_main_thread = NSThread.isMainThread;
+    TraceTermSurfPdfNativePrint(
+        base::StrCat({"mac-ask-user-enter main_thread=",
