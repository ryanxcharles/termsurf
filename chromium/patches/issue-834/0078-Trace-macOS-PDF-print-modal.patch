From 94e579f240d99bad9de011fc8f652939b997dc69 Mon Sep 17 00:00:00 2001
From: Max Commits <maxcommits@ryanxcharles.com>
Date: Mon, 22 Jun 2026 14:24:33 -0500
Subject: [PATCH 78/84] Trace macOS PDF print modal

The panel stepped on stage,
Then froze before a line.
We lit the wings with traces,
To see where print declined.
---
 .../ts_pdf_print_manager.cc                   | 54 +++++++++++++++++++
 printing/printing_context_mac.mm              | 52 +++++++++++++++++-
 2 files changed, 104 insertions(+), 2 deletions(-)

diff --git a/content/libtermsurf_chromium/ts_pdf_print_manager.cc b/content/libtermsurf_chromium/ts_pdf_print_manager.cc
index 371c80a3fe..325afb39d0 100644
--- a/content/libtermsurf_chromium/ts_pdf_print_manager.cc
+++ b/content/libtermsurf_chromium/ts_pdf_print_manager.cc
@@ -5,9 +5,16 @@
 #include "content/libtermsurf_chromium/ts_pdf_print_manager.h"
 
 #include <memory>
+#include <optional>
 #include <string>
+#include <string_view>
 
+#include "base/environment.h"
 #include "base/functional/bind.h"
+#include "base/logging.h"
+#include "base/process/process_handle.h"
+#include "base/strings/strcat.h"
+#include "base/strings/string_number_conversions.h"
 #include "components/printing/browser/print_manager_utils.h"
 #include "content/public/browser/render_frame_host.h"
 #include "content/public/browser/web_contents.h"
@@ -19,6 +26,37 @@
 namespace termsurf {
 namespace {
 
+bool IsTermSurfPdfNativePrintTraceEnabled() {
+  std::unique_ptr<base::Environment> env = base::Environment::Create();
+  std::optional<std::string> enabled =
+      env->GetVar("TERMSURF_PDF_NATIVE_PRINT_TRACE");
+  return enabled && *enabled == "1";
+}
+
+void TraceTermSurfPdfNativePrint(std::string_view event) {
+  if (!IsTermSurfPdfNativePrintTraceEnabled()) {
+    return;
+  }
+
+  LOG(INFO) << base::StrCat(
+      {"pdf-native-print pid=", base::NumberToString(base::GetCurrentProcId()),
+       " source=ts_pdf_print_manager.cc event=", event});
+}
+
+std::string ResultCodeTraceName(printing::mojom::ResultCode result) {
+  switch (result) {
+    case printing::mojom::ResultCode::kSuccess:
+      return "success";
+    case printing::mojom::ResultCode::kFailed:
+      return "failed";
+    case printing::mojom::ResultCode::kAccessDenied:
+      return "access-denied";
+    case printing::mojom::ResultCode::kCanceled:
+      return "canceled";
+  }
+  return "unknown";
+}
+
 class TsPrintingContextDelegate : public printing::PrintingContext::Delegate {
  public:
   explicit TsPrintingContextDelegate(content::WebContents* web_contents)
@@ -72,6 +110,9 @@ void TsPdfPrintManager::OnScriptedPrintSettingsReady(
     printing::mojom::ScriptedPrintParamsPtr params,
     printing::mojom::PrintManagerHost::ScriptedPrintCallback callback,
     printing::mojom::ResultCode result) {
+  TraceTermSurfPdfNativePrint(
+      base::StrCat({"ts-scripted-print-callback-result-",
+                    ResultCodeTraceName(result)}));
   if (result != printing::mojom::ResultCode::kSuccess) {
     std::move(callback).Run(nullptr);
     return;
@@ -79,6 +120,7 @@ void TsPdfPrintManager::OnScriptedPrintSettingsReady(
 
   auto settings = request->context->TakeAndResetSettings();
   if (!settings) {
+    TraceTermSurfPdfNativePrint("ts-scripted-print-callback-settings-null");
     std::move(callback).Run(nullptr);
     return;
   }
@@ -87,11 +129,13 @@ void TsPdfPrintManager::OnScriptedPrintSettingsReady(
   print_pages_params->params = CreatePrintParamsFromSettings(
       *settings, printing::PrintSettings::NewCookie());
   if (!print_pages_params->params) {
+    TraceTermSurfPdfNativePrint("ts-scripted-print-callback-params-null");
     std::move(callback).Run(nullptr);
     return;
   }
   print_pages_params->pages = settings->ranges();
 
+  TraceTermSurfPdfNativePrint("ts-scripted-print-callback-settings-ok");
   std::move(callback).Run(std::move(print_pages_params));
 }
 
@@ -148,8 +192,16 @@ void TsPdfPrintManager::GetDefaultPrintSettings(
 void TsPdfPrintManager::ScriptedPrint(
     printing::mojom::ScriptedPrintParamsPtr params,
     ScriptedPrintCallback callback) {
+  TraceTermSurfPdfNativePrint(
+      base::StrCat({"ts-scripted-print-enter expected_pages_count=",
+                    base::NumberToString(params->expected_pages_count),
+                    " has_selection=",
+                    params->has_selection ? "true" : "false",
+                    " is_scripted=", params->is_scripted ? "true" : "false",
+                    " cookie=", base::NumberToString(params->cookie)}));
   auto request_iter = pending_print_requests_.find(params->cookie);
   if (request_iter == pending_print_requests_.end()) {
+    TraceTermSurfPdfNativePrint("ts-scripted-print-missing-request");
     std::move(callback).Run(nullptr);
     return;
   }
@@ -157,11 +209,13 @@ void TsPdfPrintManager::ScriptedPrint(
   std::unique_ptr<PrintRequest> request = std::move(request_iter->second);
   pending_print_requests_.erase(request_iter);
   if (!request->context) {
+    TraceTermSurfPdfNativePrint("ts-scripted-print-context-null");
     std::move(callback).Run(nullptr);
     return;
   }
 
   request->context->set_margin_type(params->margin_type);
+  TraceTermSurfPdfNativePrint("ts-scripted-print-call-ask-user-for-settings");
   request->context->AskUserForSettings(
       static_cast<int>(params->expected_pages_count), params->has_selection,
       params->is_scripted,
