@@ -452,8 +480,15 @@ void PrintingContextMac::AskUserForSettings(int max_pages,
 
     // Set the print job title text.
     gfx::NativeView parent_view = delegate_->GetParentView();
+    TraceTermSurfPdfNativePrint(parent_view ? "mac-ask-user-parent-view-present"
