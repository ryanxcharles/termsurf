         settings_->set_ranges(GetPageRangesFromPrintInfo());
@@ -488,11 +530,17 @@ void PrintingContextMac::AskUserForSettings(int max_pages,
           result = CaptureSystemPrintDialogData(print_info_, settings_.get());
         }
 #endif
+        TraceTermSurfPdfNativePrint(
+            base::StrCat({"mac-ask-user-callback-",
+                          result == mojom::ResultCode::kSuccess ? "success"
+                                                                 : "non-success"}));
         std::move(block_callback).Run(result);
       } else {
