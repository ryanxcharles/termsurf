diff --git a/content/libtermsurf_chromium/ts_permission_manager.cc b/content/libtermsurf_chromium/ts_permission_manager.cc
new file mode 100644
index 0000000000..575f1c4455
--- /dev/null
+++ b/content/libtermsurf_chromium/ts_permission_manager.cc
@@ -0,0 +1,152 @@
+// Copyright 2025 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/libtermsurf_chromium/ts_permission_manager.h"
+
+#include <optional>
+#include <string>
+#include <vector>
+
+#include "base/functional/callback.h"
+#include "base/logging.h"
+#include "content/public/browser/permission_request_description.h"
+#include "content/public/browser/render_frame_host.h"
+#include "content/public/browser/render_process_host.h"
+#include "third_party/blink/public/common/permissions/permission_utils.h"
+#include "third_party/blink/public/mojom/permissions/permission_status.mojom.h"
+#include "url/gurl.h"
+#include "url/origin.h"
+
+namespace content {
+namespace {
+
+blink::mojom::PermissionStatus DeniedStatus() {
+  return blink::mojom::PermissionStatus::DENIED;
+}
+
+PermissionResult DeniedResult() {
+  return PermissionResult(DeniedStatus());
+}
+
+std::string PermissionNameForLog(
+    const blink::mojom::PermissionDescriptorPtr& permission_descriptor) {
+  std::optional<blink::PermissionType> permission_type =
+      blink::MaybePermissionDescriptorToPermissionType(permission_descriptor);
+  if (!permission_type.has_value()) {
+    return "unknown";
+  }
+  return blink::GetPermissionString(permission_type.value());
+}
+
+void LogDenied(const char* method,
+               const blink::mojom::PermissionDescriptorPtr& permission,
+               const GURL& requesting_origin = GURL(),
+               const GURL& embedding_origin = GURL()) {
+  LOG(INFO) << "[termsurf-permission] denied"
+            << " method=" << method
+            << " type=" << PermissionNameForLog(permission)
+            << " requesting_origin=" << requesting_origin.spec()
+            << " embedding_origin=" << embedding_origin.spec();
+}
+
+}  // namespace
+
+TsPermissionManager::TsPermissionManager() = default;
+TsPermissionManager::~TsPermissionManager() = default;
+
+void TsPermissionManager::RequestPermissionsFromCurrentDocument(
+    RenderFrameHost* render_frame_host,
+    const PermissionRequestDescription& request_description,
+    base::OnceCallback<void(const std::vector<PermissionResult>&)> callback) {
+  std::vector<PermissionResult> results;
+  results.reserve(request_description.permissions.size());
+  GURL requesting_origin = request_description.requesting_origin;
+  GURL embedding_origin;
+  if (render_frame_host) {
+    if (requesting_origin.is_empty()) {
+      requesting_origin = render_frame_host->GetLastCommittedURL();
+    }
+    if (RenderFrameHost* main_frame = render_frame_host->GetMainFrame()) {
+      embedding_origin = main_frame->GetLastCommittedURL();
+    }
+  }
+
+  for (const auto& permission : request_description.permissions) {
+    LogDenied("request-current-document", permission, requesting_origin,
+              embedding_origin);
+    results.push_back(DeniedResult());
+  }
+  std::move(callback).Run(results);
+}
+
+blink::mojom::PermissionStatus TsPermissionManager::GetPermissionStatus(
+    const blink::mojom::PermissionDescriptorPtr& permission_descriptor,
+    const GURL& requesting_origin,
+    const GURL& embedding_origin) {
+  LogDenied("status", permission_descriptor, requesting_origin,
+            embedding_origin);
+  return DeniedStatus();
+}
+
+PermissionResult
+TsPermissionManager::GetPermissionResultForOriginWithoutContext(
+    const blink::mojom::PermissionDescriptorPtr& permission_descriptor,
+    const url::Origin& requesting_origin,
+    const url::Origin& embedding_origin) {
+  LogDenied("origin-without-context", permission_descriptor,
+            requesting_origin.GetURL(), embedding_origin.GetURL());
+  return DeniedResult();
+}
+
+PermissionResult TsPermissionManager::GetPermissionResultForCurrentDocument(
+    const blink::mojom::PermissionDescriptorPtr& permission_descriptor,
+    RenderFrameHost* render_frame_host,
+    bool should_include_device_status) {
+  GURL requesting_origin;
+  GURL embedding_origin;
+  if (render_frame_host) {
+    requesting_origin = render_frame_host->GetLastCommittedURL();
+    if (RenderFrameHost* main_frame = render_frame_host->GetMainFrame()) {
+      embedding_origin = main_frame->GetLastCommittedURL();
+    }
+  }
+  LogDenied("current-document", permission_descriptor, requesting_origin,
+            embedding_origin);
+  return DeniedResult();
+}
+
+PermissionResult TsPermissionManager::GetPermissionResultForWorker(
+    const blink::mojom::PermissionDescriptorPtr& permission_descriptor,
+    RenderProcessHost* render_process_host,
+    const GURL& worker_origin) {
+  (void)render_process_host;
+  LogDenied("worker", permission_descriptor, worker_origin, worker_origin);
+  return DeniedResult();
+}
+
+PermissionResult TsPermissionManager::GetPermissionResultForEmbeddedRequester(
+    const blink::mojom::PermissionDescriptorPtr& permission_descriptor,
+    RenderFrameHost* render_frame_host,
+    const url::Origin& requesting_origin) {
+  GURL embedding_origin;
+  if (render_frame_host) {
+    if (RenderFrameHost* main_frame = render_frame_host->GetMainFrame()) {
+      embedding_origin = main_frame->GetLastCommittedURL();
+    }
+  }
+  LogDenied("embedded-requester", permission_descriptor,
+            requesting_origin.GetURL(), embedding_origin);
+  return DeniedResult();
+}
+
+void TsPermissionManager::ResetPermission(blink::PermissionType permission,
+                                          const GURL& requesting_origin,
+                                          const GURL& embedding_origin) {
+  LOG(INFO) << "[termsurf-permission] reset ignored"
+            << " type=" << blink::GetPermissionString(permission)
+            << " requesting_origin=" << requesting_origin.spec()
+            << " embedding_origin=" << embedding_origin.spec();
+}
+
+}  // namespace content
