From 890c437d5fc8a9773ed9e4de2d725b99a0aa7bb6 Mon Sep 17 00:00:00 2001
From: Max Commits <maxcommits@ryanxcharles.com>
Date: Mon, 22 Jun 2026 15:19:27 -0500
Subject: [PATCH 80/84] Probe app-modal PDF print panels

A print sheet tried the center stage,
With helper held outside the cage.
No panel sang, no queues were stirred,
But silence became a sharper word.
---
 printing/printing_context_mac.mm | 148 +++++++++++++++++++------------
 1 file changed, 93 insertions(+), 55 deletions(-)

diff --git a/printing/printing_context_mac.mm b/printing/printing_context_mac.mm
index fed3bf7135..09d030ced3 100644
--- a/printing/printing_context_mac.mm
+++ b/printing/printing_context_mac.mm
@@ -44,6 +44,40 @@
 #include "base/types/expected.h"
 #endif
 
+typedef void (^TermSurfPrintPanelCompletion)(NSInteger selection);
+
+@interface TermSurfPrintPanelDelegate : NSObject
+- (instancetype)initWithCompletion:(TermSurfPrintPanelCompletion)completion;
+- (void)printPanelDidEnd:(NSPrintPanel*)printPanel
+              returnCode:(NSInteger)returnCode
+             contextInfo:(void*)contextInfo;
+@end
+
+@implementation TermSurfPrintPanelDelegate {
+  TermSurfPrintPanelCompletion _completion;
+}
+
+- (instancetype)initWithCompletion:(TermSurfPrintPanelCompletion)completion {
+  if ((self = [super init])) {
+    _completion = [completion copy];
+  }
+  return self;
+}
+
+- (void)printPanelDidEnd:(NSPrintPanel*)printPanel
+              returnCode:(NSInteger)returnCode
+             contextInfo:(void*)contextInfo {
+  TermSurfPrintPanelDelegate* retained_self =
+      (__bridge_transfer TermSurfPrintPanelDelegate*)contextInfo;
+  TermSurfPrintPanelCompletion completion = retained_self->_completion;
+  retained_self->_completion = nil;
+  if (completion) {
+    completion(returnCode);
+  }
+}
+
+@end
+
