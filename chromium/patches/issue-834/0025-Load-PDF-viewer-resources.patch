diff --git a/content/libtermsurf_chromium/extensions/ts_pdf_resource_bundle.cc b/content/libtermsurf_chromium/extensions/ts_pdf_resource_bundle.cc
new file mode 100644
index 0000000000..c48517a134
--- /dev/null
+++ b/content/libtermsurf_chromium/extensions/ts_pdf_resource_bundle.cc
@@ -0,0 +1,67 @@
+// Copyright 2026 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/libtermsurf_chromium/extensions/ts_pdf_resource_bundle.h"
+
+#include <algorithm>
+#include <string>
+
+#include "base/base_paths.h"
+#include "base/files/file_path.h"
+#include "base/files/file_util.h"
+#include "base/logging.h"
+#include "base/path_service.h"
+#include "base/strings/string_util.h"
+#include "chrome/grit/pdf_resources.h"
+#include "ui/base/resource/resource_bundle.h"
+
+namespace content {
+namespace {
+
+bool HasHtmlSignature(std::string contents) {
+  constexpr size_t kSignatureBytes = 256;
+  if (contents.size() > kSignatureBytes) {
+    contents.resize(kSignatureBytes);
+  }
+  std::string lower = base::ToLowerASCII(contents);
+  return lower.find("<!doctype html") != std::string::npos ||
+         lower.find("<html") != std::string::npos;
+}
+
+}  // namespace
+
+void LoadTsPdfResourceBundle(const std::string& process_type) {
+  base::FilePath assets_path;
+  if (!base::PathService::Get(base::DIR_ASSETS, &assets_path)) {
+    LOG(INFO) << "[issue-792-exp4] pdf-resource-pak path= found=0 loaded=0";
+    return;
+  }
+
+  base::FilePath pak_path = assets_path.AppendASCII("gen")
+                                .AppendASCII("chrome")
+                                .AppendASCII("pdf_resources.pak");
+  const bool found = base::PathExists(pak_path);
+  if (found) {
+    ui::ResourceBundle::GetSharedInstance().AddDataPackFromPath(
+        pak_path, ui::kScaleFactorNone);
+  }
+
+  std::string index_html;
+  if (found) {
+    index_html = ui::ResourceBundle::GetSharedInstance().LoadDataResourceString(
+        IDR_PDF_INDEX_HTML);
+  }
+  const bool loaded = !index_html.empty();
+  LOG(INFO) << "[issue-792-exp4] pdf-resource-pak path="
+            << pak_path.AsUTF8Unsafe() << " found=" << found
+            << " loaded=" << loaded;
+
+  if (process_type.empty()) {
+    LOG(INFO) << "[issue-792-exp4] pdf-resource-bytes id="
+              << IDR_PDF_INDEX_HTML << " bytes=" << index_html.size()
+              << " html_signature=" << HasHtmlSignature(index_html);
+  }
+}
+
+}  // namespace content
