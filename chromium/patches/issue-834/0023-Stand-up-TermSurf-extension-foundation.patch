+#include "extensions/browser/service_worker_manager.h"
+#include "extensions/browser/user_script_manager.h"
+
+namespace content {
+
+TsExtensionSystem::TsExtensionSystem(BrowserContext* browser_context)
+    : browser_context_(browser_context),
+      store_factory_(base::MakeRefCounted<value_store::ValueStoreFactoryImpl>(
+          browser_context->GetPath())) {}
+
+TsExtensionSystem::~TsExtensionSystem() = default;
+
+void TsExtensionSystem::FinishInitialization() {
+  ready_.Signal();
+}
+
+void TsExtensionSystem::ReloadExtension(
+    const extensions::ExtensionId& extension_id) {}
+
+void TsExtensionSystem::InitForRegularProfile(bool extensions_enabled) {
+  service_worker_manager_ =
+      std::make_unique<extensions::ServiceWorkerManager>(browser_context_);
+  user_script_manager_ =
+      std::make_unique<extensions::UserScriptManager>(browser_context_);
+  quota_service_ = std::make_unique<extensions::QuotaService>();
+  app_sorting_ = std::make_unique<extensions::NullAppSorting>();
+}
+
+extensions::ExtensionService* TsExtensionSystem::extension_service() {
+  return nullptr;
+}
+
+extensions::ManagementPolicy* TsExtensionSystem::management_policy() {
+  return nullptr;
+}
+
+extensions::ServiceWorkerManager* TsExtensionSystem::service_worker_manager() {
+  return service_worker_manager_.get();
+}
+
+extensions::UserScriptManager* TsExtensionSystem::user_script_manager() {
+  return user_script_manager_.get();
+}
+
+extensions::StateStore* TsExtensionSystem::state_store() {
+  return nullptr;
+}
+
+extensions::StateStore* TsExtensionSystem::rules_store() {
+  return nullptr;
+}
+
+extensions::StateStore* TsExtensionSystem::dynamic_user_scripts_store() {
+  return nullptr;
+}
+
+scoped_refptr<value_store::ValueStoreFactory>
+TsExtensionSystem::store_factory() {
+  return store_factory_;
+}
+
+extensions::QuotaService* TsExtensionSystem::quota_service() {
+  return quota_service_.get();
+}
+
+extensions::AppSorting* TsExtensionSystem::app_sorting() {
+  return app_sorting_.get();
+}
+
+const base::OneShotEvent& TsExtensionSystem::ready() const {
+  return ready_;
+}
+
+bool TsExtensionSystem::is_ready() const {
+  return ready_.is_signaled();
+}
+
+extensions::ContentVerifier* TsExtensionSystem::content_verifier() {
+  return nullptr;
+}
+
+void TsExtensionSystem::InstallUpdate(
+    const extensions::ExtensionId& extension_id,
+    const std::string& public_key,
+    const base::FilePath& temp_dir,
+    bool install_immediately,
+    InstallUpdateCallback install_update_callback) {
+  NOTREACHED();
+}
+
+void TsExtensionSystem::PerformActionBasedOnOmahaAttributes(
+    const extensions::ExtensionId& extension_id,
+    const base::DictValue& attributes) {
+  NOTREACHED();
+}
