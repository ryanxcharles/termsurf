+extensions::KioskDelegate* TsExtensionsBrowserClient::GetKioskDelegate() {
+  if (!kiosk_delegate_) {
+    kiosk_delegate_ = std::make_unique<TsKioskDelegate>();
+  }
+  return kiosk_delegate_.get();
+}
