+  extensions::ExtensionsClient::Set(nullptr);
+  extensions_client_.reset();
+  ShellBrowserMainParts::PostDestroyThreads();
+}
+
+void TsBrowserMainParts::InitializeExtensionContext(
+    ShellBrowserContext* context,
+    bool in_memory) {
+  auto pref_service =
+      CreateTsExtensionPrefService(context, context->GetPath(), in_memory);
+  PrefService* pref_service_ptr = pref_service.get();
+  extension_pref_services_[context] = std::move(pref_service);
+  extensions_browser_client_->RegisterContext(context, pref_service_ptr);
+  LOG(INFO) << "[issue-792-exp2] extension-prefs-ready context=" << context
+            << " prefs=" << pref_service_ptr;
+
+  auto* extension_system = static_cast<TsExtensionSystem*>(
+      extensions::ExtensionSystem::Get(context));
+  CHECK(extension_system);
+  extension_system->InitForRegularProfile(/*extensions_enabled=*/true);
+  LOG(INFO) << "[issue-792-exp2] extension-system-init-for-regular-profile"
+            << " context=" << context;
+  extension_system->FinishInitialization();
+  LOG(INFO) << "[issue-792-exp2] extension-system-finish-initialization"
+            << " context=" << context;
+
+  auto* registry = extensions::ExtensionRegistry::Get(context);
+  LOG(INFO) << "[issue-792-exp2] extension-system-ready context=" << context
+            << " registry=" << registry
+            << " is_ready=" << extension_system->is_ready();
+}
