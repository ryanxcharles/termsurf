@@ -0,0 +1,52 @@
+// Copyright 2026 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/libtermsurf_chromium/extensions/ts_extension_prefs.h"
+
+#include "base/files/file_path.h"
+#include "base/memory/ref_counted.h"
+#include "components/pref_registry/pref_registry_syncable.h"
+#include "components/prefs/json_pref_store.h"
+#include "components/prefs/pref_registry_simple.h"
+#include "components/prefs/pref_service.h"
+#include "components/prefs/pref_service_factory.h"
+#include "components/user_prefs/user_prefs.h"
+#include "content/public/browser/browser_context.h"
+#include "extensions/browser/extension_prefs.h"
+#include "extensions/browser/permissions_manager.h"
+
+namespace content {
+namespace {
+
+scoped_refptr<PersistentPrefStore> CreatePrefStore(
+    const base::FilePath& profile_path,
+    bool is_off_the_record) {
+  const char* file_name = is_off_the_record
+                              ? "termsurf_extension_prefs_otr.json"
+                              : "termsurf_extension_prefs.json";
+  auto store =
+      base::MakeRefCounted<JsonPrefStore>(profile_path.AppendASCII(file_name));
+  store->ReadPrefs();
+  return store;
+}
+
+}  // namespace
+
+std::unique_ptr<PrefService> CreateTsExtensionPrefService(
+    BrowserContext* browser_context,
+    const base::FilePath& profile_path,
+    bool is_off_the_record) {
+  PrefServiceFactory factory;
+  factory.set_user_prefs(CreatePrefStore(profile_path, is_off_the_record));
+
+  auto* registry = new user_prefs::PrefRegistrySyncable;
+  extensions::ExtensionPrefs::RegisterProfilePrefs(registry);
+  extensions::PermissionsManager::RegisterProfilePrefs(registry);
+
+  std::unique_ptr<PrefService> pref_service = factory.Create(registry);
+  user_prefs::UserPrefs::Set(browser_context, pref_service.get());
+  return pref_service;
+}
+
+}  // namespace content
