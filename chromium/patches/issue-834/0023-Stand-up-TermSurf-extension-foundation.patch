+extensions::SafeBrowsingDelegate*
+TsExtensionsBrowserClient::GetSafeBrowsingDelegate() {
+  return safe_browsing_delegate_.get();
+}
+
+std::string TsExtensionsBrowserClient::GetApplicationLocale() {
+  return "en-US";
+}
+
+custom_handlers::ProtocolHandlerRegistry*
+TsExtensionsBrowserClient::GetProtocolHandlerRegistry(BrowserContext* context) {
+  return custom_handlers::SimpleProtocolHandlerRegistryFactory::
+      GetForBrowserContext(context, true);
+}
+
+void TsExtensionsBrowserClient::RegisterContext(BrowserContext* context,
+                                                PrefService* pref_service) {
+  pref_services_[context] = pref_service;
+}
+
+void TsExtensionsBrowserClient::SetOffTheRecordContext(
+    BrowserContext* original,
+    BrowserContext* off_the_record) {
+  off_the_record_contexts_[original] = off_the_record;
+  original_contexts_[off_the_record] = original;
+}
+
+BrowserContext* TsExtensionsBrowserClient::OriginalContextFor(
+    BrowserContext* context) const {
+  auto it = original_contexts_.find(context);
+  return it == original_contexts_.end() ? context : it->second.get();
+}
