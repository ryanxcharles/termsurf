+// Copyright 2026 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/libtermsurf_chromium/extensions/ts_extension_system_factory.h"
+
+#include "components/keyed_service/content/browser_context_dependency_manager.h"
+#include "content/libtermsurf_chromium/extensions/ts_extension_system.h"
+#include "extensions/browser/extension_prefs_factory.h"
+#include "extensions/browser/extension_registry_factory.h"
+
+namespace content {
+
+TsExtensionSystemFactory* TsExtensionSystemFactory::GetInstance() {
+  static base::NoDestructor<TsExtensionSystemFactory> instance;
+  return instance.get();
+}
+
+extensions::ExtensionSystem* TsExtensionSystemFactory::GetForBrowserContext(
+    BrowserContext* context) {
+  return static_cast<TsExtensionSystem*>(
+      GetInstance()->GetServiceForBrowserContext(context, true));
+}
+
+TsExtensionSystemFactory::TsExtensionSystemFactory()
+    : extensions::ExtensionSystemProvider(
+          "TsExtensionSystem",
+          BrowserContextDependencyManager::GetInstance()) {
+  DependsOn(extensions::ExtensionPrefsFactory::GetInstance());
+  DependsOn(extensions::ExtensionRegistryFactory::GetInstance());
+}
+
+TsExtensionSystemFactory::~TsExtensionSystemFactory() = default;
+
+std::unique_ptr<KeyedService>
+TsExtensionSystemFactory::BuildServiceInstanceForBrowserContext(
+    BrowserContext* context) const {
+  return std::make_unique<TsExtensionSystem>(context);
+}
+
+BrowserContext* TsExtensionSystemFactory::GetBrowserContextToUse(
+    BrowserContext* context) const {
+  return context;
+}
+
+bool TsExtensionSystemFactory::ServiceIsCreatedWithBrowserContext() const {
+  return true;
+}
+
+}  // namespace content
