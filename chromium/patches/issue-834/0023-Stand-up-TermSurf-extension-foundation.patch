+  EnsureTsBrowserContextKeyedServiceFactoriesBuilt();
+  LOG(INFO) << "[issue-792-exp2] keyed-service-factories-built";
+
+  set_browser_context(new ShellBrowserContext(false, true));
+  set_off_the_record_browser_context(new ShellBrowserContext(true, true));
+
+  InitializeExtensionContext(browser_context(), false);
