+std::optional<base::FilePath> GetTermSurfPdfNativePrintTracePath() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (command_line->HasSwitch(kTsPdfNativePrintTraceSwitch)) {
+    base::FilePath path =
+        command_line->GetSwitchValuePath(kTsPdfNativePrintTraceFileSwitch);
+    if (!path.empty()) {
+      return path;
+    }
+  }
+
+  std::unique_ptr<base::Environment> env = base::Environment::Create();
+  std::optional<std::string> enabled =
+      env->GetVar("TERMSURF_PDF_NATIVE_PRINT_TRACE");
+  if (!enabled || *enabled != "1") {
+    return std::nullopt;
+  }
+
+  std::optional<std::string> path =
+      env->GetVar("TERMSURF_PDF_NATIVE_PRINT_TRACE_FILE");
+  if (!path || path->empty()) {
+    return std::nullopt;
+  }
+
+  return base::FilePath::FromUTF8Unsafe(*path);
+}
+
+std::string TermSurfPdfPrintDocumentUrl(content::RenderFrame* render_frame) {
+  if (!render_frame || !render_frame->GetWebFrame()) {
+    return "";
+  }
+  return render_frame->GetWebFrame()->GetDocument().Url().GetString().Utf8();
+}
+
+void TraceTermSurfPdfNativePrint(content::RenderFrame* render_frame,
+                                 std::string_view event,
+                                 bool has_helper) {
+  std::optional<base::FilePath> trace_path =
+      GetTermSurfPdfNativePrintTracePath();
+  if (!trace_path) {
+    return;
+  }
+
+#if BUILDFLAG(ENABLE_PRINTING)
+  const char kEnablePrinting[] = "1";
+#else
+  const char kEnablePrinting[] = "0";
+#endif
+  const std::string line = base::StrCat(
+      {"pdf-native-print pid=", base::NumberToString(base::GetCurrentProcId()),
+       " source=pdf_view_web_plugin_client.cc event=", event, " render_frame=",
+       base::NumberToString(reinterpret_cast<uintptr_t>(render_frame)),
+       " helper=", has_helper ? "present" : "missing",
+       " enable_printing=", kEnablePrinting,
+       " document_url=", TermSurfPdfPrintDocumentUrl(render_frame), "\n"});
+  base::AppendToFile(*trace_path, line);
+}
+
 }  // namespace
 
 PdfViewWebPluginClient::PdfViewWebPluginClient(
@@ -368,7 +433,16 @@ void PdfViewWebPluginClient::Print() {
     return;
   }
 #if BUILDFLAG(ENABLE_PRINTING)
-  printing::PrintRenderFrameHelper::Get(render_frame_)->PrintNode(element);
+  auto* print_helper = printing::PrintRenderFrameHelper::Get(render_frame_);
+  TraceTermSurfPdfNativePrint(render_frame_, "client-print", print_helper);
+  if (!print_helper) {
+    TraceTermSurfPdfNativePrint(render_frame_, "helper-missing", false);
+    return;
+  }
+  TraceTermSurfPdfNativePrint(render_frame_, "print-node", true);
+  print_helper->PrintNode(element);
+#else
+  TraceTermSurfPdfNativePrint(render_frame_, "printing-disabled", false);
 #endif  // BUILDFLAG(ENABLE_PRINTING)
 }
 
