+
+void TsBrowserClient::RegisterAssociatedInterfaceBindersForRenderFrameHost(
+    RenderFrameHost& render_frame_host,
+    blink::AssociatedInterfaceRegistry& associated_registry) {
+  ShellContentBrowserClient::
+      RegisterAssociatedInterfaceBindersForRenderFrameHost(render_frame_host,
+                                                           associated_registry);
+  associated_registry.AddInterface<pdf::mojom::PdfHost>(base::BindRepeating(
+      [](RenderFrameHost* render_frame_host,
+         mojo::PendingAssociatedReceiver<pdf::mojom::PdfHost> receiver) {
+        LOG(INFO) << "[issue-792-exp10] pdf-host-binder frame_url="
+                  << render_frame_host->GetLastCommittedURL() << " site_url="
+                  << render_frame_host->GetSiteInstance()->GetSiteURL();
+        pdf::PDFDocumentHelper::BindPdfHost(
+            std::move(receiver), render_frame_host,
+            std::make_unique<pdf::TsPDFDocumentHelperClient>());
+      },
+      &render_frame_host));
 }
 
