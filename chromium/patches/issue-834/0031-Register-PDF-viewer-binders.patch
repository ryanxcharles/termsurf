index 0000000000..f5ea3ecf71
--- /dev/null
+++ b/content/libtermsurf_chromium/ts_pdf_help_bubble_handler_factory.cc
@@ -0,0 +1,77 @@
+// Copyright 2025 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/libtermsurf_chromium/ts_pdf_help_bubble_handler_factory.h"
+
+#include <memory>
+#include <string>
+#include <utility>
+
+#include "base/logging.h"
+#include "content/public/browser/render_frame_host.h"
+#include "content/public/browser/site_instance.h"
+#include "extensions/common/constants.h"
+#include "mojo/public/cpp/bindings/self_owned_receiver.h"
+#include "url/gurl.h"
+
+namespace pdf {
+namespace {
+
+bool IsPdfExtensionFrame(content::RenderFrameHost* render_frame_host) {
+  const GURL& url = render_frame_host->GetLastCommittedURL();
+  return url.SchemeIs(extensions::kExtensionScheme) &&
+         url.host() == extension_misc::kPdfExtensionId;
+}
+
+class TsPdfHelpBubbleHandlerFactory
+    : public help_bubble::mojom::PdfHelpBubbleHandlerFactory {
+ public:
+  TsPdfHelpBubbleHandlerFactory(std::string frame_url, std::string site_url)
+      : frame_url_(std::move(frame_url)), site_url_(std::move(site_url)) {}
+
+  TsPdfHelpBubbleHandlerFactory(const TsPdfHelpBubbleHandlerFactory&) = delete;
+  TsPdfHelpBubbleHandlerFactory& operator=(
+      const TsPdfHelpBubbleHandlerFactory&) = delete;
+
+  ~TsPdfHelpBubbleHandlerFactory() override = default;
+
+  // help_bubble::mojom::PdfHelpBubbleHandlerFactory:
+  void CreateHelpBubbleHandler(
+      mojo::PendingRemote<help_bubble::mojom::HelpBubbleClient> client,
+      mojo::PendingReceiver<help_bubble::mojom::HelpBubbleHandler> handler)
+      override {
+    LOG(INFO) << "[issue-792-exp10] pdf-help-bubble-create-handler frame_url="
+              << frame_url_ << " site_url=" << site_url_;
+  }
+
+ private:
+  std::string frame_url_;
+  std::string site_url_;
+};
+
+}  // namespace
+
+void BindTsPdfHelpBubbleHandlerFactory(
+    content::RenderFrameHost* render_frame_host,
+    mojo::PendingReceiver<help_bubble::mojom::PdfHelpBubbleHandlerFactory>
+        receiver) {
+  const std::string frame_url =
+      render_frame_host->GetLastCommittedURL().spec();
+  const std::string site_url =
+      render_frame_host->GetSiteInstance()->GetSiteURL().spec();
+
+  if (!IsPdfExtensionFrame(render_frame_host)) {
+    LOG(INFO) << "[issue-792-exp10] pdf-help-bubble-binder-reject frame_url="
+              << frame_url << " site_url=" << site_url;
+    return;
+  }
+
+  LOG(INFO) << "[issue-792-exp10] pdf-help-bubble-binder frame_url="
+            << frame_url << " site_url=" << site_url;
+  mojo::MakeSelfOwnedReceiver(
+      std::make_unique<TsPdfHelpBubbleHandlerFactory>(frame_url, site_url),
+      std::move(receiver));
+}
+
+}  // namespace pdf
