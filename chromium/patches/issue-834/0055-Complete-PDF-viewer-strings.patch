 TsComponentExtensionResourceManager::TsComponentExtensionResourceManager() {
   for (const auto& resource : kPdfResources) {
     path_to_resource_id_[NormalizeAsciiPath(resource.path)] = resource.id;
   }
+  PopulatePdfTemplateReplacements(&pdf_template_replacements_);
 
   LOG(INFO) << "[issue-792-exp3] pdf-resource-manager-ready count="
             << path_to_resource_id_.size() << " manifest_parsed=0";
@@ -47,8 +234,9 @@ bool TsComponentExtensionResourceManager::IsComponentExtensionResource(
     *resource_id = entry->second;
   }
   LOG(INFO) << "[issue-792-exp3] pdf-component-resource path="
-            << resource_path.AsUTF8Unsafe() << " resource_id="
-            << (found ? entry->second : 0) << " found=" << found;
+            << resource_path.AsUTF8Unsafe()
+            << " resource_id=" << (found ? entry->second : 0)
+            << " found=" << found;
   return found;
 }
 
