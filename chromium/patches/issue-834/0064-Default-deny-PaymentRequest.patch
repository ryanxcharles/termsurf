diff --git a/content/libtermsurf_chromium/ts_payment_request.cc b/content/libtermsurf_chromium/ts_payment_request.cc
new file mode 100644
index 0000000000..8e5f0c3d99
--- /dev/null
+++ b/content/libtermsurf_chromium/ts_payment_request.cc
@@ -0,0 +1,88 @@
+// Copyright 2026 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/libtermsurf_chromium/ts_payment_request.h"
+
+#include <memory>
+#include <utility>
+#include <vector>
+
+#include "mojo/public/cpp/bindings/remote.h"
+#include "mojo/public/cpp/bindings/self_owned_receiver.h"
+#include "third_party/blink/public/mojom/payments/payment_request.mojom.h"
+
+namespace content {
+namespace {
+
+class TsPaymentRequest final : public payments::mojom::PaymentRequest {
+ public:
+  TsPaymentRequest() = default;
+  TsPaymentRequest(const TsPaymentRequest&) = delete;
+  TsPaymentRequest& operator=(const TsPaymentRequest&) = delete;
+  ~TsPaymentRequest() override = default;
+
+  // payments::mojom::PaymentRequest:
+  void Init(mojo::PendingRemote<payments::mojom::PaymentRequestClient> client,
+            std::vector<payments::mojom::PaymentMethodDataPtr> method_data,
+            payments::mojom::PaymentDetailsPtr details,
+            payments::mojom::PaymentOptionsPtr options) override {
+    client_.Bind(std::move(client));
+  }
+
+  void Show(bool wait_for_updated_details, bool had_user_activation) override {
+    SendUnsupported();
+  }
+
+  void UpdateWith(payments::mojom::PaymentDetailsPtr details) override {}
+
+  void OnPaymentDetailsNotUpdated() override {}
+
+  void Abort() override {
+    if (client_) {
+      client_->OnAbort(false);
+    }
+  }
+
+  void Complete(payments::mojom::PaymentComplete result) override {}
+
+  void Retry(payments::mojom::PaymentValidationErrorsPtr errors) override {
+    SendUnsupported();
+  }
+
+  void CanMakePayment() override {
+    if (client_) {
+      client_->OnCanMakePayment(
+          payments::mojom::CanMakePaymentQueryResult::CANNOT_MAKE_PAYMENT);
+    }
+  }
+
+  void HasEnrolledInstrument() override {
+    if (client_) {
+      client_->OnHasEnrolledInstrument(
+          payments::mojom::HasEnrolledInstrumentQueryResult::
+              HAS_NO_ENROLLED_INSTRUMENT);
+    }
+  }
+
+ private:
+  void SendUnsupported() {
+    if (client_) {
+      client_->OnError(payments::mojom::PaymentErrorReason::NOT_SUPPORTED,
+                       "Payment Request is not supported in TermSurf");
+    }
+  }
+
+  mojo::Remote<payments::mojom::PaymentRequestClient> client_;
+};
+
+}  // namespace
+
+void BindTsPaymentRequest(
+    RenderFrameHost* render_frame_host,
+    mojo::PendingReceiver<payments::mojom::PaymentRequest> receiver) {
+  mojo::MakeSelfOwnedReceiver(std::make_unique<TsPaymentRequest>(),
+                              std::move(receiver));
+}
+
+}  // namespace content
diff --git a/content/libtermsurf_chromium/ts_payment_request.h b/content/libtermsurf_chromium/ts_payment_request.h
