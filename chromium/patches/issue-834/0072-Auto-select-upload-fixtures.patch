@@ -0,0 +1,144 @@
+// Copyright 2026 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/libtermsurf_chromium/ts_file_select_helper.h"
+
+#include <stdint.h>
+#include <sys/stat.h>
+
+#include <utility>
+#include <vector>
+
+#include "base/command_line.h"
+#include "base/files/file_path.h"
+#include "base/logging.h"
+#include "content/public/browser/file_select_listener.h"
+#include "content/public/browser/render_frame_host.h"
+#include "third_party/blink/public/mojom/choosers/file_chooser.mojom.h"
+
+namespace content {
+namespace {
+
+constexpr char kTermSurfFileUploadAutoSelectSwitch[] =
+    "termsurf-file-upload-auto-select";
+
+const char* FileChooserModeName(blink::mojom::FileChooserParams::Mode mode) {
+  switch (mode) {
+    case blink::mojom::FileChooserParams::Mode::kOpen:
+      return "kOpen";
+    case blink::mojom::FileChooserParams::Mode::kOpenMultiple:
+      return "kOpenMultiple";
+    case blink::mojom::FileChooserParams::Mode::kUploadFolder:
+      return "kUploadFolder";
+    case blink::mojom::FileChooserParams::Mode::kOpenDirectory:
+      return "kOpenDirectory";
+    case blink::mojom::FileChooserParams::Mode::kSave:
+      return "kSave";
+  }
+}
+
+void LogChooserRequest(const char* event,
+                       const blink::mojom::FileChooserParams& params) {
+  LOG(INFO) << "[termsurf-file-upload] " << event
+            << " mode=" << FileChooserModeName(params.mode)
+            << " need_local_path=" << (params.need_local_path ? 1 : 0)
+            << " use_media_capture=" << (params.use_media_capture ? 1 : 0)
+            << " open_writable=" << (params.open_writable ? 1 : 0);
+}
+
+bool IsOrdinaryReadOnlyUpload(const blink::mojom::FileChooserParams& params,
+                              const char** reason) {
+  if (params.mode != blink::mojom::FileChooserParams::Mode::kOpen &&
+      params.mode != blink::mojom::FileChooserParams::Mode::kOpenMultiple) {
+    *reason = "unsupported-mode";
+    return false;
+  }
+  if (params.use_media_capture) {
+    *reason = "media-capture";
+    return false;
+  }
+  if (params.open_writable) {
+    *reason = "writable";
+    return false;
+  }
+  return true;
+}
+
+bool IsValidUploadFixturePath(const base::FilePath& path,
+                              int64_t* size,
+                              const char** reason) {
+  if (path.empty()) {
+    *reason = "empty-path";
+    return false;
+  }
+  if (!path.IsAbsolute()) {
+    *reason = "relative-path";
+    return false;
+  }
+  struct stat stat_info;
+  if (lstat(path.value().c_str(), &stat_info) != 0) {
+    *reason = "missing-path";
+    return false;
+  }
+  if (S_ISLNK(stat_info.st_mode)) {
+    *reason = "symlink";
+    return false;
+  }
+  if (S_ISDIR(stat_info.st_mode)) {
+    *reason = "directory";
+    return false;
+  }
+  if (!S_ISREG(stat_info.st_mode)) {
+    *reason = "non-regular-file";
+    return false;
+  }
+  *size = stat_info.st_size;
+  return true;
+}
+
+}  // namespace
+
+bool MaybeRunTsFileChooser(RenderFrameHost* render_frame_host,
+                           scoped_refptr<FileSelectListener> listener,
+                           const blink::mojom::FileChooserParams& params) {
+  base::CommandLine* command_line = base::CommandLine::ForCurrentProcess();
+  if (!command_line->HasSwitch(kTermSurfFileUploadAutoSelectSwitch)) {
+    return false;
+  }
+
+  LogChooserRequest("request", params);
+
+  const char* reason = nullptr;
+  if (!IsOrdinaryReadOnlyUpload(params, &reason)) {
+    LOG(WARNING) << "[termsurf-file-upload] cancelled reason=" << reason;
+    listener->FileSelectionCanceled();
+    return true;
+  }
+
+  base::FilePath selected_path =
+      command_line->GetSwitchValuePath(kTermSurfFileUploadAutoSelectSwitch);
+  int64_t selected_size = 0;
+  if (!IsValidUploadFixturePath(selected_path, &selected_size, &reason)) {
+    LOG(WARNING) << "[termsurf-file-upload] cancelled reason=" << reason
+                 << " path=" << selected_path.AsUTF8Unsafe();
+    listener->FileSelectionCanceled();
+    return true;
+  }
+
+  std::vector<blink::mojom::FileChooserFileInfoPtr> files;
+  files.push_back(blink::mojom::FileChooserFileInfo::NewNativeFile(
+      blink::mojom::NativeFileInfo::New(
+          selected_path, selected_path.BaseName().AsUTF16Unsafe(),
+          std::vector<std::u16string>())));
+
+  LOG(INFO) << "[termsurf-file-upload] selected"
+            << " path=" << selected_path.AsUTF8Unsafe()
+            << " basename=" << selected_path.BaseName().AsUTF8Unsafe()
+            << " size=" << selected_size << " frame=" << render_frame_host;
+
+  listener->FileSelected(std::move(files), base::FilePath(), params.mode);
+  return true;
+}
+
+}  // namespace content
