@@ -0,0 +1,158 @@
+// Copyright 2025 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/libtermsurf_chromium/ts_shell_window_mac.h"
+
+#import <Cocoa/Cocoa.h>
+
+#include <algorithm>
+#include <cmath>
+#include <cstdlib>
+#include <string>
+
+#include "base/logging.h"
+#include "base/strings/sys_string_conversions.h"
+#include "content/public/browser/web_contents.h"
+#include "content/shell/browser/shell.h"
+#include "ui/gfx/native_ui_types.h"
+
+namespace content {
+namespace {
+
+bool Issue779TraceEnabled() {
+  static const bool enabled =
+      std::getenv("TERMSURF_ISSUE_779_TRACE") != nullptr;
+  return enabled;
+}
+
+void Issue779TraceAnnounce() {
+  static bool announced = false;
+  if (!announced) {
+    announced = true;
+    LOG(INFO) << "[issue-779-trace] trace_enabled component=chromium-shell-window";
+  }
+}
+
+std::string NSRectToString(NSRect rect) {
+  return base::SysNSStringToUTF8(NSStringFromRect(rect));
+}
+
+bool NearlyEqual(CGFloat lhs, CGFloat rhs) {
+  return std::abs(lhs - rhs) <= 0.5;
+}
+
+bool RectNearlyEqual(NSRect lhs, NSRect rhs) {
+  return NearlyEqual(lhs.origin.x, rhs.origin.x) &&
+         NearlyEqual(lhs.origin.y, rhs.origin.y) &&
+         NearlyEqual(lhs.size.width, rhs.size.width) &&
+         NearlyEqual(lhs.size.height, rhs.size.height);
+}
+
+NSString* BoolString(BOOL value) {
+  return value ? @"true" : @"false";
+}
+
+NSRect PrimaryScreenFrame() {
+  NSScreen* screen = NSScreen.screens.firstObject ?: NSScreen.mainScreen;
+  if (!screen)
+    return NSZeroRect;
+  return screen.frame;
+}
+
+}  // namespace
+
+void MoveShellWindowToTermSurfScreenRect(Shell* shell,
+                                         double screen_x,
+                                         double screen_y,
+                                         double screen_width,
+                                         double screen_height,
+                                         double screen_scale,
+                                         const gfx::Size& content_size) {
+  if (!shell || screen_width <= 0 || screen_height <= 0)
+    return;
+
+  NSWindow* window = shell->window().GetNativeNSWindow();
+  if (!window)
+    return;
+
+  NSRect primary_frame = PrimaryScreenFrame();
+  if (NSIsEmptyRect(primary_frame))
+    return;
+
+  NSView* content_view = window.contentView;
+  NSView* web_view = shell->web_contents()
+                         ? shell->web_contents()->GetNativeView().GetNativeNSView()
+                         : nil;
+  CGFloat web_chrome_height = 0;
+  if (content_view && web_view) {
+    web_chrome_height =
+        std::max<CGFloat>(0, NSHeight(content_view.frame) - NSHeight(web_view.frame));
+  }
+  NSRect target_webview_frame = NSMakeRect(
+      screen_x,
+      NSMaxY(primary_frame) - screen_y - screen_height,
+      screen_width,
+      screen_height);
+  NSRect target_content_frame =
+      NSMakeRect(screen_x, NSMinY(target_webview_frame), screen_width,
+                 screen_height + web_chrome_height);
+  NSRect target_frame = [window frameRectForContentRect:target_content_frame];
+  NSRect current_frame = window.frame;
+  BOOL already_there = RectNearlyEqual(current_frame, target_frame);
+
+  if (Issue779TraceEnabled()) {
+    Issue779TraceAnnounce();
+    LOG(INFO) << "[issue-779-trace] content_shell_window"
+              << " event=TermSurfMoveShellWindow.before"
+              << " shell=" << static_cast<void*>(shell)
+              << " webcontents=" << static_cast<void*>(shell->web_contents())
+              << " window=" << (__bridge void*)window
+              << " screen_top_left=(" << screen_x << "," << screen_y << " "
+              << screen_width << "x" << screen_height << ")"
+              << " screen_scale=" << screen_scale
+              << " primary_screen_frame=" << NSRectToString(primary_frame)
+              << " current_frame=" << NSRectToString(current_frame)
+              << " target_webview_frame=" << NSRectToString(target_webview_frame)
+              << " target_content_frame=" << NSRectToString(target_content_frame)
+              << " target_window_frame=" << NSRectToString(target_frame)
+              << " web_chrome_height=" << web_chrome_height
+              << " already_there=" << BoolString(already_there)
+              << " alphaValue=" << window.alphaValue
+              << " isVisible=" << BoolString(window.isVisible)
+              << " ignoresMouseEvents=" << BoolString(window.ignoresMouseEvents)
+              << " level=" << window.level
+              << " styleMask=" << window.styleMask
+              << " collectionBehavior=" << window.collectionBehavior
+              << " isKey=" << BoolString(window.isKeyWindow)
+              << " isMain=" << BoolString(window.isMainWindow)
+              << " content_size=" << content_size.ToString();
+  }
+
+  if (!already_there)
+    [window setFrame:target_frame display:NO];
+
+  if (Issue779TraceEnabled()) {
+    LOG(INFO) << "[issue-779-trace] content_shell_window"
+              << " event=TermSurfMoveShellWindow.after"
+              << " shell=" << static_cast<void*>(shell)
+              << " webcontents=" << static_cast<void*>(shell->web_contents())
+              << " window=" << (__bridge void*)window
+              << " window_frame=" << NSRectToString(window.frame)
+              << " content_frame="
+              << (content_view ? NSRectToString(content_view.frame)
+                               : std::string("null"))
+              << " web_view=" << (__bridge void*)web_view
+              << " web_view_frame="
+              << (web_view ? NSRectToString(web_view.frame)
+                           : std::string("null"))
+              << " alphaValue=" << window.alphaValue
+              << " isVisible=" << BoolString(window.isVisible)
+              << " ignoresMouseEvents=" << BoolString(window.ignoresMouseEvents)
+              << " level=" << window.level
+              << " isKey=" << BoolString(window.isKeyWindow)
+              << " isMain=" << BoolString(window.isMainWindow);
+  }
+}
+
+}  // namespace content
