+void TsBrowserClient::CreateThrottlesForNavigation(
+    NavigationThrottleRegistry& registry) {
+  ShellContentBrowserClient::CreateThrottlesForNavigation(registry);
+  TsPdfIframeNavigationThrottle::MaybeCreateAndAdd(registry);
+  registry.AddThrottle(std::make_unique<pdf::PdfNavigationThrottle>(
+      registry, std::make_unique<TsPdfStreamDelegate>()));
+  NavigationHandle& handle = registry.GetNavigationHandle();
+  LOG(INFO) << "[issue-792-exp14] navigation-throttles frame_tree_node_id="
+            << handle.GetFrameTreeNodeId() << " url=" << handle.GetURL()
+            << " pdf_throttle=1 iframe_throttle="
+            << (handle.IsInMainFrame() ? 0 : 1);
+}
+
+std::vector<std::unique_ptr<blink::URLLoaderThrottle>>
+TsBrowserClient::CreateURLLoaderThrottles(
+    const network::ResourceRequest& request,
+    BrowserContext* browser_context,
+    const base::RepeatingCallback<WebContents*()>& wc_getter,
+    NavigationUIData* navigation_ui_data,
+    FrameTreeNodeId frame_tree_node_id,
+    std::optional<int64_t> navigation_id) {
+  auto result = ShellContentBrowserClient::CreateURLLoaderThrottles(
+      request, browser_context, wc_getter, navigation_ui_data,
+      frame_tree_node_id, navigation_id);
+  result.push_back(
+      std::make_unique<TsPluginResponseInterceptorURLLoaderThrottle>(
+          request.destination, frame_tree_node_id));
+  LOG(INFO) << "[issue-792-exp14] url-loader-throttle destination="
+            << static_cast<int>(request.destination)
+            << " frame_tree_node_id=" << frame_tree_node_id
+            << " plugin_interceptor=1";
+  return result;
+}
+
+std::vector<std::unique_ptr<URLLoaderRequestInterceptor>>
+TsBrowserClient::WillCreateURLLoaderRequestInterceptors(
+    NavigationUIData* navigation_ui_data,
+    FrameTreeNodeId frame_tree_node_id,
+    int64_t navigation_id,
+    bool force_no_https_upgrade,
+    scoped_refptr<base::SequencedTaskRunner> navigation_response_task_runner) {
+  auto interceptors =
+      ShellContentBrowserClient::WillCreateURLLoaderRequestInterceptors(
+          navigation_ui_data, frame_tree_node_id, navigation_id,
+          force_no_https_upgrade, navigation_response_task_runner);
+  auto pdf_interceptor =
+      pdf::PdfURLLoaderRequestInterceptor::MaybeCreateInterceptor(
+          frame_tree_node_id, std::make_unique<TsPdfStreamDelegate>());
+  LOG(INFO) << "[issue-792-exp14] pdf-request-interceptor frame_tree_node_id="
+            << frame_tree_node_id << " created=" << (pdf_interceptor ? 1 : 0);
+  if (pdf_interceptor) {
+    interceptors.push_back(std::move(pdf_interceptor));
+  }
+  return interceptors;
+}
+
+base::flat_set<std::string>
+TsBrowserClient::GetPluginMimeTypesWithExternalHandlers(
+    BrowserContext* browser_context) {
+  base::flat_set<std::string> mime_types;
+  auto map = GetTsPluginMimeTypeToExtensionIdMap(browser_context);
+  for (const auto& pair : map) {
+    mime_types.insert(pair.first);
+  }
+  LOG(INFO) << "[issue-792-exp14] external-plugin-mime-types count="
+            << mime_types.size()
+            << " has_pdf=" << (mime_types.contains(pdf::kPDFMimeType) ? 1 : 0);
+  return mime_types;
+}
