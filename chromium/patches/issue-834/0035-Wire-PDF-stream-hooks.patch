+TsPdfStreamDelegate::TsPdfStreamDelegate() = default;
+TsPdfStreamDelegate::~TsPdfStreamDelegate() = default;
+
+std::optional<GURL> TsPdfStreamDelegate::MapToOriginalUrl(
+    NavigationHandle& navigation_handle) {
+  RenderFrameHost* embedder_frame = navigation_handle.GetParentFrame();
+  if (!embedder_frame) {
+    LOG(INFO) << "[issue-792-exp14] pdf-map-to-original stream_url="
+              << navigation_handle.GetURL() << " original_url= success=0";
+    return std::nullopt;
+  }
+
+  if (TsStreamInfoHelper::GetForCurrentDocument(embedder_frame)) {
+    return std::nullopt;
+  }
+
+  WebContents* contents = navigation_handle.GetWebContents();
+  base::WeakPtr<extensions::StreamContainer> stream;
+  RenderFrameHost* embedder_parent_frame = embedder_frame->GetParent();
+  if (chrome_pdf::features::IsOopifPdfEnabled() && embedder_parent_frame) {
+    auto* manager = pdf::PdfViewerStreamManager::FromWebContents(contents);
+    if (manager) {
+      stream = manager->GetStreamContainer(embedder_parent_frame);
+    }
+  }
+
+  const GURL& stream_url = navigation_handle.GetURL();
+  if (!stream || stream->extension_id() != extension_misc::kPdfExtensionId ||
+      stream->stream_url() != stream_url || !stream->pdf_plugin_attributes()) {
+    LOG(INFO) << "[issue-792-exp14] pdf-map-to-original stream_url="
+              << stream_url << " original_url= success=0";
+    return std::nullopt;
+  }
+
+  pdf::PdfStreamDelegate::StreamInfo info;
+  info.background_color = base::checked_cast<SkColor>(
+      stream->pdf_plugin_attributes()->background_color);
+  info.full_frame = !stream->embedded();
+  info.allow_javascript = stream->pdf_plugin_attributes()->allow_javascript;
+  info.use_skia =
+      base::FeatureList::IsEnabled(chrome_pdf::features::kPdfUseSkiaRenderer);
+  info.allow_xfa_forms =
+      base::FeatureList::IsEnabled(chrome_pdf::features::kPdfXfaSupport);
+
+  net::HttpResponseHeaders* response_headers = stream->response_headers();
+  if (response_headers) {
+    std::optional<std::string> coep_header =
+        response_headers->GetNormalizedHeader("Cross-Origin-Embedder-Policy");
+    if (coep_header.has_value()) {
+      info.coep_header = coep_header.value();
+    }
+  }
+
+  static const base::NoDestructor<std::string> injected_script(
+      ui::ResourceBundle::GetSharedInstance().LoadDataResourceString(
+          IDR_PDF_PDF_INTERNAL_PLUGIN_WRAPPER_ROLLUP_JS));
+
+  const GURL original_url = stream->original_url();
+  info.stream_url = stream_url;
+  info.original_url = original_url;
+  info.injected_script = injected_script.get();
+
+  TsStreamInfoHelper::CreateForCurrentDocument(embedder_frame,
+                                               std::move(info));
+  LOG(INFO) << "[issue-792-exp14] pdf-map-to-original stream_url="
+            << stream_url << " original_url=" << original_url
+            << " success=1";
+  return original_url;
+}
+
+std::optional<pdf::PdfStreamDelegate::StreamInfo>
+TsPdfStreamDelegate::GetStreamInfo(RenderFrameHost* embedder_frame) {
+  if (!embedder_frame) {
+    LOG(INFO) << "[issue-792-exp14] pdf-get-stream-info frame_url="
+              << " has_stream=0";
+    return std::nullopt;
+  }
+
+  TsStreamInfoHelper* helper =
+      TsStreamInfoHelper::GetForCurrentDocument(embedder_frame);
+  if (!helper) {
+    LOG(INFO) << "[issue-792-exp14] pdf-get-stream-info frame_url="
+              << embedder_frame->GetLastCommittedURL() << " has_stream=0";
+    return std::nullopt;
+  }
+
+  auto stream_info = helper->TakeStreamInfo();
+  LOG(INFO) << "[issue-792-exp14] pdf-get-stream-info frame_url="
+            << embedder_frame->GetLastCommittedURL()
+            << " has_stream=" << (stream_info.has_value() ? 1 : 0);
+  return stream_info;
+}
+
+bool TsPdfStreamDelegate::MaybeDeleteSandboxedStream(
+    FrameTreeNodeId frame_tree_node_id) {
+  WebContents* web_contents = WebContents::FromFrameTreeNodeId(
+      frame_tree_node_id);
+  if (!web_contents) {
+    return false;
+  }
+
+  auto* manager = pdf::PdfViewerStreamManager::FromWebContents(web_contents);
+  if (!manager ||
+      !manager->ContainsUnclaimedStreamInfo(frame_tree_node_id)) {
+    return false;
+  }
+
+  manager->DeleteUnclaimedStreamInfo(frame_tree_node_id);
+  return true;
+}
+
+bool TsPdfStreamDelegate::ShouldAllowPdfExtensionFrameNavigation(
+    NavigationHandle* navigation_handle) {
+  return chrome_pdf::features::IsOopifPdfEnabled() ||
+         navigation_handle->GetURL().IsAboutBlank() ||
+         IsPdfExtensionFrameUrl(navigation_handle->GetURL());
+}
+
+bool TsPdfStreamDelegate::ShouldAllowPdfFrameNavigation(
+    NavigationHandle* navigation_handle) {
+  if (!chrome_pdf::features::IsOopifPdfEnabled()) {
+    return true;
+  }
+
+  auto* manager = pdf::PdfViewerStreamManager::FromWebContents(
+      navigation_handle->GetWebContents());
+  if (!manager) {
+    return true;
+  }
+
+  RenderFrameHost* parent_frame = navigation_handle->GetParentFrame();
+  if (!parent_frame) {
+    return true;
+  }
+
+  const GURL& url = navigation_handle->GetURL();
+  const FrameTreeNodeId frame_tree_node_id =
+      navigation_handle->GetFrameTreeNodeId();
+  base::WeakPtr<extensions::StreamContainer> stream =
+      manager->GetStreamContainer(parent_frame);
+  if (stream) {
+    return !manager->IsPdfExtensionFrameTreeNodeId(parent_frame,
+                                                  frame_tree_node_id) ||
+           (!manager->DidPdfExtensionFinishNavigation(parent_frame) &&
+            url == stream->handler_url());
+  }
+
+  RenderFrameHost* grandparent_frame = parent_frame->GetParent();
+  if (!grandparent_frame) {
+    return true;
+  }
+
+  stream = manager->GetStreamContainer(grandparent_frame);
+  if (!stream) {
+    return true;
+  }
+
+  return !manager->IsPdfContentFrameTreeNodeId(grandparent_frame,
+                                               frame_tree_node_id) ||
+         (!manager->DidPdfContentNavigate(grandparent_frame) &&
+          url == stream->original_url());
+}
+
+}  // namespace content
