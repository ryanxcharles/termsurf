+#include "extensions/common/manifest_handlers/mime_types_handler.h"
+
+namespace content {
+
+base::flat_map<std::string, std::string> GetTsPluginMimeTypeToExtensionIdMap(
+    BrowserContext* browser_context) {
+  base::flat_map<std::string, std::string> result;
+  auto* registry = extensions::ExtensionRegistry::Get(browser_context);
+  if (!registry) {
+    return result;
+  }
+
+  const extensions::Extension* extension =
+      registry->enabled_extensions().GetByID(extension_misc::kPdfExtensionId);
+  if (!extension) {
+    return result;
+  }
+
+  const auto* handler = MimeTypesHandler::GetHandler(extension);
+  if (!handler) {
+    return result;
+  }
+
+  for (const auto& mime_type : handler->mime_type_set()) {
+    if (mime_type == pdf::kPDFMimeType) {
+      result[mime_type] = extension_misc::kPdfExtensionId;
+    }
+  }
+
+  LOG(INFO) << "[issue-792-exp14] plugin-mime-map mime_type="
+            << pdf::kPDFMimeType << " extension_id="
+            << (result.contains(pdf::kPDFMimeType)
+                    ? result[pdf::kPDFMimeType]
+                    : std::string());
+  return result;
+}
+
+std::string GetTsPluginExtensionIdForMimeType(BrowserContext* browser_context,
+                                              const std::string& mime_type) {
+  auto map = GetTsPluginMimeTypeToExtensionIdMap(browser_context);
+  auto it = map.find(mime_type);
+  return it == map.end() ? std::string() : it->second;
+}
+
+}  // namespace content
