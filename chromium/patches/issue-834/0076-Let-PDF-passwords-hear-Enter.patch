From 0195b42d781781f44f7d0ca152e77f68a6c0549e Mon Sep 17 00:00:00 2001
From: Max Commits <maxcommits@ryanxcharles.com>
Date: Mon, 22 Jun 2026 08:51:48 -0500
Subject: [PATCH 76/84] Let PDF passwords hear Enter

The button had a secret door,
The keyboard tapped and asked for more.
Now Return may press the same old bell,
And guarded PDFs open well.
---
 .../resources/pdf/elements/viewer_password_dialog.html.ts | 2 +-
 .../resources/pdf/elements/viewer_password_dialog.ts      | 8 ++++++++
 2 files changed, 9 insertions(+), 1 deletion(-)

diff --git a/chrome/browser/resources/pdf/elements/viewer_password_dialog.html.ts b/chrome/browser/resources/pdf/elements/viewer_password_dialog.html.ts
index da69d59886..c4882811f6 100644
--- a/chrome/browser/resources/pdf/elements/viewer_password_dialog.html.ts
+++ b/chrome/browser/resources/pdf/elements/viewer_password_dialog.html.ts
@@ -15,7 +15,7 @@ export function getHtml(this: ViewerPasswordDialogElement) {
     <div id="message">$i18n{passwordPrompt}</div>
     <cr-input id="password" type="password"
         error-message="$i18n{passwordInvalid}" .invalid="${this.invalid}"
-        autofocus>
+        @keydown="${this.onPasswordKeydown_}" autofocus>
     </cr-input>
   </div>
   <div slot="button-container">
diff --git a/chrome/browser/resources/pdf/elements/viewer_password_dialog.ts b/chrome/browser/resources/pdf/elements/viewer_password_dialog.ts
index 508a3ef4d7..b0c2c9d455 100644
--- a/chrome/browser/resources/pdf/elements/viewer_password_dialog.ts
+++ b/chrome/browser/resources/pdf/elements/viewer_password_dialog.ts
@@ -68,6 +68,14 @@ export class ViewerPasswordDialogElement extends CrLitElement {
       detail: {password: password.value},
     }));
   }
+
+  protected onPasswordKeydown_(e: KeyboardEvent) {
+    if (e.key !== 'Enter') {
+      return;
+    }
+    e.preventDefault();
+    this.onSubmitClick_();
+  }
 }
 
 declare global {
-- 
