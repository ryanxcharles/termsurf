+}
+
+void LogIssue792Exp22Chunk(const char* tag,
+                           const DocumentLoader& loader,
+                           base::span<const char> data,
+                           int parser_blocked_count,
+                           bool in_commit_data) {
+  if (!ShouldLogIssue792Exp22DocumentLoader(loader)) {
+    return;
+  }
+  LOG(INFO) << "[issue-792-exp22] " << tag << " url="
+            << loader.Url().GetString().Utf8()
+            << " encoded_size=" << data.size()
+            << " parser_blocked=" << parser_blocked_count
+            << " in_commit_data=" << (in_commit_data ? 1 : 0)
+            << " has_template="
+            << (Issue792Exp22ChunkHas(data, "<template") ? 1 : 0)
+            << " has_iframe=" << (Issue792Exp22ChunkHas(data, "<iframe") ? 1 : 0)
+            << " has_shadowrootmode="
+            << (Issue792Exp22ChunkHas(data, "shadowrootmode") ? 1 : 0)
+            << " has_internal_id="
+            << (Issue792Exp22ChunkHas(data, "internalid") ? 1 : 0)
+            << " sample=" << Issue792Exp22Sample(data);
+}
+
+void LogIssue792Exp22BodyLoaderStart(const DocumentLoader& loader,
+                                     const char* reason,
+                                     bool has_body_loader,
+                                     bool is_static_data,
+                                     bool loading_empty,
+                                     bool is_main_frame) {
+  if (!ShouldLogIssue792Exp22DocumentLoader(loader)) {
+    return;
+  }
+  LOG(INFO) << "[issue-792-exp22] body-loader-start url="
+            << loader.Url().GetString().Utf8()
+            << " mime_type=" << loader.MimeType().Utf8()
+            << " reason=" << reason
+            << " has_body_loader=" << (has_body_loader ? 1 : 0)
+            << " is_static_data=" << (is_static_data ? 1 : 0)
+            << " loading_empty=" << (loading_empty ? 1 : 0)
+            << " is_main_frame=" << (is_main_frame ? 1 : 0);
+}
