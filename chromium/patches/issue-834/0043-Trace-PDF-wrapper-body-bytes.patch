From 95c078d4fb6f53573cb2155f06d78d10522c702b Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Fri, 29 May 2026 15:48:05 -0500
Subject: [PATCH 43/73] Trace PDF wrapper body bytes

The parser chewed a tiny page,
Not what the wrapper wrote on stage.
So every byte now signs its name,
And points us toward the static blame.
---
 .../core/html/parser/html_document_parser.cc  |  97 ++++++++++
 .../renderer/core/loader/document_loader.cc   | 168 ++++++++++++++++++
 2 files changed, 265 insertions(+)

diff --git a/third_party/blink/renderer/core/html/parser/html_document_parser.cc b/third_party/blink/renderer/core/html/parser/html_document_parser.cc
index b05d1e6c1ddda..e7145a6c3fbcf 100644
--- a/third_party/blink/renderer/core/html/parser/html_document_parser.cc
+++ b/third_party/blink/renderer/core/html/parser/html_document_parser.cc
@@ -25,10 +25,13 @@
 
 #include "third_party/blink/renderer/core/html/parser/html_document_parser.h"
 
+#include <algorithm>
 #include <memory>
+#include <string_view>
 #include <utility>
 
 #include "base/feature_list.h"
