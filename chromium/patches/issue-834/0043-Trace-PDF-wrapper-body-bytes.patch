+std::string Issue792Exp22Sample(base::span<const char> data) {
+  std::string sample;
+  const size_t limit = std::min<size_t>(data.size(), 64);
+  sample.reserve(limit);
+  for (char c : data.first(limit)) {
+    if (c == '\n') {
+      sample += "\\n";
