 #include "base/memory/scoped_refptr.h"
 #include "base/metrics/histogram_functions.h"
 #include "base/numerics/safe_conversions.h"
@@ -107,6 +110,49 @@ enum class FeatureResetMode {
 
 const char kHistogramScanAndPreloadTime[] = "Blink.ScanAndPreloadTime2";
 
+bool ShouldLogIssue792Exp22Parser(const Document& document) {
+  const std::string url = document.Url().GetString().Utf8();
+  return url.find("bitcoin.pdf") != std::string::npos ||
+         url.find("mhjfbmdgcfjbbpaeojofohoefgiehjai") != std::string::npos;
+}
+
+std::string Issue792Exp22ParserSample(base::span<const char> data) {
+  std::string sample;
+  const size_t limit = std::min<size_t>(data.size(), 64);
+  sample.reserve(limit);
+  for (char c : data.first(limit)) {
+    if (c == '\n') {
+      sample += "\\n";
+    } else if (c == '\r') {
+      sample += "\\r";
+    } else if (c == '\t') {
+      sample += "\\t";
+    } else if (c >= 0x20 && c <= 0x7e) {
+      sample.push_back(c);
+    } else {
+      sample.push_back('.');
+    }
+  }
+  return sample;
+}
+
+std::string Issue792Exp22ParserSample(const String& data) {
+  const std::string utf8 = data.Utf8();
+  return Issue792Exp22ParserSample(base::span<const char>(utf8));
+}
+
+bool Issue792Exp22ParserChunkHas(base::span<const uint8_t> data,
+                                 std::string_view needle) {
+  return std::string_view(reinterpret_cast<const char*>(data.data()),
+                          data.size())
+             .find(needle) != std::string_view::npos;
+}
+
+bool Issue792Exp22ParserStringHas(const String& data, std::string_view needle) {
+  const std::string utf8 = data.Utf8();
+  return std::string_view(utf8).find(needle) != std::string_view::npos;
+}
+
 bool ThreadedPreloadScannerEnabled(
     FeatureResetMode reset_mode = FeatureResetMode::kUseCached) {
   // Cache the feature value since checking for each parser regresses some micro
@@ -843,6 +889,14 @@ bool HTMLDocumentParser::PumpTokenizer() {
     task_runner_state_->MarkYield();
   }
 
+  if (ShouldLogIssue792Exp22Parser(*GetDocument())) {
+    LOG(INFO) << "[issue-792-exp22] parser-pump url="
+              << GetDocument()->Url().GetString().Utf8()
+              << " result=" << (should_yield ? 1 : 0)
+              << " have_seen_eof=" << (input_.HaveSeenEndOfFile() ? 1 : 0)
+              << " stopped=" << (IsStopped() ? 1 : 0);
+  }
+
   return should_yield;
 }
 
@@ -958,6 +1012,25 @@ void HTMLDocumentParser::Append(const String& input_source) {
               perfetto::Flow::FromPointer(this), "size", input_source.length(),
               "parser", (void*)this);
 
+  if (ShouldLogIssue792Exp22Parser(*GetDocument())) {
+    LOG(INFO) << "[issue-792-exp22] parser-append-string url="
+              << GetDocument()->Url().GetString().Utf8()
+              << " length=" << input_source.length()
+              << " stopped=" << (IsStopped() ? 1 : 0)
+              << " prefetch_only=" << (GetDocument()->IsPrefetchOnly() ? 1 : 0)
+              << " has_template="
+              << (Issue792Exp22ParserStringHas(input_source, "<template") ? 1
+                                                                          : 0)
+              << " has_iframe="
+              << (Issue792Exp22ParserStringHas(input_source, "<iframe") ? 1
+                                                                        : 0)
+              << " has_shadowrootmode="
+              << (Issue792Exp22ParserStringHas(input_source, "shadowrootmode")
+                      ? 1
+                      : 0)
+              << " sample=" << Issue792Exp22ParserSample(input_source);
+  }
+
   if (IsStopped()) {
     return;
   }
@@ -1030,6 +1103,15 @@ void HTMLDocumentParser::Append(const String& input_source) {
 void HTMLDocumentParser::FinishAppend() {
   TRACE_EVENT("blink", "HTMLDocumentParser::FinishAppend",
