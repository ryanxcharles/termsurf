+              << " should_pump_now="
+              << (ShouldPumpTokenizerNowForFinishAppend() ? 1 : 0)
+              << " is_preloading=" << (IsPreloading() ? 1 : 0)
+              << " in_pump_session="
+              << (task_runner_state_->InPumpSession() ? 1 : 0);
+  }
   if (ShouldPumpTokenizerNowForFinishAppend()) {
     PumpTokenizerIfPossible();
   } else {
@@ -1393,6 +1475,21 @@ void HTMLDocumentParser::AppendBytes(base::span<const uint8_t> data) {
 
   DCHECK(IsMainThread());
 
+  if (ShouldLogIssue792Exp22Parser(*GetDocument())) {
+    LOG(INFO) << "[issue-792-exp22] parser-append-bytes url="
+              << GetDocument()->Url().GetString().Utf8()
+              << " size=" << data.size() << " stopped=" << (IsStopped() ? 1 : 0)
+              << " needs_decoder=" << (NeedsDecoder() ? 1 : 0)
+              << " has_template="
+              << (Issue792Exp22ParserChunkHas(data, "<template") ? 1 : 0)
+              << " has_iframe="
+              << (Issue792Exp22ParserChunkHas(data, "<iframe") ? 1 : 0)
+              << " has_shadowrootmode="
+              << (Issue792Exp22ParserChunkHas(data, "shadowrootmode") ? 1 : 0)
+              << " sample="
+              << Issue792Exp22ParserSample(base::as_chars(data));
+  }
+
   if (data.empty() || IsStopped()) {
     return;
   }
