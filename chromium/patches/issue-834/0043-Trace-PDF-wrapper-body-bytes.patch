+
+bool Issue792Exp22ChunkHas(base::span<const char> data,
+                           std::string_view needle) {
+  return std::string_view(data.data(), data.size()).find(needle) !=
+         std::string_view::npos;
+}
+
+bool Issue792Exp22StringHas(const String& data, std::string_view needle) {
+  const std::string utf8 = data.Utf8();
