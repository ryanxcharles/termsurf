diff --git a/content/libtermsurf_chromium/ts_tab_observer.cc b/content/libtermsurf_chromium/ts_tab_observer.cc
index b3832c79484d0..aa7db70236b44 100644
--- a/content/libtermsurf_chromium/ts_tab_observer.cc
+++ b/content/libtermsurf_chromium/ts_tab_observer.cc
@@ -41,6 +41,47 @@ const char* ConsoleLevelToString(blink::mojom::ConsoleMessageLevel level) {
   return "unknown";
 }
 
+const char* TerminationStatusToString(base::TerminationStatus status) {
+  switch (status) {
+    case base::TERMINATION_STATUS_NORMAL_TERMINATION:
+      return "normal_termination";
+    case base::TERMINATION_STATUS_ABNORMAL_TERMINATION:
+      return "abnormal_termination";
+    case base::TERMINATION_STATUS_PROCESS_WAS_KILLED:
+      return "killed";
+    case base::TERMINATION_STATUS_PROCESS_CRASHED:
+      return "crashed";
+    case base::TERMINATION_STATUS_STILL_RUNNING:
+      return "still_running";
+#if BUILDFLAG(IS_CHROMEOS)
+    case base::TERMINATION_STATUS_PROCESS_WAS_KILLED_BY_OOM:
+      return "killed_by_oom";
+#endif
+#if BUILDFLAG(IS_ANDROID)
+    case base::TERMINATION_STATUS_OOM_PROTECTED:
+      return "oom_protected";
+#endif
+    case base::TERMINATION_STATUS_LAUNCH_FAILED:
+      return "launch_failed";
+    case base::TERMINATION_STATUS_OOM:
+      return "oom";
+#if BUILDFLAG(IS_WIN)
+    case base::TERMINATION_STATUS_INTEGRITY_FAILURE:
+      return "integrity_failure";
+#endif
+    case base::TERMINATION_STATUS_EVICTED_FOR_MEMORY:
+      return "evicted_for_memory";
+    case base::TERMINATION_STATUS_MAX_ENUM:
+      break;
+  }
+  return "unknown";
+}
+
+bool IsNonCrashTerminationStatus(base::TerminationStatus status) {
+  return status == base::TERMINATION_STATUS_NORMAL_TERMINATION ||
+         status == base::TERMINATION_STATUS_STILL_RUNNING;
+}
+
 }  // namespace
 
 TsTabObserver::TsTabObserver() = default;
@@ -115,6 +156,23 @@ void TsTabObserver::DidFailLoad(RenderFrameHost* render_frame_host,
 #endif
 }
 
+void TsTabObserver::PrimaryMainFrameRenderProcessGone(
+    base::TerminationStatus status) {
+#if BUILDFLAG(IS_MAC)
+  if (IsNonCrashTerminationStatus(status)) {
+    return;
+  }
+  std::string url;
+  if (web_contents()) {
+    url = web_contents()->GetVisibleURL().spec();
+  }
+  TsNotifyRendererCrashed(reinterpret_cast<void*>(handle_),
+                          TerminationStatusToString(status),
+                          static_cast<int>(status), url.c_str(), true);
+  TsNotifyLoadingState(reinterpret_cast<void*>(handle_), "error", 0);
+#endif
+}
+
 void TsTabObserver::TitleWasSet(NavigationEntry* entry) {
 #if BUILDFLAG(IS_MAC)
   if (!entry) {
