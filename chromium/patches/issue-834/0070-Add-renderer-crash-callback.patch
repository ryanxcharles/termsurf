From 53a6ebc6f534a1cbc3e86c44b669a3b4bf6f9164 Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Sat, 30 May 2026 21:21:02 -0500
Subject: [PATCH 70/73] Add renderer crash callback

When renderers trip and hit the floor,
The tab now knocks on TermSurf's door.
It names the fall, clears out the haze,
Then lets the page resume its ways.
---
 .../libtermsurf_chromium.cc                   | 32 ++++++++++
 .../libtermsurf_chromium.h                    |  9 +++
 .../ts_browser_main_parts.h                   |  5 ++
 .../libtermsurf_chromium/ts_tab_observer.cc   | 58 +++++++++++++++++++
 .../libtermsurf_chromium/ts_tab_observer.h    |  3 +
 5 files changed, 107 insertions(+)

diff --git a/content/libtermsurf_chromium/libtermsurf_chromium.cc b/content/libtermsurf_chromium/libtermsurf_chromium.cc
index e634db7c16a3f..dd399f8d36180 100644
--- a/content/libtermsurf_chromium/libtermsurf_chromium.cc
+++ b/content/libtermsurf_chromium/libtermsurf_chromium.cc
@@ -92,6 +92,15 @@ void (*g_on_http_auth_request)(ts_web_contents_t,
                                void*) = nullptr;
 void* g_on_http_auth_request_data = nullptr;
 
+// Renderer crash callback.
+void (*g_on_renderer_crashed)(ts_web_contents_t,
+                              const char*,
+                              int,
+                              const char*,
+                              bool,
+                              void*) = nullptr;
+void* g_on_renderer_crashed_data = nullptr;
+
 }  // namespace
 
 namespace content {
@@ -151,6 +160,18 @@ void TsNotifyTargetUrlChanged(void* wc_handle, const char* url) {
   }
 }
 
+void TsNotifyRendererCrashed(void* wc_handle,
+                             const char* termination_status,
+                             int termination_status_code,
+                             const char* url,
+                             bool can_reload) {
+  if (g_on_renderer_crashed) {
+    g_on_renderer_crashed(wc_handle, termination_status,
+                          termination_status_code, url, can_reload,
+                          g_on_renderer_crashed_data);
+  }
+}
+
 void TsNotifyJavaScriptDialogRequest(void* wc_handle,
                                      uint64_t request_id,
                                      const char* dialog_type,
@@ -482,3 +503,14 @@ void ts_set_on_http_auth_request(
   g_on_http_auth_request = cb;
   g_on_http_auth_request_data = user_data;
 }
+
+void ts_set_on_renderer_crashed(void (*cb)(ts_web_contents_t wc,
+                                           const char* termination_status,
+                                           int termination_status_code,
+                                           const char* url,
+                                           bool can_reload,
+                                           void* user_data),
+                                void* user_data) {
+  g_on_renderer_crashed = cb;
+  g_on_renderer_crashed_data = user_data;
+}
diff --git a/content/libtermsurf_chromium/libtermsurf_chromium.h b/content/libtermsurf_chromium/libtermsurf_chromium.h
index 84ff1ffa660bc..a35e5a7e836ae 100644
