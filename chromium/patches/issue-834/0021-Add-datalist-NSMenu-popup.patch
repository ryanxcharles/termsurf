diff --git a/content/shell/renderer/shell_datalist_autofill_client.cc b/content/shell/renderer/shell_datalist_autofill_client.cc
new file mode 100644
index 0000000000..a92f96e782
--- /dev/null
+++ b/content/shell/renderer/shell_datalist_autofill_client.cc
@@ -0,0 +1,335 @@
+// Copyright 2026 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/shell/renderer/shell_datalist_autofill_client.h"
+
+#include <cstdlib>
+#include <string>
+#include <vector>
+
+#include "base/functional/bind.h"
+#include "base/logging.h"
+#include "base/task/single_thread_task_runner.h"
+#include "content/public/renderer/render_frame.h"
+#include "third_party/blink/public/common/input/web_keyboard_event.h"
+#include "third_party/blink/public/platform/browser_interface_broker_proxy.h"
+#include "third_party/blink/public/platform/web_string.h"
+#include "third_party/blink/public/web/web_document.h"
+#include "third_party/blink/public/web/web_element.h"
+#include "third_party/blink/public/web/web_local_frame.h"
+#include "third_party/blink/public/web/web_node.h"
+#include "third_party/blink/public/web/web_option_element.h"
+#include "ui/events/keycodes/keyboard_codes.h"
+#include "ui/gfx/geometry/rect_f.h"
+
+namespace content {
+
+namespace {
+
+constexpr size_t kMaxStringLength = 1024;
+constexpr size_t kMaxListSize = 512;
+
+bool Issue779TraceEnabled() {
+  static const bool enabled =
+      std::getenv("TERMSURF_ISSUE_779_TRACE") != nullptr;
+  return enabled;
+}
+
+void Issue779TraceAnnounce() {
+  static bool announced = false;
+  if (!announced) {
+    announced = true;
+    LOG(INFO) << "[issue-779-trace] trace_enabled "
+              << "component=shell-datalist-autofill-client";
+  }
+}
+
+std::u16string TruncateForIPC(std::u16string value) {
+  if (value.size() > kMaxStringLength) {
+    value.resize(kMaxStringLength);
+  }
+  return value;
+}
+
+void TrimStringVectorForIPC(std::vector<std::u16string>* strings) {
+  if (strings->size() > kMaxListSize) {
+    strings->resize(kMaxListSize);
+  }
+  for (auto& string : *strings) {
+    if (string.size() > kMaxStringLength) {
+      string.resize(kMaxStringLength);
+    }
+  }
+}
+
+void GetDataListSuggestions(const blink::WebInputElement& element,
+                            std::vector<std::u16string>* values,
+                            std::vector<std::u16string>* labels) {
+  for (const auto& option : element.FilteredDataListOptions()) {
+    if (!option.IsEnabled()) {
+      continue;
+    }
+    std::u16string value = option.Value().Utf16();
+    if (value.empty()) {
+      continue;
+    }
+    values->push_back(TruncateForIPC(std::move(value)));
+    std::u16string label = option.Label().Utf16();
+    if (label.empty()) {
+      label = option.GetText().Utf16();
+    }
+    if (label == values->back()) {
+      labels->emplace_back();
+    } else {
+      labels->push_back(TruncateForIPC(std::move(label)));
+    }
+  }
+
+  TrimStringVectorForIPC(values);
+  TrimStringVectorForIPC(labels);
+}
+
+std::string PreviewString(const std::vector<std::u16string>& strings) {
+  std::string result;
+  const size_t count = std::min<size_t>(strings.size(), 3);
+  for (size_t i = 0; i < count; ++i) {
+    if (i > 0) {
+      result += ",";
+    }
+    result += blink::WebString(strings[i]).Utf8();
+  }
+  return result;
+}
+
+}  // namespace
+
+ShellDatalistAutofillClient::ShellDatalistAutofillClient(
+    RenderFrame* render_frame)
+    : RenderFrameObserver(render_frame) {
+  render_frame->GetWebFrame()->SetAutofillClient(this);
+  if (Issue779TraceEnabled()) {
+    Issue779TraceAnnounce();
+    LOG(INFO) << "[issue-779-trace] datalist_autofill"
+              << " boundary=shell_renderer"
+              << " event=client_installed"
+              << " render_frame=" << render_frame;
+  }
+}
+
+ShellDatalistAutofillClient::~ShellDatalistAutofillClient() = default;
+
+void ShellDatalistAutofillClient::Shutdown() {
+  HidePopup();
+  receiver_.reset();
+  driver_.reset();
+  weak_ptr_factory_.InvalidateWeakPtrs();
+}
+
+void ShellDatalistAutofillClient::OnDestruct() {
+  Shutdown();
+  base::SingleThreadTaskRunner::GetCurrentDefault()->DeleteSoon(FROM_HERE,
+                                                                this);
+}
+
+bool ShellDatalistAutofillClient::IsUserGesture() const {
+  return render_frame()->GetWebFrame()->HasTransientUserActivation();
+}
+
+void ShellDatalistAutofillClient::TextFieldDidEndEditing(
+    const blink::WebInputElement& element) {
+  if (Issue779TraceEnabled()) {
+    Issue779TraceAnnounce();
+    LOG(INFO) << "[issue-779-trace] datalist_autofill"
+              << " boundary=shell_renderer"
+              << " event=text_field_did_end_editing";
+  }
+  HidePopup();
+}
+
+void ShellDatalistAutofillClient::TextFieldValueChanged(
+    const blink::WebFormControlElement& element) {
+  const bool user_triggered = IsUserGesture() || render_frame()->IsPasting();
+  if (Issue779TraceEnabled()) {
+    Issue779TraceAnnounce();
+    LOG(INFO) << "[issue-779-trace] datalist_autofill"
+              << " boundary=shell_renderer"
+              << " event=text_field_value_changed"
+              << " user_triggered=" << user_triggered
+              << " is_pasting=" << render_frame()->IsPasting();
+  }
+  if (!user_triggered) {
+    return;
+  }
+
+  weak_ptr_factory_.InvalidateWeakPtrs();
+  base::SingleThreadTaskRunner::GetCurrentDefault()->PostTask(
+      FROM_HERE,
+      base::BindOnce(&ShellDatalistAutofillClient::TextFieldValueChangedImpl,
+                     weak_ptr_factory_.GetWeakPtr(), element));
+}
+
+void ShellDatalistAutofillClient::TextFieldValueChangedImpl(
+    blink::WebFormControlElement element) {
+  ShowSuggestions(element, {.requires_caret_at_end = true});
+}
+
+void ShellDatalistAutofillClient::TextFieldDidReceiveKeyDown(
+    const blink::WebInputElement& element,
+    const blink::WebKeyboardEvent& event) {
+  const bool arrow_key = event.windows_key_code == ui::VKEY_DOWN ||
+                         event.windows_key_code == ui::VKEY_UP;
+  if (Issue779TraceEnabled()) {
+    Issue779TraceAnnounce();
+    LOG(INFO) << "[issue-779-trace] datalist_autofill"
+              << " boundary=shell_renderer"
+              << " event=text_field_key_down"
+              << " windows_key_code=" << event.windows_key_code
+              << " arrow_key=" << arrow_key;
+  }
+  if (arrow_key) {
+    ShowSuggestions(element, {.autofill_on_empty_values = true,
+                              .requires_caret_at_end = true});
+  }
+}
+
+void ShellDatalistAutofillClient::OpenTextDataListChooser(
+    const blink::WebInputElement& element) {
+  if (Issue779TraceEnabled()) {
+    Issue779TraceAnnounce();
+    LOG(INFO) << "[issue-779-trace] datalist_autofill"
+              << " boundary=shell_renderer"
+              << " event=open_text_datalist_chooser";
+  }
+  ShowSuggestions(element, {.autofill_on_empty_values = true});
+}
+
+void ShellDatalistAutofillClient::DataListOptionsChanged(
+    const blink::WebInputElement& element) {
+  if (Issue779TraceEnabled()) {
+    Issue779TraceAnnounce();
+    LOG(INFO) << "[issue-779-trace] datalist_autofill"
+              << " boundary=shell_renderer"
+              << " event=datalist_options_changed"
+              << " focused=" << element.Focused();
+  }
+  if (!element.Focused()) {
+    return;
+  }
+  ShowSuggestions(element, {.requires_caret_at_end = true});
+}
+
+void ShellDatalistAutofillClient::ShowSuggestions(
+    const blink::WebFormControlElement& element,
+    const ShowSuggestionsOptions& options) {
+  if (!element.IsEnabled() || element.IsReadOnly()) {
+    HidePopup();
+    return;
+  }
+  if (!element.SuggestedValue().IsEmpty()) {
+    HidePopup();
+    return;
+  }
+
+  const blink::WebInputElement input_element =
+      element.DynamicTo<blink::WebInputElement>();
+  if (input_element.IsNull() || !input_element.IsTextField() ||
+      !input_element.SuggestedValue().IsEmpty()) {
+    HidePopup();
+    return;
+  }
+
+  const blink::WebString value = element.EditingValue();
+  if (value.length() > kMaxStringLength ||
+      (!options.autofill_on_empty_values && value.IsEmpty()) ||
+      (options.requires_caret_at_end &&
+       (element.SelectionStart() != element.SelectionEnd() ||
+        element.SelectionEnd() != value.length()))) {
+    HidePopup();
+    return;
+  }
+
+  std::vector<std::u16string> values;
+  std::vector<std::u16string> labels;
+  GetDataListSuggestions(input_element, &values, &labels);
+  if (values.empty()) {
+    HidePopup();
+    return;
+  }
+
+  if (Issue779TraceEnabled()) {
+    Issue779TraceAnnounce();
+    LOG(INFO) << "[issue-779-trace] datalist_autofill"
+              << " boundary=shell_renderer"
+              << " event=suggestions_extracted"
+              << " option_count=" << values.size()
+              << " preview_values=" << PreviewString(values)
+              << " preview_labels=" << PreviewString(labels);
+  }
+  ShowPopup(element, values, labels);
+}
+
+void ShellDatalistAutofillClient::ShowPopup(
+    const blink::WebFormControlElement& element,
+    const std::vector<std::u16string>& values,
+    const std::vector<std::u16string>& labels) {
+  if (receiver_.is_bound()) {
+    receiver_.reset();
+  }
+  mojo::PendingRemote<mojom::ShellDatalistAutofillAgent> agent =
+      receiver_.BindNewPipeAndPassRemote();
+  const gfx::RectF bounds_in_window(
+      render_frame()->ConvertViewportToWindow(element.BoundsInWidget()));
+  if (Issue779TraceEnabled()) {
+    Issue779TraceAnnounce();
+    LOG(INFO) << "[issue-779-trace] datalist_autofill"
+              << " boundary=shell_renderer"
+              << " event=show_popup_request"
+              << " option_count=" << values.size()
+              << " bounds_in_window=" << bounds_in_window.ToString();
+  }
+  GetDriver()->ShowDatalistPopup(bounds_in_window, values, labels,
+                                 std::move(agent));
+}
+
+void ShellDatalistAutofillClient::HidePopup() {
+  if (driver_) {
+    driver_->HideDatalistPopup();
+  }
+}
+
+const mojo::Remote<mojom::ShellDatalistAutofillDriver>&
+ShellDatalistAutofillClient::GetDriver() {
+  if (!driver_) {
+    render_frame()->GetBrowserInterfaceBroker().GetInterface(
+        driver_.BindNewPipeAndPassReceiver());
+  }
+  return driver_;
+}
+
+void ShellDatalistAutofillClient::AcceptDataListSuggestion(
+    const std::u16string& value) {
+  blink::WebElement element =
+      render_frame()->GetWebFrame()->GetDocument().FocusedElement();
+  const bool is_form_control = element.IsFormControlElement();
+  blink::WebInputElement input_element;
+  if (is_form_control) {
+    input_element = element.DynamicTo<blink::WebInputElement>();
+  }
+  const bool can_accept = !input_element.IsNull();
+  if (Issue779TraceEnabled()) {
+    Issue779TraceAnnounce();
+    LOG(INFO) << "[issue-779-trace] datalist_autofill"
+              << " boundary=shell_renderer"
+              << " event=accept_suggestion"
+              << " is_form_control=" << is_form_control
+              << " can_accept=" << can_accept
+              << " value=" << blink::WebString(value).Utf8();
+  }
+  if (!can_accept) {
+    return;
+  }
+  input_element.SetAutofillValue(blink::WebString(value));
+}
+
