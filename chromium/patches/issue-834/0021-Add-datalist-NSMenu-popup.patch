+ private:
+  struct ShowSuggestionsOptions {
+    bool autofill_on_empty_values = false;
+    bool requires_caret_at_end = false;
+  };
+
+  void Shutdown();
+  bool IsUserGesture() const;
+  void HidePopup();
+  void ShowSuggestions(const blink::WebFormControlElement& element,
+                       const ShowSuggestionsOptions& options);
+  void ShowPopup(const blink::WebFormControlElement& element,
+                 const std::vector<std::u16string>& values,
+                 const std::vector<std::u16string>& labels);
+  const mojo::Remote<mojom::ShellDatalistAutofillDriver>& GetDriver();
+
+  // RenderFrameObserver:
+  void OnDestruct() override;
+
+  // blink::WebAutofillClient:
+  void TextFieldDidEndEditing(const blink::WebInputElement& element) override;
+  void TextFieldValueChanged(
+      const blink::WebFormControlElement& element) override;
+  void TextFieldValueChangedImpl(blink::WebFormControlElement element);
+  void TextFieldDidReceiveKeyDown(
+      const blink::WebInputElement& element,
+      const blink::WebKeyboardEvent& event) override;
+  void OpenTextDataListChooser(const blink::WebInputElement& element) override;
+  void DataListOptionsChanged(const blink::WebInputElement& element) override;
+
+  // mojom::ShellDatalistAutofillAgent:
+  void AcceptDataListSuggestion(const std::u16string& value) override;
+
+  mojo::Remote<mojom::ShellDatalistAutofillDriver> driver_;
+  mojo::Receiver<mojom::ShellDatalistAutofillAgent> receiver_{this};
+  base::WeakPtrFactory<ShellDatalistAutofillClient> weak_ptr_factory_{this};
+};
