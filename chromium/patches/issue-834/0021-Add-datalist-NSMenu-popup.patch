diff --git a/content/shell/browser/shell_datalist_autofill_driver_mac.mm b/content/shell/browser/shell_datalist_autofill_driver_mac.mm
new file mode 100644
index 0000000000..85dd5cbd8a
--- /dev/null
+++ b/content/shell/browser/shell_datalist_autofill_driver_mac.mm
@@ -0,0 +1,207 @@
+// Copyright 2026 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/shell/browser/shell_datalist_autofill_driver.h"
+
+#import <Cocoa/Cocoa.h>
+
+#include <cstdlib>
+#include <memory>
+#include <string>
+#include <utility>
+#include <vector>
+
+#include "base/logging.h"
+#include "base/strings/stringprintf.h"
+#include "base/strings/sys_string_conversions.h"
+#include "content/public/browser/render_frame_host.h"
+#include "content/public/browser/web_contents.h"
+#include "mojo/public/cpp/bindings/remote.h"
+#include "mojo/public/cpp/bindings/self_owned_receiver.h"
+#include "ui/gfx/geometry/rect_f.h"
+
+@interface ShellDatalistMenuTarget : NSObject
+@property(nonatomic, assign) NSInteger selectedIndex;
+- (void)itemSelected:(id)sender;
+@end
+
+@implementation ShellDatalistMenuTarget
+@synthesize selectedIndex = _selectedIndex;
+
+- (instancetype)init {
+  if ((self = [super init])) {
+    _selectedIndex = -1;
+  }
+  return self;
+}
+
+- (void)itemSelected:(id)sender {
+  NSMenuItem* item = sender;
+  self.selectedIndex = item.tag;
+}
+
+@end
+
+namespace content {
+
+namespace {
+
+bool Issue779TraceEnabled() {
+  static const bool enabled =
+      std::getenv("TERMSURF_ISSUE_779_TRACE") != nullptr;
+  return enabled;
+}
+
+void Issue779TraceAnnounce() {
+  static bool announced = false;
+  if (!announced) {
+    announced = true;
+    LOG(INFO) << "[issue-779-trace] trace_enabled "
+              << "component=shell-datalist-autofill-driver";
+  }
+}
+
+std::string NSRectToString(NSRect rect) {
+  return base::StringPrintf("{x=%.3f y=%.3f w=%.3f h=%.3f}", rect.origin.x,
+                            rect.origin.y, rect.size.width, rect.size.height);
+}
+
+NSRect InputBoundsToHostViewRect(NSView* host_view,
+                                 const gfx::RectF& input_bounds_in_window) {
+  const NSRect host_bounds = host_view.bounds;
+  CGFloat y = input_bounds_in_window.y();
+  if (!host_view.isFlipped) {
+    y = NSHeight(host_bounds) - input_bounds_in_window.y() -
+        input_bounds_in_window.height();
+  }
+  return NSMakeRect(input_bounds_in_window.x(), y,
+                    input_bounds_in_window.width(),
+                    input_bounds_in_window.height());
+}
+
+class ShellDatalistAutofillDriverImpl
+    : public mojom::ShellDatalistAutofillDriver {
+ public:
+  explicit ShellDatalistAutofillDriverImpl(RenderFrameHost* render_frame_host)
+      : render_frame_host_id_(render_frame_host->GetGlobalId()) {}
+
+  ShellDatalistAutofillDriverImpl(const ShellDatalistAutofillDriverImpl&) =
+      delete;
+  ShellDatalistAutofillDriverImpl& operator=(
+      const ShellDatalistAutofillDriverImpl&) = delete;
+
+  void ShowDatalistPopup(
+      const gfx::RectF& input_bounds_in_window,
+      const std::vector<std::u16string>& values,
+      const std::vector<std::u16string>& labels,
+      mojo::PendingRemote<mojom::ShellDatalistAutofillAgent> agent) override {
+    mojo::Remote<mojom::ShellDatalistAutofillAgent> agent_remote(
+        std::move(agent));
+    RenderFrameHost* render_frame_host =
+        RenderFrameHost::FromID(render_frame_host_id_);
+    WebContents* web_contents =
+        render_frame_host ? WebContents::FromRenderFrameHost(render_frame_host)
+                          : nullptr;
+    NSView* host_view =
+        web_contents ? web_contents->GetNativeView().GetNativeNSView() : nil;
+    if (!host_view || values.empty()) {
+      if (Issue779TraceEnabled()) {
+        Issue779TraceAnnounce();
+        LOG(INFO) << "[issue-779-trace] datalist_autofill"
+                  << " boundary=shell_browser"
+                  << " event=show_popup_failed"
+                  << " has_render_frame_host=" << !!render_frame_host
+                  << " has_web_contents=" << !!web_contents
+                  << " has_host_view=" << !!host_view
+                  << " option_count=" << values.size();
+      }
+      return;
+    }
+
+    NSMenu* menu = [[NSMenu alloc] initWithTitle:@""];
+    menu.autoenablesItems = NO;
+    ShellDatalistMenuTarget* target = [[ShellDatalistMenuTarget alloc] init];
+    const size_t item_count = std::min(values.size(), labels.size());
+    for (size_t i = 0; i < item_count; ++i) {
+      std::u16string title = labels[i].empty() ? values[i] : labels[i];
+      NSMenuItem* item =
+          [[NSMenuItem alloc] initWithTitle:base::SysUTF16ToNSString(title)
+                                     action:@selector(itemSelected:)
+                              keyEquivalent:@""];
+      item.target = target;
+      item.tag = static_cast<NSInteger>(i);
+      item.enabled = YES;
+      [menu addItem:item];
+    }
+
+    NSRect input_rect =
+        InputBoundsToHostViewRect(host_view, input_bounds_in_window);
+    NSView* fake_control_view = [[NSView alloc] initWithFrame:input_rect];
+    [host_view addSubview:fake_control_view];
+    const NSPoint menu_location =
+        NSMakePoint(0, NSHeight(fake_control_view.bounds));
+
+    if (Issue779TraceEnabled()) {
+      Issue779TraceAnnounce();
+      LOG(INFO) << "[issue-779-trace] datalist_autofill"
+                << " boundary=shell_browser"
+                << " event=show_popup"
+                << " option_count=" << values.size()
+                << " item_count=" << item_count << " input_bounds_in_window="
+                << input_bounds_in_window.ToString()
+                << " input_rect_host_view=" << NSRectToString(input_rect)
+                << " host_view=" << (__bridge void*)host_view
+                << " host_window=" << (__bridge void*)host_view.window;
+    }
+
+    current_menu_ = menu;
+    [menu popUpMenuPositioningItem:nil
+                        atLocation:menu_location
+                            inView:fake_control_view];
+    current_menu_ = nil;
+    [fake_control_view removeFromSuperview];
+
+    const NSInteger selected_index = target.selectedIndex;
+    if (Issue779TraceEnabled()) {
+      Issue779TraceAnnounce();
+      LOG(INFO) << "[issue-779-trace] datalist_autofill"
+                << " boundary=shell_browser"
+                << " event=popup_dismissed"
+                << " selected_index=" << selected_index << " reason="
+                << (selected_index >= 0 ? "accepted" : "dismissed");
+    }
+    if (selected_index >= 0 &&
+        static_cast<size_t>(selected_index) < values.size()) {
+      agent_remote->AcceptDataListSuggestion(values[selected_index]);
+    }
+  }
+
+  void HideDatalistPopup() override {
+    if (Issue779TraceEnabled()) {
+      Issue779TraceAnnounce();
+      LOG(INFO) << "[issue-779-trace] datalist_autofill"
+                << " boundary=shell_browser"
+                << " event=hide_popup";
+    }
+    [current_menu_ cancelTracking];
+  }
+
+ private:
+  GlobalRenderFrameHostId render_frame_host_id_;
+  NSMenu* current_menu_ = nil;
+};
+
+}  // namespace
+
+// static
+void ShellDatalistAutofillDriver::Bind(
+    RenderFrameHost* render_frame_host,
+    mojo::PendingReceiver<mojom::ShellDatalistAutofillDriver>
+        pending_receiver) {
+  mojo::MakeSelfOwnedReceiver(
+      std::make_unique<ShellDatalistAutofillDriverImpl>(render_frame_host),
+      std::move(pending_receiver));
+}
+
+}  // namespace content
