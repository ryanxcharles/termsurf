+ public:
+  explicit ShellDatalistAutofillClient(RenderFrame* render_frame);
+  ~ShellDatalistAutofillClient() override;
+
+  ShellDatalistAutofillClient(const ShellDatalistAutofillClient&) = delete;
+  ShellDatalistAutofillClient& operator=(const ShellDatalistAutofillClient&) =
+      delete;
