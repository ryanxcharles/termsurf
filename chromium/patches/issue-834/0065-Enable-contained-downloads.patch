diff --git a/content/libtermsurf_chromium/ts_download_support.cc b/content/libtermsurf_chromium/ts_download_support.cc
new file mode 100644
index 0000000000000..48693925b7d5a
--- /dev/null
+++ b/content/libtermsurf_chromium/ts_download_support.cc
@@ -0,0 +1,55 @@
+// Copyright 2026 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/libtermsurf_chromium/ts_download_support.h"
+
+#include "base/command_line.h"
+#include "base/files/file_path.h"
+#include "base/files/file_util.h"
+#include "base/logging.h"
+#include "content/shell/browser/shell_browser_context.h"
+#include "content/shell/browser/shell_download_manager_delegate.h"
+
+namespace content {
+namespace {
+
+constexpr char kTermSurfDownloadDirSwitch[] = "termsurf-download-dir";
+
+base::FilePath DownloadDirectoryForContext(
+    ShellBrowserContext* browser_context) {
+  base::CommandLine* command_line = base::CommandLine::ForCurrentProcess();
+  if (command_line->HasSwitch(kTermSurfDownloadDirSwitch)) {
+    return command_line->GetSwitchValuePath(kTermSurfDownloadDirSwitch);
+  }
+  return browser_context->GetPath().Append(FILE_PATH_LITERAL("Downloads"));
+}
+
+}  // namespace
+
+void ConfigureTsDownloads(ShellBrowserContext* browser_context) {
+  if (!browser_context) {
+    return;
+  }
+
+  base::FilePath download_dir = DownloadDirectoryForContext(browser_context);
+  if (download_dir.empty()) {
+    LOG(WARNING) << "[termsurf-download] skipped reason=empty-path";
+    return;
+  }
+
+  if (!base::CreateDirectory(download_dir)) {
+    LOG(WARNING) << "[termsurf-download] skipped reason=create-failed path="
+                 << download_dir.AsUTF8Unsafe();
+    return;
+  }
+
+  auto* delegate = static_cast<ShellDownloadManagerDelegate*>(
+      browser_context->GetDownloadManagerDelegate());
+  delegate->SetDownloadBehaviorForTesting(download_dir);
+  LOG(INFO) << "[termsurf-download] configured path="
+            << download_dir.AsUTF8Unsafe() << " off_the_record="
+            << (browser_context->IsOffTheRecord() ? 1 : 0);
+}
+
+}  // namespace content
diff --git a/content/libtermsurf_chromium/ts_download_support.h b/content/libtermsurf_chromium/ts_download_support.h
new file mode 100644
index 0000000000000..92fc35c219030
--- /dev/null
+++ b/content/libtermsurf_chromium/ts_download_support.h
@@ -0,0 +1,16 @@
+// Copyright 2026 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CONTENT_LIBTERMSURF_CHROMIUM_TS_DOWNLOAD_SUPPORT_H_
+#define CONTENT_LIBTERMSURF_CHROMIUM_TS_DOWNLOAD_SUPPORT_H_
+
+namespace content {
+
+class ShellBrowserContext;
+
+void ConfigureTsDownloads(ShellBrowserContext* browser_context);
+
+}  // namespace content
+
+#endif  // CONTENT_LIBTERMSURF_CHROMIUM_TS_DOWNLOAD_SUPPORT_H_
