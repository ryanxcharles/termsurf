+bool IsTsPdfComponentExtension(const extensions::Extension& extension) {
+  return extension.id() == extension_misc::kPdfExtensionId &&
+         extensions::Manifest::IsComponentLocation(extension.location());
+}
+
 class TsPermissionMessageProvider
     : public extensions::PermissionMessageProvider {
  public:
@@ -108,4 +120,21 @@ bool TsExtensionsClient::IsBlocklistUpdateURL(const GURL& url) const {
   return false;
 }
 
+void TsExtensionsClient::AddOriginAccessPermissions(
+    const extensions::Extension& extension,
+    bool is_extension_active,
+    std::vector<network::mojom::CorsOriginPatternPtr>* origin_patterns) const {
+  if (!IsTsPdfComponentExtension(extension)) {
+    return;
+  }
+
+  origin_patterns->push_back(network::mojom::CorsOriginPattern::New(
+      kChromeUIScheme, kChromeUIResourcesHost, /*port=*/0,
+      network::mojom::CorsDomainMatchMode::kDisallowSubdomains,
+      network::mojom::CorsPortMatchMode::kAllowAnyPort,
+      network::mojom::CorsOriginAccessMatchPriority::kMaxPriority));
+  LOG(INFO) << "[issue-792-exp7] chrome-resources-renderer-origin extension_id="
+            << extension.id() << " active=" << is_extension_active;
+}
+
 }  // namespace content
