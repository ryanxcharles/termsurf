 namespace content {
+namespace {
+
+bool IsTsPdfComponentExtension(const extensions::Extension* extension) {
+  return extension && extension->id() == extension_misc::kPdfExtensionId &&
+         extensions::Manifest::IsComponentLocation(extension->location());
+}
+
+const extensions::Extension* GetExtensionForInitiatorOrigin(
+    content::BrowserContext* browser_context,
+    const std::optional<url::Origin>& request_initiator_origin) {
+  if (!request_initiator_origin.has_value()) {
+    return nullptr;
+  }
+
+  auto* registry = extensions::ExtensionRegistry::Get(browser_context);
+  if (!registry) {
+    return nullptr;
+  }
+
+  return registry->enabled_extensions().GetExtensionOrAppByURL(
+      request_initiator_origin->GetURL());
+}
+
+}  // namespace
 
 // Stub BadgeService — accepts and ignores Badging API calls (Issue 655).
 // Prevents renderer kills on navigator.setAppBadge().
@@ -160,6 +188,29 @@ void TsBrowserClient::RegisterNonNetworkSubresourceURLLoaderFactories(
   factories->emplace(extensions::kExtensionScheme,
                      extensions::CreateExtensionURLLoaderFactory(
                          render_process_id, render_frame_id));
+
+  RenderProcessHost* process_host =
+      RenderProcessHost::FromID(render_process_id);
+  if (!process_host) {
+    return;
+  }
+  RenderFrameHost* frame_host =
+      RenderFrameHost::FromID(render_process_id, render_frame_id);
+  if (!frame_host) {
+    return;
+  }
+  const extensions::Extension* extension = GetExtensionForInitiatorOrigin(
+      process_host->GetBrowserContext(), request_initiator_origin);
+  if (!IsTsPdfComponentExtension(extension)) {
+    return;
+  }
+
+  factories->emplace(kChromeUIScheme,
+                     CreateWebUIURLLoaderFactory(frame_host, kChromeUIScheme,
+                                                 {kChromeUIResourcesHost}));
+  LOG(INFO) << "[issue-792-exp7] chrome-resources-factory extension_id="
+            << extension->id() << " process_id=" << render_process_id
+            << " frame_id=" << render_frame_id;
 }
 
 bool TsBrowserClient::ShouldUseProcessPerSite(BrowserContext* browser_context,
@@ -231,6 +282,14 @@ void TsBrowserClient::SiteInstanceGotProcessAndSite(
   LOG(INFO) << "[issue-792-exp6] process-map-insert extension_id="
             << extension->id() << " process_id=" << process_id
             << " site_url=" << site_instance->GetSiteURL();
+
+  if (IsTsPdfComponentExtension(extension)) {
+    ChildProcessSecurityPolicy::GetInstance()->GrantRequestOrigin(
+        process_id, url::Origin::CreateFromNormalizedTuple(
+                        kChromeUIScheme, kChromeUIResourcesHost, 0));
+    LOG(INFO) << "[issue-792-exp7] chrome-resources-grant extension_id="
+              << extension->id() << " process_id=" << process_id;
+  }
 }
 
