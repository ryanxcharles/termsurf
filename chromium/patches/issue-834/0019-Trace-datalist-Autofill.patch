+              << " document=" << static_cast<void*>(&input.GetDocument())
+              << " frame=" << static_cast<void*>(frame)
+              << " autofill_client_present=" << (fill_client != nullptr)
+              << " has_datalist=" << (input.DataList() != nullptr)
+              << " value_length=" << input.Value().length()
+              << " url=" << input.GetDocument().Url();
+  }
+  if (fill_client) {
     fill_client->OpenTextDataListChooser(WebInputElement(&input));
   }
