 void ChromeClientImpl::TextFieldDataListChanged(HTMLInputElement& input) {
-  if (auto* fill_client =
-          AutofillClientFromFrame(input.GetDocument().GetFrame())) {
+  auto* frame = input.GetDocument().GetFrame();
+  auto* fill_client = AutofillClientFromFrame(frame);
+  if (Issue779TraceEnabled()) {
+    Issue779TraceAnnounce();
+    LOG(INFO) << "[issue-779-trace] datalist_autofill"
+              << " event=ChromeClientImpl::TextFieldDataListChanged"
+              << " input=" << static_cast<void*>(&input)
+              << " document=" << static_cast<void*>(&input.GetDocument())
+              << " frame=" << static_cast<void*>(frame)
+              << " autofill_client_present=" << (fill_client != nullptr)
+              << " has_datalist=" << (input.DataList() != nullptr)
+              << " value_length=" << input.Value().length()
+              << " url=" << input.GetDocument().Url();
+  }
+  if (fill_client) {
     fill_client->DataListOptionsChanged(WebInputElement(&input));
   }
 }
