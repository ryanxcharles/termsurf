 void PdfViewWebPlugin::Print() {
+  if (std::optional<base::FilePath> intercept_path =
+          GetTermSurfPdfPrintInterceptPath()) {
+    const bool has_engine = !!engine_;
+    const bool can_print =
+        engine_ &&
+        (engine_->HasPermission(DocumentPermission::kPrintLowQuality) ||
+         engine_->HasPermission(DocumentPermission::kPrintHighQuality));
+    const std::string line = base::StrCat(
+        {"pdf-print-intercept pid=",
+         base::NumberToString(base::GetCurrentProcId()),
+         " layer=pdf-view-web-plugin", " has_engine=", has_engine ? "1" : "0",
+         " can_print=", can_print ? "1" : "0", " url=", url_, "\n"});
+    base::AppendToFile(*intercept_path, line);
+    return;
+  }
+
   if (!engine_) {
     return;
   }
