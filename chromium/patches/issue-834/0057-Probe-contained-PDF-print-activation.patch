+void TsBrowserClient::AppendExtraCommandLineSwitches(
+    base::CommandLine* command_line,
+    int child_process_id) {
+  ShellContentBrowserClient::AppendExtraCommandLineSwitches(command_line,
+                                                            child_process_id);
+
+  if (command_line->GetSwitchValueASCII(switches::kProcessType) !=
+      switches::kRendererProcess) {
+    return;
+  }
+
+  std::optional<std::string> intercept_file =
+      GetTsPdfPrintInterceptFileFromEnv();
+  if (!intercept_file) {
+    return;
+  }
+
+  // Renderer processes do not reliably inherit the browser process environment.
+  // Forward the contained PDF print test guard explicitly so the PDF plugin can
+  // intercept before reaching native print.
+  command_line->AppendSwitch(kTsPdfPrintInterceptSwitch);
+  command_line->AppendSwitchASCII(kTsPdfPrintInterceptFileSwitch,
+                                  *intercept_file);
+}
