 namespace pdf {
+namespace {
+
+constexpr char kTsPdfPrintInterceptSwitch[] = "termsurf-pdf-print-intercept";
+constexpr char kTsPdfPrintInterceptFileSwitch[] =
+    "termsurf-pdf-print-intercept-file";
+
+std::optional<base::FilePath> GetTermSurfPdfPrintInterceptPath() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (command_line->HasSwitch(kTsPdfPrintInterceptSwitch)) {
+    base::FilePath path =
+        command_line->GetSwitchValuePath(kTsPdfPrintInterceptFileSwitch);
+    if (!path.empty()) {
+      return path;
+    }
+  }
+
+  std::unique_ptr<base::Environment> env = base::Environment::Create();
+  std::optional<std::string> enabled =
+      env->GetVar("TERMSURF_PDF_PRINT_INTERCEPT");
+  if (!enabled || *enabled != "1") {
+    return std::nullopt;
+  }
+
+  std::optional<std::string> path =
+      env->GetVar("TERMSURF_PDF_PRINT_INTERCEPT_FILE");
+  if (!path || path->empty()) {
+    return std::nullopt;
+  }
+
+  return base::FilePath::FromUTF8Unsafe(*path);
+}
+
