From 99328a4ab6b628918d90c37ae07955eadbdebf90 Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Sat, 23 May 2026 07:10:34 -0500
Subject: [PATCH 17/84] Trace select menu x coords

The menu slipped sideways,
So every bridge now names its place.
No math was moved today,
Only breadcrumbs in space.
---
 .../render_widget_host_ns_view_bridge.mm      | 59 +++++++++++++++++++
 .../web_menu_runner_mac.mm                    |  8 +++
 .../renderer_host/popup_menu_helper_mac.mm    |  6 ++
 .../renderer_host/render_frame_host_impl.cc   |  7 +++
 .../web_contents/web_contents_view_mac.mm     |  3 +
 5 files changed, 83 insertions(+)

diff --git a/content/app_shim_remote_cocoa/render_widget_host_ns_view_bridge.mm b/content/app_shim_remote_cocoa/render_widget_host_ns_view_bridge.mm
index f1b928a61f..1dce73e879 100644
--- a/content/app_shim_remote_cocoa/render_widget_host_ns_view_bridge.mm
+++ b/content/app_shim_remote_cocoa/render_widget_host_ns_view_bridge.mm
@@ -62,6 +62,31 @@ std::string Issue779NSRectToString(NSRect rect) {
   return base::SysNSStringToUTF8(NSStringFromRect(rect));
 }
 
+std::string Issue779TopLeftScreenRectToString(NSRect rect, NSScreen* screen) {
+  if (!screen) {
+    return "null";
+  }
+  NSRect screen_frame = screen.frame;
+  CGFloat top_left_y = NSMaxY(screen_frame) - NSMaxY(rect);
+  return base::SysNSStringToUTF8([NSString
+      stringWithFormat:@"{{%.1f, %.1f}, {%.1f, %.1f}}", rect.origin.x,
+                       top_left_y, rect.size.width, rect.size.height]);
+}
+
+std::string Issue779ScreenFrame(NSView* view) {
+  if (!view || !view.window || !view.window.screen) {
+    return "null";
+  }
+  return Issue779NSRectToString(view.window.screen.frame);
+}
+
+std::string Issue779VisibleFrame(NSView* view) {
+  if (!view || !view.window || !view.window.screen) {
+    return "null";
+  }
+  return Issue779NSRectToString(view.window.screen.visibleFrame);
+}
+
 }  // namespace
 
 RenderWidgetHostNSViewBridge::RenderWidgetHostNSViewBridge(
@@ -465,12 +490,39 @@ void RenderWidgetHostNSViewBridge::DisplayPopupMenu(
   if (Issue779TraceEnabled()) {
     Issue779TraceAnnounce();
     NSRect flipped_bounds = [cocoa_view_ flipRectToNSRect:menu->bounds];
+    NSRect flipped_bounds_in_window =
+        [cocoa_view_ convertRect:flipped_bounds toView:nil];
+    NSRect flipped_bounds_in_screen =
+        cocoa_view_.window
+            ? [cocoa_view_.window convertRectToScreen:flipped_bounds_in_window]
+            : NSZeroRect;
+    NSScreen* screen = cocoa_view_.window.screen;
     LOG(INFO) << "[issue-779-trace] "
                  "RenderWidgetHostNSViewBridge::DisplayPopupMenu"
+              << " select_x_position=1"
+              << " boundary=appkit_bridge"
+              << " event=display_popup_menu"
               << " bridge=" << static_cast<void*>(this)
               << " cocoa_view=" << (__bridge void*)cocoa_view_
               << " menu_bounds=" << menu->bounds.ToString()
+              << " menu_bounds_space=chromium-view-top-left"
               << " flipped_bounds=" << Issue779NSRectToString(flipped_bounds)
+              << " flipped_bounds_space=view-local-appkit-bottom-left"
+              << " flipped_bounds_in_window="
+              << Issue779NSRectToString(flipped_bounds_in_window)
+              << " flipped_bounds_in_window_space=window-bottom-left"
+              << " flipped_bounds_in_screen="
+              << (cocoa_view_.window
+                      ? Issue779NSRectToString(flipped_bounds_in_screen)
+                      : std::string("null"))
+              << " flipped_bounds_in_screen_space=screen-bottom-left"
+              << " flipped_bounds_top_left_screen="
+              << (cocoa_view_.window
+                      ? Issue779TopLeftScreenRectToString(
+                            flipped_bounds_in_screen, screen)
+                      : std::string("null"))
+              << " flipped_bounds_top_left_screen_space=screen-top-left"
+              << " right_aligned=" << menu->right_aligned
               << " selected_item=" << menu->selected_item
               << " item_count=" << menu->items.size()
               << " item_font_size=" << menu->item_font_size
@@ -483,6 +535,13 @@ void RenderWidgetHostNSViewBridge::DisplayPopupMenu(
               << (cocoa_view_.window
                       ? Issue779NSRectToString(cocoa_view_.window.frame)
                       : std::string("null"))
+              << " window_content_frame="
+              << (cocoa_view_.window.contentView
+                      ? Issue779NSRectToString(
+                            cocoa_view_.window.contentView.frame)
+                      : std::string("null"))
+              << " screen_frame=" << Issue779ScreenFrame(cocoa_view_)
+              << " visible_frame=" << Issue779VisibleFrame(cocoa_view_)
               << " is_headless=" << (ns_window && ns_window.isHeadless);
   }
   if (ns_window && ns_window.isHeadless) {
