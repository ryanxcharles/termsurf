@@ -352,6 +355,7 @@ void Issue779TraceShellWindowState(NSString* boundary,
                       ? Issue779TopLeftScreenRectToString(screenBounds, screen)
                       : std::string("null"))
               << " bounds_top_left_screen_space=chromium-screen-top-left"
+              << " right_aligned=" << static_cast<bool>(_rightAligned)
               << " final_popup_top_left=unavailable-appkit-owned"
               << " initial_index=" << index
               << " item_count=" << _menu.numberOfItems;
@@ -437,6 +441,9 @@ void Issue779TraceShellWindowState(NSString* boundary,
     NSScreen* screen = fakeControlView.window.screen;
     LOG(INFO)
         << "[issue-779-trace] WebMenuRunner::fakeControlView"
+        << " select_x_position=1"
+        << " boundary=web_menu_runner"
+        << " event=fake_control_view"
         << " path=select"
         << " join_view=" << (__bridge void*)view
         << " join_window=" << (__bridge void*)fakeControlView.window
@@ -457,6 +464,7 @@ void Issue779TraceShellWindowState(NSString* boundary,
         << " attach_popup_frame="
         << Issue779NSRectToString(fakeControlView.bounds)
         << " attach_popup_frame_space=view-local"
+        << " right_aligned=" << static_cast<bool>(_rightAligned)
         << " final_popup_top_left=unavailable-appkit-owned";
   }
 
