+bool Issue794InputTraceEnabled() {
+  static const bool enabled =
+      std::getenv("TERMSURF_PDF_INPUT_TRACE") != nullptr;
+  return enabled;
+}
+
+const char* Issue794AreaLabel(PDFiumPage::Area area) {
+  switch (area) {
+    case PDFiumPage::NONSELECTABLE_AREA:
+      return "page-non-text";
+    case PDFiumPage::TEXT_AREA:
+      return "text";
+    case PDFiumPage::WEBLINK_AREA:
+    case PDFiumPage::DOCLINK_AREA:
+      return "link";
+    case PDFiumPage::FORM_TEXT_AREA:
+      return "form";
+  }
+  return "unknown";
+}
+
+std::string Issue794SelectedTextSample(std::string text) {
+  base::ReplaceChars(text, "\r\n\t", " ", &text);
+  if (text.size() > 80) {
+    text.resize(80);
+  }
+  return text;
+}
+
 template <class S>
 bool IsAboveOrDirectlyLeftOf(const S& lhs, const S& rhs) {
   return lhs.y() < rhs.y() || (lhs.y() == rhs.y() && lhs.x() < rhs.x());
@@ -1738,6 +1769,8 @@ void PDFiumEngine::OnTextOrLinkAreaClickInternal(const PointData& point_data,
