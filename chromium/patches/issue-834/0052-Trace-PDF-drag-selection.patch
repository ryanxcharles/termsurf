     "chrome-extension://mhjfbmdgcfjbbpaeojofohoefgiehjai/";
 
+bool Issue794InputTraceEnabled() {
+  static const bool enabled =
+      std::getenv("TERMSURF_PDF_INPUT_TRACE") != nullptr;
+  return enabled;
+}
+
+bool Issue794IsMousePointerEvent(blink::WebInputEvent::Type type) {
+  return type == blink::WebInputEvent::Type::kMouseDown ||
+         type == blink::WebInputEvent::Type::kMouseMove ||
+         type == blink::WebInputEvent::Type::kMouseUp;
+}
+
 // Print Preview base URL.
 constexpr std::string_view kChromePrintHost = "chrome://print/";
 
@@ -2790,7 +2803,36 @@ bool PdfViewWebPlugin::HandleWebInputEvent(const blink::WebInputEvent& event) {
   }
 #endif
 
-  if (engine_->HandleInputEvent(event_to_handle)) {
+  bool engine_handled = engine_->HandleInputEvent(event_to_handle);
+  if (Issue794InputTraceEnabled() &&
+      Issue794IsMousePointerEvent(event.GetType())) {
+    const auto& original_mouse =
+        static_cast<const blink::WebMouseEvent&>(event);
+    const auto& transformed_mouse =
+        static_cast<const blink::WebMouseEvent&>(event_to_handle);
+    const gfx::PointF original_position = original_mouse.PositionInWidget();
+    const gfx::PointF transformed_position =
+        transformed_mouse.PositionInWidget();
+    LOG(INFO) << "[issue-794-exp7] plugin-input type="
+              << static_cast<int>(event.GetType())
+              << " original_x=" << original_position.x()
+              << " original_y=" << original_position.y()
+              << " transformed_x=" << transformed_position.x()
+              << " transformed_y=" << transformed_position.y()
+              << " button=" << static_cast<int>(original_mouse.button)
+              << " click_count=" << original_mouse.ClickCount()
+              << " modifiers=" << original_mouse.GetModifiers()
+              << " available_area_x=" << available_area_.x()
+              << " available_area_y=" << available_area_.y()
+              << " available_area_width=" << available_area_.width()
+              << " available_area_height=" << available_area_.height()
+              << " viewport_to_dip_scale=" << viewport_to_dip_scale_
+              << " device_scale=" << device_scale_
+              << " viewport_to_device_scale=" << viewport_to_device_scale
+              << " engine_handled=" << engine_handled;
+  }
+
+  if (engine_handled) {
     return true;
   }
 
