 bool PDFiumEngine::OnMouseMove(const blink::WebMouseEvent& event) {
+  const bool left_button_down_before = mouse_left_button_down_;
+  const bool selecting_before = selecting_;
   const gfx::PointF& point = event.PositionInWidget();
   auto point_data = GetPointData(point);
+  auto log_result = [&](const char* outcome, bool handler_return_value,
+                        bool returned_before_selection, bool extend_reached,
+                        bool extend_return_value) {
+    if (!Issue794InputTraceEnabled()) {
+      return;
+    }
+    LOG(INFO) << "[issue-794-exp7] pdfium-mouse event=mouse-move outcome="
+              << outcome << " widget_x=" << point.x()
+              << " widget_y=" << point.y()
+              << " left_down_before=" << left_button_down_before
+              << " left_down_after=" << mouse_left_button_down_
+              << " selecting_before=" << selecting_before
+              << " selecting_after=" << selecting_
+              << " handler_return=" << handler_return_value
+              << " page_index=" << point_data.page_index
+              << " char_index=" << point_data.char_index
+              << " area=" << static_cast<int>(point_data.area)
+              << " area_label=" << Issue794AreaLabel(point_data.area)
+              << " pdf_x=" << point_data.pdf_point.x()
+              << " pdf_y=" << point_data.pdf_point.y()
+              << " returned_before_selection=" << returned_before_selection
+              << " extend_reached=" << extend_reached
+              << " extend_return=" << extend_return_value
+              << " selected_text_length=" << GetSelectedText().size();
+  };
 
   // Clear `mouse_down_state_` if mouse moves away from where the mouse down
   // happened.
@@ -2029,23 +2139,29 @@ bool PDFiumEngine::OnMouseMove(const blink::WebMouseEvent& event) {
 
     // No need to swallow the event, since this might interfere with the
     // scrollbars if the user is dragging them.
+    log_result("not-selecting", false, true, false, false);
     return false;
   }
 
   // We're selecting but right now we're not over text, so don't change the
   // current selection.
   if (!PageIndexInBounds(point_data.page_index) || point_data.char_index < 0) {
+    log_result("invalid-page-or-char", false, false, false, false);
     return false;
   }
 
   // Similarly, do not select if `area` is not a selectable type. This can occur
   // even if there is text in the area. e.g. When print previewing.
   if (!IsSelectableArea(point_data.area)) {
+    log_result("non-selectable-area", false, false, false, false);
     return false;
   }
 
   SelectionChangeInvalidator selection_invalidator(this);
-  return ExtendSelection(point_data);
