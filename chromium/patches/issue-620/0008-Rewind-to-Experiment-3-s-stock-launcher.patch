From c12e30c440fb568016c2b8eec02234057daccc77 Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Sun, 22 Feb 2026 08:55:41 -0600
Subject: [PATCH 08/13] Rewind to Experiment 3's stock launcher
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

We stripped the callbacks, the quit, the views,
Back to shell_main_mac with nothing to lose.
But two frames per second still haunted the screen—
The ghost was here all along, unseen.

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 content/zig_content_shell/BUILD.gn            |   7 +-
 content/zig_content_shell/content_api_shim.h  |  39 -------
 content/zig_content_shell/content_api_shim.mm | 103 +++++-------------
 3 files changed, 35 insertions(+), 114 deletions(-)

diff --git a/content/zig_content_shell/BUILD.gn b/content/zig_content_shell/BUILD.gn
index 915e43db79c1a..dc914d7d366fa 100644
--- a/content/zig_content_shell/BUILD.gn
+++ b/content/zig_content_shell/BUILD.gn
@@ -35,14 +35,17 @@ tweak_info_plist("zig_content_shell_plist") {
 mac_app_bundle("zig_content_shell") {
   testonly = true
   output_name = zig_content_shell_product_name
-  sources = [ "ts_main.mm" ]
+  sources = [ "//content/shell/app/shell_main_mac.cc" ]
+  defines = [ "SHELL_PRODUCT_NAME=\"$zig_content_shell_product_name\"" ]
 
-  frameworks = [ "Cocoa.framework" ]
   deps = [
     ":zig_content_shell_framework_bundle_data",
     ":zig_content_shell_resources_bundle_data",
+    "//base/allocator:early_zone_registration_apple",
+    "//sandbox/mac:seatbelt",
   ]
   info_plist_target = ":zig_content_shell_plist"
+  data_deps = [ "//content/shell:content_shell_app" ]
 
   if (is_component_build) {
     ldflags = [ "-Wl,-rpath,@executable_path/../Frameworks" ]
diff --git a/content/zig_content_shell/content_api_shim.h b/content/zig_content_shell/content_api_shim.h
index bd47c683b5afb..f7927bc636768 100644
--- a/content/zig_content_shell/content_api_shim.h
+++ b/content/zig_content_shell/content_api_shim.h
@@ -34,45 +34,6 @@ void ts_destroy_browser_context(ts_browser_context_t ctx);
 __attribute__((visibility("default")))
 void ts_create_tab(ts_browser_context_t ctx, const char* url);
 
-// Callback type for lifecycle events.
-typedef void (*ts_callback_t)(void);
-
-// Register a callback that fires once when the browser is ready.
-// Must be called before ContentMain. The callback should create
-// profiles and tabs via the C API.
-__attribute__((visibility("default")))
-void ts_set_on_initialized(ts_callback_t callback);
-
-// Register a callback that fires during shutdown, before contexts
-// are destroyed. The callback should call ts_destroy_browser_context
-// on any contexts it created.
-__attribute__((visibility("default")))
-void ts_set_on_shutdown(ts_callback_t callback);
-
-// Opaque handle for a WebContents (page).
-typedef void* ts_web_contents_t;
-
-// Create a WebContents in the given profile, loading the URL.
-// Does NOT create a window — caller must attach the native view
-// to their own window via ts_get_native_view.
-__attribute__((visibility("default")))
-ts_web_contents_t ts_create_web_contents(ts_browser_context_t ctx,
-                                         const char* url);
-
-// Get the native view (NSView* on macOS) for a WebContents.
-// The returned pointer is a valid NSView* that can be added as a
-// subview to any NSWindow's contentView.
-__attribute__((visibility("default")))
-void* ts_get_native_view(ts_web_contents_t contents);
-
-// Destroy a WebContents.
-__attribute__((visibility("default")))
-void ts_destroy_web_contents(ts_web_contents_t contents);
-
-// Quit the message loop. Call this when all windows are closed.
-__attribute__((visibility("default")))
-void ts_quit(void);
-
 #ifdef __cplusplus
 }  // extern "C"
 #endif
diff --git a/content/zig_content_shell/content_api_shim.mm b/content/zig_content_shell/content_api_shim.mm
index 42d99e8609a5e..4e79433d28263 100644
--- a/content/zig_content_shell/content_api_shim.mm
+++ b/content/zig_content_shell/content_api_shim.mm
@@ -5,14 +5,16 @@
 // ContentMain() which shell_main_mac.cc calls via dlsym, plus
 // ts_create_browser_context / ts_destroy_browser_context / ts_create_tab
 // which Zig (or any C caller) can use to control the browser.
+//
+// Experiment 8: Replay Experiment 3's exact framework state to bisect
+// the 2fps regression. No callback API, no WillRunMainMessageLoop override,
+// no quit closure — hardcoded profiles in TsBrowserMainParts.
 
 #include "content/zig_content_shell/content_api_shim.h"
 
 #include <string>
 
 #include "base/apple/bundle_locations.h"
-#include "base/no_destructor.h"
-#include "base/run_loop.h"
 #include "base/apple/foundation_util.h"
 #include "base/base_paths.h"
 #include "base/path_service.h"
@@ -26,9 +28,6 @@
 #include "content/shell/browser/shell_browser_main_parts.h"
 #include "content/shell/browser/shell_content_browser_client.h"
 #include "content/shell/common/shell_paths.h"
-#include "content/public/browser/navigation_controller.h"
-#include "content/public/browser/web_contents.h"
-#include "ui/base/page_transition_types.h"
 #include "url/gurl.h"
 
 namespace {
@@ -101,18 +100,6 @@ void TsOverrideBundleID() {
       base::SysNSStringToUTF8(bundle.bundleIdentifier));
 }
 
-// ---------------------------------------------------------------------------
-// Lifecycle callbacks (set by the launcher before ContentMain)
-// ---------------------------------------------------------------------------
-
-static ts_callback_t g_on_initialized = nullptr;
-static ts_callback_t g_on_shutdown = nullptr;
-
-base::OnceClosure& GetQuitClosure() {
-  static base::NoDestructor<base::OnceClosure> closure;
-  return *closure;
-}
-
 // ---------------------------------------------------------------------------
 // Content API subclasses
 // ---------------------------------------------------------------------------
@@ -120,35 +107,42 @@ void TsOverrideBundleID() {
 class TsBrowserMainParts : public content::ShellBrowserMainParts {
  protected:
   void InitializeBrowserContexts() override {
-    // Create a default context for parent infrastructure (DevTools, resource
-    // provider). Actual user profiles are created by the on_initialized
-    // callback.
     base::FilePath home;
     base::PathService::Get(base::DIR_HOME, &home);
-    base::PathService::Override(
-        content::SHELL_DIR_USER_DATA,
-        home.Append(".config/termsurf/zig-content-shell/default"));
-    set_browser_context(new content::ShellBrowserContext(false));
+    std::string base_path =
+        home.Append(".config/termsurf/zig-content-shell").value();
+
+    // Profile A — created via C API, ownership transferred to parent via
+    // set_browser_context so the parent's PreMainMessageLoopRun can pass
+    // it to DevTools and other infrastructure.
+    ctx_a_ = ts_create_browser_context(
+        (base_path + "/profile-a").c_str());
+    set_browser_context(
+        static_cast<content::ShellBrowserContext*>(ctx_a_));
+
+    // Profile B — created via C API, we own it.
+    ctx_b_ = ts_create_browser_context(
+        (base_path + "/profile-b").c_str());
   }
 
   void InitializeMessageLoopContext() override {
-    if (g_on_initialized) {
-      g_on_initialized();
-    }
-  }
-
-  void WillRunMainMessageLoop(
-      std::unique_ptr<base::RunLoop>& run_loop) override {
-    GetQuitClosure() = run_loop->QuitClosure();
-    ShellBrowserMainParts::WillRunMainMessageLoop(run_loop);
+    ts_create_tab(ctx_a_, "https://google.com");
+    ts_create_tab(ctx_b_, "https://example.com");
   }
 
   void PostMainMessageLoopRun() override {
-    if (g_on_shutdown) {
-      g_on_shutdown();
-    }
+    // Destroy profile B (we own it).
+    ts_destroy_browser_context(ctx_b_);
+    ctx_b_ = nullptr;
+    // Profile A is owned by the parent via set_browser_context — the parent's
+    // PostMainMessageLoopRun will destroy it.
+    ctx_a_ = nullptr;
     ShellBrowserMainParts::PostMainMessageLoopRun();
   }
+
+ private:
+  ts_browser_context_t ctx_a_ = nullptr;
+  ts_browser_context_t ctx_b_ = nullptr;
 };
 
 class TsContentBrowserClient : public content::ShellContentBrowserClient {
@@ -214,41 +208,4 @@ void ts_create_tab(ts_browser_context_t ctx, const char* url) {
                                   gfx::Size());
 }
 
-void ts_set_on_initialized(ts_callback_t callback) {
-  g_on_initialized = callback;
-}
-
-void ts_set_on_shutdown(ts_callback_t callback) {
-  g_on_shutdown = callback;
-}
-
-ts_web_contents_t ts_create_web_contents(ts_browser_context_t ctx,
-                                         const char* url) {
-  auto* browser_context =
-      static_cast<content::ShellBrowserContext*>(ctx);
-  content::WebContents::CreateParams params(browser_context);
-  auto* wc = content::WebContents::Create(params).release();
-
-  content::NavigationController::LoadURLParams load_params{GURL(url)};
-  load_params.transition_type = ui::PAGE_TRANSITION_TYPED;
-  wc->GetController().LoadURLWithParams(load_params);
-
-  return static_cast<ts_web_contents_t>(wc);
-}
-
-void* ts_get_native_view(ts_web_contents_t contents) {
-  auto* wc = static_cast<content::WebContents*>(contents);
-  return (__bridge void*)wc->GetNativeView().GetNativeNSView();
-}
-
-void ts_destroy_web_contents(ts_web_contents_t contents) {
-  delete static_cast<content::WebContents*>(contents);
-}
-
-void ts_quit(void) {
-  auto& quit = GetQuitClosure();
-  if (quit)
-    std::move(quit).Run();
-}
-
 #endif  // BUILDFLAG(IS_MAC)
-- 
