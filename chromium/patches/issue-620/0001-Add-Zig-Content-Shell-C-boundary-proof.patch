diff --git a/content/zig_content_shell/BUILD.gn b/content/zig_content_shell/BUILD.gn
new file mode 100644
index 0000000000000..dc914d7d366fa
--- /dev/null
+++ b/content/zig_content_shell/BUILD.gn
@@ -0,0 +1,253 @@
+# Copyright 2025 TermSurf. All rights reserved.
+#
+# Minimal Content Shell derivative that proves the Content API can be driven
+# through a C function boundary. Reuses content_shell_lib and content_shell_app
+# from //content/shell — only adds a thin shim (content_api_shim.cc) with
+# custom subclasses and path overrides.
+
+import("//build/config/mac/rules.gni")
+import("//build/apple/tweak_info_plist.gni")
+import("//content/public/app/mac_helpers.gni")
+import("//third_party/icu/config.gni")
+import("//tools/v8_context_snapshot/v8_context_snapshot.gni")
+import("//ui/gl/features.gni")
+
+declare_args() {
+  zig_content_shell_product_name = "Zig Content Shell"
+  zig_content_shell_version = "1.0.0.0"
+}
+
+zig_content_shell_framework_name = "$zig_content_shell_product_name Framework"
+zig_content_shell_helper_name = "$zig_content_shell_product_name Helper"
+
+# --- App bundle (thin launcher that dlopen's the framework) ---
+
+tweak_info_plist("zig_content_shell_plist") {
+  testonly = true
+  info_plist = "app-Info.plist"
+  args = [
+    "--scm=1",
+    "--version",
+    zig_content_shell_version,
+  ]
+}
+
+mac_app_bundle("zig_content_shell") {
+  testonly = true
+  output_name = zig_content_shell_product_name
+  sources = [ "//content/shell/app/shell_main_mac.cc" ]
+  defines = [ "SHELL_PRODUCT_NAME=\"$zig_content_shell_product_name\"" ]
+
+  deps = [
+    ":zig_content_shell_framework_bundle_data",
+    ":zig_content_shell_resources_bundle_data",
+    "//base/allocator:early_zone_registration_apple",
+    "//sandbox/mac:seatbelt",
+  ]
+  info_plist_target = ":zig_content_shell_plist"
+  data_deps = [ "//content/shell:content_shell_app" ]
+
+  if (is_component_build) {
+    ldflags = [ "-Wl,-rpath,@executable_path/../Frameworks" ]
+  }
+}
+
+# --- Framework (contains the actual Content API shim code) ---
+
+tweak_info_plist("zig_content_shell_framework_plist") {
+  testonly = true
+  info_plist = "framework-Info.plist"
+  args = [
+    "--breakpad=0",
+    "--keystone=0",
+    "--scm=1",
+    "--version",
+    zig_content_shell_version,
+    "--branding",
+    zig_content_shell_product_name,
+  ]
+}
+
+mac_framework_bundle("zig_content_shell_framework") {
+  testonly = true
+  output_name = zig_content_shell_framework_name
+  framework_version = "C"
+
+  framework_contents = [
+    "Helpers",
+    "Libraries",
+    "Resources",
+  ]
+
+  sources = [
+    "content_api_shim.mm",
+    "content_api_shim.h",
+  ]
+
+  deps = [
+    "//content/shell:content_shell_app",
+    "//content/public/app",
+    "//content/public/common",
+    "//third_party/icu:icudata",
+  ]
+
+  if (!use_static_angle) {
+    deps += [ ":zig_content_shell_angle_binaries" ]
+  }
+
+  bundle_deps = [
+    ":zig_content_shell_framework_helpers",
+    ":zig_content_shell_framework_resources",
+    ":zig_content_shell_swiftshader_binaries",
+  ]
+
+  if (!is_component_build) {
+    ldflags = [ "-Wl,-install_name,@executable_path/../Frameworks/$output_name.framework/$output_name" ]
+  } else {
+    ldflags = [
+      "-Wl,-install_name,@rpath/$output_name.framework/$output_name",
+      "-Wl,-rpath,@loader_path/../../../../../..",
+    ]
+  }
+
+  info_plist_target = ":zig_content_shell_framework_plist"
+}
+
+# --- Helper apps (GPU, Renderer, Utility processes) ---
+
+tweak_info_plist("zig_content_shell_helper_plist") {
+  testonly = true
+  info_plist = "helper-Info.plist"
+  args = [
+    "--breakpad=0",
+    "--keystone=0",
+    "--scm=0",
+    "--version",
+    zig_content_shell_version,
+  ]
+}
+
+template("zig_content_shell_helper_app") {
+  mac_app_bundle(target_name) {
+    assert(defined(invoker.helper_name_suffix))
+    assert(defined(invoker.helper_bundle_id_suffix))
+
+    testonly = true
+    output_name = zig_content_shell_helper_name + invoker.helper_name_suffix
+    sources = [ "//content/shell/app/shell_main_mac.cc" ]
+    defines = [
+      "HELPER_EXECUTABLE",
+      "SHELL_PRODUCT_NAME=\"$zig_content_shell_product_name\"",
+    ]
+    extra_substitutions = [
+      "CONTENT_ZIG_CONTENT_SHELL_HELPER_SUFFIX=${invoker.helper_name_suffix}",
+      "CONTENT_ZIG_CONTENT_SHELL_HELPER_BUNDLE_ID_SUFFIX=${invoker.helper_bundle_id_suffix}",
+    ]
+    deps = [
+      "//base/allocator:early_zone_registration_apple",
+      "//sandbox/mac:seatbelt",
+    ]
+    info_plist_target = ":zig_content_shell_helper_plist"
+
+    if (is_component_build) {
+      ldflags = [
+        "-Wl,-rpath,@executable_path/../../../../../../..",
+        "-Wl,-rpath,@executable_path/../../../../../../../../../..",
+      ]
+      deps += [ ":zig_content_shell_framework+link_nested" ]
+    }
+  }
+}
+
+foreach(helper_params, content_mac_helpers) {
+  _helper_target = helper_params[0]
+  _helper_bundle_id = helper_params[1]
+  _helper_suffix = helper_params[2]
+  zig_content_shell_helper_app(
+      "zig_content_shell_helper_app_${_helper_target}") {
+    helper_name_suffix = _helper_suffix
+    helper_bundle_id_suffix = _helper_bundle_id
+  }
+}
+
+# --- Bundle data (framework, helpers, resources, libraries) ---
+
+bundle_data("zig_content_shell_framework_helpers") {
+  testonly = true
+  sources = [ "$root_out_dir/chrome_crashpad_handler" ]
+  outputs = [ "{{bundle_contents_dir}}/Helpers/{{source_file_part}}" ]
+  public_deps = [ "//components/crash/core/app:chrome_crashpad_handler" ]
+  foreach(helper_params, content_mac_helpers) {
+    sources += [
+      "$root_out_dir/${zig_content_shell_helper_name}${helper_params[2]}.app",
+    ]
+    public_deps +=
+        [ ":zig_content_shell_helper_app_${helper_params[0]}" ]
+  }
+}
+
+bundle_data("zig_content_shell_framework_bundle_data") {
+  testonly = true
+  sources =
+      [ "$root_out_dir/$zig_content_shell_framework_name.framework" ]
+  outputs = [ "{{bundle_contents_dir}}/Frameworks/{{source_file_part}}" ]
+  if (is_component_build) {
+    public_deps = [ ":zig_content_shell_framework+link" ]
+  } else {
+    public_deps = [ ":zig_content_shell_framework" ]
+  }
+}
+
+bundle_data("zig_content_shell_framework_resources") {
+  testonly = true
+
+  # Reuse Content Shell's pak file — it contains all the resources we need.
+  sources = [ "$root_out_dir/content_shell.pak" ]
+  public_deps = [ "//content/shell:pak" ]
+
+  if (icu_use_data_file) {
+    sources += [ "$root_out_dir/icudtl.dat" ]
+    deps = [ "//third_party/icu:icudata" ]
+  }
+
+  sources += [ "//ui/gl/resources/angle-metal/gpu_shader_cache.bin" ]
+
+  if (v8_use_external_startup_data) {
+    public_deps += [ "//v8" ]
+    if (use_v8_context_snapshot) {
+      sources += [ "$root_out_dir/$v8_context_snapshot_filename" ]
+      public_deps += [ "//tools/v8_context_snapshot" ]
+    }
+    if (!use_v8_context_snapshot || include_both_v8_snapshots) {
+      sources += [ "$root_out_dir/snapshot_blob.bin" ]
+    }
+  }
+
+  outputs = [ "{{bundle_resources_dir}}/{{source_file_part}}" ]
+}
+
+bundle_data("zig_content_shell_resources_bundle_data") {
+  testonly = true
+  sources = [ "//content/shell/app/app.icns" ]
+  outputs = [ "{{bundle_resources_dir}}/{{source_file_part}}" ]
+}
+
+if (!use_static_angle) {
+  bundle_data("zig_content_shell_angle_binaries") {
+    sources = [
+      "$root_out_dir/egl_intermediates/libEGL.dylib",
+      "$root_out_dir/egl_intermediates/libGLESv2.dylib",
+    ]
+    outputs = [ "{{bundle_contents_dir}}/Libraries/{{source_file_part}}" ]
+    public_deps = [ "//ui/gl:angle_library_copy" ]
+  }
+}
+
+bundle_data("zig_content_shell_swiftshader_binaries") {
+  sources = [
+    "$root_out_dir/vk_intermediates/libvk_swiftshader.dylib",
+    "$root_out_dir/vk_intermediates/vk_swiftshader_icd.json",
+  ]
+  outputs = [ "{{bundle_contents_dir}}/Libraries/{{source_file_part}}" ]
+  public_deps = [ "//ui/gl:swiftshader_vk_library_copy" ]
+}
