diff --git a/content/zig_content_shell/content_api_shim.mm b/content/zig_content_shell/content_api_shim.mm
new file mode 100644
index 0000000000000..b0677340322d5
--- /dev/null
+++ b/content/zig_content_shell/content_api_shim.mm
@@ -0,0 +1,154 @@
+// Copyright 2025 TermSurf. All rights reserved.
+//
+// Thin C++ shim that drives the Content API through a C function boundary.
+// Subclasses Content Shell's classes and overrides just enough to load a
+// hardcoded URL. The framework exports ContentMain() which shell_main_mac.cc
+// calls via dlsym.
+
+#include "content/zig_content_shell/content_api_shim.h"
+
+#include <string>
+
+#include "base/apple/bundle_locations.h"
+#include "base/apple/foundation_util.h"
+#include "base/base_paths.h"
+#include "base/path_service.h"
+#include "base/strings/sys_string_conversions.h"
+#include "build/build_config.h"
+#include "content/public/app/content_main.h"
+#include "content/public/common/content_paths.h"
+#include "content/shell/app/shell_main_delegate.h"
+#include "content/shell/browser/shell.h"
+#include "content/shell/browser/shell_browser_main_parts.h"
+#include "content/shell/browser/shell_content_browser_client.h"
+#include "url/gurl.h"
+
+namespace {
+
+// ---------------------------------------------------------------------------
+// Path overrides for "Zig Content Shell" product name.
+// These mirror content/shell/app/paths_apple.mm but use our bundle names.
+// We give them unique names to avoid symbol collisions with the functions
+// compiled into content_shell_app (which use "Content Shell" names).
+// ---------------------------------------------------------------------------
+
+base::FilePath GetContentsPath() {
+  base::FilePath path;
+  base::PathService::Get(base::FILE_EXE, &path);
+
+  if (path.value().find("/Helpers/") != std::string::npos) {
+    // Helper process: go up 9 levels from the helper executable.
+    path = path.DirName()
+               .DirName()
+               .DirName()
+               .DirName()
+               .DirName()
+               .DirName()
+               .DirName()
+               .DirName()
+               .DirName();
+  } else {
+    // Main process: up to MacOS, then to Contents.
+    path = path.DirName().DirName();
+  }
+  return path;
+}
+
+base::FilePath GetFrameworksPath() {
+  return GetContentsPath().Append("Frameworks");
+}
+
+void TsOverrideFrameworkBundlePath() {
+  base::FilePath path =
+      GetFrameworksPath().Append("Zig Content Shell Framework.framework");
+  base::apple::SetOverrideFrameworkBundlePath(path);
+}
+
+void TsOverrideOuterBundlePath() {
+  base::FilePath path = GetContentsPath().DirName();
+  base::apple::SetOverrideOuterBundlePath(path);
+}
+
+void TsOverrideChildProcessPath() {
+  base::FilePath path = base::apple::FrameworkBundlePath()
+                             .Append("Helpers")
+                             .Append("Zig Content Shell Helper.app")
+                             .Append("Contents")
+                             .Append("MacOS")
+                             .Append("Zig Content Shell Helper");
+  base::PathService::OverrideAndCreateIfNeeded(
+      content::CHILD_PROCESS_EXE, path, /*is_absolute=*/true,
+      /*create=*/false);
+}
+
+void TsOverrideSourceRootPath() {
+  base::PathService::Override(
+      base::DIR_SRC_TEST_DATA_ROOT,
+      GetFrameworksPath().DirName().DirName().DirName().DirName().DirName());
+}
+
+void TsOverrideBundleID() {
+  NSBundle* bundle = base::apple::OuterBundle();
+  base::apple::SetBaseBundleIDOverride(
+      base::SysNSStringToUTF8(bundle.bundleIdentifier));
+}
+
+// ---------------------------------------------------------------------------
+// Content API subclasses
+// ---------------------------------------------------------------------------
+
+// The URL to load. Hardcoded for Experiment 1.
+const char* kInitialUrl = "https://google.com";
+
+class TsBrowserMainParts : public content::ShellBrowserMainParts {
+ protected:
+  void InitializeMessageLoopContext() override {
+    content::Shell::CreateNewWindow(browser_context(), GURL(kInitialUrl),
+                                    nullptr, gfx::Size());
+  }
+};
+
+class TsContentBrowserClient : public content::ShellContentBrowserClient {
+ public:
+  std::unique_ptr<content::BrowserMainParts> CreateBrowserMainParts(
+      bool /* is_integration_test */) override {
+    auto parts = std::make_unique<TsBrowserMainParts>();
+    set_browser_main_parts(parts.get());
+    return parts;
+  }
+};
+
+class TsMainDelegate : public content::ShellMainDelegate {
+ protected:
+  content::ContentBrowserClient* CreateContentBrowserClient() override {
+    browser_client_ = std::make_unique<TsContentBrowserClient>();
+    return browser_client_.get();
+  }
+
+ private:
+  std::unique_ptr<TsContentBrowserClient> browser_client_;
+};
+
+}  // namespace
+
+// ---------------------------------------------------------------------------
+// Framework entry point — called by shell_main_mac.cc via dlsym.
+// ---------------------------------------------------------------------------
+
+#if BUILDFLAG(IS_MAC)
+int ContentMain(int argc, const char** argv) {
+  TsMainDelegate delegate;
+  content::ContentMainParams params(&delegate);
+  params.argc = argc;
+  params.argv = argv;
+
+  // Set up bundle paths before ContentMain runs.
+  TsOverrideFrameworkBundlePath();
+  TsOverrideOuterBundlePath();
+  TsOverrideChildProcessPath();
+  TsOverrideSourceRootPath();
+  TsOverrideBundleID();
+
+  return content::ContentMain(std::move(params));
+}
+#endif  // BUILDFLAG(IS_MAC)
