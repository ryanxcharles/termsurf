diff --git a/content/zig_content_shell/ts_main.mm b/content/zig_content_shell/ts_main.mm
new file mode 100644
index 0000000000000..c1d1ff4480b7c
--- /dev/null
+++ b/content/zig_content_shell/ts_main.mm
@@ -0,0 +1,131 @@
+// Copyright 2025 TermSurf. All rights reserved.
+//
+// Custom launcher for Zig Content Shell. Replaces shell_main_mac.cc.
+// Pure C with dlopen/dlsym — no Chromium headers, no C++ includes.
+// Proves the full external-control pattern: a Zig launcher would use
+// the identical dlsym approach.
+
+#ifdef UNSAFE_BUFFERS_BUILD
+#pragma allow_unsafe_libc_calls
+#endif
+
+#include <dlfcn.h>
+#include <errno.h>
+#include <libgen.h>
+#include <mach-o/dyld.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+
+// Function pointer types matching content_api_shim.h.
+typedef int (*ContentMainFn)(int, const char**);
+typedef void (*CallbackFn)(void);
+typedef void (*SetCallbackFn)(CallbackFn);
+typedef void* (*CreateContextFn)(const char*);
+typedef void (*DestroyContextFn)(void*);
+typedef void (*CreateTabFn)(void*, const char*);
+
+// dlsym'd function pointers (set in main, used by callbacks).
+static CreateContextFn g_create_ctx;
+static DestroyContextFn g_destroy_ctx;
+static CreateTabFn g_create_tab;
+
+// Context handles (created in on_initialized, destroyed in on_shutdown).
+static void* ctx_a;
+static void* ctx_b;
+
+static void on_initialized(void) {
+  const char* home = getenv("HOME");
+  if (!home) {
+    fprintf(stderr, "HOME not set\n");
+    abort();
+  }
+
+  char path_a[1024];
+  char path_b[1024];
+  snprintf(path_a, sizeof(path_a),
+           "%s/.config/termsurf/zig-content-shell/profile-a", home);
+  snprintf(path_b, sizeof(path_b),
+           "%s/.config/termsurf/zig-content-shell/profile-b", home);
+
+  ctx_a = g_create_ctx(path_a);
+  ctx_b = g_create_ctx(path_b);
+  g_create_tab(ctx_a, "https://google.com");
+  g_create_tab(ctx_b, "https://example.com");
+}
+
+static void on_shutdown(void) {
+  g_destroy_ctx(ctx_b);
+  ctx_b = NULL;
+  g_destroy_ctx(ctx_a);
+  ctx_a = NULL;
+}
+
+int main(int argc, const char** argv) {
+  // Find the executable path.
+  uint32_t exec_path_size = 0;
+  int rv = _NSGetExecutablePath(NULL, &exec_path_size);
+  if (rv != -1) {
+    fprintf(stderr, "_NSGetExecutablePath: get length failed\n");
+    abort();
+  }
+
+  char* exec_path = (char*)malloc(exec_path_size);
+  rv = _NSGetExecutablePath(exec_path, &exec_path_size);
+  if (rv != 0) {
+    fprintf(stderr, "_NSGetExecutablePath: get path failed\n");
+    abort();
+  }
+
+  // Framework path relative to the executable:
+  //   <MacOS>/../Frameworks/Zig Content Shell Framework.framework/
+  //   Zig Content Shell Framework
+  const char* parent_dir = dirname(exec_path);
+  if (!parent_dir) {
+    fprintf(stderr, "dirname %s: %s\n", exec_path, strerror(errno));
+    abort();
+  }
+
+  const char rel_path[] =
+      "../Frameworks/Zig Content Shell Framework.framework/"
+      "Zig Content Shell Framework";
+  size_t fw_path_size = strlen(parent_dir) + sizeof(rel_path) + 1;
+  char* fw_path = (char*)malloc(fw_path_size);
+  snprintf(fw_path, fw_path_size, "%s/%s", parent_dir, rel_path);
+
+  // Load the framework.
+  void* library = dlopen(fw_path, RTLD_LAZY | RTLD_LOCAL | RTLD_FIRST);
+  if (!library) {
+    fprintf(stderr, "dlopen %s: %s\n", fw_path, dlerror());
+    abort();
+  }
+
+  // Resolve all C API symbols.
+  ContentMainFn content_main =
+      (ContentMainFn)dlsym(library, "ContentMain");
+  SetCallbackFn set_on_initialized =
+      (SetCallbackFn)dlsym(library, "ts_set_on_initialized");
+  SetCallbackFn set_on_shutdown =
+      (SetCallbackFn)dlsym(library, "ts_set_on_shutdown");
+  g_create_ctx =
+      (CreateContextFn)dlsym(library, "ts_create_browser_context");
+  g_destroy_ctx =
+      (DestroyContextFn)dlsym(library, "ts_destroy_browser_context");
+  g_create_tab =
+      (CreateTabFn)dlsym(library, "ts_create_tab");
+
+  if (!content_main || !set_on_initialized || !set_on_shutdown ||
+      !g_create_ctx || !g_destroy_ctx || !g_create_tab) {
+    fprintf(stderr, "dlsym failed: %s\n", dlerror());
+    abort();
+  }
+
+  // Register callbacks and run.
+  set_on_initialized(on_initialized);
+  set_on_shutdown(on_shutdown);
+  rv = content_main(argc, argv);
+
+  // exit, don't return from main, to avoid the apparent removal of main
+  // from stack backtraces under tail call optimization.
+  exit(rv);
+}
