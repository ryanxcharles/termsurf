From 1b880a670972812258ba0f433b8d4c67e63612d5 Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Sun, 22 Feb 2026 07:41:29 -0600
Subject: [PATCH 02/13] Add two-profile support to Zig Content Shell
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Two contexts walked into a bar,
Each with storage near and far.
Profile A got google.com,
Profile B got example drawn—
Both rendered like a shining star.

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 content/zig_content_shell/content_api_shim.mm | 43 ++++++++++++++++---
 1 file changed, 37 insertions(+), 6 deletions(-)

diff --git a/content/zig_content_shell/content_api_shim.mm b/content/zig_content_shell/content_api_shim.mm
index b0677340322d5..c7001f6654d00 100644
--- a/content/zig_content_shell/content_api_shim.mm
+++ b/content/zig_content_shell/content_api_shim.mm
@@ -1,9 +1,9 @@
 // Copyright 2025 TermSurf. All rights reserved.
 //
 // Thin C++ shim that drives the Content API through a C function boundary.
-// Subclasses Content Shell's classes and overrides just enough to load a
-// hardcoded URL. The framework exports ContentMain() which shell_main_mac.cc
-// calls via dlsym.
+// Subclasses Content Shell's classes to create two browser profiles with
+// different storage paths, each loading a different URL. The framework exports
+// ContentMain() which shell_main_mac.cc calls via dlsym.
 
 #include "content/zig_content_shell/content_api_shim.h"
 
@@ -20,7 +20,9 @@
 #include "content/shell/app/shell_main_delegate.h"
 #include "content/shell/browser/shell.h"
 #include "content/shell/browser/shell_browser_main_parts.h"
+#include "content/shell/browser/shell_browser_context.h"
 #include "content/shell/browser/shell_content_browser_client.h"
+#include "content/shell/common/shell_paths.h"
 #include "url/gurl.h"
 
 namespace {
@@ -97,15 +99,44 @@ void TsOverrideBundleID() {
 // Content API subclasses
 // ---------------------------------------------------------------------------
 
-// The URL to load. Hardcoded for Experiment 1.
-const char* kInitialUrl = "https://google.com";
+// Two profiles, two URLs. Experiment 2.
+const char* kProfileAUrl = "https://google.com";
+const char* kProfileBUrl = "https://example.com";
 
 class TsBrowserMainParts : public content::ShellBrowserMainParts {
  protected:
+  void InitializeBrowserContexts() override {
+    base::FilePath home;
+    base::PathService::Get(base::DIR_HOME, &home);
+    base::FilePath base_path = home.Append(".config")
+                                   .Append("termsurf")
+                                   .Append("zig-content-shell");
+
+    // Profile A — set path before construction (cached during init).
+    base::PathService::Override(content::SHELL_DIR_USER_DATA,
+                                base_path.Append("profile-a"));
+    set_browser_context(new content::ShellBrowserContext(false));
+
+    // Profile B — override path again, then create second context.
+    base::PathService::Override(content::SHELL_DIR_USER_DATA,
+                                base_path.Append("profile-b"));
+    browser_context_b_.reset(new content::ShellBrowserContext(false));
+  }
+
   void InitializeMessageLoopContext() override {
-    content::Shell::CreateNewWindow(browser_context(), GURL(kInitialUrl),
+    content::Shell::CreateNewWindow(browser_context(), GURL(kProfileAUrl),
+                                    nullptr, gfx::Size());
+    content::Shell::CreateNewWindow(browser_context_b_.get(), GURL(kProfileBUrl),
                                     nullptr, gfx::Size());
   }
+
+  void PostMainMessageLoopRun() override {
+    browser_context_b_.reset();
+    ShellBrowserMainParts::PostMainMessageLoopRun();
+  }
+
+ private:
+  std::unique_ptr<content::ShellBrowserContext> browser_context_b_;
 };
 
 class TsContentBrowserClient : public content::ShellContentBrowserClient {
-- 
